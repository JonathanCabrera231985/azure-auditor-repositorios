+package com.elrosado.transaction.infrastructure.config;
+
+import org.springframework.boot.context.properties.ConfigurationProperties;
+
+/**
+ * Propiedades del endpoint Central El Rosado.
+ * El campo fileTypes encapsula los valores de tipo enviados en cada solicitud HTTP,
+ * definidos por el contrato de la API legada de Central.
+ */
+@ConfigurationProperties(prefix = "app.central")
+public record CentralProperties(
+        String url,
+        int timeoutSeconds,
+        String systemName,
+        FileTypes fileTypes
+) {
+
+    /**
+     * Valores de tipo que acepta la API legada de Central para el campo "type".
+     * Deben coincidir exactamente con los definidos en el sistema Central El Rosado.
+     */
+    public record FileTypes(
+            String closingDay,
+            String journal,
+            String replicationClient
+    ) {}
+}

--- Diff for /src/main/java/com/elrosado/transaction/infrastructure/config/CentralWebClientConfig.java ---
--- a//src/main/java/com/elrosado/transaction/infrastructure/config/CentralWebClientConfig.java
+++ b//src/main/java/com/elrosado/transaction/infrastructure/config/CentralWebClientConfig.java
@@ -0,0 +1,28 @@
+package com.elrosado.transaction.infrastructure.config;
+
+import org.springframework.context.annotation.Bean;
+import org.springframework.context.annotation.Configuration;
+import org.springframework.http.client.reactive.ReactorClientHttpConnector;
+import org.springframework.web.reactive.function.client.WebClient;
+import reactor.netty.http.client.HttpClient;
+
+import java.time.Duration;
+
+/**
+ * ConfiguraciÃ³n del WebClient para el endpoint Central El Rosado.
+ * Centraliza timeout y URL base para que el adaptador solo inyecte el cliente ya listo.
+ */
+@Configuration
+public class CentralWebClientConfig {
+
+    @Bean
+    public WebClient centralWebClient(CentralProperties centralProperties) {
+        HttpClient httpClient = HttpClient.create()
+                .responseTimeout(Duration.ofSeconds(centralProperties.timeoutSeconds()));
+
+        return WebClient.builder()
+                .baseUrl(centralProperties.url())
+                .clientConnector(new ReactorClientHttpConnector(httpClient))
+                .build();
+    }
+}

