+package com.elrosado.transaction.infrastructure.config;
+
+import com.elrosado.transaction.infrastructure.adapter.out.db.entity.StoreEntity;
+import com.elrosado.transaction.infrastructure.adapter.out.db.repository.JpaStoreRepository;
+import jakarta.annotation.PostConstruct;
+import lombok.RequiredArgsConstructor;
+import lombok.extern.slf4j.Slf4j;
+import org.springframework.stereotype.Component;
+
+import java.util.Collections;
+import java.util.List;
+
+/**
+ * Registro de tiendas multi-local activas.
+ * Carga los cÃ³digos desde SAADMIN.MN_TIENDA al arranque y los expone
+ * al scheduler de rÃ©plica de clientes (TC-04).
+ */
+@Component
+@Slf4j
+@RequiredArgsConstructor
+public class StoreRegistry {
+
+    private final JpaStoreRepository storeRepository;
+
+    private volatile List<StoreEntity> activeStores = List.of();
+
+    @PostConstruct
+    public void load() {
+        try {
+            activeStores = storeRepository.findByIndActivoAndMultiLocal(1, 1);
+            log.atInfo()
+                    .setMessage("Tiendas multi-local activas cargadas desde SAADMIN")
+                    .addKeyValue("totalStores", activeStores.size())
+                    .log();
+        } catch (Exception ex) {
+            log.atWarn()
+                    .setMessage("No se pudo cargar el registro de tiendas; se continÃºa sin tiendas activas")
+                    .setCause(ex)
+                    .log();
+        }
+    }
+
+    public List<StoreEntity> getActiveStores() {
+        return Collections.unmodifiableList(activeStores);
+    }
+
+    /**
+     * Retorna los cÃ³digos de tienda formateados a 3 dÃ­gitos (ej. 65 â "065").
+     */
+    public List<String> getActiveStoreCodes() {
+        return activeStores.stream()
+                .map(s -> String.format("%03d", s.getDesClave()))
+                .toList();
+    }
+}


