+import static org.mockito.Mockito.verify;
+import static org.mockito.Mockito.when;
+
+@ExtendWith(MockitoExtension.class)
+class DevolutionPubSubSubscriberTest {
+
+    @Mock
+    private IMessageSubscriber messageSubscriber;
+
+    @Mock
+    private ExecuteDevolutionUseCase executeDevolutionUseCase;
+
+    private DevolutionPubSubSubscriber subscriber;
+
+    private static final String SUBSCRIPTION_ID = "retail.local.devolucion.request.v1-sub";
+    private static final String VALID_BODY = """
+            {"devolutionId":123,"operatorCode":"000000001"}
+            """;
+    private static final String NULL_ID_BODY = """
+            {"devolutionId":null,"operatorCode":"000000001"}
+            """;
+    private static final String INVALID_JSON = "not-json";
+
+    @BeforeEach
+    void setUp() {
+        subscriber = new DevolutionPubSubSubscriber(
+                messageSubscriber, executeDevolutionUseCase, new ObjectMapper()
+        );
+    }
+
+    @SuppressWarnings("unchecked")
+    private BiFunction<String, String, CompletableFuture<Boolean>> captureHandler() {
+        subscriber.startSubscription();
+        ArgumentCaptor<BiFunction<String, String, CompletableFuture<Boolean>>> captor =
+                ArgumentCaptor.forClass(BiFunction.class);
+        verify(messageSubscriber).startListening(captor.capture());
+        return captor.getValue();
+    }
+
+    @Test
+    void returnsAckWhenMessageProcessedSuccessfully() throws Exception {
+        when(executeDevolutionUseCase.execute(any())).thenReturn(
+                new DevolutionResult(123, "PROCESSED", "012007000000001",
+                        "DV000123.005", "devs/005/DV000123.005", Instant.now(), "msg-1")
+        );
+
+        boolean result = captureHandler()
+                .apply(SUBSCRIPTION_ID, VALID_BODY)
+                .get(5, TimeUnit.SECONDS);
+
+        assertThat(result).isTrue();
+    }
+
+    @Test
+    void returnsAckWhenDevolutionAlreadyProcessed() throws Exception {
+        doThrow(new DevolutionAlreadyProcessedException(123))
+                .when(executeDevolutionUseCase).execute(any(ExecuteDevolutionCommand.class));
+
+        boolean result = captureHandler()
+                .apply(SUBSCRIPTION_ID, VALID_BODY)
+                .get(5, TimeUnit.SECONDS);
+
+        assertThat(result).isTrue();
+    }
+
+    @Test
+    void returnsAckWhenValidationFails() throws Exception {
+        doThrow(new DevolutionValidationException("totales invalidos"))
+                .when(executeDevolutionUseCase).execute(any(ExecuteDevolutionCommand.class));
+
+        boolean result = captureHandler()
+                .apply(SUBSCRIPTION_ID, VALID_BODY)
+                .get(5, TimeUnit.SECONDS);
+
+        assertThat(result).isTrue();
+    }
+
+    @Test
+    void returnsAckWhenCreditNoteNotEligible() throws Exception {
+        doThrow(new CreditNoteNotEligibleException("consumidor final"))
+                .when(executeDevolutionUseCase).execute(any(ExecuteDevolutionCommand.class));
+
+        boolean result = captureHandler()
+                .apply(SUBSCRIPTION_ID, VALID_BODY)
+                .get(5, TimeUnit.SECONDS);
+
+        assertThat(result).isTrue();
+    }
+
+    @Test
+    void returnsNackWhenDevolutionSessionNotFound() throws Exception {
+        doThrow(new NoSuchElementException("no encontrado"))
+                .when(executeDevolutionUseCase).execute(any(ExecuteDevolutionCommand.class));
+
+        boolean result = captureHandler()
+                .apply(SUBSCRIPTION_ID, VALID_BODY)
+                .get(5, TimeUnit.SECONDS);
+
+        assertThat(result).isFalse();
+    }
+
+    @Test
+    void returnsAckWhenJsonIsInvalid() throws Exception {
+        boolean result = captureHandler()
+                .apply(SUBSCRIPTION_ID, INVALID_JSON)
+                .get(5, TimeUnit.SECONDS);
+
+        assertThat(result).isTrue();
+    }
+
+    @Test
+    void returnsAckWhenDevolutionIdIsNull() throws Exception {
+        boolean result = captureHandler()
+                .apply(SUBSCRIPTION_ID, NULL_ID_BODY)
+                .get(5, TimeUnit.SECONDS);
+
+        assertThat(result).isTrue();
+    }
+
+    @Test
+    void returnsNackWhenUnexpectedErrorOccurs() throws Exception {
+        doThrow(new RuntimeException("BD no disponible"))
+                .when(executeDevolutionUseCase).execute(any(ExecuteDevolutionCommand.class));
+
+        boolean result = captureHandler()
+                .apply(SUBSCRIPTION_ID, VALID_BODY)
+                .get(5, TimeUnit.SECONDS);
+
+        assertThat(result).isFalse();
+    }
+}


