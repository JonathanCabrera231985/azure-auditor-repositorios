--- Diff for /src/main/java/com/elrosado/integration/infrastructure/adapter/in/pubsub/DevolutionPubSubSubscriber.java ---
--- a//src/main/java/com/elrosado/integration/infrastructure/adapter/in/pubsub/DevolutionPubSubSubscriber.java
+++ b//src/main/java/com/elrosado/integration/infrastructure/adapter/in/pubsub/DevolutionPubSubSubscriber.java
@@ -0,0 +1,135 @@
+package com.elrosado.integration.infrastructure.adapter.in.pubsub;
+
+import com.elrosado.integration.application.command.ExecuteDevolutionCommand;
+import com.elrosado.integration.domain.exception.CreditNoteNotEligibleException;
+import com.elrosado.integration.domain.exception.DevolutionAlreadyProcessedException;
+import com.elrosado.integration.domain.exception.DevolutionValidationException;
+import com.elrosado.integration.domain.port.in.ExecuteDevolutionUseCase;
+import com.elrosado.jlib_pubsub.interfaces.IMessageSubscriber;
+import com.fasterxml.jackson.core.JsonProcessingException;
+import com.fasterxml.jackson.databind.ObjectMapper;
+import jakarta.annotation.PostConstruct;
+import lombok.RequiredArgsConstructor;
+import lombok.extern.slf4j.Slf4j;
+import org.slf4j.MDC;
+import org.springframework.stereotype.Component;
+
+import java.util.NoSuchElementException;
+import java.util.concurrent.CompletableFuture;
+import java.util.concurrent.ExecutorService;
+import java.util.concurrent.Executors;
+
+/**
+ * Adaptador de entrada: suscriptor al topic retail.local.devolucion.request.v1.
+ * Cada mensaje recibido dispara la generaciГѓВіn del archivo DV de forma asГѓВ­ncrona
+ * en un virtual thread independiente.
+ */
+@Component
+@RequiredArgsConstructor
+@Slf4j
+public class DevolutionPubSubSubscriber {
+
+    private static final ExecutorService VIRTUAL_EXECUTOR =
+            Executors.newVirtualThreadPerTaskExecutor();
+
+    private final IMessageSubscriber messageSubscriber;
+    private final ExecuteDevolutionUseCase executeDevolutionUseCase;
+    private final ObjectMapper objectMapper;
+
+    @PostConstruct
+    public void startSubscription() {
+        messageSubscriber.startListening(this::handleMessage);
+        log.atInfo()
+                .setMessage("Suscriptor Pub/Sub de devoluciones iniciado")
+                .addKeyValue("topic", "retail.local.devolucion.request.v1")
+                .log();
+    }
+
+    private CompletableFuture<Boolean> handleMessage(String subscriptionId, String body) {
+        return CompletableFuture.supplyAsync(
+                () -> processMessage(subscriptionId, body),
+                VIRTUAL_EXECUTOR
+        );
+    }
+
+    private boolean processMessage(String subscriptionId, String body) {
+        DevolutionTriggerMessage message = null;
+        try {
+            message = objectMapper.readValue(body, DevolutionTriggerMessage.class);
+
+            if (message.devolutionId() == null) {
+                log.atWarn()
+                        .setMessage("Mensaje Pub/Sub descartado: devolutionId ausente")
+                        .addKeyValue("subscriptionId", subscriptionId)
+                        .log();
+                return true;
+            }
+
+            MDC.put("devolutionId", String.valueOf(message.devolutionId()));
+
+            executeDevolutionUseCase.execute(
+                    new ExecuteDevolutionCommand(message.devolutionId(), message.operatorCode())
+            );
+
+            log.atInfo()
+                    .setMessage("Devolucion procesada exitosamente via Pub/Sub")
+                    .addKeyValue("subscriptionId", subscriptionId)
+                    .addKeyValue("devolutionId", message.devolutionId())
+                    .log();
+
+            return true;
+
+        } catch (DevolutionAlreadyProcessedException ex) {
+            // Ack: ya fue procesado previamente, el reintento no ayuda
+            log.atWarn()
+                    .setMessage("Devolucion ya procesada ГўВЂВ” descartando mensaje duplicado")
+                    .addKeyValue("subscriptionId", subscriptionId)
+                    .addKeyValue("devolutionId", message != null ? message.devolutionId() : null)
+                    .setCause(ex)
+                    .log();
+            return true;
+
+        } catch (DevolutionValidationException | CreditNoteNotEligibleException ex) {
+            // Ack: regla de negocio violada, el reintento no cambia el resultado
+            log.atWarn()
+                    .setMessage("Devolucion rechazada por regla de negocio ГўВЂВ” descartando mensaje")
+                    .addKeyValue("subscriptionId", subscriptionId)
+                    .addKeyValue("devolutionId", message != null ? message.devolutionId() : null)
+                    .setCause(ex)
+                    .log();
+            return true;
+
+        } catch (NoSuchElementException ex) {
+            // Nack: sesiГѓВіn no encontrada ГўВЂВ” posible retraso de escritura, reintento puede resolver
+            log.atError()
+                    .setMessage("Sesion de devolucion no encontrada ГўВЂВ” reintentando via Nack")
+                    .addKeyValue("subscriptionId", subscriptionId)
+                    .addKeyValue("devolutionId", message != null ? message.devolutionId() : null)
+                    .setCause(ex)
+                    .log();
+            return false;
+
+        } catch (JsonProcessingException ex) {
+            // Ack: mensaje mal formado, el reintento no lo corregirГѓВЎ
+            log.atError()
+                    .setMessage("Mensaje Pub/Sub con JSON invalido ГўВЂВ” descartando mensaje")
+                    .addKeyValue("subscriptionId", subscriptionId)
+                    .setCause(ex)
+                    .log();
+            return true;
+
+        } catch (Exception ex) {
+            // Nack: error transitorio desconocido, reintento puede resolver
+            log.atError()
+                    .setMessage("Error inesperado procesando devolucion ГўВЂВ” reintentando via Nack")
+                    .addKeyValue("subscriptionId", subscriptionId)
+                    .addKeyValue("devolutionId", message != null ? message.devolutionId() : null)
+                    .setCause(ex)
+                    .log();
+            return false;
+
+        } finally {
+            MDC.remove("devolutionId");
+        }
+    }
+}


