-// infrastructure/web/TransactionController.java
-@RestController
-public class TransactionController {
-    @PostMapping("/login")
-    public Map<String, String> login(@RequestParam String user, @RequestParam String pass) {
-        // Validación quemada y sin token estructurado
-        if("admin".equals(user) && "admin".equals(pass)) {
