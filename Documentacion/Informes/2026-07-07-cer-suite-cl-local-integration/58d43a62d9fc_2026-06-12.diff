+import com.elrosado.integration.infrastructure.security.BearerTokenProvider;
+import lombok.RequiredArgsConstructor;
+import lombok.extern.slf4j.Slf4j;
+import org.springframework.beans.factory.annotation.Qualifier;
+import org.springframework.http.HttpHeaders;
+import org.springframework.http.MediaType;
+import org.springframework.http.ResponseEntity;
+import org.springframework.http.client.SimpleClientHttpRequestFactory;
+import org.springframework.stereotype.Component;
+import org.springframework.web.client.*;
+
+import java.time.Duration;
+import java.time.Instant;
+import java.util.Base64;
+
+@Component
+@Slf4j
+@RequiredArgsConstructor
+public class SecureFileTransferAdapter implements FileTransferPort {
+
+    @Qualifier("fileTransferRestClient")
+    private final RestClient restClient;
+    private final FileTransferProperties properties;
+    private final BearerTokenProvider bearerTokenProvider;
+
+    @Override
+    public FileTransferResult transfer(String fileName, byte[] content) {
+        validateRequest(fileName, content);
+
+        FileTransferRequestBody body = new FileTransferRequestBody(
+                fileName,
+                normalizeTargetDir(properties.getTargetDir()),
+                Base64.getEncoder().encodeToString(content)
+        );
+
+        try {
+            ResponseEntity<Void> response = restClient.post()
+                    .uri(properties.normalizedFilesPath())
+                    .header(HttpHeaders.AUTHORIZATION, bearerTokenProvider.authorizationHeader())
+                    .contentType(MediaType.APPLICATION_JSON)
+                    .body(body)
+                    .retrieve()
+                    .toBodilessEntity();
+
+            int statusCode = response.getStatusCode().value();
+            if (statusCode != 201) {
+                log.atWarn()
+                        .setMessage("API de transferencia respondio con codigo 2xx distinto de 201")
+                        .addKeyValue("fileName", fileName)
+                        .addKeyValue("statusCode", statusCode)
+                        .log();
+            }
+
+            return new FileTransferResult(fileName, properties.endpoint(), statusCode, Instant.now());
+        } catch (HttpClientErrorException ex) {
+            throw new FileTransferPermanentException(
+                    "Error permanente transfiriendo archivo DV. statusCode=" + ex.getStatusCode().value(),
+                    ex
+            );
+        } catch (HttpServerErrorException | ResourceAccessException ex) {
+            throw new FileTransferTransientException("Error transitorio transfiriendo archivo DV", ex);
+        } catch (RestClientException ex) {
+            throw new FileTransferTransientException("Error HTTP inesperado transfiriendo archivo DV", ex);
+        }
+    }
+
+    private void validateRequest(String fileName, byte[] content) {
+        if (fileName == null || fileName.isBlank()) {
+            throw new FileTransferPermanentException("fileName es requerido para transferir archivo DV");
+        }
+        if (content == null) {
+            throw new FileTransferPermanentException("content es requerido para transferir archivo DV");
+        }
+    }
+
+    private String normalizeTargetDir(String targetDir) {
+        if (targetDir == null || targetDir.isBlank()) {
+            throw new FileTransferPermanentException("FILE_TRANSFER_TARGET_DIR no esta configurado");
+        }
+
+        String normalized = targetDir.strip();
+        while (normalized.endsWith("/") || normalized.endsWith("\\")) {
+            normalized = normalized.substring(0, normalized.length() - 1);
+        }
+        if (normalized.isBlank()) {
+            throw new FileTransferPermanentException("FILE_TRANSFER_TARGET_DIR no puede quedar vacio");
+        }
+        return normalized;
+    }
+
+    private SimpleClientHttpRequestFactory requestFactory(FileTransferProperties properties) {
+        SimpleClientHttpRequestFactory requestFactory = new SimpleClientHttpRequestFactory();
+        Duration timeout = Duration.ofSeconds(Math.max(1, properties.getTimeoutSeconds()));
+        requestFactory.setConnectTimeout(timeout);
+        requestFactory.setReadTimeout(timeout);
+        return requestFactory;
+    }
+
+    private record FileTransferRequestBody(String file, String dir, String content) {
+    }
+}


