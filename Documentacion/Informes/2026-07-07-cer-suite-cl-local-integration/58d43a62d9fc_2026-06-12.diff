@@ -0,0 +1,65 @@
+package com.elrosado.integration.infrastructure.adapter.out.storage;
+
+import com.elrosado.integration.domain.port.out.DvFileReaderPort;
+import com.elrosado.jlib_storage.interfaces.IGoogleCloudStorageService;
+import lombok.RequiredArgsConstructor;
+import lombok.extern.slf4j.Slf4j;
+import org.springframework.beans.factory.annotation.Value;
+import org.springframework.stereotype.Component;
+
+import java.net.URI;
+
+@Component
+@RequiredArgsConstructor
+@Slf4j
+public class GcsDvFileReaderAdapter implements DvFileReaderPort {
+
+    private final IGoogleCloudStorageService googleCloudStorageService;
+
+    @Value("${app.gcp.storage.bucket-name}")
+    private String defaultBucketName;
+
+    @Override
+    public byte[] read(String gcsPath) {
+        GcsObjectLocation location = resolveLocation(gcsPath);
+        byte[] content = googleCloudStorageService.downloadFile(location.bucketName(), location.objectName());
+
+        log.atInfo()
+                .setMessage("Archivo DV leido desde GCS")
+                .addKeyValue("bucketName", location.bucketName())
+                .addKeyValue("objectName", location.objectName())
+                .addKeyValue("size", content.length)
+                .log();
+
+        return content;
+    }
+
+    private GcsObjectLocation resolveLocation(String gcsPath) {
+        if (gcsPath == null || gcsPath.isBlank()) {
+            throw new IllegalArgumentException("gcsPath es requerido para leer el archivo DV");
+        }
+
+        String bucketName = defaultBucketName;
+        String objectName = gcsPath.strip();
+        if (objectName.startsWith("gs://")) {
+            URI uri = URI.create(objectName);
+            bucketName = uri.getHost();
+            objectName = uri.getPath();
+        }
+
+        while (objectName.startsWith("/")) {
+            objectName = objectName.substring(1);
+        }
+
+        if (bucketName == null || bucketName.isBlank()) {
+            throw new IllegalArgumentException("bucketName es requerido para leer gcsPath=" + gcsPath);
+        }
+        if (objectName.isBlank()) {
+            throw new IllegalArgumentException("objectName es requerido para leer gcsPath=" + gcsPath);
+        }
+
+        return new GcsObjectLocation(bucketName, objectName);
+    }
+
+    private record GcsObjectLocation(String bucketName, String objectName) {}
+}


