--- a//src/main/java/com/elrosado/integration/infrastructure/adapter/in/pubsub/DevolutionTransferMessageHandler.java
+++ b//src/main/java/com/elrosado/integration/infrastructure/adapter/in/pubsub/DevolutionTransferMessageHandler.java
@@ -0,0 +1,127 @@
+package com.elrosado.integration.infrastructure.adapter.in.pubsub;
+
+import com.elrosado.integration.application.command.TransferDevolutionFileCommand;
+import com.elrosado.integration.domain.exception.FileTransferPermanentException;
+import com.elrosado.integration.domain.exception.FileTransferTransientException;
+import com.elrosado.integration.domain.port.in.TransferDevolutionFileUseCase;
+import com.elrosado.integration.domain.port.out.DevolutionAuditPort;
+import com.elrosado.integration.infrastructure.adapter.out.pubsub.DevolutionProcessedEvent;
+import com.elrosado.integration.infrastructure.config.FileTransferProperties;
+import lombok.RequiredArgsConstructor;
+import lombok.extern.slf4j.Slf4j;
+import org.slf4j.MDC;
+import org.springframework.stereotype.Component;
+import tools.jackson.databind.ObjectMapper;
+
+@Component
+@RequiredArgsConstructor
+@Slf4j
+public class DevolutionTransferMessageHandler {
+
+    private final TransferDevolutionFileUseCase transferDevolutionFileUseCase;
+    private final DevolutionAuditPort devolutionAuditPort;
+    private final FileTransferProperties fileTransferProperties;
+    private final ObjectMapper objectMapper;
+
+    public boolean handle(String subscriptionId, String body) {
+        DevolutionProcessedEvent event;
+        try {
+            event = objectMapper.readValue(body, DevolutionProcessedEvent.class);
+        } catch (Exception ex) {
+            log.atWarn()
+                    .setMessage("Evento de transferencia descartado: JSON invalido")
+                    .addKeyValue("subscriptionId", subscriptionId)
+                    .setCause(ex)
+                    .log();
+            return true;
+        }
+
+        if (event == null) {
+            log.atWarn()
+                    .setMessage("Evento de transferencia descartado: payload nulo")
+                    .addKeyValue("subscriptionId", subscriptionId)
+                    .log();
+            return true;
+        }
+
+        try {
+            if (event.devolutionId() == null || event.gcsPath() == null || event.gcsPath().isBlank()) {
+                log.atWarn()
+                        .setMessage("Evento de transferencia descartado por datos incompletos")
+                        .addKeyValue("subscriptionId", subscriptionId)
+                        .addKeyValue("devolutionId", event.devolutionId())
+                        .log();
+                return true;
+            }
+
+            MDC.put("devolutionId", String.valueOf(event.devolutionId()));
+
+            if (!fileTransferProperties.isEnabled()) {
+                log.atWarn()
+                        .setMessage("Transferencia de archivo DV deshabilitada por configuracion")
+                        .addKeyValue("subscriptionId", subscriptionId)
+                        .addKeyValue("devolutionId", event.devolutionId())
+                        .log();
+                return true;
+            }
+
+            transferDevolutionFileUseCase.transfer(new TransferDevolutionFileCommand(
+                    event.devolutionId(),
+                    event.numNc(),
+                    event.creditNoteNumber(),
+                    event.gcsPath(),
+                    event.processedAt()
+            ));
+
+            log.atInfo()
+                    .setMessage("Transferencia de devolucion procesada exitosamente via Pub/Sub")
+                    .addKeyValue("subscriptionId", subscriptionId)
+                    .addKeyValue("devolutionId", event.devolutionId())
+                    .log();
+
+            return true;
+        } catch (FileTransferPermanentException | IllegalArgumentException ex) {
+            audit(event, "file_transfer_permanent_error", ex.getMessage());
+            log.atError()
+                    .setMessage("Error permanente en transferencia de devolucion - descartando mensaje")
+                    .addKeyValue("subscriptionId", subscriptionId)
+                    .addKeyValue("devolutionId", event.devolutionId())
+                    .setCause(ex)
+                    .log();
+            return true;
+        } catch (FileTransferTransientException ex) {
+            log.atError()
+                    .setMessage("Error transitorio en transferencia de devolucion - reintentando via Nack")
+                    .addKeyValue("subscriptionId", subscriptionId)
+                    .addKeyValue("devolutionId", event.devolutionId())
+                    .setCause(ex)
+                    .log();
+            return false;
+        } catch (Exception ex) {
+            log.atError()
+                    .setMessage("Error inesperado procesando evento de transferencia - reintentando via Nack")
+                    .addKeyValue("subscriptionId", subscriptionId)
+                    .addKeyValue("devolutionId", event.devolutionId())
+                    .setCause(ex)
+                    .log();
+            return false;
+        } finally {
+            MDC.remove("devolutionId");
+        }
+    }
+
+    private void audit(DevolutionProcessedEvent event, String reason, String message) {
+        if (event == null || event.devolutionId() == null) {
+            return;
+        }
+        try {
+            devolutionAuditPort.log(event.devolutionId(), reason, message);
+        } catch (Exception auditEx) {
+            log.atWarn()
+                    .setMessage("No se pudo auditar error de transferencia")
+                    .addKeyValue("devolutionId", event.devolutionId())
+                    .setCause(auditEx)
+                    .log();
+        }
+    }
+}


