+
+    public String normalizedFilesPath() {
+        if (filesPath == null || filesPath.isBlank()) {
+            return "/files";
+        }
+        return filesPath.startsWith("/") ? filesPath : "/" + filesPath;
+    }
+
+    public String endpoint() {
+        String normalizedBaseUrl = baseUrl == null ? "" : baseUrl.strip();
+        while (normalizedBaseUrl.endsWith("/")) {
+            normalizedBaseUrl = normalizedBaseUrl.substring(0, normalizedBaseUrl.length() - 1);
+        }
+        return normalizedBaseUrl + normalizedFilesPath();
