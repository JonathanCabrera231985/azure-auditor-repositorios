--- Diff for /src/main/java/com/elrosado/integration/application/service/TransferDevolutionFileService.java ---
--- a//src/main/java/com/elrosado/integration/application/service/TransferDevolutionFileService.java
+++ b//src/main/java/com/elrosado/integration/application/service/TransferDevolutionFileService.java
@@ -0,0 +1,56 @@
+package com.elrosado.integration.application.service;
+
+import com.elrosado.integration.application.command.TransferDevolutionFileCommand;
+import com.elrosado.integration.domain.model.FileTransferResult;
+import com.elrosado.integration.domain.port.in.TransferDevolutionFileUseCase;
+import com.elrosado.integration.domain.port.out.DvFileReaderPort;
+import com.elrosado.integration.domain.port.out.FileTransferPort;
+import lombok.RequiredArgsConstructor;
+import lombok.extern.slf4j.Slf4j;
+import org.springframework.stereotype.Service;
+
+import java.net.URI;
+
+@Service
+@RequiredArgsConstructor
+@Slf4j
+public class TransferDevolutionFileService implements TransferDevolutionFileUseCase {
+
+    private final DvFileReaderPort dvFileReaderPort;
+    private final FileTransferPort fileTransferPort;
+
+    @Override
+    public FileTransferResult transfer(TransferDevolutionFileCommand command) {
+        String fileName = extractFileName(command.gcsPath());
+        byte[] content = dvFileReaderPort.read(command.gcsPath());
+        FileTransferResult result = fileTransferPort.transfer(fileName, content);
+
+        log.atInfo()
+                .setMessage("Archivo DV transferido exitosamente")
+                .addKeyValue("devolutionId", command.devolutionId())
+                .addKeyValue("fileName", result.fileName())
+                .addKeyValue("endpoint", result.endpoint())
+                .addKeyValue("statusCode", result.statusCode())
+                .log();
+
+        return result;
+    }
+
+    private String extractFileName(String gcsPath) {
+        if (gcsPath == null || gcsPath.isBlank()) {
+            throw new IllegalArgumentException("gcsPath es requerido para transferir el archivo DV");
+        }
+
+        String normalized = gcsPath.strip();
+        if (normalized.startsWith("gs://")) {
+            normalized = URI.create(normalized).getPath();
+        }
+
+        int index = normalized.lastIndexOf('/');
+        String fileName = index >= 0 ? normalized.substring(index + 1) : normalized;
+        if (fileName.isBlank()) {
+            throw new IllegalArgumentException("No se pudo obtener el nombre del archivo desde gcsPath=" + gcsPath);
+        }
+        return fileName;
+    }
+}


