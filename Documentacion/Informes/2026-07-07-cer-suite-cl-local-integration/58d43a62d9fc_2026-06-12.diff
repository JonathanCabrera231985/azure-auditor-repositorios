--- a//src/main/java/com/elrosado/integration/infrastructure/security/SecretManagerBearerTokenProvider.java
+++ b//src/main/java/com/elrosado/integration/infrastructure/security/SecretManagerBearerTokenProvider.java
@@ -0,0 +1,117 @@
+package com.elrosado.integration.infrastructure.security;
+
+import com.elrosado.integration.domain.exception.FileTransferPermanentException;
+import com.elrosado.integration.domain.exception.FileTransferTransientException;
+import com.elrosado.integration.infrastructure.config.FileTransferProperties;
+import com.google.api.gax.rpc.ApiException;
+import com.google.api.gax.rpc.StatusCode;
+import com.google.cloud.secretmanager.v1.AccessSecretVersionResponse;
+import com.google.cloud.secretmanager.v1.SecretManagerServiceClient;
+import com.google.cloud.secretmanager.v1.SecretVersionName;
+import org.springframework.beans.factory.annotation.Value;
+import org.springframework.stereotype.Component;
+
+import java.time.Duration;
+
+@Component
+public class SecretManagerBearerTokenProvider implements BearerTokenProvider {
+
+    private final SecretManagerServiceClient secretManagerServiceClient;
+    private final FileTransferProperties properties;
+    private final String projectId;
+
+    private volatile CachedAuthorizationHeader cachedAuthorizationHeader;
+
+    public SecretManagerBearerTokenProvider(
+            SecretManagerServiceClient secretManagerServiceClient,
+            FileTransferProperties properties,
+            @Value("${spring.cloud.gcp.project-id:}") String projectId
+    ) {
+        this.secretManagerServiceClient = secretManagerServiceClient;
+        this.properties = properties;
+        this.projectId = projectId;
+    }
+
+    @Override
+    public String authorizationHeader() {
+        long nowNanos = System.nanoTime();
+        CachedAuthorizationHeader header = cachedAuthorizationHeader;
+        if (isCacheValid(header, nowNanos)) {
+            return header.value();
+        }
+
+        synchronized (this) {
+            header = cachedAuthorizationHeader;
+            if (!isCacheValid(header, nowNanos)) {
+                header = new CachedAuthorizationHeader(buildAuthorizationHeader(), System.nanoTime());
+                cachedAuthorizationHeader = header;
+            }
+            return header.value();
+        }
+    }
+
+    private String buildAuthorizationHeader() {
+        String secretId = required(properties.getBearerTokenSecretId(), "FILE_TRANSFER_BEARER_TOKEN_SECRET_ID");
+        String version = defaultIfBlank(properties.getBearerTokenSecretVersion(), "latest");
+        String resolvedProjectId = required(projectId, "spring.cloud.gcp.project-id");
+
+        try {
+            SecretVersionName secretVersionName = SecretVersionName.of(resolvedProjectId, secretId, version);
+            AccessSecretVersionResponse response = secretManagerServiceClient.accessSecretVersion(secretVersionName);
+            String token = response.getPayload().getData().toStringUtf8();
+            if (token == null || token.isBlank()) {
+                throw new FileTransferPermanentException("El bearer token obtenido desde Secret Manager esta vacio");
+            }
+            return token.regionMatches(true, 0, "Bearer ", 0, "Bearer ".length())
+                    ? token.strip()
+                    : "Bearer " + token.strip();
+        } catch (FileTransferPermanentException ex) {
+            throw ex;
+        } catch (ApiException ex) {
+            if (isPermanentSecretManagerError(ex)) {
+                throw new FileTransferPermanentException(
+                        "No se pudo leer bearer token desde Secret Manager. statusCode="
+                                + ex.getStatusCode().getCode(),
+                        ex
+                );
+            }
+            throw new FileTransferTransientException("Error transitorio leyendo bearer token desde Secret Manager", ex);
+        } catch (Exception ex) {
+            throw new FileTransferTransientException("No se pudo leer bearer token desde Secret Manager", ex);
+        }
+    }
+
+    private boolean isCacheValid(CachedAuthorizationHeader header, long nowNanos) {
+        if (header == null) {
+            return false;
+        }
+        long ttlSeconds = properties.getBearerTokenCacheTtlSeconds();
+        if (ttlSeconds <= 0) {
+            return false;
+        }
+        long ttlNanos = Duration.ofSeconds(ttlSeconds).toNanos();
+        return nowNanos - header.loadedAtNanos() < ttlNanos;
+    }
+
+    private String required(String value, String propertyName) {
+        if (value == null || value.isBlank()) {
+            throw new FileTransferPermanentException(propertyName + " no esta configurado");
+        }
+        return value.strip();
+    }
+
+    private String defaultIfBlank(String value, String defaultValue) {
+        return value == null || value.isBlank() ? defaultValue : value.strip();
+    }
+
+    private boolean isPermanentSecretManagerError(ApiException ex) {
+        StatusCode.Code code = ex.getStatusCode().getCode();
+        return code == StatusCode.Code.NOT_FOUND
+                || code == StatusCode.Code.PERMISSION_DENIED
+                || code == StatusCode.Code.UNAUTHENTICATED
+                || code == StatusCode.Code.INVALID_ARGUMENT
+                || code == StatusCode.Code.FAILED_PRECONDITION;
+    }
+
+    private record CachedAuthorizationHeader(String value, long loadedAtNanos) {}
+}


