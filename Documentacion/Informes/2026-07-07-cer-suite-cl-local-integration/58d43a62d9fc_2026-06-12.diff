+asyncapi: 3.0.0
+
+info:
+  title: cer-suite-cl-local-integration
+  version: 0.0.1-SNAPSHOT
+  description: |
+    Microservicio de integración local CER Suite Cloud.
+    Responsabilidad: generar el archivo DV del proceso de devoluciones del POS retail CER/El Rosado,
+    escribirlo en GCS y transferirlo al POS mediante la API de sincronización.
+
+    **Flujo principal:**
+    1. Recibe solicitud de devolución desde el portal Angular via `retail.local.devolucion.request.v1`
+    2. Ejecuta el caso de uso `ExecuteDevolutionUseCase` (consulta BD, genera DV, escribe en GCS)
+    3. Publica resultado en `retail.local.devolution.processed.v1` para el SincronizadorService
+    4. Recibe el evento publicado via `retail.local.devolution.processed.v1` y transfiere el archivo al POS
+
+    **Política de Ack/Nack:**
+    - `Ack` (true): procesamiento exitoso, error permanente de negocio, mensaje inválido o duplicado
+    - `Nack` (false): error transitorio (BD no disponible, API de transferencia caída) — reintento automático
+
+  contact:
+    name: CER Suite Cloud — SIPECOM
+  license:
+    name: Privado — uso interno SIPECOM
+
+servers:
+  gcp-local:
+    host: pubsub.googleapis.com
+    protocol: googlepubsub
+    description: GCP Pub/Sub — proyecto modern-suite-cloud-inf (entorno local)
+    tags:
+      - name: env:local
+  gcp-prod:
+    host: pubsub.googleapis.com
+    protocol: googlepubsub
+    description: GCP Pub/Sub — proyecto GKE producción (Workload Identity)
+    tags:
+      - name: env:prod
+
+channels:
+
+  devolutionRequest:
+    address: retail.local.devolucion.request.v1
+    description: |
+      Topic de entrada. El backend del portal Angular publica aquí cuando el operador
+      confirma una devolución en el POS. Este microservicio consume la subscription
+      `retail.local.devolution.request.v1-sub`.
+    messages:
+      DevolutionTriggerMessage:
+        $ref: '#/components/messages/DevolutionTriggerMessage'
+    bindings:
+      googlepubsub:
+        topic: retail.local.devolucion.request.v1
+        subscription: retail.local.devolution.request.v1-sub
+
+  devolutionProcessed:
+    address: retail.local.devolution.processed.v1
+    description: |
+      Topic de salida y de entrada.
+      - **Publicación (OUT):** este microservicio publica aquí el evento `DevolutionProcessedEvent`
+        tras generar el archivo DV y escribirlo en GCS. El SincronizadorService lo consume para
+        entregar el archivo al POS.
+      - **Suscripción (IN):** este mismo microservicio también consume la subscription
+        `retail.local.devolution.processed.v1-sub` para ejecutar la transferencia HTTP del archivo DV
+        a la API del sincronizador local.
+    messages:
+      DevolutionProcessedEvent:
+        $ref: '#/components/messages/DevolutionProcessedEvent'
+    bindings:
+      googlepubsub:
+        topic: retail.local.devolution.processed.v1
+        subscription: retail.local.devolution.processed.v1-sub
+
+operations:
+
+  receiveDevolutionRequest:
+    action: receive
+    channel:
+      $ref: '#/channels/devolutionRequest'
+    title: Recibir solicitud de devolución desde el portal
+    summary: |
+      Desencadena la ejecución de `ExecuteDevolutionUseCase`: consulta BD (DEVS_EC, ARTS_EC, SAADMIN),
+      genera el archivo DV en formato de ancho fijo ISO-8859-1, lo escribe en GCS y publica el evento
+      de resultado en `retail.local.devolution.processed.v1`.
+    description: |
+      **Handler:** `DevolutionCreationMessageHandler`
+
+      **Política de Ack/Nack:**
+      | Situación | Resultado |
+      |-----------|-----------|
+      | Procesamiento exitoso | Ack |
+      | JSON inválido o payload nulo | Ack (descarte) |
+      | `devolutionId` ausente | Ack (descarte) |
+      | `DevolutionAlreadyProcessedException` | Ack (duplicado) |
+      | `DevolutionValidationException` | Ack (regla de negocio) |
+      | `CreditNoteNotEligibleException` | Ack (regla de negocio) |
+      | `NoSuchElementException` (sesión no encontrada) | Nack → reintento |
+      | Error inesperado | Nack → reintento |
+    messages:
+      - $ref: '#/channels/devolutionRequest/messages/DevolutionTriggerMessage'
+    bindings:
+      googlepubsub:
+        clientId: DevolutionPubSubSubscriber
+
+  publishDevolutionProcessed:
+    action: send
+    channel:
+      $ref: '#/channels/devolutionProcessed'
+    title: Publicar evento de devolución procesada
+    summary: |
+      Se publica tras confirmar la escritura del archivo DV en GCS. El SincronizadorService
+      lo consume para descargar el archivo de GCS y entregarlo al POS.
+    description: |
+      **Publisher:** `DevolutionEventAdapter` → `IMessagePublisher.publishAsync()`
+
+      El mensaje se serializa a JSON con Jackson. El campo `gcsPath` contiene la ruta completa
+      en formato `gs://{bucket}/{storeId}/{fileName}`.
+    messages:
+      - $ref: '#/channels/devolutionProcessed/messages/DevolutionProcessedEvent'
+
+  receiveDevolutionProcessed:
+    action: receive
+    channel:
+      $ref: '#/channels/devolutionProcessed'
+    title: Recibir evento de devolución procesada para transferencia HTTP
+    summary: |
+      Descarga el archivo DV desde GCS y lo transfiere mediante HTTP a la API del sincronizador
+      local (`SecureFileTransferAdapter`). La autenticación usa un Bearer token obtenido desde
+      GCP Secret Manager con caché TTL configurable.
+    description: |
+      **Handler:** `DevolutionTransferMessageHandler`
+
+      **Política de Ack/Nack:**
+      | Situación | Resultado |
+      |-----------|-----------|
+      | Transferencia exitosa | Ack |
+      | JSON inválido o payload nulo | Ack (descarte) |
+      | `devolutionId` o `gcsPath` ausente | Ack (descarte) |
+      | Transferencia deshabilitada (`FILE_TRANSFER_ENABLED=false`) | Ack (skip) |
+      | `FileTransferPermanentException` (400, 401, 403, 404) | Ack + auditoría |
+      | `FileTransferTransientException` (500, timeout, red) | Nack → reintento |
+      | Error inesperado | Nack → reintento |
+    messages:
+      - $ref: '#/channels/devolutionProcessed/messages/DevolutionProcessedEvent'
+    bindings:
+      googlepubsub:
+        clientId: DevolutionPubSubSubscriber
+
+components:
+
+  messages:
+
+    DevolutionTriggerMessage:
+      name: DevolutionTriggerMessage
+      title: Solicitud de ejecución de devolución
+      summary: Publicado por el backend del portal Angular cuando el operador confirma la devolución.
+      contentType: application/json
+      payload:
+        $ref: '#/components/schemas/DevolutionTriggerMessagePayload'
+      examples:
+        - name: Devolución estándar con código de operador
+          payload:
+            devolutionId: 12345
+            operatorCode: "001234567"
+        - name: Devolución sin operador (operatorCode opcional)
+          payload:
+            devolutionId: 99001
+            operatorCode: null
+
+    DevolutionProcessedEvent:
+      name: DevolutionProcessedEvent
+      title: Evento de devolución procesada
+      summary: |
+        Publicado por este microservicio tras generar el archivo DV y escribirlo en GCS.
+        Consumido por el SincronizadorService y también por este mismo microservicio
+        para ejecutar la transferencia HTTP al POS.
+      contentType: application/json
+      payload:
+        $ref: '#/components/schemas/DevolutionProcessedEventPayload'
+      examples:
+        - name: Devolución con nota de crédito generada
+          payload:
+            devolutionId: 12345
+            numNc: 87
+            creditNoteNumber: "NC-2026-0087"
+            gcsPath: "gs://gcs-cer-syncrhonization-files-dev/001/DV_20260612_12345.txt"
+            processedAt: "2026-06-12T14:35:22.123Z"
+
+  schemas:
+
+    DevolutionTriggerMessagePayload:
+      type: object
+      required:
+        - devolutionId
+      properties:
+        devolutionId:
+          type: integer
+          format: int32
+          description: |
+            Identificador de la sesión de devolución en DEVS_EC.DV_TICKET.
+            Corresponde al campo ID_DEV de la tabla.
+          minimum: 1
+          example: 12345
+        operatorCode:
+          type: string
+          description: |
+            Código del operador que ejecuta la devolución. Formato: 9 dígitos numéricos.
+            Corresponde a PaOprEntity.codOpr. Puede ser null si la devolución no requiere operador.
+          pattern: '^\d{9}$'
+          nullable: true
+          example: "001234567"
+
+    DevolutionProcessedEventPayload:
+      type: object
+      required:
+        - devolutionId
+        - gcsPath
+        - processedAt
+      properties:
+        devolutionId:
+          type: integer
+          format: int32
+          description: Identificador de la sesión de devolución. Mismo valor que en `DevolutionTriggerMessage`.
+          minimum: 1
+          example: 12345
+        numNc:
+          type: integer
+          format: int32
+          description: |
+            Número de secuencia de la nota de crédito generada por el POS (campo NUM_NC).
+            Null para devoluciones en modo 80 (devolución sin nota de crédito).
+          nullable: true
+          example: 87
+        creditNoteNumber:
+          type: string
+          description: |
+            Número de nota de crédito formateado para visualización.
+            Null para modo 80.
+          nullable: true
+          example: "NC-2026-0087"
+        gcsPath:
+          type: string
+          description: |
+            Ruta completa del archivo DV en Google Cloud Storage.
+            Formato: `gs://{bucket}/{storeId}/{fileName}`.
+            El SincronizadorService descarga el archivo desde esta ruta para entregarlo al POS.
+          example: "gs://gcs-cer-syncrhonization-files-dev/001/DV_20260612_12345.txt"
+        processedAt:
+          type: string
+          format: date-time
+          description: Timestamp UTC del momento en que el archivo DV fue generado y escrito en GCS.
+          example: "2026-06-12T14:35:22.123Z"


