+package com.elrosado.integration.infrastructure.security;
+
+import com.elrosado.integration.domain.exception.FileTransferPermanentException;
+import com.elrosado.integration.domain.exception.FileTransferTransientException;
+import com.elrosado.integration.infrastructure.config.FileTransferProperties;
+import com.google.cloud.secretmanager.v1.AccessSecretVersionResponse;
+import com.google.cloud.secretmanager.v1.SecretManagerServiceClient;
+import com.google.cloud.secretmanager.v1.SecretPayload;
+import com.google.cloud.secretmanager.v1.SecretVersionName;
+import com.google.protobuf.ByteString;
+import org.junit.jupiter.api.BeforeEach;
+import org.junit.jupiter.api.Test;
+import org.junit.jupiter.api.extension.ExtendWith;
+import org.mockito.ArgumentCaptor;
+import org.mockito.Mock;
+import org.mockito.junit.jupiter.MockitoExtension;
+
+import static org.assertj.core.api.Assertions.assertThat;
+import static org.assertj.core.api.Assertions.assertThatThrownBy;
+import static org.mockito.ArgumentMatchers.any;
+import static org.mockito.Mockito.verify;
+import static org.mockito.Mockito.verifyNoInteractions;
+import static org.mockito.Mockito.verifyNoMoreInteractions;
+import static org.mockito.Mockito.when;
+
+@ExtendWith(MockitoExtension.class)
+class SecretManagerBearerTokenProviderTest {
+
+    @Mock
+    private SecretManagerServiceClient secretManagerServiceClient;
+
+    private FileTransferProperties properties;
+    private SecretManagerBearerTokenProvider provider;
+
+    @BeforeEach
+    void setUp() {
+        properties = new FileTransferProperties();
+        properties.setBearerTokenSecretId("integration-file-transfer-bearer-token");
+        properties.setBearerTokenSecretVersion("latest");
+        properties.setBearerTokenCacheTtlSeconds(300);
+        provider = new SecretManagerBearerTokenProvider(secretManagerServiceClient, properties, "test-project");
+    }
+
+    @Test
+    void readsSecretAndBuildsBearerHeader() {
+        when(secretManagerServiceClient.accessSecretVersion(any(SecretVersionName.class)))
+                .thenReturn(secretResponse("token-value"));
+
+        String header = provider.authorizationHeader();
+
+        assertThat(header).isEqualTo("Bearer token-value");
+        ArgumentCaptor<SecretVersionName> captor = ArgumentCaptor.forClass(SecretVersionName.class);
+        verify(secretManagerServiceClient).accessSecretVersion(captor.capture());
+        assertThat(captor.getValue().toString())
+                .isEqualTo("projects/test-project/secrets/integration-file-transfer-bearer-token/versions/latest");
+    }
+
+    @Test
+    void preservesBearerPrefixWhenSecretAlreadyContainsIt() {
+        when(secretManagerServiceClient.accessSecretVersion(any(SecretVersionName.class)))
+                .thenReturn(secretResponse("Bearer token-value"));
+
+        String header = provider.authorizationHeader();
+
+        assertThat(header).isEqualTo("Bearer token-value");
+    }
+
+    @Test
+    void cachesHeaderWithinConfiguredTtl() {
+        when(secretManagerServiceClient.accessSecretVersion(any(SecretVersionName.class)))
+                .thenReturn(secretResponse("token-value"));
+
+        assertThat(provider.authorizationHeader()).isEqualTo("Bearer token-value");
+        assertThat(provider.authorizationHeader()).isEqualTo("Bearer token-value");
+
+        verify(secretManagerServiceClient).accessSecretVersion(any(SecretVersionName.class));
+        verifyNoMoreInteractions(secretManagerServiceClient);
+    }
+
+    @Test
+    void throwsPermanentExceptionWhenSecretIdIsMissing() {
+        properties.setBearerTokenSecretId(" ");
+
+        assertThatThrownBy(() -> provider.authorizationHeader())
+                .isInstanceOf(FileTransferPermanentException.class)
+                .hasMessageContaining("FILE_TRANSFER_BEARER_TOKEN_SECRET_ID");
+        verifyNoInteractions(secretManagerServiceClient);
+    }
+
+    @Test
+    void throwsPermanentExceptionWhenSecretPayloadIsBlank() {
+        when(secretManagerServiceClient.accessSecretVersion(any(SecretVersionName.class)))
+                .thenReturn(secretResponse(" "));
+
+        assertThatThrownBy(() -> provider.authorizationHeader())
+                .isInstanceOf(FileTransferPermanentException.class)
+                .hasMessageContaining("esta vacio");
+    }
+
+    @Test
+    void wrapsUnexpectedSecretManagerErrorsAsTransient() {
+        when(secretManagerServiceClient.accessSecretVersion(any(SecretVersionName.class)))
+                .thenThrow(new RuntimeException("secret manager unavailable"));
+
+        assertThatThrownBy(() -> provider.authorizationHeader())
+                .isInstanceOf(FileTransferTransientException.class)
+                .hasMessageContaining("Secret Manager");
+    }
+
+    private AccessSecretVersionResponse secretResponse(String value) {
+        return AccessSecretVersionResponse.newBuilder()
+                .setPayload(SecretPayload.newBuilder()
+                        .setData(ByteString.copyFromUtf8(value))
+                        .build())
+                .build();
+    }
+}


