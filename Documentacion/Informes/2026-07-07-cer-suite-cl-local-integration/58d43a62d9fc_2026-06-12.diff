+package com.elrosado.integration.infrastructure.adapter.in.pubsub;
+
+import com.elrosado.integration.application.command.ExecuteDevolutionCommand;
+import com.elrosado.integration.domain.exception.CreditNoteNotEligibleException;
+import com.elrosado.integration.domain.exception.DevolutionAlreadyProcessedException;
+import com.elrosado.integration.domain.exception.DevolutionValidationException;
+import com.elrosado.integration.domain.port.in.ExecuteDevolutionUseCase;
+import lombok.RequiredArgsConstructor;
+import lombok.extern.slf4j.Slf4j;
+import org.slf4j.MDC;
+import org.springframework.stereotype.Component;
+import tools.jackson.databind.ObjectMapper;
+
+import java.util.NoSuchElementException;
+
+@Component
+@RequiredArgsConstructor
+@Slf4j
+public class DevolutionCreationMessageHandler {
+
+    private final ExecuteDevolutionUseCase executeDevolutionUseCase;
+    private final ObjectMapper objectMapper;
+
+    public boolean handle(String subscriptionId, String body) {
+        DevolutionTriggerMessage message;
+        try {
+            message = objectMapper.readValue(body, DevolutionTriggerMessage.class);
+        } catch (Exception ex) {
+            log.atWarn()
+                    .setMessage("Mensaje Pub/Sub descartado: JSON invalido")
+                    .addKeyValue("subscriptionId", subscriptionId)
+                    .setCause(ex)
+                    .log();
+            return true;
+        }
+
+        if (message == null) {
+            log.atWarn()
+                    .setMessage("Mensaje Pub/Sub descartado: payload nulo")
+                    .addKeyValue("subscriptionId", subscriptionId)
+                    .log();
+            return true;
+        }
+
+        try {
+            if (message.devolutionId() == null) {
+                log.atWarn()
+                        .setMessage("Mensaje Pub/Sub descartado: devolutionId ausente")
+                        .addKeyValue("subscriptionId", subscriptionId)
+                        .log();
+                return true;
+            }
+
+            MDC.put("devolutionId", String.valueOf(message.devolutionId()));
+
+            executeDevolutionUseCase.execute(
+                    new ExecuteDevolutionCommand(message.devolutionId(), message.operatorCode())
+            );
+
+            log.atInfo()
+                    .setMessage("Devolucion procesada exitosamente via Pub/Sub")
+                    .addKeyValue("subscriptionId", subscriptionId)
+                    .addKeyValue("devolutionId", message.devolutionId())
+                    .log();
+
+            return true;
+        } catch (DevolutionAlreadyProcessedException ex) {
+            log.atWarn()
+                    .setMessage("Devolucion ya procesada - descartando mensaje duplicado")
+                    .addKeyValue("subscriptionId", subscriptionId)
+                    .addKeyValue("devolutionId", message != null ? message.devolutionId() : null)
+                    .setCause(ex)
+                    .log();
+            return true;
+        } catch (DevolutionValidationException | CreditNoteNotEligibleException ex) {
+            log.atWarn()
+                    .setMessage("Devolucion rechazada por regla de negocio - descartando mensaje")
+                    .addKeyValue("subscriptionId", subscriptionId)
+                    .addKeyValue("devolutionId", message != null ? message.devolutionId() : null)
+                    .setCause(ex)
+                    .log();
+            return true;
+        } catch (NoSuchElementException ex) {
+            log.atError()
+                    .setMessage("Sesion de devolucion no encontrada - reintentando via Nack")
+                    .addKeyValue("subscriptionId", subscriptionId)
+                    .addKeyValue("devolutionId", message != null ? message.devolutionId() : null)
+                    .setCause(ex)
+                    .log();
+            return false;
+        } catch (Exception ex) {
+            log.atError()
+                    .setMessage("Error inesperado procesando devolucion - reintentando via Nack")
+                    .addKeyValue("subscriptionId", subscriptionId)
+                    .addKeyValue("devolutionId", message.devolutionId())
+                    .setCause(ex)
+                    .log();
+            return false;
+        } finally {
+            MDC.remove("devolutionId");
+        }
+    }
+}


