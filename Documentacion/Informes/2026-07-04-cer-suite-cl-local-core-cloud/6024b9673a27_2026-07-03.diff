+package com.elrosado.cersuitecloudlocalcore.infrastructure.adapter.out.db;
+
+import com.elrosado.cersuitecloudlocalcore.domain.model.RegItemControl;
+import com.elrosado.cersuitecloudlocalcore.domain.port.out.RegItemControlPort;
+import com.elrosado.cersuitecloudlocalcore.infrastructure.adapter.out.db.entity.UpdateRegItemControlEntity;
+import com.elrosado.cersuitecloudlocalcore.infrastructure.adapter.out.db.repository.JpaUpdateRegItemControlRepository;
+import lombok.RequiredArgsConstructor;
+import lombok.extern.slf4j.Slf4j;
+import org.springframework.stereotype.Component;
+import org.springframework.transaction.annotation.Transactional;
+
+import java.time.LocalDateTime;
+import java.util.ArrayList;
+import java.util.List;
+
+/**
+ * Adaptador de control de estado en UPDATE_REG_ITEM_CONTROL (ARTS_EC).
+ * Replica la lÃ³gica de SP_Control_RegItem_ConsPendProcesar y SP_Control_RegItem_InsertUpdate.
+ */
+@Slf4j
+@Component
+@RequiredArgsConstructor
+public class DbRegItemControlAdapter implements RegItemControlPort {
+
+    private static final List<String> PENDING_STATES = List.of("NP", "ER");
+
+    private final JpaUpdateRegItemControlRepository repository;
+
+    @Override
+    @Transactional(transactionManager = "artsEcTransactionManager", readOnly = true)
+    public List<RegItemControl> getPendingFiles(String storeCode) {
+        List<UpdateRegItemControlEntity> all = repository
+                .findByCodigoTiendaAndEstadoInOrderByNombreRegItemAsc(storeCode, PENDING_STATES);
+
+        // Replica lÃ³gica del SP: retorna elementos hasta el primer ER (exclusive)
+        List<RegItemControl> result = new ArrayList<>();
+        for (UpdateRegItemControlEntity entity : all) {
+            if ("ER".equals(entity.getEstado())) {
+                break;
+            }
+            result.add(entity.toDomain());
+        }
+        return result;
+    }
+
+    @Override
+    @Transactional(transactionManager = "artsEcTransactionManager")
+    public void updateStatus(String storeCode, String fileName, String estado) {
+        repository.findByCodigoTiendaAndNombreRegItem(storeCode, fileName)
+                .ifPresentOrElse(
+                        entity -> applyUpdate(entity, estado),
+                        () -> log.atWarn()
+                                .setMessage("Registro de control no encontrado para actualizar estado")
+                                .addKeyValue("storeCode", storeCode)
+                                .addKeyValue("fileName", fileName)
+                                .addKeyValue("estado", estado)
+                                .log()
+                );
+    }
+
+    private void applyUpdate(UpdateRegItemControlEntity entity, String estado) {
+        entity.setEstado(estado);
+        LocalDateTime now = LocalDateTime.now();
+        if ("EP".equals(estado) || "PR".equals(estado)) {
+            entity.setFechaProceso(now);
+        } else {
+            entity.setFechaReintento(now);
+        }
+        repository.save(entity);
+    }
+}


