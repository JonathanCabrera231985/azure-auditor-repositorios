+package com.elrosado.cersuitecloudlocalcore.service;
+
+import com.elrosado.cersuitecloudlocalcore.domain.model.RegItemControl;
+import com.elrosado.cersuitecloudlocalcore.domain.model.RegItemFile;
+import com.elrosado.cersuitecloudlocalcore.domain.model.RegItemManifest;
+import com.elrosado.cersuitecloudlocalcore.domain.port.in.RegisterItemFilesUseCase;
+import com.elrosado.cersuitecloudlocalcore.domain.port.out.RegItemControlPort;
+import com.elrosado.cersuitecloudlocalcore.domain.port.out.RegItemDepartmentQueryPort;
+import com.elrosado.cersuitecloudlocalcore.domain.port.out.RegItemPersistencePort;
+import com.elrosado.cersuitecloudlocalcore.domain.port.out.RegItemStoragePort;
+import com.elrosado.cersuitecloudlocalcore.infrastructure.adapter.out.db.saadmin.entity.StoreEntity;
+import com.elrosado.cersuitecloudlocalcore.infrastructure.config.RegisterItemFilesProperties;
+import com.elrosado.cersuitecloudlocalcore.infrastructure.config.StoreRegistry;
+import lombok.extern.slf4j.Slf4j;
+import org.springframework.beans.factory.annotation.Qualifier;
+import org.springframework.core.task.AsyncTaskExecutor;
+import org.springframework.stereotype.Service;
+
+import java.io.BufferedReader;
+import java.io.IOException;
+import java.util.List;
+import java.util.concurrent.CompletableFuture;
+
+/**
+ * Servicio principal del proceso RegisterItemFiles.
+ * Itera todas las tiendas activas (MULTI_LOCAL), procesa en virtual thread independiente
+ * por tienda los archivos REG_ITEM pendientes en GCS EYES/ARSAP/IN.
+ */
+@Slf4j
+@Service
+public class RegisterItemFilesService implements RegisterItemFilesUseCase {
+
+    private static final String ESTADO_EXITOSO = "EP";
+    private static final String ESTADO_ERROR_COPIA = "NP";
+    private static final String ESTADO_ERROR = "ER";
+
+    private final RegItemStoragePort storagePort;
+    private final RegItemPersistencePort persistencePort;
+    private final RegItemControlPort controlPort;
+    private final RegItemDepartmentQueryPort departmentPort;
+    private final RegItemParserService parserService;
+    private final StoreRegistry storeRegistry;
+    private final RegisterItemFilesProperties properties;
+    private final AsyncTaskExecutor executor;
+
+    public RegisterItemFilesService(
+            RegItemStoragePort storagePort,
+            RegItemPersistencePort persistencePort,
+            RegItemControlPort controlPort,
+            RegItemDepartmentQueryPort departmentPort,
+            RegItemParserService parserService,
+            StoreRegistry storeRegistry,
+            RegisterItemFilesProperties properties,
+            @Qualifier("virtualThreadTaskExecutor") AsyncTaskExecutor executor) {
+        this.storagePort = storagePort;
+        this.persistencePort = persistencePort;
+        this.controlPort = controlPort;
+        this.departmentPort = departmentPort;
+        this.parserService = parserService;
+        this.storeRegistry = storeRegistry;
+        this.properties = properties;
+        this.executor = executor;
+    }
+
+    @Override
+    public void processAllPendingFiles() {
+        if (!properties.enabled()) {
+            log.debug("Proceso RegisterItemFiles deshabilitado, omitiendo ejecuciÃ³n");
+            return;
+        }
+
+        List<StoreEntity> stores = storeRegistry.getActiveMultiLocalStores();
+        if (stores.isEmpty()) {
+            log.debug("Sin tiendas activas para procesar REG_ITEM");
+            return;
+        }
+
+        List<CompletableFuture<Void>> futures = stores.stream()
+                .map(store -> CompletableFuture.runAsync(
+                        () -> processStore(String.valueOf(store.getDesClave())), executor))
+                .toList();
+
+        futures.forEach(f -> {
+            try {
+                f.join();
+            } catch (Exception e) {
+                log.atError()
+                        .setMessage("Error no controlado en hilo virtual de tienda RegisterItemFiles")
+                        .setCause(e)
+                        .log();
+            }
+        });
+    }
+
+    private void processStore(String storeCode) {
+        List<RegItemControl> pending = controlPort.getPendingFiles(storeCode);
+        if (pending.isEmpty()) {
+            return;
+        }
+
+        log.atInfo()
+                .setMessage("Procesando archivos REG_ITEM pendientes")
+                .addKeyValue("storeCode", storeCode)
+                .addKeyValue("cantidad", pending.size())
+                .log();
+
+        for (RegItemControl control : pending) {
+            processFile(storeCode, control.fileName());
+        }
+    }
+
+    private void processFile(String storeCode, String fileName) {
+        List<RegItemFile> available = storagePort.listPendingRegItemFiles(storeCode);
+        RegItemFile file = available.stream()
+                .filter(f -> f.location().fileName().equals(fileName))
+                .findFirst()
+                .orElse(null);
+
+        if (file == null) {
+            log.atWarn()
+                    .setMessage("Archivo REG_ITEM en control pero no encontrado en GCS")
+                    .addKeyValue("storeCode", storeCode)
+                    .addKeyValue("fileName", fileName)
+                    .log();
+            return;
+        }
+
+        try {
+            RegItemManifest manifest = parseWithDepartmentResolution(file);
+            copyDesatendidosFiles(storeCode, fileName, manifest);
+            persistencePort.save(manifest);
+            storagePort.moveRegItemToBkp(file);
+            controlPort.updateStatus(storeCode, fileName, ESTADO_EXITOSO);
+
+            log.atInfo()
+                    .setMessage("Archivo REG_ITEM procesado exitosamente")
+                    .addKeyValue("storeCode", storeCode)
+                    .addKeyValue("fileName", fileName)
+                    .addKeyValue("flejes", manifest.flejes().size())
+                    .log();
+
+        } catch (CopyFilesException e) {
+            log.atError()
+                    .setMessage("Error al copiar archivos LO*/PE* â marcado como NP")
+                    .addKeyValue("storeCode", storeCode)
+                    .addKeyValue("fileName", fileName)
+                    .setCause(e.getCause())
+                    .log();
+            controlPort.updateStatus(storeCode, fileName, ESTADO_ERROR_COPIA);
+
+        } catch (Exception e) {
+            log.atError()
+                    .setMessage("Error inesperado al procesar REG_ITEM â marcado como ER")
+                    .addKeyValue("storeCode", storeCode)
+                    .addKeyValue("fileName", fileName)
+                    .setCause(e)
+                    .log();
+            tryDeleteOnError(fileName);
+            controlPort.updateStatus(storeCode, fileName, ESTADO_ERROR);
+        }
+    }
+
+    private RegItemManifest parseWithDepartmentResolution(RegItemFile file) throws IOException {
+        try (BufferedReader reader = storagePort.openRegItem(file)) {
+            RegItemManifest raw = parserService.parse(reader);
+            List<com.elrosado.cersuitecloudlocalcore.domain.model.RegItemFleje> resolved =
+                    raw.flejes().stream()
+                            .map(fleje -> {
+                                int codDepto = departmentPort
+                                        .findDepartmentIdByCode(fleje.codDptoCer())
+                                        .orElseGet(() -> {
+                                            log.atWarn()
+                                                    .setMessage("Departamento no encontrado, asignando 0")
+                                                    .addKeyValue("codDptoCer", fleje.codDptoCer())
+                                                    .log();
+                                            return 0;
+                                        });
+                                return new com.elrosado.cersuitecloudlocalcore.domain.model.RegItemFleje(
+                                        fleje.name(), fleje.numItems(), fleje.store(), fleje.status(),
+                                        fleje.lote(), fleje.codNegocio(), fleje.codDptoCer(),
+                                        codDepto, fleje.archivos());
+                            })
+                            .toList();
+            return new RegItemManifest(raw.archivoSap(), resolved, raw.lotesMayoreo());
+        }
+    }
+
+    private void copyDesatendidosFiles(String storeCode, String fileName, RegItemManifest manifest) {
+        for (com.elrosado.cersuitecloudlocalcore.domain.model.RegItemFleje fleje : manifest.flejes()) {
+            if (fleje.isDesatendido()) {
+                try {
+                    storagePort.copyLoteAndPrecioFiles(storeCode, fleje.lote());
+                } catch (Exception e) {
+                    throw new CopyFilesException(fileName, e);
+                }
+            }
+        }
+    }
+
+    private void tryDeleteOnError(String fileName) {
+        try {
+            String arcItemName = fileName.startsWith("REG_")
+                    ? fileName.substring(4)
+                    : fileName;
+            persistencePort.deleteOnError(arcItemName);
+        } catch (Exception ex) {
+            log.atWarn()
+                    .setMessage("No se pudo ejecutar cascada de eliminaciÃ³n PRCFLJ_EC para ER")
+                    .addKeyValue("fileName", fileName)
+                    .setCause(ex)
+                    .log();
+        }
+    }
+
+    /** ExcepciÃ³n interna para seÃ±alizar fallo en copia GCS (estado NP). */
+    private static final class CopyFilesException extends RuntimeException {
+        CopyFilesException(String fileName, Throwable cause) {
+            super("Error al copiar LO*/PE* de " + fileName, cause);
+        }
+    }
+}


