+import java.util.concurrent.CompletableFuture;
+
+/**
+ * Orquesta la sincronizaciÃ³n de journals electrÃ³nicos por tienda MULTI_LOCAL: descarga
+ * desde el controlador POS, parseo ticket/voucher, ZIP en memoria, subida a GCS y
+ * publicaciÃ³n del evento Pub/Sub. TraducciÃ³n de {@code ReadJournalFileFromControllerTimerTask}
+ * legacy (ArmsServerLocal), con un ciclo (virtual thread) por tienda activa en vez de una
+ * tienda Ãºnica global.
+ */
+@Service
+public class JournalFileService implements ProcessJournalFilesUseCase {
+
+    private static final Logger log = LoggerFactory.getLogger(JournalFileService.class);
+    private static final DateTimeFormatter ZIP_DATE_SUFFIX = DateTimeFormatter.ofPattern("yyyy");
+    private static final int MAX_DOWNLOAD_ATTEMPTS = 3;
+
+    private final JournalControlPort controlPort;
+    private final JournalErrorPort errorPort;
+    private final JournalControllerPort controllerPort;
+    private final JournalStoragePort storagePort;
+    private final JournalEventPort eventPort;
+    private final JournalErrorTrackerPort errorTrackerPort;
+    private final JournalParserService parserService;
+    private final StoreRegistry storeRegistry;
+    private final SendJournalFileFtpProperties properties;
+    private final LegacyJournalFileFtpProperties legacyProperties;
+    private final ObjectMapper objectMapper;
+    private final AsyncTaskExecutor virtualThreadTaskExecutor;
+
+    public JournalFileService(
+            JournalControlPort controlPort,
+            JournalErrorPort errorPort,
+            JournalControllerPort controllerPort,
+            JournalStoragePort storagePort,
+            JournalEventPort eventPort,
+            JournalErrorTrackerPort errorTrackerPort,
+            JournalParserService parserService,
+            StoreRegistry storeRegistry,
+            SendJournalFileFtpProperties properties,
+            LegacyJournalFileFtpProperties legacyProperties,
+            ObjectMapper objectMapper,
+            @Qualifier("virtualThreadTaskExecutor") AsyncTaskExecutor virtualThreadTaskExecutor) {
+        this.controlPort = controlPort;
+        this.errorPort = errorPort;
+        this.controllerPort = controllerPort;
+        this.storagePort = storagePort;
+        this.eventPort = eventPort;
+        this.errorTrackerPort = errorTrackerPort;
+        this.parserService = parserService;
+        this.storeRegistry = storeRegistry;
+        this.properties = properties;
+        this.legacyProperties = legacyProperties;
+        this.objectMapper = objectMapper;
+        this.virtualThreadTaskExecutor = virtualThreadTaskExecutor;
+    }
+
+    @Override
+    public void processAllPendingStores() {
+        if (!properties.enabled()) {
+            log.atDebug().setMessage("JournalFileFtp deshabilitado").log();
+            return;
+        }
+
+        if (!storeRegistry.isMultiLocalEnabled()) {
+            log.atWarn().setMessage("JournalFileFtp omitido - sin tiendas multi-local activas en MN_TIENDA").log();
+            return;
+        }
+
+        List<CompletableFuture<Void>> futures = storeRegistry.getActiveMultiLocalStores().stream()
+                .map(store -> {
+                    int desClave = store.getDesClave();
+                    String ip = store.getIp();
+                    return CompletableFuture
+                            .runAsync(() -> processStore(desClave, ip), virtualThreadTaskExecutor)
+                            .exceptionally(ex -> {
+                                log.atError()
+                                        .setMessage("Error no controlado en hilo de tienda para JournalFileFtp")
+                                        .addKeyValue("desClave", desClave)
+                                        .setCause(ex)
+                                        .log();
+                                return null;
+                            });
+                })
+                .toList();
+
+        CompletableFuture.allOf(futures.toArray(CompletableFuture[]::new)).join();
+    }
+
+    private void processStore(int codStore, String ip) {
+        String storeCode = String.valueOf(codStore);
+
+        if (ip == null || ip.isBlank()) {
+            log.atWarn()
+                    .setMessage("Tienda sin IP registrada en MN_TIENDA - omitida para JournalFileFtp")
+                    .addKeyValue("storeCode", storeCode)
+                    .log();
+            return;
+        }
+
+        List<JournalPendingDate> pending = controlPort.findPendingByStore(codStore);
+        pending.forEach(date -> {
+            try {
+                processPendingDate(storeCode, ip, codStore, date);
+            } catch (RuntimeException e) {
+                log.atError()
+                        .setMessage("Fecha pendiente de journal no pudo procesarse - continua con las siguientes")
+                        .addKeyValue("storeCode", storeCode)
+                        .addKeyValue("anio", date.anio())
+                        .addKeyValue("mes", date.mes())
+                        .addKeyValue("dia", date.dia())
+                        .setCause(e)
+                        .log();
+            }
+        });
+
+        controlPort.insertTodayPendingIfAbsent(codStore);
+    }
+
+    private void processPendingDate(String storeCode, String ip, int codStore, JournalPendingDate date) {
+        String dir = legacyProperties.controllerFolder();
+        String pattern = "J" + date.mes() + "%02d".formatted(date.dia()) + "*";
+
+        Set<String> filesToDownload = new LinkedHashSet<>(filterValidJournalFileNames(
+                controllerPort.listFiles(ip, dir, pattern)));
+
+        List<JournalErrorPending> retryableErrors = errorPort.findRetryableByStore(codStore);
+        Set<String> recoveredFromError = new LinkedHashSet<>();
+        retryableErrors.forEach(errorEntry -> {
+            filesToDownload.add(errorEntry.journal());
+            recoveredFromError.add(errorEntry.journal());
+        });
+
+        Map<String, byte[]> downloaded = new LinkedHashMap<>();
+        for (String fileName : filesToDownload) {
+            downloadWithRetry(ip, dir, fileName, storeCode).ifPresentOrElse(
+                    content -> {
+                        downloaded.put(fileName, content);
+                        if (recoveredFromError.contains(fileName)) {
+                            errorPort.upsertError(codStore, fileName, "PR");
+                        }
+                    },
+                    () -> errorPort.upsertError(codStore, fileName, "PE")
+            );
+        }
+
+        if (!downloaded.isEmpty()) {
+            packageAndPublish(storeCode, codStore, date, downloaded);
+        } else {
+            log.atDebug()
+                    .setMessage("Sin archivos journal descargados para la fecha pendiente")
+                    .addKeyValue("storeCode", storeCode)
+                    .addKeyValue("anio", date.anio())
+                    .addKeyValue("mes", date.mes())
+                    .addKeyValue("dia", date.dia())
