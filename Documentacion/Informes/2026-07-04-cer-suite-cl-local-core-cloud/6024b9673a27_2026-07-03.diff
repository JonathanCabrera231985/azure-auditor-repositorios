+import com.elrosado.cersuitecloudlocalcore.infrastructure.config.LegacyJournalFileFtpProperties;
+import com.elrosado.cersuitecloudlocalcore.infrastructure.config.SendJournalFileFtpProperties;
+import com.elrosado.cersuitecloudlocalcore.infrastructure.config.StoreRegistry;
+import org.slf4j.Logger;
