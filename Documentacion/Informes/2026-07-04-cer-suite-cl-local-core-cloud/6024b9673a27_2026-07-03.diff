+package com.elrosado.cersuitecloudlocalcore.infrastructure.adapter.in.scheduler;
+
+import com.elrosado.cersuitecloudlocalcore.domain.port.in.ProcessJournalFilesUseCase;
+import com.elrosado.cersuitecloudlocalcore.infrastructure.config.LegacyJournalFileFtpProperties;
+import org.slf4j.Logger;
+import org.slf4j.LoggerFactory;
+import org.springframework.scheduling.annotation.Scheduled;
+import org.springframework.stereotype.Component;
+
+import java.time.LocalTime;
+import java.time.format.DateTimeFormatter;
+
+/**
+ * Dispara la sincronizaciÃ³n de journals cuando la hora actual coincide con
+ * {@code journalFileFtp.tiempoEjecucion} (HH:mm), igual que el gate legacy
+ * {@code journal.tiempo.ejecucion} de {@code ReadJournalFileFromControllerTimerTask}.
+ */
+@Component
+public class JournalFileFtpSchedulerAdapter {
+
+    private static final Logger log = LoggerFactory.getLogger(JournalFileFtpSchedulerAdapter.class);
+    private static final DateTimeFormatter HHMM = DateTimeFormatter.ofPattern("HH:mm");
+
+    private final ProcessJournalFilesUseCase processJournalFilesUseCase;
+    private final LegacyJournalFileFtpProperties properties;
+
+    public JournalFileFtpSchedulerAdapter(
+            ProcessJournalFilesUseCase processJournalFilesUseCase,
+            LegacyJournalFileFtpProperties properties) {
+        this.processJournalFilesUseCase = processJournalFilesUseCase;
+        this.properties = properties;
+    }
+
+    @Scheduled(fixedDelayString = "${journalFileFtp.sleeptime:30000}")
+    public void execute() {
+        try {
+            String horaActual = LocalTime.now().format(HHMM);
+            if (!horaActual.equals(properties.tiempoEjecucion())) {
+                return;
+            }
+            processJournalFilesUseCase.processAllPendingStores();
+        } catch (Exception e) {
+            log.atError()
+                    .setMessage("Error no controlado en scheduler de JournalFileFtp")
+                    .setCause(e)
+                    .log();
+        }
+    }
+}


