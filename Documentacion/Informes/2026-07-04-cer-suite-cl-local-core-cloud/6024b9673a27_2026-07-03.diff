--- a//src/main/java/com/elrosado/cersuitecloudlocalcore/infrastructure/adapter/out/storage/GcsRegItemStorageAdapter.java
+++ b//src/main/java/com/elrosado/cersuitecloudlocalcore/infrastructure/adapter/out/storage/GcsRegItemStorageAdapter.java
@@ -0,0 +1,132 @@
+package com.elrosado.cersuitecloudlocalcore.infrastructure.adapter.out.storage;
+
+import com.elrosado.cersuitecloudlocalcore.domain.model.GcsObjectReference;
+import com.elrosado.cersuitecloudlocalcore.domain.model.RegItemFile;
+import com.elrosado.cersuitecloudlocalcore.domain.port.out.RegItemStoragePort;
+import com.elrosado.cersuitecloudlocalcore.infrastructure.config.LegacyRegisterItemFilesProperties;
+import com.google.cloud.storage.BlobId;
+import com.google.cloud.storage.BlobInfo;
+import com.google.cloud.storage.Storage;
+import lombok.RequiredArgsConstructor;
+import lombok.extern.slf4j.Slf4j;
+import org.springframework.stereotype.Component;
+
+import java.io.BufferedReader;
+import java.util.List;
+import java.util.regex.Pattern;
+
+/**
+ * Adaptador GCS para el proceso RegisterItemFiles.
+ * Gestiona lectura de REG_ITEM, copia de LO* y PE* a prcFolder+ctrlFolder, y movimiento a bkp.
+ */
+@Slf4j
+@Component
+@RequiredArgsConstructor
+public class GcsRegItemStorageAdapter implements RegItemStoragePort {
+
+    private static final Pattern REG_ITEM_PATTERN = Pattern.compile("REG_ITEM(\\d+)\\..*");
+
+    private final GcsStorageHelper gcsHelper;
+    private final Storage storage;
+    private final LegacyRegisterItemFilesProperties legacyProperties;
+
+    @Override
+    public List<RegItemFile> listPendingRegItemFiles(String storeCode) {
+        String storeCodePadded = String.format("%03d", parseStoreCodeInt(storeCode));
+        GcsObjectReference inFolder = buildRef(legacyProperties.gcs().inputPrefix());
+        return gcsHelper.streamBlobs(inFolder)
+                .filter(blob -> {
+                    String name = blob.getName().contains("/")
+                            ? blob.getName().substring(blob.getName().lastIndexOf('/') + 1)
+                            : blob.getName();
+                    return REG_ITEM_PATTERN.matcher(name).matches()
+                            && name.startsWith("REG_ITEM" + storeCodePadded);
+                })
+                .map(blob -> new RegItemFile(
+                        new GcsObjectReference(blob.getBucket(), blob.getName()), storeCode))
+                .sorted((a, b) -> a.location().fileName().compareTo(b.location().fileName()))
+                .toList();
+    }
+
+    @Override
+    public BufferedReader openRegItem(RegItemFile file) {
+        return gcsHelper.openReader(file.location());
+    }
+
+    @Override
+    public void copyLoteAndPrecioFiles(String storeCode, String loteName) {
+        String sanitizedLote = sanitizeObjectName(loteName);
+        String bucket = legacyProperties.gcs().bucket();
+        String inPrefix = legacyProperties.gcs().inputPrefix();
+        String prcPrefix = legacyProperties.gcs().prcPrefix();
+        String ctrlPrefix = legacyProperties.gcs().ctrlPrefix(storeCode);
+        String peanName = derivePeanName(sanitizedLote);
+
+        copyBlob(bucket, inPrefix + "/" + sanitizedLote, prcPrefix + "/" + sanitizedLote);
+        copyBlob(bucket, inPrefix + "/" + sanitizedLote, ctrlPrefix + "/" + sanitizedLote);
+        deleteBlob(bucket, inPrefix + "/" + sanitizedLote);
+
+        copyBlob(bucket, inPrefix + "/" + peanName, prcPrefix + "/" + peanName);
+        copyBlob(bucket, inPrefix + "/" + peanName, ctrlPrefix + "/" + peanName);
+        deleteBlob(bucket, inPrefix + "/" + peanName);
+
+        log.atInfo()
+                .setMessage("Archivos LO*/PE* copiados a prcFolder y ctrlFolder")
+                .addKeyValue("loteName", loteName)
+                .addKeyValue("storeCode", storeCode)
+                .log();
+    }
+
+    @Override
+    public void moveRegItemToBkp(RegItemFile file) {
+        GcsObjectReference bkpFolder = buildRef(legacyProperties.gcs().bkpPrefix());
+        gcsHelper.moveBlob(file.location(), bkpFolder);
+        log.atInfo()
+                .setMessage("REG_ITEM movido a BKP")
+                .addKeyValue("file", file.location().toUri())
+                .log();
+    }
+
+    private void copyBlob(String bucket, String srcObject, String dstObject) {
+        BlobId srcId = BlobId.of(bucket, srcObject);
+        BlobId dstId = BlobId.of(bucket, dstObject);
+        storage.copy(Storage.CopyRequest.newBuilder()
+                .setSource(srcId)
+                .setTarget(BlobInfo.newBuilder(dstId).build())
+                .build()).getResult();
+    }
+
+    private void deleteBlob(String bucket, String objectName) {
+        storage.delete(BlobId.of(bucket, objectName));
+    }
+
+    private GcsObjectReference buildRef(String prefix) {
+        return new GcsObjectReference(legacyProperties.gcs().bucket(), prefix);
+    }
+
+    private static String derivePeanName(String loteName) {
+        if (loteName != null && loteName.startsWith("LO")) {
+            return "PE" + loteName.substring(2);
+        }
+        return loteName;
+    }
+
+    /**
+     * Elimina separadores de ruta y caracteres de control del nombre de archivo proveniente
+     * del contenido parseado, previniendo path traversal en object names de GCS (SonarQube S2083).
+     */
+    private static String sanitizeObjectName(String name) {
+        if (name == null) {
+            return "";
+        }
+        return name.replaceAll("[/\\\\]", "").replaceAll("\\.\\.", "");
+    }
+
+    private static int parseStoreCodeInt(String storeCode) {
+        try {
+            return Integer.parseInt(storeCode.trim());
+        } catch (NumberFormatException e) {
+            return 0;
+        }
+    }
+}


