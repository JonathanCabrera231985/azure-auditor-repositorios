--- Diff for /src/main/java/com/elrosado/cersuitecloudlocalcore/domain/model/JournalMonthCode.java ---
--- a//src/main/java/com/elrosado/cersuitecloudlocalcore/domain/model/JournalMonthCode.java
+++ b//src/main/java/com/elrosado/cersuitecloudlocalcore/domain/model/JournalMonthCode.java
@@ -0,0 +1,53 @@
+package com.elrosado.cersuitecloudlocalcore.domain.model;
+
+import java.util.Arrays;
+
+/**
+ * CÃ³digo legacy de un carÃ¡cter para el mes, usado tanto en el nombre de archivo del
+ * controlador ({@code J<mes><dia>*}) como en la columna {@code MES} de JOURNAL_PROCESO.
+ * TraducciÃ³n de {@code MesEnum} (ArmsServerLocal legacy).
+ */
+public enum JournalMonthCode {
+    ENERO("1", 1),
+    FEBRERO("2", 2),
+    MARZO("3", 3),
+    ABRIL("4", 4),
+    MAYO("5", 5),
+    JUNIO("6", 6),
+    JULIO("7", 7),
+    AGOSTO("8", 8),
+    SEPTIEMBRE("9", 9),
+    OCTUBRE("A", 10),
+    NOVIEMBRE("B", 11),
+    DICIEMBRE("C", 12);
+
+    private final String code;
+    private final int monthValue;
+
+    JournalMonthCode(String code, int monthValue) {
+        this.code = code;
+        this.monthValue = monthValue;
+    }
+
+    public String code() {
+        return code;
+    }
+
+    public int monthValue() {
+        return monthValue;
+    }
+
+    public static JournalMonthCode fromCode(String code) {
+        return Arrays.stream(values())
+                .filter(m -> m.code.equals(code))
+                .findFirst()
+                .orElseThrow(() -> new IllegalArgumentException("Codigo de mes legacy invalido: " + code));
+    }
+
+    public static JournalMonthCode fromMonthValue(int monthValue) {
+        return Arrays.stream(values())
+                .filter(m -> m.monthValue == monthValue)
+                .findFirst()
+                .orElseThrow(() -> new IllegalArgumentException("Mes invalido: " + monthValue));
+    }
+}


