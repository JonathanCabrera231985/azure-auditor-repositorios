+package com.elrosado.cersuitecloudlocalcore.service;
+
+import com.elrosado.cersuitecloudlocalcore.domain.model.RegItemArchivoImp;
+import com.elrosado.cersuitecloudlocalcore.domain.model.RegItemArchivoImpMayoreo;
+import com.elrosado.cersuitecloudlocalcore.domain.model.RegItemArchivoSap;
+import com.elrosado.cersuitecloudlocalcore.domain.model.RegItemFleje;
+import com.elrosado.cersuitecloudlocalcore.domain.model.RegItemLoteMayoreo;
+import com.elrosado.cersuitecloudlocalcore.domain.model.RegItemManifest;
+import lombok.extern.slf4j.Slf4j;
+import org.springframework.stereotype.Service;
+
+import java.io.BufferedReader;
+import java.io.IOException;
+import java.util.ArrayList;
+import java.util.List;
+
+/**
+ * Parsea el contenido de un archivo REG_ITEM (formato de ancho fijo) a {@link RegItemManifest}.
+ *
+ * LÃ­neas soportadas:
+ *   ARC_SAP  â cabecera del lote (primera lÃ­nea, ancho fijo 253+ chars)
+ *   ARC_PRC  â un fleje por lÃ­nea (ancho fijo 131+ chars)
+ *   ARC_ITE  â archivo de impresiÃ³n del fleje anterior (ancho fijo 58+ chars)
+ *   LOTE_MAYOREO,...     â CSV con 7 campos mÃ­nimo
+ *   ARCHIVO_IMPRESION_MAYOREO,... â CSV con 3 campos mÃ­nimo
+ */
+@Slf4j
+@Service
+public class RegItemParserService {
+
+    private static final String PREFIX_ARC_SAP = "ARC_SAP";
+    private static final String PREFIX_ARC_PRC = "ARC_PRC";
+    private static final String PREFIX_ARC_ITE = "ARC_ITE";
+    private static final String PREFIX_LOTE_MAYOREO = "LOTE_MAYOREO";
+    private static final String PREFIX_ARCHIVO_IMP_MAYOREO = "ARCHIVO_IMPRESION_MAYOREO";
+
+    public RegItemManifest parse(BufferedReader reader) throws IOException {
+        RegItemArchivoSap archivoSap = null;
+        List<RegItemFleje> flejes = new ArrayList<>();
+        List<RegItemLoteMayoreo> lotesMayoreo = new ArrayList<>();
+
+        FlejeBuilder currentFleje = null;
+        LoteMayoreoBuilder currentLote = null;
+
+        String line;
+        while ((line = reader.readLine()) != null) {
+            if (line.isBlank()) {
+                continue;
+            }
+
+            if (line.startsWith(PREFIX_ARC_SAP)) {
+                archivoSap = parseArchivoSap(line);
+
+            } else if (line.startsWith(PREFIX_ARC_PRC)) {
+                if (currentFleje != null) {
+                    flejes.add(currentFleje.build());
+                }
+                currentFleje = parseFleje(line);
+
+            } else if (line.startsWith(PREFIX_ARC_ITE)) {
+                if (currentFleje != null) {
+                    currentFleje.addArchivo(parseArchivoImp(line));
+                }
+
+            } else if (line.startsWith(PREFIX_LOTE_MAYOREO)) {
+                if (currentFleje != null) {
+                    flejes.add(currentFleje.build());
+                    currentFleje = null;
+                }
+                if (currentLote != null) {
+                    lotesMayoreo.add(currentLote.build());
+                }
+                currentLote = parseLoteMayoreo(line);
+
+            } else if (line.startsWith(PREFIX_ARCHIVO_IMP_MAYOREO)) {
+                if (currentLote != null) {
+                    currentLote.addArchivo(parseArchivoImpMayoreo(line));
+                }
+
+            } else {
+                log.debug("LÃ­nea desconocida ignorada en REG_ITEM: {}",
+                        line.substring(0, Math.min(10, line.length())));
+            }
+        }
+
+        if (currentFleje != null) {
+            flejes.add(currentFleje.build());
+        }
+        if (currentLote != null) {
+            lotesMayoreo.add(currentLote.build());
+        }
+
+        if (archivoSap == null) {
+            throw new IllegalArgumentException("Archivo REG_ITEM sin lÃ­nea ARC_SAP");
+        }
+
+        return new RegItemManifest(archivoSap, flejes, lotesMayoreo);
+    }
+
+    private RegItemArchivoSap parseArchivoSap(String line) {
+        requireMinLength(line, 253);
+        return new RegItemArchivoSap(
+                parseIntField(line, 7, 13),
+                parseLongField(line, 13, 27),
+                line.substring(27, 77).trim(),
+                parseIntField(line, 77, 83),
+                line.substring(83, 133).trim(),
+                parseIntField(line, 133, 139),
+                line.substring(139, 189).trim(),
+                parseIntField(line, 189, 195),
+                line.substring(195, 245).trim(),
+                parseIntField(line, 245, 251),
+                parseIntField(line, 251, 253)
+        );
+    }
+
+    private FlejeBuilder parseFleje(String line) {
+        requireMinLength(line, 131);
+        return new FlejeBuilder(
+                line.substring(7, 57).trim(),
+                parseIntField(line, 57, 63),
+                parseIntField(line, 63, 69),
+                parseIntField(line, 69, 70),
+                line.substring(70, 120).trim(),
+                parseIntField(line, 120, 123),
+                line.substring(127, 131).trim()
+        );
+    }
+
+    private RegItemArchivoImp parseArchivoImp(String line) {
+        requireMinLength(line, 58);
+        return new RegItemArchivoImp(
+                parseIntField(line, 7, 8),
+                line.substring(8, 58).trim()
+        );
+    }
+
+    private LoteMayoreoBuilder parseLoteMayoreo(String line) {
+        String[] parts = line.split(",", -1);
+        if (parts.length < 7) {
+            throw new IllegalArgumentException(
+                    "LÃ­nea LOTE_MAYOREO con campos insuficientes: " + parts.length);
+        }
+        return new LoteMayoreoBuilder(
+                parts[1].trim(),
+                Integer.parseInt(parts[2].trim()),
+                Integer.parseInt(parts[3].trim()),
+                Integer.parseInt(parts[4].trim()),
+                Integer.parseInt(parts[6].trim())
+        );
+    }
+
+    private RegItemArchivoImpMayoreo parseArchivoImpMayoreo(String line) {
+        String[] parts = line.split(",", -1);
+        if (parts.length < 3) {
+            throw new IllegalArgumentException("LÃ­nea ARCHIVO_IMPRESION_MAYOREO con campos insuficientes");
+        }
+        return new RegItemArchivoImpMayoreo(
+                Integer.parseInt(parts[1].trim()),
+                parts[2].trim()
+        );
+    }
+
+    private static void requireMinLength(String line, int min) {
+        if (line.length() < min) {
+            throw new IllegalArgumentException(
+                    "LÃ­nea demasiado corta: esperaba >= " + min + ", encontrÃ³ " + line.length());
+        }
+    }
+
+    private static int parseIntField(String line, int from, int to) {
+        String raw = line.substring(from, to).trim();
+        if (raw.isEmpty()) return 0;
+        try {
+            return Integer.parseInt(raw);
+        } catch (NumberFormatException e) {
+            return 0;
+        }
+    }
+
+    private static long parseLongField(String line, int from, int to) {
+        String raw = line.substring(from, to).trim();
+        if (raw.isEmpty()) return 0L;
+        try {
+            return Long.parseLong(raw);
+        } catch (NumberFormatException e) {
+            return 0L;
+        }
+    }
+
+    /** Builder mutable para acumular un {@link RegItemFleje} con sus hijos ARC_ITE. */
+    static final class FlejeBuilder {
+        private final String name;
+        private final int numItems;
+        private final int store;
+        private final int status;
+        private final String lote;
+        private final int codNegocio;
+        private final String codDptoCer;
+        private int codDepto = 0;
+        private final List<RegItemArchivoImp> archivos = new ArrayList<>();
+
+        FlejeBuilder(String name, int numItems, int store, int status,
+                     String lote, int codNegocio, String codDptoCer) {
+            this.name = name;
+            this.numItems = numItems;
+            this.store = store;
+            this.status = status;
+            this.lote = lote;
+            this.codNegocio = codNegocio;
+            this.codDptoCer = codDptoCer;
+        }
+
+        void addArchivo(RegItemArchivoImp imp) { archivos.add(imp); }
+
+        RegItemFleje build() {
+            return new RegItemFleje(name, numItems, store, status,
+                    lote, codNegocio, codDptoCer, codDepto, archivos);
+        }
+    }
+
+    /** Builder mutable para acumular un {@link RegItemLoteMayoreo} con sus hijos ARCHIVO_IMPRESION. */
+    static final class LoteMayoreoBuilder {
+        private final String nombreLote;
+        private final int numItems;
+        private final int estado;
+        private final int codNegocio;
+        private final int codDepto;
+        private final List<RegItemArchivoImpMayoreo> archivos = new ArrayList<>();
+
+        LoteMayoreoBuilder(String nombreLote, int numItems, int estado, int codNegocio, int codDepto) {
+            this.nombreLote = nombreLote;
+            this.numItems = numItems;
+            this.estado = estado;
+            this.codNegocio = codNegocio;
+            this.codDepto = codDepto;
+        }
+
+        void addArchivo(RegItemArchivoImpMayoreo imp) { archivos.add(imp); }
+
+        RegItemLoteMayoreo build() {
+            return new RegItemLoteMayoreo(nombreLote, numItems, estado, codNegocio, codDepto, archivos);
+        }
+    }
+}


