+    private Optional<byte[]> downloadWithRetry(String ip, String dir, String fileName, String storeCode) {
+        for (int attempt = 1; attempt <= MAX_DOWNLOAD_ATTEMPTS; attempt++) {
+            try {
+                Optional<byte[]> content = controllerPort.downloadFile(ip, dir, fileName);
+                if (content.isPresent()) {
+                    return content;
+                }
+            } catch (RuntimeException e) {
+                log.atWarn()
+                        .setMessage("Error descargando archivo journal del controlador; reintentando")
+                        .addKeyValue("storeCode", storeCode)
+                        .addKeyValue("fileName", fileName)
+                        .addKeyValue("attempt", attempt)
+                        .setCause(e)
+                        .log();
+            }
+        }
+
+        log.atWarn()
+                .setMessage("Archivo journal no pudo descargarse tras todos los reintentos")
+                .addKeyValue("storeCode", storeCode)
+                .addKeyValue("fileName", fileName)
+                .addKeyValue("maxAttempts", MAX_DOWNLOAD_ATTEMPTS)
+                .log();
+        return Optional.empty();
+    }
+
+    private void packageAndPublish(String storeCode, int codStore, JournalPendingDate date,
+                                    Map<String, byte[]> downloaded) {
+        Map<String, byte[]> zipEntries = new LinkedHashMap<>();
+
+        downloaded.forEach((fileName, content) -> {
+            List<JournalEntry> entries = parseFile(storeCode, codStore, date, fileName, content);
+            if (!entries.isEmpty()) {
+                zipEntries.put(fileName + ".dat", objectMapper.writeValueAsBytes(entries));
+            }
+        });
+
+        downloaded.forEach((fileName, content) -> storagePort.backupRawFile(storeCode, fileName, content));
+
+        if (zipEntries.isEmpty()) {
+            log.atDebug()
+                    .setMessage("Ningun archivo journal descargado produjo tickets/vouchers - sin ZIP para esta fecha")
+                    .addKeyValue("storeCode", storeCode)
+                    .log();
+            return;
+        }
+
+        byte[] zipContent = JournalZipService.compress(zipEntries);
+        String zipName = buildZipName(storeCode, date);
+
+        GcsObjectReference zipRef;
+        try {
+            zipRef = storagePort.uploadZip(storeCode, zipName, zipContent);
+        } catch (RuntimeException e) {
+            recordError(storeCode, date, JournalFileFtpStage.GCS_UPLOAD, e);
+            throw new JournalFileFtpException(JournalFileFtpStage.GCS_UPLOAD,
+                    "Error subiendo ZIP de journal a GCS", e);
+        }
+
+        try {
+            eventPort.publishZipReady(storeCode, zipRef.objectName());
+        } catch (RuntimeException e) {
+            recordError(storeCode, date, JournalFileFtpStage.PUBLISH, e);
+        }
+
+        log.atInfo()
+                .setMessage("ZIP de journal generado y publicado")
+                .addKeyValue("storeCode", storeCode)
+                .addKeyValue("zipName", zipName)
+                .addKeyValue("archivos", zipEntries.size())
+                .log();
+    }
+
+    private List<JournalEntry> parseFile(String storeCode, int codStore, JournalPendingDate date,
+                                          String fileName, byte[] content) {
+        try {
+            List<String> lines = new String(content, java.nio.charset.StandardCharsets.ISO_8859_1).lines().toList();
+            return parserService.parse(lines, date.anio(), codStore);
+        } catch (RuntimeException e) {
+            recordError(storeCode, date, JournalFileFtpStage.PARSE, e);
+            log.atWarn()
+                    .setMessage("Error parseando archivo journal - se omite")
+                    .addKeyValue("storeCode", storeCode)
+                    .addKeyValue("fileName", fileName)
+                    .setCause(e)
+                    .log();
+            return List.of();
+        }
+    }
+
+    private String buildZipName(String storeCode, JournalPendingDate date) {
+        // Fidelidad legacy: el anio del nombre del ZIP es el anio del sistema (no el anio del
+        // lote pendiente); mes/dia si vienen del cÃ³digo legacy de la fecha procesada.
+        String currentYear = LocalDate.now().format(ZIP_DATE_SUFFIX);
+        int monthValue = JournalMonthCode.fromCode(date.mes()).monthValue();
+        return "%s-%s%02d%02d.zip".formatted(storeCode, currentYear, monthValue, date.dia());
+    }
+
+    private List<String> filterValidJournalFileNames(List<String> rawNames) {
+        return rawNames.stream()
+                .filter(this::isValidJournalFileName)
+                .toList();
+    }
+
+    private boolean isValidJournalFileName(String name) {
+        int dotIndex = name.indexOf('.');
+        if (dotIndex < 0) {
+            return name.length() == 7;
+        }
+        String extension = name.substring(dotIndex);
+        if (extension.equalsIgnoreCase(".dat")) {
+            return legacyProperties.addExtDat() && name.length() == 11;
+        }
+        return extension.length() > 2;
+    }
+
+    private void recordError(String storeCode, JournalPendingDate date, JournalFileFtpStage stage, Exception e) {
+        try {
+            errorTrackerPort.recordError(new JournalErrorRecord(
+                    "JournalFileFtp",
+                    "SCHEDULED",
+                    java.util.UUID.randomUUID().toString(),
+                    storeCode,
+                    "",
+                    "",
+                    "",
+                    stage.name(),
+                    "",
+                    e.getClass().getSimpleName(),
+                    "",
+                    e.getMessage() == null ? "" : e.getMessage(),
+                    "",
+                    0,
+                    MAX_DOWNLOAD_ATTEMPTS,
+                    false,
+                    "ERROR",
+                    java.time.Instant.now(),
+                    java.time.Instant.now(),
+                    System.getenv().getOrDefault("HOSTNAME", ""),
+                    System.getenv().getOrDefault("POD_NAME", ""),
+                    "%s-%d-%s-%d".formatted(storeCode, date.anio(), date.mes(), date.dia())
+            ));
+        } catch (RuntimeException trackerFailure) {
+            log.atError()
+                    .setMessage("No se pudo registrar el error de JournalFileFtp en Firestore")
+                    .addKeyValue("storeCode", storeCode)
+                    .setCause(trackerFailure)
+                    .log();
+        }
+    }
+}


