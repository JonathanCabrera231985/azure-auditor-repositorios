+        // T.CONT y CAJERO de distinta longitud, mayÃºsculas/tildes).
+        List<String> lines = List.of(
+                "*** INICIO ***",
+                "2026/07/02 TIENDA:293 POS:14           ",
+                "CAJERO(A)#:202926 RAMON CED            ",
+                "T.CONT.:2014   09:00:34                ",
+                "                                 0.00 ",
+                "        EFECTIVO              150.00   ",
+                "TOTAL DOTACIÃN                150.00   "
+        );
+
+        List<JournalEntry> entries = parser.parse(lines, 2026, 293);
+
+        assertThat(entries).hasSize(1);
+        JournalEntry entry = entries.get(0);
+        assertThat(entry.store()).isEqualTo(293);
+        assertThat(entry.cajero()).isEqualTo("202926");
