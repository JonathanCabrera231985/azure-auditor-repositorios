+package com.elrosado.cersuitecloudlocalcore.infrastructure.adapter.out.firestore;
+
+import com.elrosado.cersuitecloudlocalcore.domain.model.JournalErrorRecord;
+import com.elrosado.cersuitecloudlocalcore.domain.port.out.JournalErrorTrackerPort;
+import com.google.cloud.Timestamp;
+import com.google.cloud.firestore.Firestore;
+import org.springframework.beans.factory.annotation.Value;
+import org.springframework.stereotype.Component;
+
+import java.time.Instant;
+import java.util.LinkedHashMap;
+import java.util.Map;
+import java.util.concurrent.ExecutionException;
+
+@Component
+public class JournalProcessErrorFirestoreAdapter implements JournalErrorTrackerPort {
+
+    private final Firestore firestore;
+
+    @Value("${app.gcp.firestore.collection-process-error:process_error}")
+    private String collection;
+
+    public JournalProcessErrorFirestoreAdapter(Firestore firestore) {
+        this.firestore = firestore;
+    }
+
+    @Override
+    public void recordError(JournalErrorRecord errorRecord) {
+        Map<String, Object> document = new LinkedHashMap<>();
+        document.put("processName", errorRecord.processName());
+        document.put("processType", errorRecord.processType());
+        document.put("executionId", errorRecord.executionId());
+        document.put("storeCode", errorRecord.storeCode());
+        document.put("fileName", errorRecord.fileName());
+        document.put("bucket", errorRecord.bucket());
+        document.put("gcsPath", errorRecord.gcsPath());
+        document.put("stage", errorRecord.stage());
+        document.put("operation", valueOrDefault(errorRecord.operation()));
+        document.put("errorType", valueOrDefault(errorRecord.errorType()));
+        document.put("errorCode", valueOrDefault(errorRecord.errorCode()));
+        document.put("errorMessage", valueOrDefault(errorRecord.errorMessage()));
+        document.put("stackTrace", valueOrDefault(errorRecord.stackTrace()));
+        document.put("retry", errorRecord.retry());
+        document.put("maxRetries", errorRecord.maxRetries());
+        document.put("stopRetries", errorRecord.stopRetries());
+        document.put("status", errorRecord.status());
+        document.put("createdAt", toTimestamp(errorRecord.createdAt()));
+        document.put("updatedAt", toTimestamp(errorRecord.updatedAt()));
+        document.put("hostname", valueOrDefault(errorRecord.hostname()));
+        document.put("podName", valueOrDefault(errorRecord.podName()));
+        document.put("schedulerExecutionId", valueOrDefault(errorRecord.schedulerExecutionId()));
+
+        try {
+            firestore.collection(collection)
+                    .document(errorRecord.executionId())
+                    .set(document)
+                    .get();
+        } catch (InterruptedException e) {
+            Thread.currentThread().interrupt();
+            throw new IllegalStateException("Firestore Journal error registration interrupted", e);
+        } catch (ExecutionException e) {
+            throw new IllegalStateException("Error registering Firestore Journal error", e);
+        }
+    }
+
+    private Timestamp toTimestamp(Instant instant) {
+        return Timestamp.ofTimeSecondsAndNanos(instant.getEpochSecond(), instant.getNano());
+    }
+
+    private String valueOrDefault(String value) {
+        return value == null ? "" : value;
+    }
+}


--- Diff for /src/main/java/com/elrosado/cersuitecloudlocalcore/infrastructure/adapter/out/http/JournalControllerHttpAdapter.java ---
--- a//src/main/java/com/elrosado/cersuitecloudlocalcore/infrastructure/adapter/out/http/JournalControllerHttpAdapter.java
+++ b//src/main/java/com/elrosado/cersuitecloudlocalcore/infrastructure/adapter/out/http/JournalControllerHttpAdapter.java
@@ -0,0 +1,133 @@
+package com.elrosado.cersuitecloudlocalcore.infrastructure.adapter.out.http;
+
+import com.elrosado.cersuitecloudlocalcore.domain.port.out.JournalControllerPort;
+import com.elrosado.cersuitecloudlocalcore.infrastructure.config.LegacyJournalFileFtpProperties;
+import org.slf4j.Logger;
+import org.slf4j.LoggerFactory;
+import org.springframework.stereotype.Component;
+import tools.jackson.databind.ObjectMapper;
+
+import java.io.IOException;
+import java.net.URI;
+import java.net.URLEncoder;
+import java.net.http.HttpClient;
+import java.net.http.HttpRequest;
+import java.net.http.HttpResponse;
+import java.nio.charset.StandardCharsets;
+import java.time.Duration;
+import java.util.Base64;
+import java.util.LinkedHashMap;
+import java.util.List;
+import java.util.Map;
+import java.util.Optional;
+import java.util.stream.Collectors;
+
+/**
+ * Cliente HTTP hacia el controlador POS de una tienda. Reemplaza al {@code HttpImpl} legacy
+ * (que aceptaba cualquier certificado TLS); aquÃ­ se usa el {@link HttpClient} del JDK con
+ * validaciÃ³n TLS estÃ¡ndar (truststore real, sin bypass de hostname).
+ */
+@Component
+public class JournalControllerHttpAdapter implements JournalControllerPort {
+
+    private static final Logger log = LoggerFactory.getLogger(JournalControllerHttpAdapter.class);
+    private static final Duration REQUEST_TIMEOUT = Duration.ofSeconds(15);
+    private static final String LIST_SUFFIX = "/ls";
+
+    private final HttpClient httpClient;
+    private final ObjectMapper objectMapper;
+    private final LegacyJournalFileFtpProperties properties;
+
+    public JournalControllerHttpAdapter(ObjectMapper objectMapper, LegacyJournalFileFtpProperties properties) {
+        this.httpClient = HttpClient.newBuilder()
+                .connectTimeout(REQUEST_TIMEOUT)
+                .build();
+        this.objectMapper = objectMapper;
+        this.properties = properties;
+    }
+
+    @Override
+    public List<String> listFiles(String ip, String dir, String pattern) {
+        URI uri = buildUri(ip, LIST_SUFFIX, Map.of("dir", dir, "pattern", pattern.toLowerCase()));
+        try {
+            HttpResponse<byte[]> response = send(uri);
+            if (response.statusCode() != 200) {
+                log.atWarn()
+                        .setMessage("Listado de journals del controlador respondio con error")
+                        .addKeyValue("ip", ip)
+                        .addKeyValue("status", response.statusCode())
+                        .log();
+                return List.of();
+            }
+            ControllerListResponse body = objectMapper.readValue(response.body(), ControllerListResponse.class);
+            return body.files() == null ? List.of() : body.files();
+        } catch (IOException e) {
+            log.atWarn()
+                    .setMessage("Error de comunicacion listando journals del controlador")
+                    .addKeyValue("ip", ip)
+                    .setCause(e)
+                    .log();
+            return List.of();
+        } catch (InterruptedException e) {
+            Thread.currentThread().interrupt();
+            log.atWarn().setMessage("Listado de journals interrumpido").addKeyValue("ip", ip).log();
+            return List.of();
+        }
+    }
+
+    @Override
+    public Optional<byte[]> downloadFile(String ip, String dir, String fileName) {
+        URI uri = buildUri(ip, "", Map.of("dir", dir, "file", fileName.toUpperCase()));
+        try {
+            HttpResponse<byte[]> response = send(uri);
+            if (response.statusCode() != 200) {
+                log.atWarn()
+                        .setMessage("Descarga de journal respondio con error")
+                        .addKeyValue("ip", ip)
+                        .addKeyValue("fileName", fileName)
+                        .addKeyValue("status", response.statusCode())
+                        .log();
+                return Optional.empty();
+            }
+
+            ControllerFileResponse body = objectMapper.readValue(response.body(), ControllerFileResponse.class);
+            if (body.content() == null || body.content().isBlank()) {
+                return Optional.empty();
+            }
+            return Optional.of(Base64.getDecoder().decode(body.content()));
+        } catch (IOException e) {
+            throw new IllegalStateException("Error de comunicacion descargando journal del controlador", e);
+        } catch (InterruptedException e) {
+            Thread.currentThread().interrupt();
+            throw new IllegalStateException("Descarga de journal interrumpida", e);
+        }
+    }
+
+    private HttpResponse<byte[]> send(URI uri) throws IOException, InterruptedException {
+        return httpClient.send(buildRequest(uri), HttpResponse.BodyHandlers.ofByteArray());
+    }
+
+    HttpRequest buildRequest(URI uri) {
+        return HttpRequest.newBuilder(uri)
+                .timeout(REQUEST_TIMEOUT)
+                .header("Authorization", "Bearer " + properties.jwt())
+                .GET()
+                .build();
+    }
+
+    URI buildUri(String ip, String suffix, Map<String, String> params) {
+        Map<String, String> ordered = new LinkedHashMap<>(params);
+        String query = ordered.entrySet().stream()
+                .map(e -> URLEncoder.encode(e.getKey(), StandardCharsets.UTF_8)
+                        + "=" + URLEncoder.encode(e.getValue(), StandardCharsets.UTF_8))
+                .collect(Collectors.joining("&"));
+        String path = properties.controllerPath() + suffix;
+        return URI.create("https://" + ip + ":" + properties.controllerPort() + path + "?" + query);
+    }
+
+    private record ControllerListResponse(List<String> files) {
+    }
+
+    private record ControllerFileResponse(String file, String dir, String content) {
+    }
+}


