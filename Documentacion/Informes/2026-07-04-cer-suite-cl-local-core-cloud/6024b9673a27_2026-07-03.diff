+        this.messagePublisher = messagePublisher;
+        this.objectMapper = objectMapper;
+        this.properties = properties;
+    }
+
+    @Override
+    public void publishZipReady(String storeCode, String gcsBlobName) {
+        String topic = properties.pubsub().topic();
+
+        Map<String, Object> payload = new LinkedHashMap<>();
+        payload.put("storeCode", storeCode);
+        payload.put("gcsBlobName", gcsBlobName);
+
+        String message = objectMapper.writeValueAsString(payload);
+
+        messagePublisher.publishAsync(topic, message)
+                .whenComplete((msgId, ex) -> {
+                    if (ex != null) {
+                        log.atError()
+                                .setMessage("Error publicando evento de journal a Pub/Sub")
+                                .addKeyValue("storeCode", storeCode)
+                                .addKeyValue("gcsBlobName", gcsBlobName)
+                                .addKeyValue("topic", topic)
+                                .setCause(ex)
+                                .log();
+                    } else {
+                        log.atInfo()
+                                .setMessage("Evento de journal publicado exitosamente")
+                                .addKeyValue("storeCode", storeCode)
+                                .addKeyValue("gcsBlobName", gcsBlobName)
+                                .addKeyValue("messageId", msgId)
+                                .log();
+                    }
+                });
+    }
+}


