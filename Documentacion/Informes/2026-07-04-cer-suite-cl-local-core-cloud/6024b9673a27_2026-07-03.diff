@@ -0,0 +1,90 @@
+package com.elrosado.cersuitecloudlocalcore.infrastructure.adapter.out.db;
+
+import com.elrosado.cersuitecloudlocalcore.domain.model.JournalMonthCode;
+import com.elrosado.cersuitecloudlocalcore.domain.model.JournalPendingDate;
+import com.elrosado.cersuitecloudlocalcore.domain.port.out.JournalControlPort;
+import com.elrosado.cersuitecloudlocalcore.infrastructure.adapter.out.db.entity.JournalProcesoEntity;
+import com.elrosado.cersuitecloudlocalcore.infrastructure.adapter.out.db.entity.JournalProcesoEntityId;
+import com.elrosado.cersuitecloudlocalcore.infrastructure.adapter.out.db.repository.JpaJournalProcesoRepository;
+import org.slf4j.Logger;
+import org.slf4j.LoggerFactory;
+import org.springframework.stereotype.Component;
+import org.springframework.transaction.annotation.Transactional;
+
+import java.time.LocalDate;
+import java.time.LocalDateTime;
+import java.util.List;
+
+@Component
+public class DbJournalControlAdapter implements JournalControlPort {
+
+    private static final Logger log = LoggerFactory.getLogger(DbJournalControlAdapter.class);
+    private static final String ESTADO_PENDIENTE = "PE";
+    private static final String ESTADO_PROCESADO = "TE";
+
+    private final JpaJournalProcesoRepository repository;
+
+    public DbJournalControlAdapter(JpaJournalProcesoRepository repository) {
+        this.repository = repository;
+    }
+
+    @Override
+    @Transactional(transactionManager = "artsEcTransactionManager", readOnly = true)
+    public List<JournalPendingDate> findPendingByStore(int codStore) {
+        return repository.findByIdCdStrAndEstado(codStore, ESTADO_PENDIENTE).stream()
+                .map(entity -> new JournalPendingDate(
+                        entity.getId().getCdStr(),
+                        entity.getId().getAnio(),
+                        entity.getId().getMes(),
+                        entity.getId().getDia()))
+                .toList();
+    }
+
+    @Override
+    @Transactional(transactionManager = "artsEcTransactionManager")
+    public void markProcessed(JournalPendingDate date) {
+        updateEstado(date, ESTADO_PROCESADO);
+    }
+
+    @Override
+    @Transactional(transactionManager = "artsEcTransactionManager")
+    public void markPending(JournalPendingDate date) {
+        updateEstado(date, ESTADO_PENDIENTE);
+    }
+
+    @Override
+    @Transactional(transactionManager = "artsEcTransactionManager")
+    public void insertTodayPendingIfAbsent(int codStore) {
+        LocalDate today = LocalDate.now();
+        JournalProcesoEntityId id = new JournalProcesoEntityId(
+                codStore,
+                today.getYear(),
+                JournalMonthCode.fromMonthValue(today.getMonthValue()).code(),
+                today.getDayOfMonth());
+
+        if (repository.existsById(id)) {
+            return;
+        }
+
+        repository.save(new JournalProcesoEntity(id, LocalDateTime.now(), ESTADO_PENDIENTE));
+    }
+
+    private void updateEstado(JournalPendingDate date, String estado) {
+        JournalProcesoEntityId id = new JournalProcesoEntityId(date.codStore(), date.anio(), date.mes(), date.dia());
+        repository.findById(id).ifPresentOrElse(
+                entity -> {
+                    entity.setEstado(estado);
+                    entity.setFechaProceso(LocalDateTime.now());
+                    repository.save(entity);
+                },
+                () -> log.atWarn()
+                        .setMessage("JOURNAL_PROCESO no encontrado al intentar actualizar estado")
+                        .addKeyValue("codStore", date.codStore())
+                        .addKeyValue("anio", date.anio())
+                        .addKeyValue("mes", date.mes())
+                        .addKeyValue("dia", date.dia())
+                        .addKeyValue("estado", estado)
+                        .log()
+        );
+    }
+}


