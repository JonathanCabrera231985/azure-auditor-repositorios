+package com.elrosado.cersuitecloudlocalcore.infrastructure.adapter.out.db;
+
+import com.elrosado.cersuitecloudlocalcore.domain.model.JournalErrorPending;
+import com.elrosado.cersuitecloudlocalcore.domain.port.out.JournalErrorPort;
+import com.elrosado.cersuitecloudlocalcore.infrastructure.adapter.out.db.entity.JournalErrorEntity;
+import com.elrosado.cersuitecloudlocalcore.infrastructure.adapter.out.db.entity.JournalErrorEntityId;
+import com.elrosado.cersuitecloudlocalcore.infrastructure.adapter.out.db.repository.JpaJournalErrorRepository;
+import org.springframework.stereotype.Component;
+import org.springframework.transaction.annotation.Transactional;
+
+import java.time.LocalDateTime;
+import java.util.List;
+import java.util.Optional;
+
+@Component
+public class DbJournalErrorAdapter implements JournalErrorPort {
+
+    private static final String ESTADO_PENDIENTE = "PE";
+    private static final int MAX_REINTENTOS = 3;
+
+    private final JpaJournalErrorRepository repository;
+
+    public DbJournalErrorAdapter(JpaJournalErrorRepository repository) {
+        this.repository = repository;
+    }
+
+    @Override
+    @Transactional(transactionManager = "artsEcTransactionManager", readOnly = true)
+    public List<JournalErrorPending> findRetryableByStore(int codStore) {
+        return repository.findByIdCdStrAndEstadoAndReintentoLessThan(codStore, ESTADO_PENDIENTE, MAX_REINTENTOS)
+                .stream()
+                .map(entity -> new JournalErrorPending(
+                        entity.getId().getCdStr(),
+                        entity.getId().getJournal(),
+                        entity.getReintento() == null ? 0 : entity.getReintento()))
+                .toList();
+    }
+
+    @Override
+    @Transactional(transactionManager = "artsEcTransactionManager")
+    public void upsertError(int codStore, String journal, String estado) {
+        JournalErrorEntityId id = new JournalErrorEntityId(codStore, journal);
+        Optional<JournalErrorEntity> existing = repository.findById(id);
+
+        if (existing.isPresent()) {
+            JournalErrorEntity entity = existing.get();
+            if (ESTADO_PENDIENTE.equals(estado)) {
+                int reintentoActual = entity.getReintento() == null ? 0 : entity.getReintento();
+                entity.setReintento(reintentoActual + 1);
+            }
+            entity.setEstado(estado);
+            entity.setFechaProceso(LocalDateTime.now());
+            repository.save(entity);
+        } else {
+            int reintentoInicial = ESTADO_PENDIENTE.equals(estado) ? 1 : 0;
+            repository.save(new JournalErrorEntity(id, LocalDateTime.now(), estado, reintentoInicial));
+        }
+    }
+}


