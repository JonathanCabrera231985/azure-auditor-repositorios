+package com.elrosado.cersuitecloudlocalcore.infrastructure.config;
+
+import org.springframework.boot.context.properties.ConfigurationProperties;
+
+/**
+ * Propiedades heredadas de ArmsServerConf.properties para el proceso RegisterItemFiles.
+ * Todas las rutas GCS se expresan como prefijos (sin bucket ni gs://).
+ */
+@ConfigurationProperties(prefix = "register-item-files")
+public record LegacyRegisterItemFilesProperties(
+        long sleeptime,
+        GcsConfig gcs
+) {
+    public LegacyRegisterItemFilesProperties {
+        if (sleeptime <= 0) {
+            sleeptime = 5_000L;
+        }
+        if (gcs == null) {
+            gcs = new GcsConfig("gcs-cer-suite-core-files",
+                    "EYES/ARSAP/IN", "EYES/ARSAP/PRC", "EYES/ARSAP/BKP",
+                    "ALLC_DAT/IN", "INSAP");
+        }
+    }
+
+    public record GcsConfig(
+            String bucket,
+            String inputPrefix,
+            String prcPrefix,
+            String bkpPrefix,
+            String ctrlBasePrefix,
+            String ctrlFolderName
+    ) {
+        public GcsConfig {
+            if (bucket == null || bucket.isBlank()) bucket = "gcs-cer-suite-core-files";
+            if (inputPrefix == null || inputPrefix.isBlank()) inputPrefix = "EYES/ARSAP/IN";
+            if (prcPrefix == null || prcPrefix.isBlank()) prcPrefix = "EYES/ARSAP/PRC";
+            if (bkpPrefix == null || bkpPrefix.isBlank()) bkpPrefix = "EYES/ARSAP/BKP";
+            if (ctrlBasePrefix == null || ctrlBasePrefix.isBlank()) ctrlBasePrefix = "ALLC_DAT/IN";
+            if (ctrlFolderName == null || ctrlFolderName.isBlank()) ctrlFolderName = "INSAP";
+        }
+
+        /** Retorna el prefijo completo del controlador 4690 para la tienda indicada. */
+        public String ctrlPrefix(String storeCode) {
+            return ctrlBasePrefix + "/" + storeCode + "/" + ctrlFolderName;
+        }
+    }
+}


