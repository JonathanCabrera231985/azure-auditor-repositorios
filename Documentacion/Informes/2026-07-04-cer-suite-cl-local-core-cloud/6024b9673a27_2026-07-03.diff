+import org.springframework.transaction.annotation.Transactional;
+
+import java.util.List;
+
+/**
+ * Adaptador de persistencia en PRCFLJ_EC para el proceso RegisterItemFiles.
+ * Replica la secuencia de inserts del legacy FlejesDAO con Hibernate:
+ * ARC_SAP â ARC_PRC (+ARC_ITEMS) â ARC_MOV â LOTE_MAYOREO â actualiza ARC_SAP.ID_ESTPRC=0.
+ */
+@Slf4j
+@Component
+@RequiredArgsConstructor
+public class DbRegItemPersistenceAdapter implements RegItemPersistencePort {
+
+    private final JpaArchivoSapRepository archivoSapRepository;
+    private final JpaFlejeRepository flejeRepository;
+    private final JpaArcMovRepository arcMovRepository;
+    private final JpaArcItemsRepository arcItemsRepository;
+    private final JpaLoteMayoreoRepository loteMayoreoRepository;
+    private final JpaPrcPrcRepository prcPrcRepository;
+
+    @Override
+    @Transactional(transactionManager = "prcfljEcTransactionManager")
+    public void save(RegItemManifest manifest) {
+        ArchivoSapEntity sap = archivoSapRepository.save(
+                ArchivoSapEntity.fromDomain(manifest.archivoSap()));
+        int idArcsap = sap.getIdArcsap();
+
+        for (RegItemFleje fleje : manifest.flejes()) {
+            FlejeEntity flejeEntity = flejeRepository.save(FlejeEntity.fromDomain(fleje, idArcsap));
+            int idArcprc = flejeEntity.getIdArcprc();
+
+            fleje.archivos().forEach(imp ->
+                    arcItemsRepository.save(ArcItemsEntity.fromDomain(imp, idArcprc)));
+
+            arcMovRepository.save(ArcMovEntity.create(idArcprc, flejeEntity.getIdEstprc()));
+        }
+
+        manifest.lotesMayoreo().forEach(lote ->
+                loteMayoreoRepository.save(LoteMayoreoEntity.fromDomain(lote, idArcsap)));
+
+        sap.setIdEstprc(0);
+        archivoSapRepository.save(sap);
+    }
+
+    @Override
+    @Transactional(transactionManager = "prcfljEcTransactionManager")
+    public void deleteOnError(String arcItemName) {
+        archivoSapRepository.findByArcItem(arcItemName).ifPresent(sap -> {
+            List<FlejeEntity> flejes = flejeRepository.findByIdArcsap(sap.getIdArcsap());
+            flejes.forEach(fleje -> {
+                int idArcprc = fleje.getIdArcprc();
+                arcMovRepository.findByIdArcprc(idArcprc)
+                        .forEach(mov -> arcMovRepository.deleteById(mov.getIdMov()));
+                arcItemsRepository.deleteByIdArcprc(idArcprc);
+                prcPrcRepository.deleteByIdArcprc(idArcprc);
+                flejeRepository.deleteById(idArcprc);
+            });
+            archivoSapRepository.deleteById(sap.getIdArcsap());
+
+            log.atInfo()
+                    .setMessage("Cascada de eliminaciÃ³n PRCFLJ_EC ejecutada por estado ER")
+                    .addKeyValue("arcItemName", arcItemName)
+                    .log();
+        });
+    }
+}


