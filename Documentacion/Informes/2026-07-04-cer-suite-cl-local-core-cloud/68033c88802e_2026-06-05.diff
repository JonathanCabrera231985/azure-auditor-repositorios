--- a//build.sh
+++ b//build.sh
@@ -0,0 +1,21 @@
+#!/bin/bash
+set -e
+
+ARTIFACT_ID=$(mvn help:evaluate -Dexpression=project.artifactId -q -DforceStdout)
+VERSION=$(mvn help:evaluate -Dexpression=project.version -q -DforceStdout)
+REGISTRY="localhost:30500"
+
+IMAGE_NAME="${REGISTRY}/${ARTIFACT_ID}:${VERSION}"
+LATEST_NAME="${REGISTRY}/${ARTIFACT_ID}:latest"
+
+# Skaffold inyecta $IMAGE cuando orquesta el build
+if [ -n "$IMAGE" ]; then
+    IMAGE_NAME="$IMAGE"
+    LATEST_NAME="${IMAGE%%:*}:latest"
+fi
+
+echo "Building image: ${IMAGE_NAME}"
+podman build -t "${IMAGE_NAME}" -t "${LATEST_NAME}" .
+
+podman push --tls-verify=false "${IMAGE_NAME}"
+podman push --tls-verify=false "${LATEST_NAME}"


