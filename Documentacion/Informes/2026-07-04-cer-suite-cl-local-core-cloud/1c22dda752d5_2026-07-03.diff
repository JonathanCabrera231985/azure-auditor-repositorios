+package com.elrosado.cersuitecloudlocalcore.infrastructure.adapter.in.scheduler;
+
+import com.elrosado.cersuitecloudlocalcore.domain.port.in.SearchInventarioStickerUseCase;
+import org.slf4j.Logger;
+import org.slf4j.LoggerFactory;
+import org.springframework.scheduling.annotation.Scheduled;
+import org.springframework.stereotype.Component;
+
+/**
+ * Dispara la sincronizaciÃ³n de inventario de stickers cada
+ * {@code searchInventarioSticker.sleeptime} ms, igual que el loop legacy
+ * {@code SearchInventarioStickerFileProcess} (5 minutos por defecto).
+ */
+@Component
+public class SearchInventarioStickerSchedulerAdapter {
+
+    private static final Logger log = LoggerFactory.getLogger(SearchInventarioStickerSchedulerAdapter.class);
+
+    private final SearchInventarioStickerUseCase searchInventarioStickerUseCase;
+
+    public SearchInventarioStickerSchedulerAdapter(SearchInventarioStickerUseCase searchInventarioStickerUseCase) {
+        this.searchInventarioStickerUseCase = searchInventarioStickerUseCase;
+    }
+
+    @Scheduled(fixedDelayString = "${searchInventarioSticker.sleeptime:300000}")
+    public void execute() {
+        try {
+            searchInventarioStickerUseCase.processAllPendingStores();
+        } catch (Exception e) {
+            log.atError()
