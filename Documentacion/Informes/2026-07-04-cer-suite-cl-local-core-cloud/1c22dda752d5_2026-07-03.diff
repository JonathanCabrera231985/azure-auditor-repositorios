+package com.elrosado.cersuitecloudlocalcore.service;
+
+import com.elrosado.cersuitecloudlocalcore.domain.model.StickerInventoryLine;
+import org.springframework.stereotype.Service;
+
+import java.util.ArrayList;
+import java.util.List;
+
+/**
+ * Parsea el archivo diario de inventario de stickers ({@code cajero,secuencia,hora,cantidad})
+ * a una lista de {@link StickerInventoryLine}. TraducciÃ³n de la lÃ³gica CSV inline de
+ * {@code SearchInventarioStickerFileProcess.saveOrUpdateStickerByCajeroJava8()} legacy.
+ * <p>
+ * Fidelidad legacy: si cualquier lÃ­nea tiene menos de 4 campos o un campo no numÃ©rico,
+ * se lanza {@link IllegalArgumentException} y el archivo completo falla (no se procesan
+ * lÃ­neas parciales) â igual que el legacy, que ejecuta un Ãºnico {@code CallableStatement}
+ * dentro de un solo try que aborta todo el archivo ante el primer error de lÃ­nea.
+ */
+@Service
+public class StickerInventoryParserService {
+
+    private static final int MIN_FIELDS = 4;
+    private static final int FIELD_CAJERO = 0;
+    private static final int FIELD_CANTIDAD = 3;
+
+    public List<StickerInventoryLine> parse(List<String> lines) {
+        List<StickerInventoryLine> result = new ArrayList<>();
+        for (String line : lines) {
+            if (line.isBlank()) {
+                continue;
+            }
+            result.add(parseLine(line));
+        }
+        return result;
+    }
+
+    private StickerInventoryLine parseLine(String line) {
+        String[] fields = line.split(",", -1);
+        if (fields.length < MIN_FIELDS) {
+            throw new IllegalArgumentException(
+                    "Linea de inventario de sticker con campos insuficientes: " + fields.length);
+        }
+        try {
+            int cajero = Integer.parseInt(fields[FIELD_CAJERO].trim());
+            int cantidad = Integer.parseInt(fields[FIELD_CANTIDAD].trim());
+            return new StickerInventoryLine(cajero, cantidad);
+        } catch (NumberFormatException e) {
+            throw new IllegalArgumentException("Linea de inventario de sticker con campo no numerico", e);
+        }
+    }
+}


