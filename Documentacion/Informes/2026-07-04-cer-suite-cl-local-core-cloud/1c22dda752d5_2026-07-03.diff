+import org.slf4j.Logger;
+import org.slf4j.LoggerFactory;
+import org.springframework.stereotype.Component;
+
+@Component
+public class GcsStickerInventoryStorageAdapter implements StickerInventoryStoragePort {
+
+    private static final Logger log = LoggerFactory.getLogger(GcsStickerInventoryStorageAdapter.class);
+    private static final String CONTENT_TYPE = "text/csv";
+
+    private final GcsStorageHelper gcsHelper;
+    private final Storage storage;
+    private final LegacySearchInventarioStickerProperties properties;
+
+    public GcsStickerInventoryStorageAdapter(
+            GcsStorageHelper gcsHelper, Storage storage, LegacySearchInventarioStickerProperties properties) {
+        this.gcsHelper = gcsHelper;
+        this.storage = storage;
+        this.properties = properties;
+    }
+
+    @Override
+    public GcsObjectReference uploadFile(String storeCode, String fileName, byte[] content) {
+        GcsObjectReference target = rootFolder(storeCode).resolve(fileName);
+        return gcsHelper.upload(target, content, CONTENT_TYPE);
+    }
+
+    @Override
+    public void moveToBackup(String storeCode, String fileName) {
+        GcsObjectReference source = rootFolder(storeCode).resolve(fileName);
+        GcsObjectReference backupFolder = new GcsObjectReference(
+                properties.gcs().bucket(),
+                rootPrefix(storeCode) + "/" + properties.gcs().backupSuffix());
+        gcsHelper.moveBlob(source, backupFolder);
+        log.atInfo()
+                .setMessage("Inventario de sticker movido a backup")
+                .addKeyValue("storeCode", storeCode)
+                .addKeyValue("fileName", fileName)
+                .log();
+    }
+
+    @Override
+    public void deleteFile(String storeCode, String fileName) {
+        GcsObjectReference target = rootFolder(storeCode).resolve(fileName);
+        storage.delete(BlobId.of(target.bucket(), target.objectName()));
+    }
+
+    private GcsObjectReference rootFolder(String storeCode) {
+        return new GcsObjectReference(properties.gcs().bucket(), rootPrefix(storeCode));
+    }
+
+    private String rootPrefix(String storeCode) {
+        return properties.gcs().basePrefix() + "/" + storeCode;
+    }
+}


