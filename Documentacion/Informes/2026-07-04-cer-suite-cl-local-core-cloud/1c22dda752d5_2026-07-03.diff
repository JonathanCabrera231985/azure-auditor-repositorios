+package com.elrosado.cersuitecloudlocalcore.infrastructure.adapter.out.http;
+
+import com.elrosado.cersuitecloudlocalcore.domain.port.out.StickerControllerFilePort;
+import com.elrosado.cersuitecloudlocalcore.infrastructure.config.LegacySearchInventarioStickerProperties;
+import org.slf4j.Logger;
+import org.slf4j.LoggerFactory;
+import org.springframework.stereotype.Component;
+import tools.jackson.databind.ObjectMapper;
+
+import java.io.IOException;
+import java.net.URI;
+import java.net.URLEncoder;
+import java.net.http.HttpClient;
+import java.net.http.HttpRequest;
+import java.net.http.HttpResponse;
+import java.nio.charset.StandardCharsets;
+import java.time.Duration;
+import java.util.Base64;
+import java.util.LinkedHashMap;
+import java.util.Map;
+import java.util.Optional;
+import java.util.stream.Collectors;
+
+/**
+ * Cliente HTTP hacia el controlador POS de una tienda. Reemplaza al {@code HttpImpl} legacy
+ * (que aceptaba cualquier certificado TLS); aquÃ­ se usa el {@link HttpClient} del JDK con
+ * validaciÃ³n TLS estÃ¡ndar. Mismo contrato de respuesta {@code HttpResponseWs} legacy
+ * (file/dir/content Base64) ya usado por {@code JournalControllerHttpAdapter}.
+ */
+@Component
+public class StickerControllerHttpAdapter implements StickerControllerFilePort {
+
+    private static final Logger log = LoggerFactory.getLogger(StickerControllerHttpAdapter.class);
+    private static final Duration REQUEST_TIMEOUT = Duration.ofSeconds(15);
+
+    private final HttpClient httpClient;
+    private final ObjectMapper objectMapper;
+    private final LegacySearchInventarioStickerProperties properties;
+
+    public StickerControllerHttpAdapter(ObjectMapper objectMapper, LegacySearchInventarioStickerProperties properties) {
+        this.httpClient = HttpClient.newBuilder()
+                .connectTimeout(REQUEST_TIMEOUT)
+                .build();
+        this.objectMapper = objectMapper;
+        this.properties = properties;
+    }
+
+    @Override
+    public Optional<byte[]> downloadFile(String ip, String dir, String fileName) {
+        URI uri = buildUri(ip, Map.of("dir", dir, "file", fileName));
+        try {
+            HttpResponse<byte[]> response = send(uri);
+            if (response.statusCode() != 200) {
+                log.atWarn()
+                        .setMessage("Descarga de inventario de sticker respondio con error")
+                        .addKeyValue("ip", ip)
+                        .addKeyValue("fileName", fileName)
+                        .addKeyValue("status", response.statusCode())
+                        .log();
+                return Optional.empty();
+            }
+
+            ControllerFileResponse body = objectMapper.readValue(response.body(), ControllerFileResponse.class);
+            if (body.content() == null || body.content().isBlank()) {
+                return Optional.empty();
+            }
+            return Optional.of(Base64.getDecoder().decode(body.content()));
+        } catch (IOException e) {
+            throw new IllegalStateException("Error de comunicacion descargando inventario de sticker del controlador", e);
+        } catch (InterruptedException e) {
+            Thread.currentThread().interrupt();
+            throw new IllegalStateException("Descarga de inventario de sticker interrumpida", e);
+        }
+    }
+
+    private HttpResponse<byte[]> send(URI uri) throws IOException, InterruptedException {
+        return httpClient.send(buildRequest(uri), HttpResponse.BodyHandlers.ofByteArray());
+    }
+
+    HttpRequest buildRequest(URI uri) {
+        return HttpRequest.newBuilder(uri)
+                .timeout(REQUEST_TIMEOUT)
+                .header("Authorization", "Bearer " + properties.jwt())
+                .GET()
+                .build();
+    }
+
+    URI buildUri(String ip, Map<String, String> params) {
+        Map<String, String> ordered = new LinkedHashMap<>(params);
+        String query = ordered.entrySet().stream()
+                .map(e -> URLEncoder.encode(e.getKey(), StandardCharsets.UTF_8)
+                        + "=" + URLEncoder.encode(e.getValue(), StandardCharsets.UTF_8))
+                .collect(Collectors.joining("&"));
+        return URI.create("https://" + ip + ":" + properties.controllerPort() + properties.controllerPath() + "?" + query);
+    }
+
+    private record ControllerFileResponse(String file, String dir, String content) {
+    }
+}


