--- a//src/main/java/com/elrosado/cersuitecloudlocalcore/infrastructure/adapter/out/http/StickerControllerHttpAdapter.java
+++ b//src/main/java/com/elrosado/cersuitecloudlocalcore/infrastructure/adapter/out/http/StickerControllerHttpAdapter.java
