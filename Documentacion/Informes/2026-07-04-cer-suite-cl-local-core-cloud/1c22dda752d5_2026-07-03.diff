+++ b//src/main/java/com/elrosado/cersuitecloudlocalcore/infrastructure/adapter/out/db/DbStickerInventoryPersistenceAdapter.java
@@ -0,0 +1,53 @@
+package com.elrosado.cersuitecloudlocalcore.infrastructure.adapter.out.db;
+
+import com.elrosado.cersuitecloudlocalcore.domain.port.out.StickerInventoryPersistencePort;
+import com.elrosado.cersuitecloudlocalcore.infrastructure.adapter.out.db.entity.CampaignStickerEntity;
+import com.elrosado.cersuitecloudlocalcore.infrastructure.adapter.out.db.entity.EntregaStickerPosEntity;
+import com.elrosado.cersuitecloudlocalcore.infrastructure.adapter.out.db.repository.JpaCampaignStickerRepository;
+import com.elrosado.cersuitecloudlocalcore.infrastructure.adapter.out.db.repository.JpaEntregaStickerPosRepository;
+import org.springframework.stereotype.Component;
+import org.springframework.transaction.annotation.Transactional;
+
+import java.time.LocalDate;
+import java.time.LocalDateTime;
+
+/**
+ * Adaptador de persistencia ARTS_EC para el inventario de stickers.
+ * Replica {@code SP_SAVE_ENTREGA_STICKER_POS}: busca la campaÃ±a vigente para la fecha
+ * contable y hace upsert en ENTREGA_STICKER_POS por (campaÃ±a, cajero, fecha).
+ */
+@Component
+public class DbStickerInventoryPersistenceAdapter implements StickerInventoryPersistencePort {
+
+    private final JpaCampaignStickerRepository campaignRepository;
+    private final JpaEntregaStickerPosRepository entregaRepository;
+
+    public DbStickerInventoryPersistenceAdapter(
+            JpaCampaignStickerRepository campaignRepository, JpaEntregaStickerPosRepository entregaRepository) {
+        this.campaignRepository = campaignRepository;
+        this.entregaRepository = entregaRepository;
+    }
+
+    @Override
+    @Transactional(transactionManager = "artsEcTransactionManager")
+    public void saveEntry(int cajero, LocalDate fechaContable, int cantidad) {
+        LocalDateTime fecha = fechaContable.atStartOfDay();
+
+        CampaignStickerEntity campaign = campaignRepository
+                .findFirstByFechaInicioLessThanEqualAndFechaFinGreaterThanEqual(fecha, fecha)
+                .orElseThrow(() -> new IllegalStateException(
+                        "NO EXISTE CAMPAIGN vigente para fecha contable: " + fechaContable));
+
+        String campaignCodigo = campaign.getCodigo();
+
+        entregaRepository.findByCampaignStickerAndUsuarioCajeroAndFechaEntrega(campaignCodigo, cajero, fecha)
+                .ifPresentOrElse(
+                        existing -> {
+                            existing.setCantidad(cantidad);
+                            entregaRepository.save(existing);
+                        },
+                        () -> entregaRepository.save(
+                                EntregaStickerPosEntity.forInsert(campaignCodigo, cajero, cantidad, fecha))
+                );
+    }
+}


