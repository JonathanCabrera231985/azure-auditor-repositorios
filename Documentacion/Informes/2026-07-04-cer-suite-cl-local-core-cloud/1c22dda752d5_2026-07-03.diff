+package com.elrosado.cersuitecloudlocalcore.service;
+
+import com.elrosado.cersuitecloudlocalcore.domain.exception.SearchInventarioStickerException;
+import com.elrosado.cersuitecloudlocalcore.domain.model.SearchInventarioStickerStage;
+import com.elrosado.cersuitecloudlocalcore.domain.model.StickerErrorRecord;
+import com.elrosado.cersuitecloudlocalcore.domain.model.StickerInventoryLine;
+import com.elrosado.cersuitecloudlocalcore.domain.port.in.SearchInventarioStickerUseCase;
+import com.elrosado.cersuitecloudlocalcore.domain.port.out.StickerControllerFilePort;
+import com.elrosado.cersuitecloudlocalcore.domain.port.out.StickerErrorTrackerPort;
+import com.elrosado.cersuitecloudlocalcore.domain.port.out.StickerInventoryPersistencePort;
+import com.elrosado.cersuitecloudlocalcore.domain.port.out.StickerInventoryStoragePort;
+import com.elrosado.cersuitecloudlocalcore.infrastructure.config.LegacySearchInventarioStickerProperties;
+import com.elrosado.cersuitecloudlocalcore.infrastructure.config.SearchInventarioStickerProperties;
+import com.elrosado.cersuitecloudlocalcore.infrastructure.config.StoreRegistry;
+import org.slf4j.Logger;
+import org.slf4j.LoggerFactory;
+import org.springframework.beans.factory.annotation.Qualifier;
+import org.springframework.core.task.AsyncTaskExecutor;
+import org.springframework.stereotype.Service;
+
+import java.nio.charset.StandardCharsets;
+import java.time.Instant;
+import java.time.LocalDate;
+import java.time.format.DateTimeFormatter;
+import java.util.List;
+import java.util.Optional;
+import java.util.UUID;
+import java.util.concurrent.CompletableFuture;
+
+/**
+ * Orquesta la sincronizaciÃ³n de inventario/entrega de stickers por tienda MULTI_LOCAL:
+ * descarga desde el controlador POS, respaldo en GCS, parseo CSV y upsert en ARTS_EC.
+ * TraducciÃ³n de {@code SearchInventarioStickerFileProcess} legacy (ArmsServerLocal), con un
+ * ciclo (virtual thread) por tienda activa en vez de una tienda Ãºnica global.
+ */
+@Service
+public class SearchInventarioStickerService implements SearchInventarioStickerUseCase {
+
+    private static final Logger log = LoggerFactory.getLogger(SearchInventarioStickerService.class);
+    private static final DateTimeFormatter FILE_DATE_FMT = DateTimeFormatter.ofPattern("yyyyMMdd");
+    private static final int MAX_RETRIES = 3;
+
+    private final StickerControllerFilePort controllerPort;
+    private final StickerInventoryStoragePort storagePort;
+    private final StickerInventoryPersistencePort persistencePort;
+    private final StickerErrorTrackerPort errorTrackerPort;
+    private final StickerInventoryParserService parserService;
+    private final StoreRegistry storeRegistry;
+    private final SearchInventarioStickerProperties properties;
+    private final LegacySearchInventarioStickerProperties legacyProperties;
+    private final AsyncTaskExecutor virtualThreadTaskExecutor;
+
+    public SearchInventarioStickerService(
+            StickerControllerFilePort controllerPort,
+            StickerInventoryStoragePort storagePort,
+            StickerInventoryPersistencePort persistencePort,
+            StickerErrorTrackerPort errorTrackerPort,
+            StickerInventoryParserService parserService,
+            StoreRegistry storeRegistry,
+            SearchInventarioStickerProperties properties,
+            LegacySearchInventarioStickerProperties legacyProperties,
+            @Qualifier("virtualThreadTaskExecutor") AsyncTaskExecutor virtualThreadTaskExecutor) {
+        this.controllerPort = controllerPort;
+        this.storagePort = storagePort;
+        this.persistencePort = persistencePort;
+        this.errorTrackerPort = errorTrackerPort;
+        this.parserService = parserService;
+        this.storeRegistry = storeRegistry;
+        this.properties = properties;
+        this.legacyProperties = legacyProperties;
+        this.virtualThreadTaskExecutor = virtualThreadTaskExecutor;
+    }
+
+    @Override
+    public void processAllPendingStores() {
+        if (!properties.enabled()) {
+            log.atDebug().setMessage("SearchInventarioSticker deshabilitado").log();
+            return;
+        }
+
+        if (!storeRegistry.isMultiLocalEnabled()) {
+            log.atWarn().setMessage("SearchInventarioSticker omitido - sin tiendas multi-local activas en MN_TIENDA").log();
+            return;
+        }
+
+        List<CompletableFuture<Void>> futures = storeRegistry.getActiveMultiLocalStores().stream()
+                .map(store -> {
+                    int desClave = store.getDesClave();
+                    String ip = store.getIp();
+                    return CompletableFuture
+                            .runAsync(() -> processStore(desClave, ip), virtualThreadTaskExecutor)
+                            .exceptionally(ex -> {
+                                log.atError()
+                                        .setMessage("Error no controlado en hilo de tienda para SearchInventarioSticker")
+                                        .addKeyValue("desClave", desClave)
+                                        .setCause(ex)
+                                        .log();
+                                return null;
+                            });
+                })
+                .toList();
+
+        CompletableFuture.allOf(futures.toArray(CompletableFuture[]::new)).join();
+    }
+
+    private void processStore(int codStore, String ip) {
+        String storeCode = String.valueOf(codStore);
+
+        if (ip == null || ip.isBlank()) {
+            log.atWarn()
+                    .setMessage("Tienda sin IP registrada en MN_TIENDA - omitida para SearchInventarioSticker")
+                    .addKeyValue("storeCode", storeCode)
+                    .log();
+            return;
+        }
+
+        LocalDate today = LocalDate.now();
+        String fileName = today.format(FILE_DATE_FMT) + "." + storeCode;
+
+        Optional<byte[]> content;
+        try {
+            content = controllerPort.downloadFile(ip, legacyProperties.controllerFolder(), fileName);
+        } catch (RuntimeException e) {
+            recordError(storeCode, fileName, SearchInventarioStickerStage.CONTROLLER_DOWNLOAD, e);
+            return;
+        }
+
+        if (content.isEmpty()) {
+            log.atDebug()
+                    .setMessage("Sin archivo de inventario de sticker disponible para la tienda hoy")
+                    .addKeyValue("storeCode", storeCode)
+                    .addKeyValue("fileName", fileName)
+                    .log();
+            return;
+        }
+
+        byte[] fileContent = content.get();
+
+        try {
+            storagePort.uploadFile(storeCode, fileName, fileContent);
+        } catch (RuntimeException e) {
+            recordError(storeCode, fileName, SearchInventarioStickerStage.GCS_UPLOAD, e);
+            return;
+        }
+
+        List<StickerInventoryLine> lines;
+        try {
+            List<String> rawLines = new String(fileContent, StandardCharsets.ISO_8859_1).lines().toList();
+            lines = parserService.parse(rawLines);
+        } catch (RuntimeException e) {
+            recordError(storeCode, fileName, SearchInventarioStickerStage.PARSE, e);
+            return;
+        }
+
+        if (lines.isEmpty()) {
+            storagePort.deleteFile(storeCode, fileName);
+            log.atInfo()
+                    .setMessage("Archivo de inventario de sticker vacio - eliminado")
+                    .addKeyValue("storeCode", storeCode)
+                    .addKeyValue("fileName", fileName)
+                    .log();
+            return;
+        }
+
+        try {
+            for (StickerInventoryLine line : lines) {
+                persistencePort.saveEntry(line.cajero(), today, line.cantidad());
+            }
+        } catch (RuntimeException e) {
+            // Fidelidad legacy: si una linea falla, el archivo completo no se mueve a backup
+            // y queda pendiente para reintento en el proximo ciclo.
+            recordError(storeCode, fileName, SearchInventarioStickerStage.PERSIST, e);
+            return;
+        }
+
+        try {
+            storagePort.moveToBackup(storeCode, fileName);
+        } catch (RuntimeException e) {
+            recordError(storeCode, fileName, SearchInventarioStickerStage.GCS_BACKUP, e);
+            return;
+        }
+
+        log.atInfo()
+                .setMessage("Inventario de sticker procesado y respaldado")
+                .addKeyValue("storeCode", storeCode)
+                .addKeyValue("fileName", fileName)
+                .addKeyValue("lineas", lines.size())
+                .log();
+    }
+
+    private void recordError(String storeCode, String fileName, SearchInventarioStickerStage stage, Exception e) {
+        SearchInventarioStickerException wrapped = new SearchInventarioStickerException(stage, e.getMessage(), e);
+        log.atError()
+                .setMessage("Error procesando inventario de sticker")
+                .addKeyValue("storeCode", storeCode)
+                .addKeyValue("fileName", fileName)
+                .addKeyValue("stage", stage.name())
+                .setCause(e)
+                .log();
+        try {
+            errorTrackerPort.recordError(new StickerErrorRecord(
+                    "SearchInventarioSticker",
+                    "SCHEDULED",
+                    UUID.randomUUID().toString(),
+                    storeCode,
+                    fileName,
+                    "",
+                    "",
+                    stage.name(),
+                    "",
+                    wrapped.getClass().getSimpleName(),
+                    "",
+                    wrapped.getMessage() == null ? "" : wrapped.getMessage(),
+                    "",
+                    0,
+                    MAX_RETRIES,
+                    false,
+                    "ERROR",
+                    Instant.now(),
+                    Instant.now(),
+                    System.getenv().getOrDefault("HOSTNAME", ""),
+                    System.getenv().getOrDefault("POD_NAME", ""),
+                    "%s-%s".formatted(storeCode, fileName)
