+    private static final int INVOICE_END = 88;
+    private static final int RFPU_LENGTH = 54;
+    // Factor de escala del monto almacenado en archivo (centavos con 2 decimales)
+    private static final BigDecimal AMOUNT_SCALE = new BigDecimal("100");
+
+    private static final String FILE_PREFIX = "PAG";
+
