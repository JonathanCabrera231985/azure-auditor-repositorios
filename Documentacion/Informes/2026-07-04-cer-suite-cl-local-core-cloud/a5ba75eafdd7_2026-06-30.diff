+package com.elrosado.cersuitecloudlocalcore.service;
+
+import com.elrosado.cersuitecloudlocalcore.domain.model.Iso8583ReversalResponse;
+import org.slf4j.Logger;
+import org.slf4j.LoggerFactory;
+import org.springframework.stereotype.Service;
+
+import java.util.Optional;
+
+/**
+ * Parsea la respuesta ISO8583 del gateway de pagos y extrae el cÃ³digo de respuesta (campo 39).
+ */
+@Service
+public class Iso8583MessageParserService {
+
+    private static final Logger log = LoggerFactory.getLogger(Iso8583MessageParserService.class);
+
+    // PosiciÃ³n de inicio del bitmap primario en el hex string de respuesta (sin prefijo de longitud)
+    private static final int PRIMARY_BITMAP_OFFSET = 14;
+    private static final int PRIMARY_BITMAP_HEX_LEN = 16;
+    private static final int SECONDARY_BITMAP_HEX_LEN = 16;
+
+    /**
+     * Extrae el cÃ³digo de respuesta del campo 39 del mensaje de respuesta ISO8583.
+     *
+     * @param responseHex Cadena hex completa de la respuesta (sin prefijo de longitud).
+     * @return La respuesta parseada, o {@code Optional.empty()} si el campo 39 no estÃ¡ presente.
+     */
+    public Optional<Iso8583ReversalResponse> parse(String responseHex) {
+        String upperHex = responseHex.toUpperCase();
+        if (upperHex.length() < PRIMARY_BITMAP_OFFSET + PRIMARY_BITMAP_HEX_LEN) {
+            log.atWarn()
+                    .setMessage("Respuesta ISO8583 demasiado corta para parsear")
+                    .addKeyValue("responseHexLen", upperHex.length())
+                    .log();
+            return Optional.empty();
+        }
+
+        char[] bitmap = new char[128];
+        String primaryBitmapHex = upperHex.substring(PRIMARY_BITMAP_OFFSET,
+                PRIMARY_BITMAP_OFFSET + PRIMARY_BITMAP_HEX_LEN);
+        expandBitmapHex(primaryBitmapHex, bitmap, 0);
+
+        int pos = PRIMARY_BITMAP_OFFSET + PRIMARY_BITMAP_HEX_LEN;
+        if (bitmap[0] == '1') {
+            expandBitmapHex(upperHex.substring(pos, pos + SECONDARY_BITMAP_HEX_LEN), bitmap, 64);
+            pos += SECONDARY_BITMAP_HEX_LEN;
+        }
+
+        // Avanzar campo por campo hasta llegar al campo 39
+        if (bitmap[1] == '1') { // campo 2: PAN variable
+            int len = Integer.parseInt(upperHex.substring(pos, pos + 2));
+            if (len % 2 != 0) len++;
+            pos += 2 + len;
+        }
+        if (bitmap[2] == '1') pos += 6;    // campo 3: processing code
+        if (bitmap[3] == '1') pos += 12;   // campo 4: amount
+        if (bitmap[10] == '1') pos += 6;   // campo 11: STAN
+        if (bitmap[11] == '1') pos += 6;   // campo 12: local time
+        if (bitmap[12] == '1') pos += 4;   // campo 13: local date
+        if (bitmap[13] == '1') pos += 4;   // campo 14: expiration date
+        if (bitmap[21] == '1') pos += 4;   // campo 22: POS entry mode
+        if (bitmap[23] == '1') pos += 4;   // campo 24: NII (4 hex chars = 2 bytes)
+        if (bitmap[24] == '1') pos += 2;   // campo 25: POS condition code
+        if (bitmap[34] == '1') { // campo 35: track 2 variable
+            int len = Integer.parseInt(upperHex.substring(pos, pos + 2));
+            if (len % 2 != 0) len++;
+            pos += 2 + len;
+        }
+        if (bitmap[36] == '1') pos += 24;  // campo 37: RRN (12 chars ASCII = 24 hex)
+        if (bitmap[37] == '1') pos += 12;  // campo 38: auth number (6 chars ASCII = 12 hex)
+
+        // Campo 39 â Response Code, ANS fijo 2 caracteres
+        if (bitmap[38] == '1' && pos + 4 <= upperHex.length()) {
+            String rc = hexToAscii(upperHex.substring(pos, pos + 4));
+            log.atDebug()
+                    .setMessage("CÃ³digo de respuesta ISO8583 extraÃ­do")
+                    .addKeyValue("responseCode", rc)
+                    .log();
+            return Optional.of(Iso8583ReversalResponse.of(rc));
+        }
+
+        log.atWarn()
+                .setMessage("Campo 39 (Response Code) no encontrado en respuesta ISO8583")
+                .log();
+        return Optional.empty();
+    }
+
+    private static void expandBitmapHex(String hexBitmap, char[] target, int offset) {
+        for (int i = 0; i < hexBitmap.length(); i++) {
+            int nibble = Integer.parseInt(String.valueOf(hexBitmap.charAt(i)), 16);
+            for (int j = 0; j < 4; j++) {
+                target[offset + i * 4 + j] = ((nibble >> (3 - j)) & 1) == 1 ? '1' : '0';
+            }
+        }
+    }
+
+    private static String hexToAscii(String hex) {
+        StringBuilder sb = new StringBuilder();
+        for (int i = 0; i < hex.length(); i += 2) {
+            sb.append((char) Integer.parseInt(hex.substring(i, i + 2), 16));
+        }
+        return sb.toString();
+    }
+}


