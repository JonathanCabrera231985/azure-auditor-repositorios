+package com.elrosado.cersuitecloudlocalcore.service;
+
+import com.elrosado.cersuitecloudlocalcore.domain.model.Iso8583ReversalRequest;
+import org.springframework.stereotype.Service;
+
+import java.time.LocalDateTime;
+import java.time.format.DateTimeFormatter;
+
+/**
+ * Construye el hex string del mensaje ISO8583 de reversa de tarjeta.
+ * Replica fielmente la lÃ³gica legacy de createMsg() para reversas de consumo, redenciÃ³n y pago.
+ */
+@Service
+public class Iso8583MessageBuilderService {
+
+    private static final String HEADER = "0000000000";
+    private static final String MTI = "0400";
+    private static final DateTimeFormatter DATE_TIME_FMT = DateTimeFormatter.ofPattern("MMddHHmmss");
+
+    /**
+     * Construye el hex string completo del mensaje (sin prefijo de longitud).
+     *
+     * @param request Datos del mensaje a construir.
+     * @return Cadena hexadecimal del mensaje ISO8583, en mayÃºsculas.
+     */
+    public String buildHexMessage(Iso8583ReversalRequest request) {
+        char[] bitmap = buildBitmap(request);
+        String bitmapHex = bitmapToHex(bitmap);
+
+        String nowStr = LocalDateTime.now().format(DATE_TIME_FMT);
+        String localTime = nowStr.substring(4, 10);  // HHmmss
+        String localDate = nowStr.substring(0, 4);   // MMdd
+
+        StringBuilder mje = new StringBuilder(HEADER);
+        mje.append(MTI);
+        mje.append(bitmapHex);
+
+        // Campo 2 â PAN, BCD con prefijo de 2 dÃ­gitos decimales
+        mje.append(String.format("%02d", request.primaryAccountNumber().length()));
+        mje.append(request.primaryAccountNumber());
+
+        // Campo 3 â Processing Code, numÃ©rico fijo 6
+        mje.append(request.processingCode());
+
+        // Campo 4 â Transaction Amount, numÃ©rico fijo 12
+        mje.append(request.transactionAmount());
+
+        // Campo 11 â STAN, numÃ©rico fijo 6
+        mje.append(request.stan());
+
+        // Campo 12 â Local Transaction Time, numÃ©rico fijo 6 (HHmmss)
+        mje.append(localTime);
+
+        // Campo 13 â Local Transaction Date, numÃ©rico fijo 4 (MMdd)
+        mje.append(localDate);
+
+        // Campo 14 â Expiration Date (solo para consumo y redenciÃ³n)
+        if (request.includeExpirationDate()) {
+            mje.append("9912");
+        }
+
+        // Campo 22 â POS Entry Mode, numÃ©rico fijo 4
+        mje.append("0120");
+
+        // Campo 24 â NII, numÃ©rico fijo 4 (legacy usa 4 chars "0001")
+        mje.append("0001");
+
+        // Campo 25 â POS Condition Code, numÃ©rico fijo 2
+        mje.append("00");
+
+        // Campo 38 â Authorization Number, ANS fijo 6
+        mje.append(asciiToHex(request.authorizationNumber()));
+
+        // Campo 41 â Terminal ID, ANS fijo 8
+        mje.append(asciiToHex(request.terminalId()));
+
+        // Campo 42 â Merchant ID, ANS fijo 15
+        mje.append(asciiToHex(request.merchantId()));
+
+        // Campo 61 â Lot Number, ANS variable prefijo 4 dÃ­gitos
+        mje.append(buildAnsVariable("000001", 4));
+
+        // Campo 114 â Additional Data 3, ANS variable prefijo 4 dÃ­gitos
+        mje.append(buildAnsVariable("01", 4));
+
+        // Campo 116 â RFNU, ANS variable prefijo 4 dÃ­gitos
+        mje.append(buildAnsVariable("00010001", 4));
+
+        // Campo 122 â Cupones (condicional, solo consumo con lÃ­nea 2)
+        if (request.cuponesData() != null) {
+            mje.append(buildAnsVariable(request.cuponesData(), 4));
+        }
+
+        // Campo 124 â RFPU, ANS variable prefijo 4 dÃ­gitos, 54 caracteres
+        mje.append(buildAnsVariable(request.rfpu(), 4));
+
+        // Campo 125 â Puntos (condicional, solo consumo con lÃ­nea 3)
+        if (request.puntosData() != null) {
+            mje.append(buildAnsVariable(request.puntosData(), 4));
+        }
+
+        return mje.toString().toUpperCase();
+    }
+
+    // --- Helpers privados ---
+
+    private char[] buildBitmap(Iso8583ReversalRequest request) {
+        char[] bitmap = new char[128];
+        java.util.Arrays.fill(bitmap, '0');
+
+        bitmap[0] = '1';   // bit 1: bitmap secundario activo
+        bitmap[1] = '1';   // bit 2: PAN
+        bitmap[2] = '1';   // bit 3: processing code
+        bitmap[3] = '1';   // bit 4: amount
+        bitmap[10] = '1';  // bit 11: STAN
+        bitmap[11] = '1';  // bit 12: local time
+        bitmap[12] = '1';  // bit 13: local date
+        if (request.includeExpirationDate()) {
+            bitmap[13] = '1'; // bit 14: expiration date
+        }
+        bitmap[21] = '1';  // bit 22: POS entry mode
+        bitmap[23] = '1';  // bit 24: NII
+        bitmap[24] = '1';  // bit 25: POS condition code
+        bitmap[37] = '1';  // bit 38: authorization number
+        bitmap[40] = '1';  // bit 41: terminal ID
+        bitmap[41] = '1';  // bit 42: merchant ID
+        bitmap[60] = '1';  // bit 61: lot number
+        bitmap[113] = '1'; // bit 114: additional data 3
+        bitmap[115] = '1'; // bit 116: RFNU
+        if (request.cuponesData() != null) {
+            bitmap[121] = '1'; // bit 122: cupones
+        }
+        bitmap[123] = '1'; // bit 124: RFPU
+        if (request.puntosData() != null) {
+            bitmap[124] = '1'; // bit 125: puntos
+        }
+
+        return bitmap;
+    }
+
+    private String bitmapToHex(char[] bitmap) {
+        StringBuilder hex = new StringBuilder(32);
+        for (int i = 0; i < 128; i += 4) {
+            int nibble = 0;
+            for (int j = 0; j < 4; j++) {
+                if (bitmap[i + j] == '1') {
+                    nibble |= (8 >> j);
+                }
+            }
+            hex.append(Integer.toHexString(nibble).toUpperCase());
+        }
+        return hex.toString();
+    }
+
+    private String asciiToHex(String data) {
+        StringBuilder sb = new StringBuilder(data.length() * 2);
+        for (char c : data.toCharArray()) {
+            sb.append(String.format("%02X", (int) c));
+        }
+        return sb.toString();
+    }
+
+    private String buildAnsVariable(String data, int prefixLen) {
+        String lenStr = String.format("%0" + prefixLen + "d", data.length());
+        return lenStr + asciiToHex(data);
+    }
+}


