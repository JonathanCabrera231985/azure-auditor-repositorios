+package com.elrosado.cersuitecloudlocalcore.service;
+
+import com.elrosado.cersuitecloudlocalcore.domain.model.ConsumptionReversal;
+import com.elrosado.cersuitecloudlocalcore.domain.model.GcsObjectReference;
+import com.elrosado.cersuitecloudlocalcore.domain.model.Iso8583ReversalRequest;
+import com.elrosado.cersuitecloudlocalcore.domain.model.Iso8583ReversalResponse;
+import com.elrosado.cersuitecloudlocalcore.domain.port.in.ProcessConsumptionReversalUseCase;
+import com.elrosado.cersuitecloudlocalcore.domain.port.out.ConsumptionReversalFilePort;
+import com.elrosado.cersuitecloudlocalcore.domain.port.out.PaymentGatewayPort;
+import com.elrosado.cersuitecloudlocalcore.infrastructure.config.ReversarConsumoProperties;
+import org.slf4j.Logger;
+import org.slf4j.LoggerFactory;
+import org.springframework.stereotype.Service;
+
+import java.util.List;
+import java.util.Optional;
+import java.util.concurrent.ConcurrentHashMap;
+
+/**
+ * Orquesta la reversiÃ³n de consumos de tarjeta: lee archivos CON* de GCS, envÃ­a mensaje ISO8583
+ * al gateway de pagos y mueve el archivo a backup (respuesta recibida) o contabiliza el fallo
+ * de socket para eventual envÃ­o a error.
+ */
+@Service
+public class ReversarConsumoService implements ProcessConsumptionReversalUseCase {
+
+    private static final Logger log = LoggerFactory.getLogger(ReversarConsumoService.class);
+    private static final String PROCESSING_CODE = "284000";
+
+    private final ConsumptionReversalFilePort filePort;
+    private final PaymentGatewayPort gatewayPort;
+    private final ReversarConsumoProperties properties;
+    // Contador de fallos de socket por nombre de archivo (persiste entre ciclos del scheduler)
+    private final ConcurrentHashMap<String, Integer> socketFailureCount = new ConcurrentHashMap<>();
+
+    public ReversarConsumoService(
+            ConsumptionReversalFilePort filePort,
+            PaymentGatewayPort gatewayPort,
+            ReversarConsumoProperties properties) {
+        this.filePort = filePort;
+        this.gatewayPort = gatewayPort;
+        this.properties = properties;
+    }
+
+    @Override
+    public void processNextCycle() {
+        if (!properties.enabled()) {
+            log.atDebug().setMessage("ReversarConsumo deshabilitado; ciclo omitido").log();
+            return;
+        }
+
+        List<GcsObjectReference> files = filePort.listPendingFiles();
+        if (files.isEmpty()) {
+            log.atDebug().setMessage("No hay archivos CON pendientes de reversa").log();
+            return;
+        }
+
+        log.atInfo()
+                .setMessage("Iniciando ciclo de reversa de consumos")
+                .addKeyValue("archivosPendientes", files.size())
+                .log();
+
+        files.forEach(this::processFile);
+    }
+
+    private void processFile(GcsObjectReference file) {
+        String fileName = file.fileName();
+
+        ConsumptionReversal reversal;
+        try {
+            reversal = filePort.parseFile(file);
+        } catch (IllegalArgumentException e) {
+            log.atError()
+                    .setMessage("Archivo CON con formato invÃ¡lido â movido a error")
+                    .addKeyValue("archivo", fileName)
+                    .setCause(e)
+                    .log();
+            filePort.moveToError(file);
+            socketFailureCount.remove(fileName);
+            return;
+        }
+
+        Iso8583ReversalRequest request = buildRequest(reversal);
+        Optional<Iso8583ReversalResponse> response;
+        try {
+            response = gatewayPort.send(request);
+        } catch (Exception e) {
+            handleSocketFailure(file, fileName, e);
+            return;
+        }
+
+        if (response.isEmpty()) {
+            handleSocketFailure(file, fileName, null);
+            return;
+        }
+
+        // Respuesta recibida (cualquier RC) â mover a backup
+        socketFailureCount.remove(fileName);
+        filePort.moveToBackup(file);
+
+        Iso8583ReversalResponse resp = response.get();
+        log.atInfo()
+                .setMessage("Reversa de consumo procesada")
+                .addKeyValue("archivo", fileName)
+                .addKeyValue("responseCode", resp.responseCode())
+                .addKeyValue("afirmativo", resp.affirmative())
+                .log();
+    }
+
+    private void handleSocketFailure(GcsObjectReference file, String fileName, Exception cause) {
+        int failures = socketFailureCount.merge(fileName, 1, Integer::sum);
+        if (failures >= properties.socketRetryThreshold()) {
+            log.atError()
+                    .setMessage("Umbral de fallos de socket alcanzado â archivo CON movido a error")
+                    .addKeyValue("archivo", fileName)
+                    .addKeyValue("intentos", failures)
+                    .log();
+            filePort.moveToError(file);
+            socketFailureCount.remove(fileName);
+        } else {
+            if (cause != null) {
+                log.atWarn()
+                        .setMessage("Fallo de conexiÃ³n al gateway en reversa de consumo; se reintentarÃ¡")
+                        .addKeyValue("archivo", fileName)
+                        .addKeyValue("intentos", failures)
+                        .addKeyValue("umbral", properties.socketRetryThreshold())
+                        .setCause(cause)
+                        .log();
+            } else {
+                log.atWarn()
+                        .setMessage("Sin respuesta del gateway en reversa de consumo; se reintentarÃ¡")
+                        .addKeyValue("archivo", fileName)
+                        .addKeyValue("intentos", failures)
+                        .addKeyValue("umbral", properties.socketRetryThreshold())
+                        .log();
+            }
+        }
+    }
+
+    private Iso8583ReversalRequest buildRequest(ConsumptionReversal reversal) {
+        return new Iso8583ReversalRequest(
+                PROCESSING_CODE,
+                reversal.primaryAccountNumber(),
+                reversal.transactionAmount(),
+                reversal.stan(),
+                reversal.authorizationNumber(),
+                reversal.terminalId(),
+                reversal.merchantId(),
+                reversal.rfpu(),
+                true,
+                reversal.cuponesData(),
+                reversal.puntosData()
+        );
+    }
+}


