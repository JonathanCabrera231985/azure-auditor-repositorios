+                    .addKeyValue("card", maskCard(cardNumber))
+                    .log();
+            return Optional.empty();
+        }
+        CoCardDataEntity first = matches.getFirst();
+        return Optional.of(new int[]{first.getId().getIdTrn(), first.getId().getSqNbr()});
+    }
+
+    @Override
+    @Transactional(transactionManager = "artsEcTransactionManager")
+    public void markReversed(int idTrn, int sqNbr) {
+        cardDataRepository.markReversed(idTrn, sqNbr);
+        log.atDebug()
+                .setMessage("STS_CRD marcado como '2' en CO_CRD_DT")
+                .addKeyValue("idTrn", idTrn)
+                .addKeyValue("sqNbr", sqNbr)
+                .log();
+    }
+
+    private static String maskCard(String cardNumber) {
+        if (cardNumber == null || cardNumber.length() < 4) {
+            return "****";
+        }
+        return "*".repeat(cardNumber.length() - 4) + cardNumber.substring(cardNumber.length() - 4);
+    }
+}


