+
+/**
+ * Adaptador que persiste el resultado de cada reversa de pago en la tabla DV_PCER de DEVS_EC.
+ */
+@Component
+public class DbReversarPagoDevsAdapter implements PaymentReversalResultPort {
+
+    private static final Logger log = LoggerFactory.getLogger(DbReversarPagoDevsAdapter.class);
+
+    private final JpaDvPcerRepository repository;
+
+    public DbReversarPagoDevsAdapter(JpaDvPcerRepository repository) {
+        this.repository = repository;
+    }
+
+    @Override
+    @Transactional(transactionManager = "devsEcTransactionManager")
+    public void save(PaymentReversalResult result) {
+        DvPcerEntityId id = new DvPcerEntityId(result.fileId(), result.sequenceNumber());
+        DvPcerEntity entity = new DvPcerEntity(id, result.status().dbValue(), result.responseCode());
