+package com.elrosado.cersuitecloudlocalcore.infrastructure.adapter.out.payment;
+
+import com.elrosado.cersuitecloudlocalcore.domain.model.Iso8583ReversalRequest;
+import com.elrosado.cersuitecloudlocalcore.domain.model.Iso8583ReversalResponse;
+import com.elrosado.cersuitecloudlocalcore.domain.port.out.PaymentGatewayPort;
+import com.elrosado.cersuitecloudlocalcore.infrastructure.config.PaymentServerProperties;
+import com.elrosado.cersuitecloudlocalcore.service.Iso8583MessageBuilderService;
+import com.elrosado.cersuitecloudlocalcore.service.Iso8583MessageParserService;
+import org.slf4j.Logger;
+import org.slf4j.LoggerFactory;
+import org.springframework.stereotype.Component;
+
+import java.io.IOException;
+import java.io.InputStream;
+import java.io.OutputStream;
+import java.net.Socket;
+import java.util.HexFormat;
+import java.util.Optional;
+
+/**
+ * EnvÃ­a mensajes ISO8583 de reversiÃ³n al gateway de pagos mediante socket TCP.
+ * El protocolo usa prefijo de 2 bytes big-endian con el tamaÃ±o del payload.
+ * Reintenta hasta {@code retries} veces con {@code retrySleepMs} de pausa entre intentos.
+ * Retorna {@code Optional.empty()} Ãºnicamente cuando se agotan todos los reintentos sin respuesta.
+ */
+@Component
+public class Iso8583SocketAdapter implements PaymentGatewayPort {
+
+    private static final Logger log = LoggerFactory.getLogger(Iso8583SocketAdapter.class);
+
+    private final Iso8583MessageBuilderService builder;
+    private final Iso8583MessageParserService parser;
+    private final PaymentServerProperties properties;
+
+    public Iso8583SocketAdapter(
+            Iso8583MessageBuilderService builder,
+            Iso8583MessageParserService parser,
+            PaymentServerProperties properties) {
+        this.builder = builder;
+        this.parser = parser;
+        this.properties = properties;
+    }
+
+    @Override
+    public Optional<Iso8583ReversalResponse> send(Iso8583ReversalRequest request) {
+        String hexMessage = builder.buildHexMessage(request);
+        byte[] payload = hexStringToBytes(hexMessage);
+        byte[] frame = buildFrame(payload);
+
+        for (int attempt = 1; attempt <= properties.retries(); attempt++) {
+            Optional<Iso8583ReversalResponse> response = trySend(frame, attempt);
+            if (response.isPresent()) {
+                return response;
+            }
+            if (attempt < properties.retries()) {
+                sleepBetweenRetries(attempt);
+            }
+        }
+
+        log.atWarn()
+                .setMessage("Sin respuesta del gateway tras todos los reintentos")
+                .addKeyValue("host", properties.ip())
+                .addKeyValue("port", properties.port())
+                .addKeyValue("reintentos", properties.retries())
+                .log();
+        return Optional.empty();
+    }
+
+    private Optional<Iso8583ReversalResponse> trySend(byte[] frame, int attempt) {
+        try (Socket socket = new Socket()) {
+            socket.setSoTimeout(properties.timeoutMs());
+            socket.connect(
+                    new java.net.InetSocketAddress(properties.ip(), properties.port()),
+                    properties.timeoutMs()
+            );
+
+            OutputStream out = socket.getOutputStream();
+            out.write(frame);
+            out.flush();
+
+            InputStream in = socket.getInputStream();
+            byte[] responseFrame = readFrame(in);
+            if (responseFrame == null) {
+                log.atWarn()
+                        .setMessage("Respuesta vacÃ­a del gateway de pagos")
+                        .addKeyValue("intento", attempt)
+                        .log();
+                return Optional.empty();
+            }
+
+            String responseHex = HexFormat.of().formatHex(responseFrame).toUpperCase();
+            return parser.parse(responseHex);
+
+        } catch (IOException e) {
+            log.atWarn()
+                    .setMessage("Error de socket al comunicar con gateway de pagos")
+                    .addKeyValue("intento", attempt)
+                    .addKeyValue("host", properties.ip())
+                    .addKeyValue("port", properties.port())
+                    .setCause(e)
+                    .log();
+            return Optional.empty();
+        }
+    }
+
+    /**
+     * Construye el frame TCP: prefijo de 2 bytes big-endian con el tamaÃ±o del payload + payload.
+     */
+    private static byte[] buildFrame(byte[] payload) {
+        int length = payload.length;
+        byte[] frame = new byte[2 + length];
+        frame[0] = (byte) ((length >> 8) & 0xFF);
+        frame[1] = (byte) (length & 0xFF);
+        System.arraycopy(payload, 0, frame, 2, length);
+        return frame;
+    }
+
+    /**
+     * Lee el frame de respuesta: lee 2 bytes de longitud, luego esa cantidad de bytes de payload.
+     */
+    private static byte[] readFrame(InputStream in) throws IOException {
+        byte[] lengthBytes = readExact(in, 2);
+        if (lengthBytes == null) {
+            return null;
+        }
+        int length = ((lengthBytes[0] & 0xFF) << 8) | (lengthBytes[1] & 0xFF);
+        if (length <= 0) {
+            return null;
+        }
+        return readExact(in, length);
+    }
+
+    private static byte[] readExact(InputStream in, int count) throws IOException {
+        byte[] buffer = new byte[count];
+        int offset = 0;
+        while (offset < count) {
+            int read = in.read(buffer, offset, count - offset);
+            if (read < 0) {
+                return null;
+            }
+            offset += read;
+        }
+        return buffer;
+    }
+
+    private static byte[] hexStringToBytes(String hex) {
+        return HexFormat.of().parseHex(hex.toLowerCase());
+    }
+
+    private void sleepBetweenRetries(int attempt) {
+        try {
+            log.atDebug()
+                    .setMessage("Pausa antes del siguiente reintento al gateway")
+                    .addKeyValue("intento", attempt)
+                    .addKeyValue("pausaMs", properties.retrySleepMs())
+                    .log();
+            Thread.sleep(properties.retrySleepMs());
+        } catch (InterruptedException ie) {
+            Thread.currentThread().interrupt();
+        }
+    }
+}


