+import com.elrosado.cersuitecloudlocalcore.domain.port.out.PaymentReversalFilePort;
+import com.elrosado.cersuitecloudlocalcore.domain.port.out.PaymentReversalResultPort;
+import com.elrosado.cersuitecloudlocalcore.infrastructure.config.ReversarPagoProperties;
+import org.slf4j.Logger;
+import org.slf4j.LoggerFactory;
+import org.springframework.stereotype.Service;
+
+import java.util.List;
+import java.util.Optional;
+import java.util.concurrent.ConcurrentHashMap;
+
+/**
+ * Orquesta la reversiÃ³n de pagos de tarjeta: lee archivos PAG* de GCS, envÃ­a mensaje ISO8583 por cada
+ * lÃ­nea, persiste el resultado en DV_PCER y actualiza STS_CRD cuando la reversa es aprobada.
+ */
+@Service
+public class ReversarPagoService implements ProcessPaymentReversalUseCase {
+
+    private static final Logger log = LoggerFactory.getLogger(ReversarPagoService.class);
+    private static final String PROCESSING_CODE = "284000";
+
+    private final PaymentReversalFilePort filePort;
+    private final PaymentGatewayPort gatewayPort;
+    private final PaymentReversalResultPort resultPort;
+    private final CardCreditStatusPort cardCreditStatusPort;
+    private final ReversarPagoProperties properties;
+    private final ConcurrentHashMap<String, Integer> socketFailureCount = new ConcurrentHashMap<>();
+
+    public ReversarPagoService(
+            PaymentReversalFilePort filePort,
+            PaymentGatewayPort gatewayPort,
+            PaymentReversalResultPort resultPort,
+            CardCreditStatusPort cardCreditStatusPort,
+            ReversarPagoProperties properties) {
+        this.filePort = filePort;
+        this.gatewayPort = gatewayPort;
+        this.resultPort = resultPort;
+        this.cardCreditStatusPort = cardCreditStatusPort;
+        this.properties = properties;
+    }
+
+    @Override
+    public void processNextCycle() {
+        if (!properties.enabled()) {
+            log.atDebug().setMessage("ReversarPago deshabilitado; ciclo omitido").log();
+            return;
+        }
+
+        List<GcsObjectReference> files = filePort.listPendingFiles();
+        if (files.isEmpty()) {
+            log.atDebug().setMessage("No hay archivos PAG pendientes de reversa").log();
+            return;
+        }
+
+        log.atInfo()
+                .setMessage("Iniciando ciclo de reversa de pagos")
+                .addKeyValue("archivosPendientes", files.size())
+                .log();
+
+        files.forEach(this::processFile);
+    }
+
+    private void processFile(GcsObjectReference file) {
+        String fileName = file.fileName();
+
+        List<PaymentReversal> lines;
+        try {
+            lines = filePort.parseAllLines(file);
+        } catch (IllegalArgumentException e) {
+            log.atError()
+                    .setMessage("Archivo PAG con formato invÃ¡lido â movido a error")
+                    .addKeyValue("archivo", fileName)
+                    .setCause(e)
+                    .log();
+            filePort.moveToError(file);
+            socketFailureCount.remove(fileName);
+            return;
+        }
+
+        boolean hasSocketFailure = false;
+        for (PaymentReversal reversal : lines) {
+            boolean socketFailed = processLine(reversal);
+            if (socketFailed) {
+                hasSocketFailure = true;
+                break;
+            }
+        }
+
+        if (hasSocketFailure) {
+            int failures = socketFailureCount.merge(fileName, 1, Integer::sum);
+            if (failures >= properties.socketRetryThreshold()) {
+                log.atError()
+                        .setMessage("Umbral de fallos de socket alcanzado â archivo PAG movido a error")
+                        .addKeyValue("archivo", fileName)
+                        .addKeyValue("intentos", failures)
+                        .log();
+                filePort.moveToError(file);
+                socketFailureCount.remove(fileName);
+            } else {
+                log.atWarn()
+                        .setMessage("Fallo de conexiÃ³n al gateway en reversa de pago; se reintentarÃ¡")
+                        .addKeyValue("archivo", fileName)
+                        .addKeyValue("intentos", failures)
+                        .addKeyValue("umbral", properties.socketRetryThreshold())
+                        .log();
+            }
+        } else {
+            socketFailureCount.remove(fileName);
+            filePort.moveToBackup(file);
+            log.atInfo()
+                    .setMessage("Archivo PAG procesado completamente")
+                    .addKeyValue("archivo", fileName)
+                    .addKeyValue("lineas", lines.size())
+                    .log();
+        }
+    }
+
+    /**
+     * Procesa una lÃ­nea del archivo PAG.
+     *
+     * @return {@code true} si hubo fallo de socket (sin respuesta del gateway).
+     */
+    private boolean processLine(PaymentReversal reversal) {
+        Iso8583ReversalRequest request = buildRequest(reversal);
+        Optional<Iso8583ReversalResponse> response;
+        try {
+            response = gatewayPort.send(request);
+        } catch (Exception e) {
+            log.atWarn()
+                    .setMessage("ExcepciÃ³n al enviar reversa de pago al gateway")
+                    .addKeyValue("fileId", reversal.fileId())
+                    .addKeyValue("seqNum", reversal.sequenceNumber())
+                    .setCause(e)
+                    .log();
+            return true;
+        }
+
+        if (response.isEmpty()) {
+            log.atWarn()
+                    .setMessage("Sin respuesta del gateway para reversa de pago")
+                    .addKeyValue("fileId", reversal.fileId())
+                    .addKeyValue("seqNum", reversal.sequenceNumber())
+                    .log();
+            saveResult(reversal, ReversalStatus.NO_RESPONSE, null);
+            return false;
+        }
+
+        Iso8583ReversalResponse resp = response.get();
+        if (resp.affirmative()) {
+            saveResult(reversal, ReversalStatus.APPROVED, resp.responseCode());
+            updateCardCreditStatus(reversal);
+        } else {
+            saveResult(reversal, ReversalStatus.REJECTED, resp.responseCode());
+        }
+
+        log.atInfo()
+                .setMessage("LÃ­nea de reversa de pago procesada")
+                .addKeyValue("fileId", reversal.fileId())
+                .addKeyValue("seqNum", reversal.sequenceNumber())
+                .addKeyValue("responseCode", resp.responseCode())
+                .addKeyValue("afirmativo", resp.affirmative())
+                .log();
+        return false;
+    }
+
+    private void saveResult(PaymentReversal reversal, ReversalStatus status, String responseCode) {
+        try {
+            resultPort.save(new PaymentReversalResult(
+                    reversal.fileId(),
+                    reversal.sequenceNumber(),
+                    status,
+                    responseCode
+            ));
+        } catch (Exception e) {
+            log.atError()
+                    .setMessage("Error al persistir resultado de reversa de pago en DV_PCER")
+                    .addKeyValue("fileId", reversal.fileId())
+                    .addKeyValue("seqNum", reversal.sequenceNumber())
+                    .addKeyValue("status", status)
+                    .setCause(e)
+                    .log();
+        }
+    }
+
+    private void updateCardCreditStatus(PaymentReversal reversal) {
+        try {
+            cardCreditStatusPort.findByInvoiceAndCard(
+                    reversal.invoiceNumber(),
+                    reversal.primaryAccountNumber(),
+                    reversal.amountValue()
+            ).ifPresentOrElse(
+                    ids -> {
+                        cardCreditStatusPort.markReversed(ids[0], ids[1]);
+                        log.atDebug()
+                                .setMessage("STS_CRD actualizado a '2' en CO_CRD_DT")
+                                .addKeyValue("idTrn", ids[0])
+                                .addKeyValue("sqNbr", ids[1])
+                                .log();
+                    },
+                    () -> log.atWarn()
+                            .setMessage("No se encontrÃ³ registro en CO_CRD_DT para actualizar STS_CRD")
+                            .addKeyValue("invoiceNumber", reversal.invoiceNumber())
+                            .addKeyValue("fileId", reversal.fileId())
+                            .addKeyValue("seqNum", reversal.sequenceNumber())
+                            .log()
+            );
+        } catch (Exception e) {
+            log.atError()
+                    .setMessage("Error al actualizar STS_CRD en CO_CRD_DT")
+                    .addKeyValue("fileId", reversal.fileId())
+                    .addKeyValue("seqNum", reversal.sequenceNumber())
+                    .setCause(e)
+                    .log();
+        }
+    }
+
+    private Iso8583ReversalRequest buildRequest(PaymentReversal reversal) {
+        return new Iso8583ReversalRequest(
+                PROCESSING_CODE,
+                reversal.primaryAccountNumber(),
+                reversal.transactionAmount(),
+                reversal.stan(),
+                reversal.authorizationNumber(),
+                reversal.terminalId(),
+                reversal.merchantId(),
+                reversal.rfpu(),
+                false,
+                null,
+                null
+        );
+    }
+}


