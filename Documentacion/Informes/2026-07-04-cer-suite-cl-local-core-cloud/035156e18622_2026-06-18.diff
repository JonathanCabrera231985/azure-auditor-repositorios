+package com.elrosado.cersuitecloudlocalcore.service;
+
+import com.elrosado.cersuitecloudlocalcore.domain.exception.UpdateCedPadRucProcessingException;
+import com.elrosado.cersuitecloudlocalcore.domain.model.CedRucUpdateRecord;
+import com.elrosado.cersuitecloudlocalcore.domain.model.CedulaUpdateRecord;
+import com.elrosado.cersuitecloudlocalcore.domain.model.GcsObjectReference;
+import com.elrosado.cersuitecloudlocalcore.domain.model.PadronUpdateRecord;
+import com.elrosado.cersuitecloudlocalcore.domain.model.UpdateCedPadRucErrorRecord;
+import com.elrosado.cersuitecloudlocalcore.domain.model.UpdateCedPadRucFile;
+import com.elrosado.cersuitecloudlocalcore.domain.model.UpdateCedPadRucFileType;
+import com.elrosado.cersuitecloudlocalcore.domain.model.UpdateCedPadRucProcessingResult;
+import com.elrosado.cersuitecloudlocalcore.domain.model.UpdateCedPadRucProcessingStage;
+import com.elrosado.cersuitecloudlocalcore.domain.port.in.UpdateCedPadRucUseCase;
+import com.elrosado.cersuitecloudlocalcore.domain.port.out.UpdateCedPadRucErrorTrackerPort;
+import com.elrosado.cersuitecloudlocalcore.domain.port.out.UpdateCedPadRucPersistencePort;
+import com.elrosado.cersuitecloudlocalcore.domain.port.out.UpdateCedPadRucStoragePort;
+import com.elrosado.cersuitecloudlocalcore.infrastructure.config.UpdateCedPadRucProperties;
+import org.slf4j.Logger;
+import org.slf4j.LoggerFactory;
+import org.springframework.stereotype.Service;
+
+import java.io.BufferedReader;
+import java.io.IOException;
+import java.time.Instant;
+import java.util.ArrayList;
+import java.util.List;
+import java.util.UUID;
+
+@Service
+public class UpdateCedPadRucService implements UpdateCedPadRucUseCase {
+
+    private static final Logger log = LoggerFactory.getLogger(UpdateCedPadRucService.class);
+    private static final int MAX_ATTEMPTS = 3;
+    private static final int STACKTRACE_MAX_LINES = 8;
+
+    private final UpdateCedPadRucStoragePort storagePort;
+    private final UpdateCedPadRucPersistencePort persistencePort;
+    private final UpdateCedPadRucErrorTrackerPort errorTrackerPort;
+    private final UpdateCedPadRucParser parser;
+    private final UpdateCedPadRucProperties properties;
+
+    public UpdateCedPadRucService(
+            UpdateCedPadRucStoragePort storagePort,
+            UpdateCedPadRucPersistencePort persistencePort,
+            UpdateCedPadRucErrorTrackerPort errorTrackerPort,
+            UpdateCedPadRucParser parser,
+            UpdateCedPadRucProperties properties) {
+        this.storagePort = storagePort;
+        this.persistencePort = persistencePort;
+        this.errorTrackerPort = errorTrackerPort;
+        this.parser = parser;
+        this.properties = properties;
+    }
+
+    @Override
+    public void processPendingFiles() {
+        if (!properties.enabled()) {
+            log.atDebug().setMessage("UpdateCedPadRuc deshabilitado").log();
+            return;
+        }
+
+        List<UpdateCedPadRucFile> pendingFiles;
+        try {
+            pendingFiles = storagePort.listPendingFiles();
+        } catch (RuntimeException e) {
+            throw new UpdateCedPadRucProcessingException(
+                    UpdateCedPadRucProcessingStage.GCS_LIST,
+                    "Error listando archivos UpdateCedPadRuc en GCS",
+                    e);
+        }
+
+        if (pendingFiles.isEmpty()) {
+            log.atDebug().setMessage("Sin archivos UpdateCedPadRuc pendientes").log();
+            return;
+        }
+
+        log.atInfo()
+                .setMessage("Archivos UpdateCedPadRuc pendientes detectados")
+                .addKeyValue("count", pendingFiles.size())
+                .log();
+
+        pendingFiles.forEach(this::processWithRetry);
+    }
+
+    private void processWithRetry(UpdateCedPadRucFile file) {
+        String processId = UUID.randomUUID().toString();
+        Instant executionDate = Instant.now();
+
+        for (int attempt = 1; attempt <= MAX_ATTEMPTS; attempt++) {
+            try {
+                UpdateCedPadRucProcessingResult result = processFile(file);
+                GcsObjectReference backupObject = moveToBackup(file);
+
+                log.atInfo()
+                        .setMessage("Archivo UpdateCedPadRuc procesado")
+                        .addKeyValue("processId", processId)
+                        .addKeyValue("fileName", file.fileName())
+                        .addKeyValue("fileType", result.fileType())
+                        .addKeyValue("recordsProcessed", result.recordsProcessed())
+                        .addKeyValue("backupObject", backupObject.toUri())
+                        .log();
+                return;
+
+            } catch (Exception e) {
+                UpdateCedPadRucProcessingStage stage = resolveStage(e);
+                if (attempt < MAX_ATTEMPTS) {
+                    log.atWarn()
+                            .setMessage("Error procesando UpdateCedPadRuc; se reintentara")
+                            .addKeyValue("processId", processId)
+                            .addKeyValue("fileName", file.fileName())
+                            .addKeyValue("attempt", attempt)
+                            .addKeyValue("stage", stage)
+                            .setCause(e)
+                            .log();
+                    continue;
+                }
+
+                handleFinalFailure(file, processId, executionDate, stage, e);
+            }
+        }
+    }
+
+    private UpdateCedPadRucProcessingResult processFile(UpdateCedPadRucFile file) {
+        return switch (file.type()) {
+            case CED -> processCedulaFile(file);
+            case PAD -> processPadronFile(file);
+            case RUC -> processRucFile(file);
+        };
+    }
+
+    private UpdateCedPadRucProcessingResult processCedulaFile(UpdateCedPadRucFile file) {
+        List<CedulaUpdateRecord> batch = new ArrayList<>(properties.batchSize());
+        long processed = 0;
+        long lineNumber = 0;
+
+        try (BufferedReader reader = openReader(file)) {
+            String line;
+            while ((line = reader.readLine()) != null) {
+                lineNumber++;
+                if (lineNumber == 1) {
+                    continue;
+                }
+                batch.add(parseCedula(line, lineNumber));
+                if (batch.size() >= properties.batchSize()) {
+                    saveCedulas(batch);
+                    processed += batch.size();
+                    batch.clear();
+                }
+            }
+            if (!batch.isEmpty()) {
+                saveCedulas(batch);
+                processed += batch.size();
+            }
+            return new UpdateCedPadRucProcessingResult(UpdateCedPadRucFileType.CED, processed);
+        } catch (IOException e) {
+            throw new UpdateCedPadRucProcessingException(
+                    UpdateCedPadRucProcessingStage.GCS_READ,
+                    "Error leyendo archivo CED desde GCS",
+                    e);
+        }
+    }
+
+    private UpdateCedPadRucProcessingResult processPadronFile(UpdateCedPadRucFile file) {
+        List<PadronUpdateRecord> batch = new ArrayList<>(properties.batchSize());
+        long processed = 0;
+        long lineNumber = 0;
+
+        try (BufferedReader reader = openReader(file)) {
+            String line;
+            while ((line = reader.readLine()) != null) {
+                lineNumber++;
+                batch.add(parsePadron(line, lineNumber));
+                if (batch.size() >= properties.batchSize()) {
+                    savePadrones(batch);
+                    processed += batch.size();
+                    batch.clear();
+                }
+            }
+            if (!batch.isEmpty()) {
+                savePadrones(batch);
+                processed += batch.size();
+            }
+            return new UpdateCedPadRucProcessingResult(UpdateCedPadRucFileType.PAD, processed);
+        } catch (IOException e) {
+            throw new UpdateCedPadRucProcessingException(
+                    UpdateCedPadRucProcessingStage.GCS_READ,
+                    "Error leyendo archivo PAD desde GCS",
+                    e);
+        }
+    }
+
+    private UpdateCedPadRucProcessingResult processRucFile(UpdateCedPadRucFile file) {
+        List<CedRucUpdateRecord> batch = new ArrayList<>(properties.batchSize());
+        long processed = 0;
+        long lineNumber = 0;
+
+        try (BufferedReader reader = openReader(file)) {
+            String line;
+            while ((line = reader.readLine()) != null) {
+                lineNumber++;
+                batch.add(parseRuc(line, lineNumber));
+                if (batch.size() >= properties.batchSize()) {
+                    saveRucs(batch);
+                    processed += batch.size();
+                    batch.clear();
+                }
+            }
+            if (!batch.isEmpty()) {
+                saveRucs(batch);
+                processed += batch.size();
+            }
+            return new UpdateCedPadRucProcessingResult(UpdateCedPadRucFileType.RUC, processed);
+        } catch (IOException e) {
+            throw new UpdateCedPadRucProcessingException(
+                    UpdateCedPadRucProcessingStage.GCS_READ,
+                    "Error leyendo archivo RUC desde GCS",
+                    e);
+        }
+    }
+
+    private BufferedReader openReader(UpdateCedPadRucFile file) {
+        try {
+            return storagePort.openReader(file);
+        } catch (RuntimeException e) {
+            throw new UpdateCedPadRucProcessingException(
+                    UpdateCedPadRucProcessingStage.GCS_READ,
+                    "Error abriendo archivo UpdateCedPadRuc desde GCS",
+                    e);
+        }
+    }
+
+    private CedulaUpdateRecord parseCedula(String line, long lineNumber) {
+        try {
+            return parser.parseCedula(line, lineNumber);
+        } catch (RuntimeException e) {
+            throw new UpdateCedPadRucProcessingException(
+                    UpdateCedPadRucProcessingStage.PARSING,
+                    "Error parseando linea CED " + lineNumber,
+                    e);
+        }
+    }
+
+    private PadronUpdateRecord parsePadron(String line, long lineNumber) {
+        try {
+            return parser.parsePadron(line, lineNumber);
+        } catch (RuntimeException e) {
+            throw new UpdateCedPadRucProcessingException(
+                    UpdateCedPadRucProcessingStage.PARSING,
+                    "Error parseando linea PAD " + lineNumber,
+                    e);
+        }
+    }
+
+    private CedRucUpdateRecord parseRuc(String line, long lineNumber) {
+        try {
+            return parser.parseRuc(line, lineNumber);
+        } catch (RuntimeException e) {
+            throw new UpdateCedPadRucProcessingException(
+                    UpdateCedPadRucProcessingStage.PARSING,
+                    "Error parseando linea RUC " + lineNumber,
+                    e);
+        }
+    }
+
+    private void saveCedulas(List<CedulaUpdateRecord> records) {
+        try {
+            persistencePort.saveCedulas(List.copyOf(records));
+        } catch (RuntimeException e) {
+            throw new UpdateCedPadRucProcessingException(
+                    UpdateCedPadRucProcessingStage.DATABASE_WRITE,
+                    "Error persistiendo registros CED",
+                    e);
+        }
+    }
+
+    private void savePadrones(List<PadronUpdateRecord> records) {
+        try {
+            persistencePort.savePadrones(List.copyOf(records));
+        } catch (RuntimeException e) {
+            throw new UpdateCedPadRucProcessingException(
+                    UpdateCedPadRucProcessingStage.DATABASE_WRITE,
+                    "Error persistiendo registros PAD",
+                    e);
+        }
+    }
+
+    private void saveRucs(List<CedRucUpdateRecord> records) {
+        try {
+            persistencePort.saveRucs(List.copyOf(records));
+        } catch (RuntimeException e) {
+            throw new UpdateCedPadRucProcessingException(
+                    UpdateCedPadRucProcessingStage.DATABASE_WRITE,
+                    "Error persistiendo registros RUC",
+                    e);
+        }
+    }
+
+    private GcsObjectReference moveToBackup(UpdateCedPadRucFile file) {
+        try {
+            return storagePort.moveToBackup(file);
+        } catch (RuntimeException e) {
+            throw new UpdateCedPadRucProcessingException(
+                    UpdateCedPadRucProcessingStage.GCS_MOVE_TO_BACKUP,
+                    "Error moviendo archivo procesado a backup GCS",
+                    e);
+        }
+    }
+
+    private void handleFinalFailure(
+            UpdateCedPadRucFile file,
+            String processId,
+            Instant executionDate,
+            UpdateCedPadRucProcessingStage stage,
+            Exception error) {
+        GcsObjectReference errorObject;
+        try {
+            errorObject = storagePort.moveToError(file);
+        } catch (RuntimeException moveError) {
+            log.atError()
+                    .setMessage("No fue posible mover archivo UpdateCedPadRuc al bucket de error")
+                    .addKeyValue("processId", processId)
+                    .addKeyValue("fileName", file.fileName())
+                    .addKeyValue("stage", UpdateCedPadRucProcessingStage.GCS_MOVE_TO_ERROR)
+                    .setCause(moveError)
+                    .log();
+            return;
+        }
+
+        try {
+            errorTrackerPort.recordError(new UpdateCedPadRucErrorRecord(
+                    processId,
+                    executionDate,
+                    file.fileName(),
+                    file.location().bucket(),
+                    file.location().objectName(),
+                    errorObject.objectName(),
+                    error.getClass().getSimpleName(),
+                    error.getMessage(),
+                    summarizeStackTrace(error),
+                    stage,
+                    Instant.now()
+            ));
+        } catch (RuntimeException trackingError) {
+            log.atError()
+                    .setMessage("Archivo UpdateCedPadRuc movido a error sin registro Firestore")
+                    .addKeyValue("processId", processId)
+                    .addKeyValue("fileName", file.fileName())
+                    .addKeyValue("errorObject", errorObject.toUri())
+                    .setCause(trackingError)
+                    .log();
+        }
+
+        log.atError()
+                .setMessage("Archivo UpdateCedPadRuc enviado a error")
+                .addKeyValue("processId", processId)
+                .addKeyValue("fileName", file.fileName())
+                .addKeyValue("stage", stage)
+                .addKeyValue("errorObject", errorObject.toUri())
+                .setCause(error)
+                .log();
+    }
+
+    private UpdateCedPadRucProcessingStage resolveStage(Exception error) {
+        if (error instanceof UpdateCedPadRucProcessingException processingException) {
+            return processingException.stage();
+        }
+        return UpdateCedPadRucProcessingStage.UNKNOWN;
+    }
+
+    private String summarizeStackTrace(Exception error) {
+        StringBuilder summary = new StringBuilder(error.toString());
+        StackTraceElement[] stackTrace = error.getStackTrace();
+        int max = Math.min(stackTrace.length, STACKTRACE_MAX_LINES);
+        for (int i = 0; i < max; i++) {
+            summary.append(System.lineSeparator()).append("at ").append(stackTrace[i]);
+        }
+        return summary.toString();
+    }
+}


