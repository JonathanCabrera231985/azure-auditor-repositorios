+import com.elrosado.cersuitecloudlocalcore.infrastructure.adapter.out.db.repository.CedRegElecUpdateJpaRepository;
+import com.elrosado.cersuitecloudlocalcore.infrastructure.adapter.out.db.repository.CedRucUpdateJpaRepository;
+import com.elrosado.cersuitecloudlocalcore.infrastructure.adapter.out.db.repository.PadronUpdateJpaRepository;
+import org.springframework.stereotype.Component;
+import org.springframework.transaction.annotation.Transactional;
+
+import java.util.List;
+
+@Component
+public class DbUpdateCedPadRucAdapter implements UpdateCedPadRucPersistencePort {
+
+    private final CedRucUpdateJpaRepository cedRucRepository;
+    private final CedRegElecUpdateJpaRepository cedRegElecRepository;
+    private final PadronUpdateJpaRepository padronRepository;
+
+    public DbUpdateCedPadRucAdapter(
+            CedRucUpdateJpaRepository cedRucRepository,
+            CedRegElecUpdateJpaRepository cedRegElecRepository,
+            PadronUpdateJpaRepository padronRepository) {
+        this.cedRucRepository = cedRucRepository;
+        this.cedRegElecRepository = cedRegElecRepository;
+        this.padronRepository = padronRepository;
+    }
+
+    @Override
+    @Transactional(transactionManager = "artsEcTransactionManager")
+    public void saveCedulas(List<CedulaUpdateRecord> records) {
+        if (records.isEmpty()) {
+            return;
+        }
+        cedRucRepository.saveAll(records.stream()
+                .map(CedulaUpdateRecord::customer)
+                .map(CedRucUpdateEntity::fromDomain)
+                .toList());
+        cedRegElecRepository.saveAll(records.stream()
+                .map(CedulaUpdateRecord::electoralRecord)
+                .map(CedRegElecUpdateEntity::fromDomain)
+                .toList());
+    }
+
+    @Override
+    @Transactional(transactionManager = "artsEcTransactionManager")
+    public void saveRucs(List<CedRucUpdateRecord> records) {
+        if (records.isEmpty()) {
+            return;
+        }
+        cedRucRepository.saveAll(records.stream()
+                .map(CedRucUpdateEntity::fromDomain)
+                .toList());
+    }
+
+    @Override
+    @Transactional(transactionManager = "artsEcTransactionManager")
+    public void savePadrones(List<PadronUpdateRecord> records) {
+        if (records.isEmpty()) {
+            return;
+        }
+        padronRepository.saveAll(records.stream()
+                .map(PadronUpdateEntity::fromDomain)
+                .toList());
+    }
+}


