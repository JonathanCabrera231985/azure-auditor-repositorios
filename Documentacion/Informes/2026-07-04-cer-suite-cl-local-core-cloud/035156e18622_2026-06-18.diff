--- a//src/main/java/com/elrosado/cersuitecloudlocalcore/service/UpdateCedPadRucParser.java
+++ b//src/main/java/com/elrosado/cersuitecloudlocalcore/service/UpdateCedPadRucParser.java
@@ -0,0 +1,91 @@
+package com.elrosado.cersuitecloudlocalcore.service;
+
+import com.elrosado.cersuitecloudlocalcore.domain.model.CedRegElecUpdateRecord;
+import com.elrosado.cersuitecloudlocalcore.domain.model.CedRucUpdateRecord;
+import com.elrosado.cersuitecloudlocalcore.domain.model.CedulaUpdateRecord;
+import com.elrosado.cersuitecloudlocalcore.domain.model.PadronUpdateRecord;
+import org.springframework.stereotype.Service;
+
+@Service
+public class UpdateCedPadRucParser {
+
+    private static final String PIPE_REGEX = "\\|";
+
+    public CedulaUpdateRecord parseCedula(String line, long lineNumber) {
+        String[] fields = split(line, 11, lineNumber);
+        Long id = parseLong(fields[0], lineNumber);
+        String gender = fields[7];
+
+        return new CedulaUpdateRecord(
+                new CedRucUpdateRecord(id, fields[0], "C", 0, fields[1], gender),
+                new CedRegElecUpdateRecord(
+                        id,
+                        truncate(fields[2], 25),
+                        truncate(fields[4], 25),
+                        truncate(fields[5], 30),
+                        truncate(fields[6], 40),
+                        truncate(fields[8], 80),
+                        "",
+                        truncate(fields[10], 5),
+                        truncate(fields[3], 75),
+                        "",
+                        gender
+                )
+        );
+    }
+
+    public PadronUpdateRecord parsePadron(String line, long lineNumber) {
+        String[] fields = split(line, 6, lineNumber);
+        Integer id = parseInteger(fields[0], lineNumber);
+        return new PadronUpdateRecord(
+                id,
+                fields[0],
+                fields[2],
+                fields[4],
+                fields[5],
+                fields[1],
+                fields[3]
+        );
+    }
+
+    public CedRucUpdateRecord parseRuc(String line, long lineNumber) {
+        String[] fields = split(line, 2, lineNumber);
+        Long id = parseLong(fields[0], lineNumber);
+        return new CedRucUpdateRecord(id, fields[0], "R", 0, fields[1], "");
+    }
+
+    private String[] split(String line, int expectedFields, long lineNumber) {
+        if (line == null) {
+            throw new IllegalArgumentException("Line " + lineNumber + " is null");
+        }
+        String[] fields = line.split(PIPE_REGEX, -1);
+        if (fields.length < expectedFields) {
+            throw new IllegalArgumentException(
+                    "Line " + lineNumber + " has " + fields.length + " fields; expected at least " + expectedFields);
+        }
+        return fields;
+    }
+
+    private Long parseLong(String value, long lineNumber) {
+        try {
+            return Long.parseLong(value);
+        } catch (NumberFormatException e) {
+            throw new IllegalArgumentException("Line " + lineNumber + " has invalid long id: " + value, e);
+        }
+    }
+
+    private Integer parseInteger(String value, long lineNumber) {
+        try {
+            return Integer.parseInt(value);
+        } catch (NumberFormatException e) {
+            throw new IllegalArgumentException("Line " + lineNumber + " has invalid integer id: " + value, e);
+        }
+    }
+
+    private String truncate(String value, int maxLength) {
+        if (value == null || value.length() <= maxLength) {
+            return value;
+        }
+        return value.substring(0, maxLength);
+    }
+}


