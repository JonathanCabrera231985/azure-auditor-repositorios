+
+public enum UpdateCedPadRucFileType {
+    CED(1),
+    PAD(2),
+    RUC(3);
+
+    private final int legacyOrder;
+
+    UpdateCedPadRucFileType(int legacyOrder) {
+        this.legacyOrder = legacyOrder;
+    }
+
+    public int legacyOrder() {
+        return legacyOrder;
+    }
+
+    public static Optional<UpdateCedPadRucFileType> fromFileName(String fileName) {
+        if (fileName == null || fileName.length() < 3) {
+            return Optional.empty();
+        }
+
