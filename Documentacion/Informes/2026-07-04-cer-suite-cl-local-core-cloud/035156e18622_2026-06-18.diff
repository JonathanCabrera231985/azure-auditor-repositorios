--- Diff for /src/main/java/com/elrosado/cersuitecloudlocalcore/domain/model/GcsObjectReference.java ---
--- a//src/main/java/com/elrosado/cersuitecloudlocalcore/domain/model/GcsObjectReference.java
+++ b//src/main/java/com/elrosado/cersuitecloudlocalcore/domain/model/GcsObjectReference.java
@@ -0,0 +1,64 @@
+package com.elrosado.cersuitecloudlocalcore.domain.model;
+
+public record GcsObjectReference(String bucket, String objectName) {
+
+    private static final String GCS_SCHEME = "gs://";
+
+    public GcsObjectReference {
+        if (bucket == null || bucket.isBlank()) {
+            throw new IllegalArgumentException("bucket is required");
+        }
+        if (objectName == null || objectName.isBlank()) {
+            throw new IllegalArgumentException("objectName is required");
+        }
+        objectName = normalizeObjectName(objectName);
+    }
+
+    public static GcsObjectReference fromUri(String uri) {
+        if (uri == null || !uri.startsWith(GCS_SCHEME)) {
+            throw new IllegalArgumentException("GCS URI must start with gs://");
+        }
+
+        String value = uri.substring(GCS_SCHEME.length());
+        int separator = value.indexOf('/');
+        if (separator <= 0 || separator == value.length() - 1) {
+            throw new IllegalArgumentException("GCS URI must include bucket and object path");
+        }
+
+        return new GcsObjectReference(
+                value.substring(0, separator),
+                value.substring(separator + 1)
+        );
+    }
+
+    public GcsObjectReference resolve(String fileName) {
+        if (fileName == null || fileName.isBlank() || fileName.contains("/")) {
+            throw new IllegalArgumentException("fileName must be a single object name");
+        }
+        return new GcsObjectReference(bucket, objectName + "/" + fileName);
+    }
+
+    public String fileName() {
+        int index = objectName.lastIndexOf('/');
+        return index >= 0 ? objectName.substring(index + 1) : objectName;
+    }
+
+    public String prefixWithSlash() {
+        return objectName.endsWith("/") ? objectName : objectName + "/";
+    }
+
+    public String toUri() {
+        return GCS_SCHEME + bucket + "/" + objectName;
+    }
+
+    private static String normalizeObjectName(String value) {
+        String normalized = value;
+        while (normalized.startsWith("/")) {
+            normalized = normalized.substring(1);
+        }
+        while (normalized.endsWith("/")) {
+            normalized = normalized.substring(0, normalized.length() - 1);
+        }
+        return normalized;
+    }
+}


