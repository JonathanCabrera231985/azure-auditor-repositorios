+package com.elrosado.cersuitecloudlocalcore.infrastructure.adapter.out.db;
+
+import com.elrosado.cersuitecloudlocalcore.domain.model.CedRucUpdateRecord;
+import com.elrosado.cersuitecloudlocalcore.domain.model.CedulaUpdateRecord;
+import com.elrosado.cersuitecloudlocalcore.domain.model.PadronUpdateRecord;
+import com.elrosado.cersuitecloudlocalcore.domain.port.out.UpdateCedPadRucPersistencePort;
+import com.elrosado.cersuitecloudlocalcore.infrastructure.adapter.out.db.entity.CedRegElecUpdateEntity;
+import com.elrosado.cersuitecloudlocalcore.infrastructure.adapter.out.db.entity.CedRucUpdateEntity;
