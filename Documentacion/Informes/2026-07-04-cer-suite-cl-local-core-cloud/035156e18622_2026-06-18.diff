+
+        CedulaUpdateRecord record = parser.parseCedula(line, 2);
+
+        assertEquals(1234567890L, record.customer().id());
+        assertEquals("C", record.customer().type());
+        assertEquals(0, record.customer().registryInternal());
+        assertEquals("CLIENTE UNO", record.customer().name());
+        assertEquals("M", record.customer().gender());
+        assertEquals(25, record.electoralRecord().province().length());
+        assertEquals(25, record.electoralRecord().canton().length());
+        assertEquals(30, record.electoralRecord().parish().length());
+        assertEquals(40, record.electoralRecord().zone().length());
+        assertEquals(5, record.electoralRecord().board().length());
+        assertEquals("", record.electoralRecord().table());
+        assertEquals("", record.electoralRecord().function());
+    }
+
+    @Test
+    void parsePadron_noOmitePrimeraLinea() {
+        PadronUpdateRecord record = parser.parsePadron("123|FUNCION|RECINTO|DIRECCION|MESA|J", 1);
+
+        assertEquals(123, record.id());
+        assertEquals("123", record.code());
+        assertEquals("FUNCION", record.function());
+        assertEquals("RECINTO", record.precinct());
+        assertEquals("DIRECCION", record.address());
+        assertEquals("MESA", record.table());
+        assertEquals("J", record.board());
+    }
+
+    @Test
+    void parseRuc_generaCedRucTipoR() {
+        CedRucUpdateRecord record = parser.parseRuc("1790012345001|EMPRESA UNO", 1);
+
+        assertEquals(1790012345001L, record.id());
+        assertEquals("1790012345001", record.code());
+        assertEquals("R", record.type());
+        assertEquals("EMPRESA UNO", record.name());
+        assertEquals("", record.gender());
+    }
+
+    @Test
+    void parseCedula_camposInsuficientes_lanzaExcepcion() {
+        assertThrows(IllegalArgumentException.class, () -> parser.parseCedula("1|NOMBRE", 5));
+    }
+}


