+package com.elrosado.cersuitecloudlocalcore.infrastructure.adapter.out.firestore;
+
+import com.elrosado.cersuitecloudlocalcore.domain.model.UpdateCedPadRucErrorRecord;
+import com.elrosado.cersuitecloudlocalcore.domain.port.out.UpdateCedPadRucErrorTrackerPort;
+import com.google.cloud.Timestamp;
+import com.google.cloud.firestore.Firestore;
+import org.springframework.stereotype.Component;
+
+import java.util.LinkedHashMap;
+import java.util.Map;
+import java.util.concurrent.ExecutionException;
+
+@Component
+public class UpdateCedPadRucErrorFirestoreAdapter implements UpdateCedPadRucErrorTrackerPort {
+
+    private static final String COLLECTION = "update_ced_pad_ruc_error";
+
+    private final Firestore firestore;
+
+    public UpdateCedPadRucErrorFirestoreAdapter(Firestore firestore) {
+        this.firestore = firestore;
+    }
+
+    @Override
+    public void recordError(UpdateCedPadRucErrorRecord errorRecord) {
+        Map<String, Object> document = new LinkedHashMap<>();
+        document.put("processId", errorRecord.processId());
+        document.put("executionDate", Timestamp.ofTimeSecondsAndNanos(
+                errorRecord.executionDate().getEpochSecond(),
+                errorRecord.executionDate().getNano()));
+        document.put("fileName", errorRecord.fileName());
+        document.put("bucket", errorRecord.bucket());
+        document.put("sourceObjectName", errorRecord.sourceObjectName());
+        document.put("errorObjectName", errorRecord.errorObjectName());
+        document.put("errorType", valueOrDefault(errorRecord.errorType()));
+        document.put("errorMessage", valueOrDefault(errorRecord.errorMessage()));
+        document.put("stackTrace", valueOrDefault(errorRecord.stackTrace()));
+        document.put("processingStage", errorRecord.processingStage().name());
+        document.put("createdAt", Timestamp.ofTimeSecondsAndNanos(
+                errorRecord.createdAt().getEpochSecond(),
+                errorRecord.createdAt().getNano()));
+
+        try {
+            firestore.collection(COLLECTION)
+                    .document(errorRecord.processId())
+                    .set(document)
+                    .get();
+        } catch (InterruptedException e) {
+            Thread.currentThread().interrupt();
+            throw new IllegalStateException("Registro Firestore UpdateCedPadRuc interrumpido", e);
+        } catch (ExecutionException e) {
+            throw new IllegalStateException("Error registrando Firestore UpdateCedPadRuc", e.getCause());
+        }
+    }
+
+    private String valueOrDefault(String value) {
+        return value == null ? "" : value;
+    }
+}


--- Diff for /src/main/java/com/elrosado/cersuitecloudlocalcore/infrastructure/adapter/out/storage/GcsUpdateCedPadRucStorageAdapter.java ---
--- a//src/main/java/com/elrosado/cersuitecloudlocalcore/infrastructure/adapter/out/storage/GcsUpdateCedPadRucStorageAdapter.java
+++ b//src/main/java/com/elrosado/cersuitecloudlocalcore/infrastructure/adapter/out/storage/GcsUpdateCedPadRucStorageAdapter.java
@@ -0,0 +1,140 @@
+package com.elrosado.cersuitecloudlocalcore.infrastructure.adapter.out.storage;
+
+import com.elrosado.cersuitecloudlocalcore.domain.model.GcsObjectReference;
+import com.elrosado.cersuitecloudlocalcore.domain.model.UpdateCedPadRucFile;
+import com.elrosado.cersuitecloudlocalcore.domain.model.UpdateCedPadRucFileType;
+import com.elrosado.cersuitecloudlocalcore.domain.port.out.UpdateCedPadRucStoragePort;
+import com.elrosado.cersuitecloudlocalcore.infrastructure.config.LegacyUpdateCedPadRucProperties;
+import com.elrosado.cersuitecloudlocalcore.infrastructure.config.UpdateCedPadRucProperties;
+import com.google.cloud.storage.Blob;
+import com.google.cloud.storage.BlobId;
+import com.google.cloud.storage.BlobInfo;
+import com.google.cloud.storage.Storage;
+import org.slf4j.Logger;
+import org.slf4j.LoggerFactory;
+import org.springframework.stereotype.Component;
+
+import java.io.BufferedReader;
+import java.io.InputStreamReader;
+import java.nio.channels.Channels;
+import java.nio.charset.StandardCharsets;
+import java.util.Comparator;
+import java.util.List;
+import java.util.Optional;
+import java.util.stream.StreamSupport;
+
+@Component
+public class GcsUpdateCedPadRucStorageAdapter implements UpdateCedPadRucStoragePort {
+
+    private static final Logger log = LoggerFactory.getLogger(GcsUpdateCedPadRucStorageAdapter.class);
+
+    private final Storage storage;
+    private final LegacyUpdateCedPadRucProperties legacyProperties;
+    private final UpdateCedPadRucProperties properties;
+
+    public GcsUpdateCedPadRucStorageAdapter(
+            Storage storage,
+            LegacyUpdateCedPadRucProperties legacyProperties,
+            UpdateCedPadRucProperties properties) {
+        this.storage = storage;
+        this.legacyProperties = legacyProperties;
+        this.properties = properties;
+    }
+
+    @Override
+    public List<UpdateCedPadRucFile> listPendingFiles() {
+        GcsObjectReference input = GcsObjectReference.fromUri(legacyProperties.inputUri());
+        String prefix = input.prefixWithSlash();
+
+        return StreamSupport.stream(storage.list(input.bucket(), Storage.BlobListOption.prefix(prefix))
+                        .iterateAll()
+                        .spliterator(), false)
+                .filter(blob -> !blob.isDirectory())
+                .flatMap(blob -> toPendingFile(input, prefix, blob).stream())
+                .sorted(Comparator
+                        .comparing((UpdateCedPadRucFile file) -> file.type().legacyOrder())
+                        .thenComparingInt(UpdateCedPadRucFile::sequenceNumber)
+                        .thenComparing(UpdateCedPadRucFile::fileName))
+                .toList();
+    }
+
+    @Override
+    public BufferedReader openReader(UpdateCedPadRucFile file) {
+        Blob blob = storage.get(BlobId.of(file.location().bucket(), file.location().objectName()));
+        if (blob == null) {
+            throw new IllegalArgumentException("Objeto GCS no encontrado: " + file.location().toUri());
+        }
+        return new BufferedReader(new InputStreamReader(
+                Channels.newInputStream(blob.reader()),
+                StandardCharsets.UTF_8));
+    }
+
+    @Override
+    public GcsObjectReference moveToBackup(UpdateCedPadRucFile file) {
+        return move(file, GcsObjectReference.fromUri(legacyProperties.backupUri()));
+    }
+
+    @Override
+    public GcsObjectReference moveToError(UpdateCedPadRucFile file) {
+        return move(file, GcsObjectReference.fromUri(properties.gcs().errorUri()));
+    }
+
+    private Optional<UpdateCedPadRucFile> toPendingFile(
+            GcsObjectReference input,
+            String prefix,
+            Blob blob) {
+        String objectName = blob.getName();
+        if (!objectName.startsWith(prefix)) {
+            return Optional.empty();
+        }
+
+        String relativeName = objectName.substring(prefix.length());
+        if (relativeName.isBlank() || relativeName.contains("/")) {
+            return Optional.empty();
+        }
+
+        return UpdateCedPadRucFileType.fromFileName(relativeName)
+                .map(type -> new UpdateCedPadRucFile(
+                        new GcsObjectReference(input.bucket(), objectName),
+                        relativeName,
+                        type,
+                        sequenceNumber(relativeName)
+                ));
+    }
+
+    private int sequenceNumber(String fileName) {
+        if (fileName.length() < 7) {
+            return Integer.MAX_VALUE;
+        }
+        try {
+            return Integer.parseInt(fileName.substring(3, 7));
+        } catch (NumberFormatException e) {
+            log.atWarn()
+                    .setMessage("Secuencia UpdateCedPadRuc invalida; se procesara al final del tipo")
+                    .addKeyValue("fileName", fileName)
+                    .log();
+            return Integer.MAX_VALUE;
+        }
+    }
+
+    private GcsObjectReference move(UpdateCedPadRucFile file, GcsObjectReference targetFolder) {
+        GcsObjectReference target = targetFolder.resolve(file.fileName());
+        BlobId sourceId = BlobId.of(file.location().bucket(), file.location().objectName());
+        BlobId targetId = BlobId.of(target.bucket(), target.objectName());
+
+        storage.delete(targetId);
+        storage.copy(Storage.CopyRequest.newBuilder()
+                .setSource(sourceId)
+                .setTarget(BlobInfo.newBuilder(targetId).build())
+                .build()).getResult();
+
+        boolean deleted = storage.delete(sourceId);
+        if (!deleted) {
+            log.atWarn()
+                    .setMessage("Objeto fuente no eliminado luego del movimiento GCS")
+                    .addKeyValue("sourceObject", file.location().toUri())
+                    .log();
+        }
+        return target;
+    }
+}


