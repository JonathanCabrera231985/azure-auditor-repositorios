@@ -0,0 +1,72 @@
+package com.elrosado.cersuitecloudlocalcore.infrastructure.adapter.out.messaging;
+
+import com.elrosado.cersuitecloudlocalcore.domain.port.out.SynchroControllerPublisherPort;
+import com.elrosado.jlib_pubsub.interfaces.IMessagePublisher;
+import org.slf4j.Logger;
+import org.slf4j.LoggerFactory;
+import org.springframework.beans.factory.annotation.Value;
+import org.springframework.stereotype.Component;
+import tools.jackson.databind.ObjectMapper;
+
+import java.time.Instant;
+import java.util.LinkedHashMap;
+import java.util.Map;
+import java.util.UUID;
+
+@Component
+public class PubSubSynchroControllerPublisher implements SynchroControllerPublisherPort {
+
+    private static final Logger log = LoggerFactory.getLogger(PubSubSynchroControllerPublisher.class);
+
+    private final IMessagePublisher messagePublisher;
+    private final ObjectMapper objectMapper;
+
+    @Value("${app.gcp.pubsub.topic-synchro-controller}")
+    private String synchroTopic;
+
+    public PubSubSynchroControllerPublisher(IMessagePublisher messagePublisher, ObjectMapper objectMapper) {
+        this.messagePublisher = messagePublisher;
+        this.objectMapper = objectMapper;
+    }
+
+    @Override
+    public void publishFileReady(int codStore, String gcsBucket, String gcsPath, String fileName, String targetDir) {
+        try {
+            Map<String, Object> payload = new LinkedHashMap<>();
+            payload.put("eventId", UUID.randomUUID().toString());
+            payload.put("eventType", "file.ready");
+            payload.put("source", "cer-suite-cloud-local-core");
+            payload.put("codStore", codStore);
+            payload.put("gcsBucket", gcsBucket);
+            payload.put("gcsPath", gcsPath);
+            payload.put("fileName", fileName);
+            payload.put("targetDir", targetDir);
+            payload.put("createdAt", Instant.now().toString());
+
+            String message = objectMapper.writeValueAsString(payload);
+
+            messagePublisher.publishAsync(synchroTopic, message)
+                    .whenComplete((msgId, ex) -> {
+                        if (ex != null) {
+                            log.atError()
+                                    .setMessage("Error publicando evento a synchro-controller")
+                                    .addKeyValue("codStore", codStore)
+                                    .addKeyValue("fileName", fileName)
+                                    .addKeyValue("topic", synchroTopic)
+                                    .setCause(ex)
+                                    .log();
+                        } else {
+                            log.atInfo()
+                                    .setMessage("Evento publicado a synchro-controller")
+                                    .addKeyValue("codStore", codStore)
+                                    .addKeyValue("fileName", fileName)
+                                    .addKeyValue("messageId", msgId)
+                                    .log();
+                        }
+                    });
+        } catch (Exception e) {
+            throw new IllegalStateException(
+                    "Error publicando evento synchro-controller para archivo: " + fileName, e);
+        }
+    }
+}


--- Diff for /src/main/java/com/elrosado/cersuitecloudlocalcore/infrastructure/adapter/out/storage/GcsStorageHelper.java ---
--- a//src/main/java/com/elrosado/cersuitecloudlocalcore/infrastructure/adapter/out/storage/GcsStorageHelper.java
+++ b//src/main/java/com/elrosado/cersuitecloudlocalcore/infrastructure/adapter/out/storage/GcsStorageHelper.java
@@ -0,0 +1,84 @@
+package com.elrosado.cersuitecloudlocalcore.infrastructure.adapter.out.storage;
+
+import com.elrosado.cersuitecloudlocalcore.domain.model.GcsObjectReference;
+import com.google.cloud.storage.Blob;
+import com.google.cloud.storage.BlobId;
+import com.google.cloud.storage.BlobInfo;
+import com.google.cloud.storage.Storage;
+import org.slf4j.Logger;
+import org.slf4j.LoggerFactory;
+import org.springframework.stereotype.Component;
+
+import java.io.BufferedReader;
+import java.io.InputStreamReader;
+import java.nio.channels.Channels;
+import java.nio.charset.StandardCharsets;
+import java.util.stream.Stream;
+import java.util.stream.StreamSupport;
+
+/**
+ * Utilitario stateless para operaciones GCS compartidas entre adaptadores de almacenamiento.
+ * No contiene lÃ³gica de negocio ni dependencias del dominio.
+ */
+@Component
+public class GcsStorageHelper {
+
+    private static final Logger log = LoggerFactory.getLogger(GcsStorageHelper.class);
+
+    private final Storage storage;
+
+    public GcsStorageHelper(Storage storage) {
+        this.storage = storage;
+    }
+
+    public BufferedReader openReader(GcsObjectReference location) {
+        Blob blob = storage.get(BlobId.of(location.bucket(), location.objectName()));
+        if (blob == null) {
+            throw new IllegalArgumentException("Objeto GCS no encontrado: " + location.toUri());
+        }
+        return new BufferedReader(
+                new InputStreamReader(Channels.newInputStream(blob.reader()), StandardCharsets.UTF_8));
+    }
+
+    public GcsObjectReference moveBlob(GcsObjectReference source, GcsObjectReference targetFolder) {
+        GcsObjectReference target = targetFolder.resolve(source.fileName());
+        BlobId sourceId = BlobId.of(source.bucket(), source.objectName());
+        BlobId targetId = BlobId.of(target.bucket(), target.objectName());
+
+        storage.delete(targetId);
+        storage.copy(Storage.CopyRequest.newBuilder()
+                .setSource(sourceId)
+                .setTarget(BlobInfo.newBuilder(targetId).build())
+                .build()).getResult();
+
+        boolean deleted = storage.delete(sourceId);
+        if (!deleted) {
+            log.atWarn()
+                    .setMessage("Objeto fuente no eliminado luego del movimiento GCS")
+                    .addKeyValue("sourceObject", source.toUri())
+                    .log();
+        }
+        return target;
+    }
+
+    public GcsObjectReference upload(GcsObjectReference target, byte[] content, String contentType) {
+        BlobInfo blobInfo = BlobInfo.newBuilder(BlobId.of(target.bucket(), target.objectName()))
+                .setContentType(contentType)
+                .build();
+        storage.create(blobInfo, content);
+        log.atInfo()
+                .setMessage("Archivo subido a GCS")
+                .addKeyValue("uri", target.toUri())
+                .log();
+        return target;
+    }
+
+    public Stream<Blob> streamBlobs(GcsObjectReference folder) {
+        String prefix = folder.prefixWithSlash();
+        return StreamSupport.stream(
+                        storage.list(folder.bucket(), Storage.BlobListOption.prefix(prefix))
+                                .iterateAll()
+                                .spliterator(), false)
+                .filter(blob -> !blob.isDirectory());
+    }
+}


