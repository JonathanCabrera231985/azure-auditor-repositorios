+    @Column(name = "PORC_REC", nullable = false)
+    private Integer porcentajeRecargo = 0;
+
+    @Column(name = "PORC_DESEMP", nullable = false)
+    private Integer porcentajeDscEmp = 0;
+
+    @Column(name = "PORC_BOSOL", nullable = false)
+    private Integer porcentajeBonSol = 0;
+
+    @Column(name = "QTY_MRHRC_GP", nullable = false)
+    private Integer qtyFlias = 0;
+
+    protected PosDepartmentEntity() {}
+
+    public static PosDepartmentEntity fromDomain(PosDepartment d) {
+        PosDepartmentEntity e = new PosDepartmentEntity();
+        e.id = d.id();
+        e.name = d.name();
+        e.codDptoCer = d.codDptoCer();
+        e.codNegocio = (d.codNegocio() == null || d.codNegocio().isBlank())
+                ? 0 : Integer.parseInt(d.codNegocio().trim());
+        e.porcentajeRecargo = d.porcentajeRecargo();
+        e.porcentajeDscEmp = d.porcentajeDscEmp();
+        e.porcentajeBonSol = d.porcentajeBonSol();
+        e.qtyFlias = d.qtyFlias();
+        return e;
+    }
+
+    public PosDepartment toDomain() {
+        return new PosDepartment(
+                id,
+                codDptoCer,
+                name,
+                codNegocio == null ? "0" : String.valueOf(codNegocio),
+                porcentajeRecargo == null ? 0 : porcentajeRecargo,
+                porcentajeDscEmp == null ? 0 : porcentajeDscEmp,
+                porcentajeBonSol == null ? 0 : porcentajeBonSol,
+                qtyFlias == null ? 0 : qtyFlias);
+    }
+
+    public Integer getId() { return id; }
+    public String getCodDptoCer() { return codDptoCer; }
+    public Integer getQtyFlias() { return qtyFlias; }
+}


