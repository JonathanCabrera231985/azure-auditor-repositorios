+++ b//src/main/java/com/elrosado/cersuitecloudlocalcore/infrastructure/adapter/in/scheduler/UpdateSecSubSecSchedulerAdapter.java
@@ -0,0 +1,31 @@
+package com.elrosado.cersuitecloudlocalcore.infrastructure.adapter.in.scheduler;
+
+import com.elrosado.cersuitecloudlocalcore.domain.port.in.UpdateSecSubSecUseCase;
+import org.slf4j.Logger;
+import org.slf4j.LoggerFactory;
+import org.springframework.scheduling.annotation.Scheduled;
+import org.springframework.stereotype.Component;
+
+@Component
+public class UpdateSecSubSecSchedulerAdapter {
+
+    private static final Logger log = LoggerFactory.getLogger(UpdateSecSubSecSchedulerAdapter.class);
+
+    private final UpdateSecSubSecUseCase useCase;
+
+    public UpdateSecSubSecSchedulerAdapter(UpdateSecSubSecUseCase useCase) {
+        this.useCase = useCase;
+    }
+
+    @Scheduled(fixedDelayString = "${updateSecSubSec.timesleep:30000}")
+    public void poll() {
+        try {
+            useCase.processPendingFiles();
+        } catch (Exception e) {
+            log.atError()
+                    .setMessage("Error no controlado en scheduler UpdateSecSubSec")
+                    .setCause(e)
+                    .log();
+        }
+    }
+}


