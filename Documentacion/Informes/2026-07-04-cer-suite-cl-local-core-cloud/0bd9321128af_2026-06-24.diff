+        when(blob.reader()).thenReturn(mock(com.google.cloud.ReadChannel.class));
+
+        // No lanza excepciÃ³n â el lector se crea
+        assertThat(helper.openReader(SOURCE)).isNotNull();
+    }
+
+    @Test
+    void openReader_blobNoExiste_lanzaIllegalArgument() {
+        when(storage.get(BlobId.of("bucket", "prefix/file.txt"))).thenReturn(null);
+
+        assertThatThrownBy(() -> helper.openReader(SOURCE))
+                .isInstanceOf(IllegalArgumentException.class)
+                .hasMessageContaining("gs://bucket/prefix/file.txt");
+    }
+
+    // --- moveBlob ---
+
+    @Test
+    void moveBlob_copiaYEliminaFuente() {
+        when(storage.copy(any(CopyRequest.class))).thenReturn(copyWriter);
+        // delete se llama 2 veces: primero el target (bkp/file.txt), luego el source (prefix/file.txt)
+        when(storage.delete(any(BlobId.class))).thenReturn(true);
+
+        GcsObjectReference result = helper.moveBlob(SOURCE, FOLDER);
+
+        assertThat(result.objectName()).isEqualTo("bkp/file.txt");
+        verify(storage).copy(any(CopyRequest.class));
+        verify(storage, times(2)).delete(any(BlobId.class));
+    }
+
+    @Test
+    void moveBlob_eliminarFuenteFalla_noLanzaExcepcion() {
+        when(storage.copy(any(CopyRequest.class))).thenReturn(copyWriter);
+        // Primera llamada (target) devuelve true; segunda (source) devuelve false
+        when(storage.delete(any(BlobId.class))).thenReturn(true, false);
+
+        // No lanza excepciÃ³n â solo hace WARN en log
