+        return new SecSubSecFile(new GcsObjectReference("bucket", "EYES/ARSAP/IN/" + name),
+                name, SecSubSecFileType.SUBSEC, sortKey);
+    }
+
+    private BufferedReader reader(String content) {
+        return new BufferedReader(new StringReader(content));
+    }
+
+    /**
+     * Construye una lÃ­nea SEC de exactamente 72 caracteres.
+     * Formato: code(4)+name(50)+negocio(4)+porcRec(4)+flagDsc(1)+flagBon(1)+porcDscRaw(4)+porcBonRaw(4)
+     */
+    private String buildSecLine(String code, String name, String negocio,
+                                int porcRec, String flagDsc, String flagBon,
+                                String porcDscRaw, String porcBonRaw) {
+        return padRight(code, 4)
+                + padRight(name, 50)
+                + padRight(negocio, 4)
+                + leftPad(String.valueOf(porcRec), 4)
+                + flagDsc
+                + flagBon
+                + porcDscRaw
+                + porcBonRaw;
+    }
+
+    /**
+     * Construye una lÃ­nea SUBSEC de exactamente 61 caracteres.
+     * Formato: codDpto(4)+codMhg(3)+name(50)+porcRec(4)
+     */
+    private String buildSubsecLine(String codDpto, String codMhg, String name, int porcRec) {
+        return padRight(codDpto, 4)
+                + padRight(codMhg, 3)
+                + padRight(name, 50)
+                + leftPad(String.valueOf(porcRec), 4);
+    }
+
+    private String padRight(String s, int len) {
+        String result = s;
+        while (result.length() < len) result = result + " ";
+        return result.substring(0, len);
+    }
+
+    private String leftPad(String s, int len) {
+        String result = s;
+        while (result.length() < len) result = "0" + result;
+        return result;
+    }
