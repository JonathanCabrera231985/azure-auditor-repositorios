@@ -0,0 +1,360 @@
+package com.elrosado.cersuitecloudlocalcore.service;
+
+import com.elrosado.cersuitecloudlocalcore.domain.model.ActiveStoreInfo;
+import com.elrosado.cersuitecloudlocalcore.domain.model.GcsObjectReference;
+import com.elrosado.cersuitecloudlocalcore.domain.model.MerchandiseHierarchyGroup;
+import com.elrosado.cersuitecloudlocalcore.domain.model.PosDepartment;
+import com.elrosado.cersuitecloudlocalcore.domain.model.SecSubSecFile;
+import com.elrosado.cersuitecloudlocalcore.domain.model.SecSubSecFile.SecSubSecFileType;
+import com.elrosado.cersuitecloudlocalcore.domain.port.in.UpdateSecSubSecUseCase;
+import com.elrosado.cersuitecloudlocalcore.domain.port.out.ActiveStoreQueryPort;
+import com.elrosado.cersuitecloudlocalcore.domain.port.out.PosDepartmentPersistencePort;
+import com.elrosado.cersuitecloudlocalcore.domain.port.out.SynchroControllerPublisherPort;
+import com.elrosado.cersuitecloudlocalcore.domain.port.out.UpdateSecSubSecStoragePort;
+import com.elrosado.cersuitecloudlocalcore.infrastructure.config.LegacyUpdateSecSubSecProperties;
+import com.elrosado.cersuitecloudlocalcore.infrastructure.config.UpdateSecSubSecProperties;
+import org.slf4j.Logger;
+import org.slf4j.LoggerFactory;
+import org.springframework.stereotype.Service;
+
+import java.io.BufferedReader;
+import java.io.IOException;
+import java.nio.charset.StandardCharsets;
+import java.util.List;
+
+@Service
+public class UpdateSecSubSecService implements UpdateSecSubSecUseCase {
+
+    private static final Logger log = LoggerFactory.getLogger(UpdateSecSubSecService.class);
+    private static final int MAX_ATTEMPTS = 3;
+    private static final String PROCESS_CODE = "UPD_SECSUBSEC_P";
+
+    private final UpdateSecSubSecStoragePort storagePort;
+    private final PosDepartmentPersistencePort persistencePort;
+    private final ActiveStoreQueryPort storeQueryPort;
+    private final SynchroControllerPublisherPort synchroPublisher;
+    private final UpdateSecSubSecProperties properties;
+    private final LegacyUpdateSecSubSecProperties legacyProperties;
+
+    public UpdateSecSubSecService(
+            UpdateSecSubSecStoragePort storagePort,
+            PosDepartmentPersistencePort persistencePort,
+            ActiveStoreQueryPort storeQueryPort,
+            SynchroControllerPublisherPort synchroPublisher,
+            UpdateSecSubSecProperties properties,
+            LegacyUpdateSecSubSecProperties legacyProperties) {
+        this.storagePort = storagePort;
+        this.persistencePort = persistencePort;
+        this.storeQueryPort = storeQueryPort;
+        this.synchroPublisher = synchroPublisher;
+        this.properties = properties;
+        this.legacyProperties = legacyProperties;
+    }
+
+    @Override
+    public void processPendingFiles() {
+        if (!properties.enabled()) {
+            log.atDebug().setMessage("UpdateSecSubSec deshabilitado por configuracion").log();
+            return;
+        }
+
+        List<SecSubSecFile> pendingFiles;
+        try {
+            pendingFiles = storagePort.listPendingFiles();
+        } catch (RuntimeException e) {
+            log.atError()
+                    .setMessage("Error listando archivos UpdateSecSubSec en GCS")
+                    .addKeyValue("process", PROCESS_CODE)
+                    .setCause(e)
+                    .log();
+            return;
+        }
+
+        if (pendingFiles.isEmpty()) {
+            log.atDebug()
+                    .setMessage("Sin archivos UpdateSecSubSec pendientes en GCS")
+                    .addKeyValue("process", PROCESS_CODE)
+                    .log();
+            return;
+        }
+
+        log.atInfo()
+                .setMessage("Archivos UpdateSecSubSec pendientes detectados")
+                .addKeyValue("process", PROCESS_CODE)
+                .addKeyValue("count", pendingFiles.size())
+                .log();
+
+        boolean anyProcessed = false;
+        for (SecSubSecFile file : pendingFiles) {
+            boolean ok = processWithRetry(file);
+            if (ok) {
+                anyProcessed = true;
+            }
+        }
+
+        if (anyProcessed) {
+            log.atInfo()
+                    .setMessage("Iniciando generacion de archivos para controlador")
+                    .addKeyValue("process", PROCESS_CODE)
+                    .log();
+            boolean created = createAndPublishControllerFiles();
+            if (created) {
+                log.atInfo()
+                        .setMessage("Archivos de controlador creados y eventos Pub/Sub publicados")
+                        .addKeyValue("process", PROCESS_CODE)
+                        .log();
+            } else {
+                log.atWarn()
+                        .setMessage("No se pudieron generar archivos de controlador (sin departamentos)")
+                        .addKeyValue("process", PROCESS_CODE)
+                        .log();
+            }
+        }
+    }
+
+    private boolean processWithRetry(SecSubSecFile file) {
+        for (int attempt = 1; attempt <= MAX_ATTEMPTS; attempt++) {
+            try {
+                log.atInfo()
+                        .setMessage("Procesando archivo SecSubSec")
+                        .addKeyValue("process", PROCESS_CODE)
+                        .addKeyValue("fileName", file.fileName())
+                        .addKeyValue("type", file.type())
+                        .addKeyValue("attempt", attempt)
+                        .log();
+
+                if (file.type() == SecSubSecFileType.SEC) {
+                    processSecFile(file);
+                } else {
+                    processSubSecFile(file);
+                }
+
+                storagePort.moveToBackup(file);
+
+                log.atInfo()
+                        .setMessage("Archivo SecSubSec procesado y movido a backup")
+                        .addKeyValue("process", PROCESS_CODE)
+                        .addKeyValue("fileName", file.fileName())
+                        .log();
+                return true;
+            } catch (Exception e) {
+                log.atError()
+                        .setMessage("Error procesando archivo SecSubSec")
+                        .addKeyValue("process", PROCESS_CODE)
+                        .addKeyValue("fileName", file.fileName())
+                        .addKeyValue("attempt", attempt)
+                        .setCause(e)
+                        .log();
+            }
+        }
+        log.atError()
+                .setMessage("Archivo SecSubSec descartado por maximo de reintentos alcanzado")
+                .addKeyValue("process", PROCESS_CODE)
+                .addKeyValue("fileName", file.fileName())
+                .addKeyValue("maxAttempts", MAX_ATTEMPTS)
+                .log();
+        return false;
+    }
+
+    // Procesa archivo SEC (secciones/departamentos). Cada lÃ­nea es de 72 caracteres.
+    private void processSecFile(SecSubSecFile file) throws IOException {
+        try (BufferedReader reader = storagePort.openReader(file)) {
+            String line;
+            while ((line = reader.readLine()) != null) {
+                if (line.trim().length() != 72) continue;
+
+                String codDptoCer     = line.substring(0, 4);
+                String name           = line.substring(4, 54);
+                String codNegocio     = line.substring(54, 58);
+                int    porcRecargo    = Integer.parseInt(line.substring(58, 62).trim());
+                String flagDscEmp     = line.substring(62, 63);
+                String flagBonSol     = line.substring(63, 64);
+                String rawPorcDscEmp  = line.substring(64, 68);
+                String rawPorcBonSol  = line.substring(68, 72);
+
+                int porcDscEmp = resolvePercent(flagDscEmp, rawPorcDscEmp, legacyProperties.pctEmpDefault());
+                int porcBonSol = resolvePercent(flagBonSol, rawPorcBonSol, legacyProperties.pctSolDefault());
+
+                PosDepartment existing = persistencePort.findByCodDptoCer(codDptoCer)
+                        .orElse(new PosDepartment(null, codDptoCer, "", "", 0, 0, 0, 0));
+
+                PosDepartment updated = new PosDepartment(
+                        existing.id(),
+                        codDptoCer,
+                        name,
+                        codNegocio,
+                        porcRecargo,
+                        porcDscEmp,
+                        porcBonSol,
+                        existing.qtyFlias());
+
+                persistencePort.save(updated);
+            }
+        }
+    }
+
+    // Procesa archivo SUBSEC (subsecciones/familias). Cada lÃ­nea es de 61 caracteres.
+    private void processSubSecFile(SecSubSecFile file) throws IOException {
+        try (BufferedReader reader = storagePort.openReader(file)) {
+            String line;
+            while ((line = reader.readLine()) != null) {
+                if (line.trim().length() != 61) continue;
+
+                String codDptoCer  = line.substring(0, 4);
+                String codMrhCer   = line.substring(4, 7);
+                String name        = line.substring(7, 57);
+                int    porcRecargo = Integer.parseInt(line.substring(57, 61).trim());
+
+                PosDepartment dept = persistencePort.findByCodDptoCer(codDptoCer).orElse(null);
+                if (dept == null) {
+                    log.atWarn()
+                            .setMessage("Departamento no encontrado para subseccion; linea ignorada")
+                            .addKeyValue("process", PROCESS_CODE)
+                            .addKeyValue("codDptoCer", codDptoCer)
+                            .addKeyValue("codMrhCer", codMrhCer)
+                            .log();
+                    continue;
+                }
+
+                MerchandiseHierarchyGroup existing = persistencePort
+                        .findMhgByCodAndDept(codMrhCer, dept.id())
+                        .orElse(new MerchandiseHierarchyGroup(null, null, codMrhCer, "", "", dept.id(), 0));
+
+                Integer code = existing.code();
+                if (code == null) {
+                    int nextCode = dept.qtyFlias() + 1;
+                    code = nextCode;
+                    PosDepartment updatedDept = dept.withQtyFlias(nextCode);
+                    persistencePort.save(updatedDept);
+                }
+
+                MerchandiseHierarchyGroup updated = new MerchandiseHierarchyGroup(
+                        existing.id(),
+                        code,
+                        codMrhCer,
+                        name,
+                        name,
+                        dept.id(),
+                        porcRecargo);
+
+                persistencePort.saveMhg(updated);
+            }
+        }
+    }
+
+    private boolean createAndPublishControllerFiles() {
+        List<PosDepartment> deptos = persistencePort.findAllOrderById();
+        if (deptos == null || deptos.isEmpty()) {
+            return false;
+        }
+
+        String controllerName = legacyProperties.controllerName();
+        String guiName        = legacyProperties.guiName();
+        String targetDir      = legacyProperties.targetDir();
+        String cmdLine        = legacyProperties.cmdLine();
+
+        // Genera contenido {controllerName}.DAT con datos de secciones
+        StringBuilder controllerDat = new StringBuilder();
+        StringBuilder guiDat        = new StringBuilder();
+
+        for (int i = 0; i < deptos.size(); i++) {
+            PosDepartment dept = deptos.get(i);
+            String codDepto    = leftPad(String.valueOf(dept.id()), 4);
+            String porcRecFinal = leftPad(String.valueOf(dept.porcentajeRecargo() / 100), 2);
+            String flDscEmp    = dept.porcentajeDscEmp() > 0 ? "1" : "0";
+            String flBonSol    = dept.porcentajeBonSol() > 0 ? "1" : "0";
+
+            // SecciÃ³n base (cÃ³digo familia 0000)
+            controllerDat.append(codDepto).append("0000").append(porcRecFinal)
+                    .append(flDscEmp).append(flBonSol).append("\n");
+
+            // GUI: codDptoCer-nombre separados por |
+            guiDat.append(dept.codDptoCer()).append("-").append(dept.name().trim());
+            if (i < deptos.size() - 1) {
+                guiDat.append("|");
+            }
+        }
+
+        // Agrega datos de familias (MerchandiseHierarchyGroup) al controllerDat
+        List<Object[]> mhgData = persistencePort.findAllMhgWithDeptData();
+        if (mhgData != null) {
+            for (Object[] row : mhgData) {
+                String codDepto = leftPad(row[0].toString(), 4);
+                String codFlia  = leftPad(row[1].toString(), 4);
+                String porcRec  = row[2].toString();
+                // Toma primeros 2 dÃ­gitos del porcentaje de recargo de familia
+                String porcRecFinal = porcRec.length() >= 2
+                        ? porcRec.substring(0, 2)
+                        : leftPad(porcRec, 2);
+                int porcDesEmp = Integer.parseInt(row[3].toString());
+                int porcBonSol = Integer.parseInt(row[4].toString());
+                String flDscEmp = porcDesEmp > 0 ? "1" : "0";
+                String flBonSol = porcBonSol > 0 ? "1" : "0";
+
+                controllerDat.append(codDepto).append(codFlia).append(porcRecFinal)
+                        .append(flDscEmp).append(flBonSol).append("\n");
+            }
+        }
+
+        // Genera contenido de archivos .CMD (instrucciones para el controlador)
+        String controllerCmd = cmdLine + "\n" + cmdLine + "\n";
+        String guiCmd        = targetDir + "\n";
+
+        // Sube los 4 archivos a GCS
+        GcsObjectReference controllerDatRef = storagePort.uploadControllerFile(
+                controllerName + ".DAT", controllerDat.toString().getBytes(StandardCharsets.UTF_8));
+        GcsObjectReference controllerCmdRef = storagePort.uploadControllerFile(
+                controllerName + ".CMD", controllerCmd.getBytes(StandardCharsets.UTF_8));
+        GcsObjectReference guiDatRef = storagePort.uploadControllerFile(
+                guiName + ".DAT", guiDat.toString().getBytes(StandardCharsets.UTF_8));
+        GcsObjectReference guiCmdRef = storagePort.uploadControllerFile(
+                guiName + ".CMD", guiCmd.getBytes(StandardCharsets.UTF_8));
+
+        // Publica evento Pub/Sub por cada tienda activa con servidor local
+        List<ActiveStoreInfo> stores = storeQueryPort.findActiveStoresWithLocalServer();
+        String bucket = controllerDatRef.bucket();
+
+        for (ActiveStoreInfo store : stores) {
+            synchroPublisher.publishFileReady(
+                    store.desClave(), bucket, controllerDatRef.objectName(), controllerName + ".DAT", targetDir);
+            synchroPublisher.publishFileReady(
+                    store.desClave(), bucket, controllerCmdRef.objectName(), controllerName + ".CMD", targetDir);
+            synchroPublisher.publishFileReady(
+                    store.desClave(), bucket, guiDatRef.objectName(), guiName + ".DAT", targetDir);
+            synchroPublisher.publishFileReady(
+                    store.desClave(), bucket, guiCmdRef.objectName(), guiName + ".CMD", targetDir);
+        }
+
+        log.atInfo()
+                .setMessage("Eventos Pub/Sub publicados al topic synchro-controller")
+                .addKeyValue("process", PROCESS_CODE)
+                .addKeyValue("stores", stores.size())
+                .addKeyValue("filesPerStore", 4)
+                .log();
+
+        return true;
+    }
+
+    private int resolvePercent(String flag, String rawValue, String defaultValue) {
+        if ("1".equals(flag)) {
+            return "0000".equals(rawValue) ? parseIntSafe(defaultValue) : parseIntSafe(rawValue);
+        }
+        return 0;
+    }
+
+    private int parseIntSafe(String val) {
+        try {
+            return Integer.parseInt(val == null ? "0" : val.trim());
+        } catch (NumberFormatException e) {
+            return 0;
+        }
+    }
+
+    private String leftPad(String value, int length) {
+        String result = value;
+        while (result.length() < length) {
+            result = "0" + result;
+        }
+        return result;
+    }
+}


