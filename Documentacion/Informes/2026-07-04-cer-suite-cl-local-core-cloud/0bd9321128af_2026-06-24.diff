@@ -0,0 +1,21 @@
+package com.elrosado.cersuitecloudlocalcore.domain.model;
+
+public record SecSubSecFile(
+        GcsObjectReference location,
+        String fileName,
+        SecSubSecFileType type,
+        long sortKey
+) {
+
+    public enum SecSubSecFileType {
+        SEC, SUBSEC;
+
+        public static SecSubSecFileType fromFileName(String name) {
+            if (name == null) return null;
+            String upper = name.toUpperCase();
+            if (upper.startsWith("SUBSEC") && name.length() == 21) return SUBSEC;
+            if (upper.startsWith("SEC") && name.length() == 18) return SEC;
+            return null;
+        }
+    }
+}


