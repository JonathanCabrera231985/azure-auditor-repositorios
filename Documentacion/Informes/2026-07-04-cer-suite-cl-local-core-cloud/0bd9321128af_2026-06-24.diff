--- Diff for /src/main/java/com/elrosado/cersuitecloudlocalcore/infrastructure/adapter/out/storage/GcsUpdateSecSubSecStorageAdapter.java ---
--- a//src/main/java/com/elrosado/cersuitecloudlocalcore/infrastructure/adapter/out/storage/GcsUpdateSecSubSecStorageAdapter.java
+++ b//src/main/java/com/elrosado/cersuitecloudlocalcore/infrastructure/adapter/out/storage/GcsUpdateSecSubSecStorageAdapter.java
@@ -0,0 +1,91 @@
+package com.elrosado.cersuitecloudlocalcore.infrastructure.adapter.out.storage;
+
+import com.elrosado.cersuitecloudlocalcore.domain.model.GcsObjectReference;
+import com.elrosado.cersuitecloudlocalcore.domain.model.SecSubSecFile;
+import com.elrosado.cersuitecloudlocalcore.domain.model.SecSubSecFile.SecSubSecFileType;
+import com.elrosado.cersuitecloudlocalcore.domain.port.out.UpdateSecSubSecStoragePort;
+import com.elrosado.cersuitecloudlocalcore.infrastructure.config.LegacyUpdateSecSubSecProperties;
+import com.google.cloud.storage.Blob;
+import org.springframework.stereotype.Component;
+
+import java.io.BufferedReader;
+import java.util.Comparator;
+import java.util.List;
+import java.util.Optional;
+
+@Component
+public class GcsUpdateSecSubSecStorageAdapter implements UpdateSecSubSecStoragePort {
+
+    private final GcsStorageHelper gcsHelper;
+    private final LegacyUpdateSecSubSecProperties legacyProperties;
+
+    public GcsUpdateSecSubSecStorageAdapter(
+            GcsStorageHelper gcsHelper,
+            LegacyUpdateSecSubSecProperties legacyProperties) {
+        this.gcsHelper = gcsHelper;
+        this.legacyProperties = legacyProperties;
+    }
+
+    @Override
+    public List<SecSubSecFile> listPendingFiles() {
+        GcsObjectReference input = GcsObjectReference.fromUri(legacyProperties.inputUri());
+        String prefix = input.prefixWithSlash();
+
+        return gcsHelper.streamBlobs(input)
+                .flatMap(blob -> toPendingFile(input, prefix, blob).stream())
+                // SEC (ordinal 0) antes que SUBSEC (ordinal 1); dentro del mismo tipo, por sortKey
+                .sorted(Comparator
+                        .comparingInt((SecSubSecFile f) -> f.type().ordinal())
+                        .thenComparingLong(SecSubSecFile::sortKey))
+                .toList();
+    }
+
+    @Override
+    public BufferedReader openReader(SecSubSecFile file) {
+        return gcsHelper.openReader(file.location());
+    }
+
+    @Override
+    public GcsObjectReference moveToBackup(SecSubSecFile file) {
+        return gcsHelper.moveBlob(file.location(), GcsObjectReference.fromUri(legacyProperties.backupUri()));
+    }
+
+    @Override
+    public GcsObjectReference uploadControllerFile(String fileName, byte[] content) {
+        GcsObjectReference target = GcsObjectReference.fromUri(legacyProperties.inputUri()).resolve(fileName);
+        return gcsHelper.upload(target, content, "application/octet-stream");
+    }
+
+    private Optional<SecSubSecFile> toPendingFile(GcsObjectReference input, String prefix, Blob blob) {
+        String objectName = blob.getName();
+        if (!objectName.startsWith(prefix)) {
+            return Optional.empty();
+        }
+
+        String relativeName = objectName.substring(prefix.length());
+        if (relativeName.isBlank() || relativeName.contains("/")) {
+            return Optional.empty();
+        }
+
+        SecSubSecFileType type = SecSubSecFileType.fromFileName(relativeName);
+        if (type == null) {
+            return Optional.empty();
+        }
+
+        long sortKey = parseSortKey(relativeName);
+        return Optional.of(new SecSubSecFile(
+                new GcsObjectReference(input.bucket(), objectName),
+                relativeName,
+                type,
+                sortKey));
+    }
+
+    // Usa los Ãºltimos 14 caracteres del nombre de archivo como clave de ordenaciÃ³n (timestamp)
+    private long parseSortKey(String fileName) {
+        try {
+            return Long.parseLong(fileName.substring(fileName.length() - 14));
+        } catch (Exception e) {
+            return Long.MAX_VALUE;
+        }
+    }
+}


