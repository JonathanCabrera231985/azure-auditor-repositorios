@@ -0,0 +1,49 @@
+package com.elrosado.cersuitecloudlocalcore.infrastructure.config;
+
+import org.springframework.boot.context.properties.ConfigurationProperties;
+
+@ConfigurationProperties(prefix = "update-sec-sub-sec")
+public record LegacyUpdateSecSubSecProperties(
+        LegacyRoute in,
+        LegacyRoute bkp,
+        long timesleep,
+        String controllerName,
+        String targetDir,
+        String cmdLine,
+        String pctEmpDefault,
+        String pctSolDefault,
+        String guiName
+) {
+
+    public LegacyUpdateSecSubSecProperties {
+        if (in == null) in = new LegacyRoute(new LegacyFolder(""));
+        if (bkp == null) bkp = new LegacyRoute(new LegacyFolder(""));
+        if (timesleep <= 0) timesleep = 30_000L;
+        if (controllerName == null) controllerName = "";
+        if (targetDir == null) targetDir = "";
+        if (cmdLine == null) cmdLine = "";
+        if (pctEmpDefault == null) pctEmpDefault = "0";
+        if (pctSolDefault == null) pctSolDefault = "0";
+        if (guiName == null) guiName = "";
+    }
+
+    public String inputUri() {
+        return in.folder().path();
+    }
+
+    public String backupUri() {
+        return bkp.folder().path();
+    }
+
+    public record LegacyRoute(LegacyFolder folder) {
+        public LegacyRoute {
+            if (folder == null) folder = new LegacyFolder("");
+        }
+    }
+
+    public record LegacyFolder(String path) {
+        public LegacyFolder {
+            if (path == null) path = "";
+        }
+    }
+}


