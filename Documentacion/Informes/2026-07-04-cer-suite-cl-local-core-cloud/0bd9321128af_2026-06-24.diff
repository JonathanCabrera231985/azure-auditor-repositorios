+package com.elrosado.cersuitecloudlocalcore.infrastructure.adapter.out.db;
+
+import com.elrosado.cersuitecloudlocalcore.domain.model.MerchandiseHierarchyGroup;
+import com.elrosado.cersuitecloudlocalcore.domain.model.PosDepartment;
+import com.elrosado.cersuitecloudlocalcore.domain.port.out.PosDepartmentPersistencePort;
+import com.elrosado.cersuitecloudlocalcore.infrastructure.adapter.out.db.entity.MerchandiseHierarchyGroupEntity;
+import com.elrosado.cersuitecloudlocalcore.infrastructure.adapter.out.db.entity.PosDepartmentEntity;
+import com.elrosado.cersuitecloudlocalcore.infrastructure.adapter.out.db.repository.JpaMerchandiseHierarchyGroupRepository;
+import com.elrosado.cersuitecloudlocalcore.infrastructure.adapter.out.db.repository.JpaPosDepartmentRepository;
+import org.springframework.stereotype.Component;
+import org.springframework.transaction.annotation.Transactional;
+
+import java.util.List;
+import java.util.Optional;
+
+@Component
+public class DbUpdateSecSubSecAdapter implements PosDepartmentPersistencePort {
+
+    private final JpaPosDepartmentRepository deptRepo;
+    private final JpaMerchandiseHierarchyGroupRepository mhgRepo;
+
+    public DbUpdateSecSubSecAdapter(
+            JpaPosDepartmentRepository deptRepo,
+            JpaMerchandiseHierarchyGroupRepository mhgRepo) {
+        this.deptRepo = deptRepo;
+        this.mhgRepo = mhgRepo;
+    }
+
+    @Override
+    public Optional<PosDepartment> findByCodDptoCer(String codDptoCer) {
+        return deptRepo.findByCodDptoCer(codDptoCer).map(PosDepartmentEntity::toDomain);
+    }
+
+    @Override
+    @Transactional(transactionManager = "artsEcTransactionManager")
+    public PosDepartment save(PosDepartment department) {
+        return deptRepo.save(PosDepartmentEntity.fromDomain(department)).toDomain();
+    }
+
+    @Override
+    public Optional<MerchandiseHierarchyGroup> findMhgByCodAndDept(String codMrhCer, Integer deptId) {
+        return mhgRepo.findByCodMrhCerAndPosDepartmentId(codMrhCer, deptId)
+                .map(MerchandiseHierarchyGroupEntity::toDomain);
+    }
+
+    @Override
+    @Transactional(transactionManager = "artsEcTransactionManager")
+    public MerchandiseHierarchyGroup saveMhg(MerchandiseHierarchyGroup mhg) {
+        return mhgRepo.save(MerchandiseHierarchyGroupEntity.fromDomain(mhg)).toDomain();
+    }
+
+    @Override
+    public List<PosDepartment> findAllOrderById() {
+        return deptRepo.findAllOrderById().stream()
+                .map(PosDepartmentEntity::toDomain)
+                .toList();
+    }
+
+    @Override
+    public List<Object[]> findAllMhgWithDeptData() {
+        return mhgRepo.findAllWithDeptData();
+    }
+}


