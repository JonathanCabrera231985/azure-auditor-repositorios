+
+@ConfigurationProperties(prefix = "save-transaction")
+public record LegacySaveTransactionsProperties(
+        LegacyRoute in,
+        LegacyRoute bkp,
+        LegacyRoute xml,
+        LegacyRoute sync,
+        long sleeptime
+) {
+
+    public LegacySaveTransactionsProperties {
+        if (in == null) {
+            in = new LegacyRoute(new LegacyFolder(""));
+        }
+        if (bkp == null) {
+            bkp = new LegacyRoute(new LegacyFolder(""));
+        }
+        if (xml == null) {
+            xml = new LegacyRoute(new LegacyFolder(""));
+        }
+        if (sync == null) {
+            sync = new LegacyRoute(new LegacyFolder(""));
+        }
+        if (sleeptime <= 0) {
+            sleeptime = 30_000L;
+        }
+    }
+
+    public String inputUri() {
+        return in.folder().path();
+    }
+
+    public String backupUri() {
+        return bkp.folder().path();
+    }
+
+    public String xmlUri() {
+        return xml.folder().path();
+    }
+
+    public String syncUri() {
+        return sync.folder().path();
+    }
+
+    public record LegacyRoute(LegacyFolder folder) {
+        public LegacyRoute {
+            if (folder == null) {
+                folder = new LegacyFolder("");
+            }
+        }
+    }
+
+    public record LegacyFolder(String path) {
+        public LegacyFolder {
+            if (path == null) {
+                path = "";
+            }
+        }
+    }
+}


