+package com.elrosado.cersuitecloudlocalcore.infrastructure.adapter.in.scheduler;
+
+import com.elrosado.cersuitecloudlocalcore.domain.port.in.OperatorPasswordUpdateUseCase;
+import org.slf4j.Logger;
+import org.slf4j.LoggerFactory;
+import org.springframework.scheduling.annotation.Scheduled;
+import org.springframework.stereotype.Component;
+
+/**
+ * Disparador planificado del proceso OperatorPassWordUpdateProcess.
+ * Intervalo configurable via operatorPasswordUpdate.timesleep (properties.yaml).
+ */
+@Component
+public class OperatorPasswordUpdateSchedulerAdapter {
+
+    private static final Logger log = LoggerFactory.getLogger(OperatorPasswordUpdateSchedulerAdapter.class);
+
+    private final OperatorPasswordUpdateUseCase useCase;
+
+    public OperatorPasswordUpdateSchedulerAdapter(OperatorPasswordUpdateUseCase useCase) {
+        this.useCase = useCase;
+    }
+
+    @Scheduled(fixedDelayString = "${operator-password-update.timesleep:30000}")
+    public void execute() {
+        log.atInfo().setMessage("Iniciando ciclo de distribuciÃ³n de claves de supervisores").log();
+        useCase.processAllPendingUpdates();
+        log.atInfo().setMessage("Ciclo de distribuciÃ³n de claves de supervisores finalizado").log();
+    }
+}


