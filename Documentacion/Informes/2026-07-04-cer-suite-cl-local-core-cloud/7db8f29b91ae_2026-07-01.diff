+package com.elrosado.cersuitecloudlocalcore.service;
+
+import com.elrosado.cersuitecloudlocalcore.domain.model.SaveTransactionDocument;
+import com.elrosado.cersuitecloudlocalcore.domain.model.SaveTransactionItem;
+import com.elrosado.cersuitecloudlocalcore.domain.model.SaveTransactionPromotion;
+import com.elrosado.cersuitecloudlocalcore.domain.model.SaveTransactionTax;
+import com.elrosado.cersuitecloudlocalcore.domain.model.SaveTransactionTender;
+import org.springframework.stereotype.Component;
+
+import java.nio.charset.StandardCharsets;
+import java.time.format.DateTimeFormatter;
+
+@Component
+public class SaveTransactionXmlGenerator {
+
+    private static final DateTimeFormatter DATE_TIME_FORMATTER = DateTimeFormatter.ofPattern("yyyy-MM-dd'T'HH:mm:ss");
+
+    public byte[] generate(SaveTransactionDocument document) {
+        StringBuilder xml = new StringBuilder(2048);
+        xml.append("<?xml version=\"1.0\" encoding=\"UTF-8\"?>");
+        xml.append("<Transaction>");
+        appendHeader(xml, document);
+        appendCustomer(xml, document);
+        appendItems(xml, document);
+        appendTenders(xml, document);
+        appendTaxes(xml, document);
+        appendPromotions(xml, document);
+        appendExtraData(xml, document);
+        xml.append("</Transaction>");
+        return xml.toString().getBytes(StandardCharsets.UTF_8);
+    }
+
+    private void appendHeader(StringBuilder xml, SaveTransactionDocument document) {
+        var header = document.header();
+        xml.append("<Header>");
+        append(xml, "RetailStoreCode", header.storeCode());
+        append(xml, "WorkstationCode", header.workstationCode());
+        append(xml, "SequenceNumber", header.sequenceNumber());
+        append(xml, "OperatorCode", header.operatorCode());
+        append(xml, "BeginDateTime", DATE_TIME_FORMATTER.format(header.beginDateTime()));
+        append(xml, "EndDateTime", DATE_TIME_FORMATTER.format(header.endDateTime()));
+        append(xml, "BusinessDayDate", DATE_TIME_FORMATTER.format(header.businessDay()));
+        append(xml, "GrossPositiveAmount", header.grossPositiveAmount());
+        append(xml, "GrossNegativeAmount", header.grossNegativeAmount());
+        append(xml, "RetailTransactionTypeCode", header.retailTransactionTypeCode());
+        append(xml, "InvoiceNumber", document.invoiceNumber());
+        xml.append("</Header>");
+    }
+
+    private void appendCustomer(StringBuilder xml, SaveTransactionDocument document) {
+        if (document.customerId().isBlank()
+                && document.customerName().isBlank()
+                && document.customerType().isBlank()) {
+            return;
+        }
+        xml.append("<Customer>");
+        append(xml, "CustomerId", document.customerId());
+        append(xml, "CustomerName", document.customerName());
+        append(xml, "CustomerType", document.customerType());
+        xml.append("</Customer>");
+    }
+
+    private void appendItems(StringBuilder xml, SaveTransactionDocument document) {
+        xml.append("<LineItems>");
+        for (SaveTransactionItem item : document.items()) {
+            xml.append("<LineItem>");
+            append(xml, "ItemCode", item.itemCode());
+            append(xml, "RegularSalesUnitPrice", item.regularSalesUnitPrice());
+            append(xml, "ExtendedAmount", item.extendedAmount());
+            append(xml, "EntryMethodCode", item.entryMethodCode());
+            append(xml, "Quantity", item.quantity());
+            append(xml, "Units", item.units());
+            append(xml, "TaxType", item.taxType());
+            append(xml, "AppliedTax", item.appliedTax());
+            append(xml, "OrdinalNumber", item.ordinalNumber());
+            append(xml, "Wholesale", item.wholesale());
+            append(xml, "ItemType", item.itemType());
+            append(xml, "MotoSerial", item.motoSerial());
+            append(xml, "ManagerCode", item.managerCode());
+            xml.append("</LineItem>");
+        }
+        xml.append("</LineItems>");
+    }
+
+    private void appendTenders(StringBuilder xml, SaveTransactionDocument document) {
+        xml.append("<Tenders>");
+        for (SaveTransactionTender tender : document.tenders()) {
+            xml.append("<Tender>");
+            append(xml, "TenderTypeCode", tender.tenderTypeCode());
+            append(xml, "Amount", tender.amount());
+            append(xml, "AccountNumber", tender.accountNumber());
+            append(xml, "Change", tender.change());
+            xml.append("</Tender>");
+        }
+        xml.append("</Tenders>");
+    }
+
+    private void appendTaxes(StringBuilder xml, SaveTransactionDocument document) {
+        xml.append("<Taxes>");
+        for (SaveTransactionTax tax : document.taxes()) {
+            xml.append("<Tax>");
+            append(xml, "ItemTypeCode", tax.itemTypeCode());
+            append(xml, "TaxType", tax.taxType());
+            append(xml, "TaxAmount", tax.taxAmount());
+            append(xml, "TaxableAmount", tax.taxableAmount());
+            xml.append("</Tax>");
+        }
+        xml.append("</Taxes>");
+    }
+
+    private void appendPromotions(StringBuilder xml, SaveTransactionDocument document) {
+        xml.append("<Promotions>");
+        for (SaveTransactionPromotion promotion : document.promotions()) {
+            xml.append("<Promotion>");
+            append(xml, "PromotionCode", promotion.promotionCode());
+            append(xml, "Amount", promotion.amount());
+            append(xml, "OrdinalNumber", promotion.ordinalNumber());
+            append(xml, "PromotionSequenceNumber", promotion.promotionSequenceNumber());
+            xml.append("</Promotion>");
+        }
+        xml.append("</Promotions>");
+    }
+
+    private void appendExtraData(StringBuilder xml, SaveTransactionDocument document) {
+        xml.append("<ExtraData>");
+        append(xml, "WebCoupon", document.webCoupon());
+        append(xml, "WebCouponQuantity", document.webCouponQuantity());
+        append(xml, "SequenceNumberMayoreo", document.sequenceNumberMayoreo());
+        xml.append("</ExtraData>");
+    }
+
+    private void append(StringBuilder xml, String name, Object value) {
+        xml.append('<').append(name).append('>');
+        xml.append(escape(value == null ? "" : String.valueOf(value)));
+        xml.append("</").append(name).append('>');
+    }
+
+    private String escape(String value) {
+        return value
+                .replace("&", "&amp;")
+                .replace("<", "&lt;")
+                .replace(">", "&gt;")
+                .replace("\"", "&quot;")
+                .replace("'", "&apos;");
+    }
+}


--- Diff for /src/main/java/com/elrosado/cersuitecloudlocalcore/service/SaveTransactionsService.java ---
--- a//src/main/java/com/elrosado/cersuitecloudlocalcore/service/SaveTransactionsService.java
+++ b//src/main/java/com/elrosado/cersuitecloudlocalcore/service/SaveTransactionsService.java
@@ -0,0 +1,213 @@
+package com.elrosado.cersuitecloudlocalcore.service;
+
+import com.elrosado.cersuitecloudlocalcore.domain.model.GcsObjectReference;
+import com.elrosado.cersuitecloudlocalcore.domain.model.SaveTransactionDocument;
+import com.elrosado.cersuitecloudlocalcore.domain.model.SaveTransactionFile;
+import com.elrosado.cersuitecloudlocalcore.domain.model.SaveTransactionsProcessingResult;
+import com.elrosado.cersuitecloudlocalcore.domain.port.in.SaveTransactionsUseCase;
+import com.elrosado.cersuitecloudlocalcore.domain.port.out.SaveTransactionsPersistencePort;
+import com.elrosado.cersuitecloudlocalcore.domain.port.out.SaveTransactionsStoragePort;
+import com.elrosado.cersuitecloudlocalcore.infrastructure.config.SaveTransactionsProperties;
+import com.elrosado.cersuitecloudlocalcore.infrastructure.config.StoreRegistry;
+import org.slf4j.Logger;
+import org.slf4j.LoggerFactory;
+import org.springframework.beans.factory.annotation.Qualifier;
+import org.springframework.core.task.AsyncTaskExecutor;
+import org.springframework.stereotype.Service;
+
+import java.io.BufferedReader;
+import java.io.IOException;
+import java.util.ArrayList;
+import java.util.List;
+import java.util.Map;
+import java.util.concurrent.CompletableFuture;
+import java.util.stream.Collectors;
+
+@Service
+public class SaveTransactionsService implements SaveTransactionsUseCase {
+
+    private static final Logger log = LoggerFactory.getLogger(SaveTransactionsService.class);
+
+    private final SaveTransactionsStoragePort storagePort;
+    private final SaveTransactionsPersistencePort persistencePort;
+    private final SaveTransactionParser parser;
+    private final SaveTransactionXmlGenerator xmlGenerator;
+    private final SaveTransactionsProperties properties;
+    private final StoreRegistry storeRegistry;
+    private final AsyncTaskExecutor virtualThreadTaskExecutor;
+
+    public SaveTransactionsService(
+            SaveTransactionsStoragePort storagePort,
+            SaveTransactionsPersistencePort persistencePort,
+            SaveTransactionParser parser,
+            SaveTransactionXmlGenerator xmlGenerator,
+            SaveTransactionsProperties properties,
+            StoreRegistry storeRegistry,
+            @Qualifier("virtualThreadTaskExecutor") AsyncTaskExecutor virtualThreadTaskExecutor) {
+        this.storagePort = storagePort;
+        this.persistencePort = persistencePort;
+        this.parser = parser;
+        this.xmlGenerator = xmlGenerator;
+        this.properties = properties;
+        this.storeRegistry = storeRegistry;
+        this.virtualThreadTaskExecutor = virtualThreadTaskExecutor;
+    }
+
+    @Override
+    public void processPendingFiles() {
+        if (!properties.enabled()) {
+            log.atDebug().setMessage("SaveTransactions deshabilitado").log();
+            return;
+        }
+
+        if (!storeRegistry.isMultiLocalEnabled()) {
+            log.atWarn()
+                    .setMessage("SaveTransactions omitido: no hay tiendas activas cargadas en StoreRegistry")
+                    .log();
+            return;
+        }
+
+        List<SaveTransactionFile> pendingFiles = storagePort.listPendingFiles();
+        if (pendingFiles.isEmpty()) {
+            log.atDebug().setMessage("No hay archivos SaveTransactions pendientes").log();
+            return;
+        }
+
+        for (SaveTransactionFile file : pendingFiles) {
+            processFile(file);
+        }
+    }
+
+    private void processFile(SaveTransactionFile file) {
+        ParsedFile parsedFile = parseFile(file);
+        if (parsedFile.documents().isEmpty()) {
+            GcsObjectReference backupObject = storagePort.moveToBackup(file);
+            log.atWarn()
+                    .setMessage("Archivo SaveTransactions sin transacciones validas movido a backup")
+                    .addKeyValue("fileName", file.fileName())
+                    .addKeyValue("lineErrors", parsedFile.lineErrors())
+                    .addKeyValue("backupObject", backupObject.toUri())
+                    .log();
+            return;
+        }
+
+        Map<Integer, List<SaveTransactionDocument>> documentsByStore = parsedFile.documents().stream()
+                .collect(Collectors.groupingBy(SaveTransactionDocument::storeCode));
+
+        List<CompletableFuture<SaveTransactionsProcessingResult>> futures = documentsByStore.entrySet().stream()
+                .map(entry -> CompletableFuture.supplyAsync(
+                        () -> processStoreDocuments(file, entry.getKey(), entry.getValue()),
+                        virtualThreadTaskExecutor))
+                .toList();
+
+        SaveTransactionsProcessingResult total = futures.stream()
+                .map(CompletableFuture::join)
+                .reduce(new SaveTransactionsProcessingResult(
+                        parsedFile.linesRead(),
+                        0,
+                        0,
+                        0,
+                        0,
+                        0,
+                        parsedFile.lineErrors()), SaveTransactionsProcessingResult::plus);
+
+        GcsObjectReference backupObject = storagePort.moveToBackup(file);
+        log.atInfo()
+                .setMessage("Archivo SaveTransactions procesado")
+                .addKeyValue("fileName", file.fileName())
+                .addKeyValue("transactionsGenerated", total.transactionsGenerated())
+                .addKeyValue("xmlUploaded", total.xmlUploaded())
+                .addKeyValue("syncXmlUploaded", total.syncXmlUploaded())
+                .addKeyValue("pointsInserted", total.pointsInserted())
+                .addKeyValue("consumptionsInserted", total.consumptionsInserted())
+                .addKeyValue("lineErrors", total.lineErrors())
+                .addKeyValue("backupObject", backupObject.toUri())
+                .log();
+    }
+
+    private ParsedFile parseFile(SaveTransactionFile file) {
+        List<SaveTransactionDocument> documents = new ArrayList<>();
+        long linesRead = 0;
+        long lineErrors = 0;
+        int outputIndex = 0;
+
+        try (BufferedReader reader = storagePort.openReader(file)) {
+            String line;
+            while ((line = reader.readLine()) != null) {
+                linesRead++;
+                if (line.isBlank()) {
+                    continue;
+                }
+                try {
+                    documents.add(parser.parseLine(line, ++outputIndex));
+                } catch (RuntimeException e) {
+                    lineErrors++;
+                    log.atWarn()
+                            .setMessage("Linea SaveTransactions omitida")
+                            .addKeyValue("fileName", file.fileName())
+                            .addKeyValue("lineNumber", linesRead)
+                            .setCause(e)
+                            .log();
+                }
+            }
+        } catch (IOException e) {
+            throw new IllegalStateException("Error leyendo archivo SaveTransactions " + file.fileName(), e);
+        }
+
+        return new ParsedFile(linesRead, lineErrors, List.copyOf(documents));
+    }
+
+    private SaveTransactionsProcessingResult processStoreDocuments(
+            SaveTransactionFile file,
+            int storeCode,
+            List<SaveTransactionDocument> documents) {
+        if (storeRegistry.findByDesClave(storeCode).isEmpty()) {
+            log.atWarn()
+                    .setMessage("Transacciones SaveTransactions omitidas: tienda no activa en StoreRegistry")
+                    .addKeyValue("fileName", file.fileName())
+                    .addKeyValue("storeCode", "%03d".formatted(storeCode))
+                    .addKeyValue("transactionCount", documents.size())
+                    .log();
+            return new SaveTransactionsProcessingResult(0, 0, 0, 0, 0, 0, documents.size());
+        }
+
+        long xmlUploaded = 0;
+        long syncXmlUploaded = 0;
+        long pointsInserted = 0;
+        long consumptionsInserted = 0;
+
+        for (SaveTransactionDocument document : documents) {
+            byte[] xmlContent = xmlGenerator.generate(document);
+            String fileName = document.outputFileName();
+            storagePort.uploadXml(fileName, xmlContent);
+            xmlUploaded++;
+
+            if (document.storeCode() > 0) {
+                storagePort.uploadSyncXml(fileName, xmlContent);
+                syncXmlUploaded++;
+            }
+
+            persistencePort.savePoints(document.points());
+            pointsInserted += document.points().size();
+            persistencePort.saveConsumptions(document.consumptions());
+            consumptionsInserted += document.consumptions().size();
+        }
+
+        return new SaveTransactionsProcessingResult(
+                0,
+                documents.size(),
+                xmlUploaded,
+                syncXmlUploaded,
+                pointsInserted,
+                consumptionsInserted,
+                0
+        );
+    }
+
+    private record ParsedFile(
+            long linesRead,
+            long lineErrors,
+            List<SaveTransactionDocument> documents
+    ) {
+    }
+}


