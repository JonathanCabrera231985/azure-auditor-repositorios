+
+/**
+ * Propiedades legacy de OperatorPassWordUpdateProcess provenientes de ArmsServerConf.properties
+ * (k8s/properties.yaml). Solo incluye propiedades TCP al controlador POS (rama port 8000 eliminada).
+ */
+@ConfigurationProperties(prefix = "operator-password-update")
+public record LegacyOperatorPasswordUpdateProperties(
+        int posPort,
+        int posRetries,
+        int posTimeoutConnectionMs,
+        int posTimeoutSleepMs,
+        int posQtyBytesLength
+) {
+
+    public LegacyOperatorPasswordUpdateProperties {
+        if (posPort <= 0) posPort = 2040;
+        if (posRetries <= 0) posRetries = 2;
+        if (posTimeoutConnectionMs <= 0) posTimeoutConnectionMs = 5000;
+        if (posTimeoutSleepMs <= 0) posTimeoutSleepMs = 300;
+        if (posQtyBytesLength <= 0) posQtyBytesLength = 6;
+    }
+}


