--- a//src/main/java/com/elrosado/cersuitecloudlocalcore/infrastructure/adapter/out/storage/GcsSaveTransactionsStorageAdapter.java
+++ b//src/main/java/com/elrosado/cersuitecloudlocalcore/infrastructure/adapter/out/storage/GcsSaveTransactionsStorageAdapter.java
@@ -0,0 +1,82 @@
+package com.elrosado.cersuitecloudlocalcore.infrastructure.adapter.out.storage;
+
+import com.elrosado.cersuitecloudlocalcore.domain.model.GcsObjectReference;
+import com.elrosado.cersuitecloudlocalcore.domain.model.SaveTransactionFile;
+import com.elrosado.cersuitecloudlocalcore.domain.port.out.SaveTransactionsStoragePort;
+import com.elrosado.cersuitecloudlocalcore.infrastructure.config.LegacySaveTransactionsProperties;
+import com.google.cloud.storage.Blob;
+import org.springframework.stereotype.Component;
+
+import java.io.BufferedReader;
+import java.util.Comparator;
+import java.util.List;
+import java.util.Optional;
+
+@Component
+public class GcsSaveTransactionsStorageAdapter implements SaveTransactionsStoragePort {
+
+    private static final String XML_CONTENT_TYPE = "application/xml";
+
+    private final GcsStorageHelper gcsHelper;
+    private final LegacySaveTransactionsProperties legacyProperties;
+
+    public GcsSaveTransactionsStorageAdapter(
+            GcsStorageHelper gcsHelper,
+            LegacySaveTransactionsProperties legacyProperties) {
+        this.gcsHelper = gcsHelper;
+        this.legacyProperties = legacyProperties;
+    }
+
+    @Override
+    public List<SaveTransactionFile> listPendingFiles() {
+        GcsObjectReference input = GcsObjectReference.fromUri(legacyProperties.inputUri());
+        String prefix = input.prefixWithSlash();
+        return gcsHelper.streamBlobs(input)
+                .flatMap(blob -> toSaveTransactionFile(input, prefix, blob).stream())
+                .sorted(Comparator.comparing(SaveTransactionFile::fileName))
+                .toList();
+    }
+
+    @Override
+    public BufferedReader openReader(SaveTransactionFile file) {
+        return gcsHelper.openReader(file.location());
+    }
+
+    @Override
+    public GcsObjectReference uploadXml(String fileName, byte[] content) {
+        GcsObjectReference targetFolder = GcsObjectReference.fromUri(legacyProperties.xmlUri());
+        return gcsHelper.upload(targetFolder.resolve(fileName), content, XML_CONTENT_TYPE);
+    }
+
+    @Override
+    public GcsObjectReference uploadSyncXml(String fileName, byte[] content) {
+        GcsObjectReference targetFolder = GcsObjectReference.fromUri(legacyProperties.syncUri());
+        return gcsHelper.upload(targetFolder.resolve(fileName), content, XML_CONTENT_TYPE);
+    }
+
+    @Override
+    public GcsObjectReference moveToBackup(SaveTransactionFile file) {
+        GcsObjectReference targetFolder = GcsObjectReference.fromUri(legacyProperties.backupUri());
+        return gcsHelper.moveBlob(file.location(), targetFolder);
+    }
+
+    private Optional<SaveTransactionFile> toSaveTransactionFile(
+            GcsObjectReference input,
+            String prefix,
+            Blob blob) {
+        String objectName = blob.getName();
+        if (!objectName.startsWith(prefix)) {
+            return Optional.empty();
+        }
+
+        String relativeName = objectName.substring(prefix.length());
+        if (relativeName.isBlank() || relativeName.contains("/") || !relativeName.startsWith("TRX")) {
+            return Optional.empty();
+        }
+
+        return Optional.of(new SaveTransactionFile(
+                new GcsObjectReference(input.bucket(), objectName),
+                relativeName
+        ));
+    }
+}


