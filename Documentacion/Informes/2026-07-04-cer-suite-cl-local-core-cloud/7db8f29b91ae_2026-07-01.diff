+
+/**
+ * Adaptador de BD OPERAC_EC para supervisores: lectura de pendientes y actualizaciÃ³n de estado.
+ */
+@Component
+public class DbSupervisorPendingAdapter implements SupervisorPendingPort, SupervisorStatusPort {
+
+    private static final int ESTADO_ACTIVO = 4;
+    private static final int ESTADO_FALLO = 2;
+
+    private final JpaSupervisorRepository repository;
+
+    public DbSupervisorPendingAdapter(JpaSupervisorRepository repository) {
+        this.repository = repository;
+    }
+
+    @Override
+    public List<PendingSupervisorUpdate> findAllPending() {
+        return repository.findAllPending().stream()
+                .map(this::toDomain)
+                .toList();
+    }
+
+    @Override
+    public void markAsActive(int supervisorId) {
+        repository.updateEstado(supervisorId, ESTADO_ACTIVO);
+    }
+
+    @Override
+    public void markAsFailed(int supervisorId) {
+        repository.updateEstado(supervisorId, ESTADO_FALLO);
+    }
+
+    private PendingSupervisorUpdate toDomain(SupervisorEntity entity) {
+        var op = entity.getOperator();
+        return new PendingSupervisorUpdate(
+                entity.getIdCodsuper(),
+                op.getCcOperador() != null ? op.getCcOperador() : 0,
+                entity.getClave(),
+                entity.getCode128(),
+                entity.getFechaIni(),
+                entity.getIdreg(),
+                op.getIpTienda(),
+                op.getCodTienda()
+        );
+    }
+}


