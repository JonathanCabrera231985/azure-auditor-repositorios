+import org.slf4j.Logger;
+import org.slf4j.LoggerFactory;
+import org.springframework.scheduling.annotation.Scheduled;
+import org.springframework.stereotype.Component;
+
+@Component
+public class SaveTransactionsSchedulerAdapter {
+
+    private static final Logger log = LoggerFactory.getLogger(SaveTransactionsSchedulerAdapter.class);
+
+    private final SaveTransactionsUseCase saveTransactionsUseCase;
+
+    public SaveTransactionsSchedulerAdapter(SaveTransactionsUseCase saveTransactionsUseCase) {
+        this.saveTransactionsUseCase = saveTransactionsUseCase;
+    }
+
+    @Scheduled(fixedDelayString = "${saveTransaction.sleeptime:30000}")
