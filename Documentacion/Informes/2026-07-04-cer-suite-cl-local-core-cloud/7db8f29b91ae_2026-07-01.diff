+                INVC_NMB, ACNT_NMB, SEQ_TRX, AUT_NMB, AMNT_1, AMNT_2, RSP_CD
+            ) VALUES (
+                :invoiceNumber, :accountNumber, :transactionSequence,
+                :authorizationNumber, :amount1, :amount2, :responseCode
+            )
+            """;
+
+    private final NamedParameterJdbcTemplate jdbcTemplate;
+
+    public DbSaveTransactionsAdapter(@Qualifier("artsEcDataSource") DataSource artsEcDataSource) {
+        this.jdbcTemplate = new NamedParameterJdbcTemplate(artsEcDataSource);
+    }
+
+    @Override
+    @Transactional(transactionManager = "artsEcTransactionManager")
+    public void savePoints(List<SaveTransactionPointsRecord> records) {
+        if (records.isEmpty()) {
+            return;
+        }
+        jdbcTemplate.batchUpdate(INSERT_POINTS, records.stream()
+                .map(this::toPointsParams)
+                .toArray(MapSqlParameterSource[]::new));
+    }
+
+    @Override
+    @Transactional(transactionManager = "artsEcTransactionManager")
+    public void saveConsumptions(List<SaveTransactionConsumptionRecord> records) {
+        if (records.isEmpty()) {
+            return;
+        }
+        jdbcTemplate.batchUpdate(INSERT_CONSUMPTION, records.stream()
+                .map(this::toConsumptionParams)
+                .toArray(MapSqlParameterSource[]::new));
+    }
+
+    private MapSqlParameterSource toPointsParams(SaveTransactionPointsRecord record) {
+        return new MapSqlParameterSource()
+                .addValue("storeCode", record.storeCode())
+                .addValue("workstationCode", record.workstationCode())
+                .addValue("businessDay", record.businessDay())
+                .addValue("transactionNumber", record.transactionNumber())
+                .addValue("itemCode", record.itemCode())
+                .addValue("ordinalNumber", record.ordinalNumber())
+                .addValue("points", record.points())
+                .addValue("promotionCode", record.promotionCode());
+    }
+
+    private MapSqlParameterSource toConsumptionParams(SaveTransactionConsumptionRecord record) {
+        return new MapSqlParameterSource()
+                .addValue("invoiceNumber", record.invoiceNumber())
+                .addValue("accountNumber", record.accountNumber())
+                .addValue("transactionSequence", record.transactionSequence())
+                .addValue("authorizationNumber", record.authorizationNumber())
+                .addValue("amount1", record.amount1())
+                .addValue("amount2", record.amount2())
+                .addValue("responseCode", record.responseCode());
