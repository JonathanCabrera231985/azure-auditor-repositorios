+package com.elrosado.cersuitecloudlocalcore.infrastructure.adapter.out.socket;
+
+import com.elrosado.cersuitecloudlocalcore.domain.model.PendingSupervisorUpdate;
+import com.elrosado.cersuitecloudlocalcore.infrastructure.config.LegacyOperatorPasswordUpdateProperties;
+import org.slf4j.Logger;
+import org.slf4j.LoggerFactory;
+import org.springframework.stereotype.Component;
+
+import java.io.IOException;
+import java.io.InputStream;
+import java.io.OutputStream;
+import java.net.InetSocketAddress;
+import java.net.Socket;
+import java.net.SocketTimeoutException;
+import java.nio.charset.StandardCharsets;
+import java.time.format.DateTimeFormatter;
+
+/**
+ * Cliente TCP para distribuciÃ³n de claves de supervisores al controlador POS.
+ * Protocolo: prefijo decimal de 6 dÃ­gitos con la longitud del payload + frame '|' separado.
+ * Frame tipo 26 (OPER_SUP_UPDATE): S'|'26'|'000'|'{store}'|'0'|'{ts}'|'{cc}'|'{clave}'|'{code128}'|'{fechaIni}'|'{idreg}'
+ */
+@Component
+public class OperatorPasswordSocketClient {
+
+    private static final Logger log = LoggerFactory.getLogger(OperatorPasswordSocketClient.class);
+
+    private static final String FRAME_SEPARATOR = "'|'";
+    private static final String OP_CODE = "26";
+    private static final String RESPONSE_CHANNEL = "000";
+    private static final String PERM_CONN = "0";
+    private static final DateTimeFormatter TS_FORMATTER = DateTimeFormatter.ofPattern("yyyyMMddHHmmss");
+    private static final int KEEPALIVE_CYCLE_THRESHOLD = 5;
+
+    private final LegacyOperatorPasswordUpdateProperties props;
+
+    public OperatorPasswordSocketClient(LegacyOperatorPasswordUpdateProperties props) {
+        this.props = props;
+    }
+
+    /**
+     * EnvÃ­a el frame tipo 26 al controlador POS de la tienda.
+     * Retorna true si el controlador confirma Ã©xito (statusTrama == 0).
+     */
+    public boolean sendSupervisorUpdate(PendingSupervisorUpdate supervisor, String storeCode) {
+        String frame = buildFrame(supervisor, storeCode);
+        String prefixedFrame = addLengthPrefix(frame, props.posQtyBytesLength());
+        byte[] payload = prefixedFrame.getBytes(StandardCharsets.ISO_8859_1);
+
+        for (int attempt = 1; attempt <= props.posRetries(); attempt++) {
+            try {
+                boolean success = trySend(supervisor.ipTienda(), payload, attempt);
+                if (success) return true;
+            } catch (IOException e) {
+                log.atWarn()
+                        .setMessage("Error de socket al enviar clave de supervisor")
+                        .addKeyValue("supervisorId", supervisor.supervisorId())
+                        .addKeyValue("ipTienda", supervisor.ipTienda())
+                        .addKeyValue("intento", attempt)
+                        .setCause(e)
+                        .log();
+            }
+            if (attempt < props.posRetries()) sleepBetweenRetries();
+        }
+        return false;
+    }
+
+    private boolean trySend(String ipTienda, byte[] payload, int attempt) throws IOException {
+        try (Socket socket = new Socket()) {
+            socket.setSoTimeout(props.posTimeoutConnectionMs());
+            socket.connect(new InetSocketAddress(ipTienda, props.posPort()), props.posTimeoutConnectionMs());
+
+            OutputStream out = socket.getOutputStream();
+            out.write(payload);
+            out.flush();
+
+            return readAndValidateResponse(socket.getInputStream(), out, attempt);
+        }
+    }
+
+    private boolean readAndValidateResponse(InputStream in, OutputStream out, int attempt) throws IOException {
+        int keepaliveCycles = 0;
+        byte[] lenBuffer = new byte[props.posQtyBytesLength()];
+
+        while (true) {
+            try {
+                int read = in.read(lenBuffer, 0, props.posQtyBytesLength());
+                if (read <= 0) {
+                    keepaliveCycles++;
+                    if (keepaliveCycles % KEEPALIVE_CYCLE_THRESHOLD == 0) {
+                        sendKeepalive(out);
+                    }
+                    if (keepaliveCycles >= props.posRetries() * KEEPALIVE_CYCLE_THRESHOLD) {
+                        log.atWarn()
+                                .setMessage("Sin respuesta del controlador POS tras keepalives")
+                                .addKeyValue("intento", attempt)
+                                .log();
+                        return false;
+                    }
+                    continue;
+                }
+
+                int payloadLength = Integer.parseInt(new String(lenBuffer, 0, read, StandardCharsets.ISO_8859_1).trim());
+                if (payloadLength <= 0) return false;
+
+                byte[] responseBytes = readExact(in, payloadLength);
+                if (responseBytes == null) return false;
+
+                String responseFrame = new String(responseBytes, StandardCharsets.ISO_8859_1);
+                return parseStatus(responseFrame);
+
+            } catch (SocketTimeoutException e) {
+                keepaliveCycles++;
+                if (keepaliveCycles % KEEPALIVE_CYCLE_THRESHOLD == 0) {
+                    sendKeepalive(out);
+                }
+                if (keepaliveCycles >= props.posRetries() * KEEPALIVE_CYCLE_THRESHOLD) {
+                    log.atWarn()
+                            .setMessage("Timeout de lectura en controlador POS")
+                            .addKeyValue("intento", attempt)
+                            .log();
+                    return false;
+                }
+            }
+        }
+    }
+
+    private void sendKeepalive(OutputStream out) {
+        try {
+            String keepalive = "0".repeat(props.posQtyBytesLength());
+            out.write(keepalive.getBytes(StandardCharsets.ISO_8859_1));
+            out.flush();
+            log.atDebug().setMessage("Keepalive enviado al controlador POS").log();
+        } catch (IOException e) {
+            log.atDebug().setMessage("Error al enviar keepalive").setCause(e).log();
+        }
+    }
+
+    private static boolean parseStatus(String responseFrame) {
+        String[] fields = responseFrame.split(FRAME_SEPARATOR.replace("|", "\\|"), -1);
+        if (fields.length < 2) return false;
+        return "0".equals(fields[1].trim());
+    }
+
+    String buildFrame(PendingSupervisorUpdate supervisor, String storeCode) {
+        String timestamp = supervisor.fechaInicio() != null
+                ? supervisor.fechaInicio().format(TS_FORMATTER)
+                : "";
+        String fechaIniStr = supervisor.fechaInicio() != null
+                ? supervisor.fechaInicio().toString()
+                : "";
+        String idRegStr = supervisor.idRegistro() != null ? String.valueOf(supervisor.idRegistro()) : "";
+
+        return "S" + FRAME_SEPARATOR
+                + OP_CODE + FRAME_SEPARATOR
+                + RESPONSE_CHANNEL + FRAME_SEPARATOR
+                + storeCode + FRAME_SEPARATOR
+                + PERM_CONN + FRAME_SEPARATOR
+                + timestamp + FRAME_SEPARATOR
+                + supervisor.identityDocument() + FRAME_SEPARATOR
+                + nullSafe(supervisor.clave()) + FRAME_SEPARATOR
+                + nullSafe(supervisor.clave128()) + FRAME_SEPARATOR
+                + fechaIniStr + FRAME_SEPARATOR
+                + idRegStr;
+    }
+
+    private static String addLengthPrefix(String frame, int prefixLength) {
+        return String.format("%0" + prefixLength + "d", frame.length()) + frame;
+    }
+
+    private static String nullSafe(String value) {
+        return value != null ? value : "";
+    }
+
+    private static byte[] readExact(InputStream in, int count) throws IOException {
+        byte[] buffer = new byte[count];
+        int offset = 0;
+        while (offset < count) {
+            int read = in.read(buffer, offset, count - offset);
+            if (read < 0) return null;
+            offset += read;
+        }
+        return buffer;
+    }
+
+    private void sleepBetweenRetries() {
+        try {
+            Thread.sleep(props.posTimeoutSleepMs());
+        } catch (InterruptedException e) {
+            Thread.currentThread().interrupt();
+        }
+    }
+}


