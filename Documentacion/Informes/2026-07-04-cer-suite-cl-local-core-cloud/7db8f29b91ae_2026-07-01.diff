+package com.elrosado.cersuitecloudlocalcore.domain.model;
+
+import java.time.LocalDateTime;
+import java.util.List;
+
+public record SaveTransactionDocument(
+        SaveTransactionHeader header,
+        List<SaveTransactionItem> items,
+        List<SaveTransactionTender> tenders,
+        List<SaveTransactionTax> taxes,
+        List<SaveTransactionPromotion> promotions,
+        List<SaveTransactionConsumptionRecord> consumptions,
+        List<SaveTransactionPointsRecord> points,
+        String invoiceNumber,
+        String customerId,
+        String customerName,
+        String customerType,
+        String webCoupon,
+        int webCouponQuantity,
+        long sequenceNumberMayoreo,
+        int outputIndex
+) {
+
+    public SaveTransactionDocument {
+        items = List.copyOf(items);
+        tenders = List.copyOf(tenders);
+        taxes = List.copyOf(taxes);
+        promotions = List.copyOf(promotions);
+        consumptions = List.copyOf(consumptions);
+        points = List.copyOf(points);
+    }
+
+    public int storeCode() {
+        return header.storeCode();
+    }
+
+    public String outputFileName() {
+        LocalDateTime businessDay = header.businessDay();
+        String timestamp = "%04d%02d%02d%02d%02d%02d".formatted(
+                businessDay.getYear(),
+                businessDay.getMonthValue(),
+                businessDay.getDayOfMonth(),
+                businessDay.getHour(),
+                businessDay.getMinute(),
+                businessDay.getSecond());
+        return "%d-%s-%d-%s-%d.xml".formatted(
+                header.storeCode(),
+                header.workstationCode(),
+                header.sequenceNumber(),
+                timestamp,
+                outputIndex);
+    }
+}


