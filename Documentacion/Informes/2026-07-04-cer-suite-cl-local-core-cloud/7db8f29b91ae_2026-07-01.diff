--- a//src/test/java/com/elrosado/cersuitecloudlocalcore/infrastructure/adapter/out/socket/OperatorPasswordSocketClientTest.java
+++ b//src/test/java/com/elrosado/cersuitecloudlocalcore/infrastructure/adapter/out/socket/OperatorPasswordSocketClientTest.java
@@ -0,0 +1,87 @@
+package com.elrosado.cersuitecloudlocalcore.infrastructure.adapter.out.socket;
+
+import com.elrosado.cersuitecloudlocalcore.domain.model.PendingSupervisorUpdate;
+import com.elrosado.cersuitecloudlocalcore.infrastructure.config.LegacyOperatorPasswordUpdateProperties;
+import org.junit.jupiter.api.BeforeEach;
+import org.junit.jupiter.api.Test;
+import org.junit.jupiter.api.extension.ExtendWith;
+import org.mockito.junit.jupiter.MockitoExtension;
+
+import java.time.LocalDateTime;
+
+import static org.assertj.core.api.Assertions.assertThat;
+
+@ExtendWith(MockitoExtension.class)
+class OperatorPasswordSocketClientTest {
+
+    private static final LegacyOperatorPasswordUpdateProperties PROPS =
+            new LegacyOperatorPasswordUpdateProperties(2040, 2, 5000, 300, 6);
+
+    private static final PendingSupervisorUpdate SUPERVISOR = new PendingSupervisorUpdate(
+            1, 123456789, "CLAVE1", "CODE128ABC",
+            LocalDateTime.of(2026, 1, 15, 10, 30, 0),
+            42, "192.168.1.100", 10
+    );
+
+    OperatorPasswordSocketClient client;
+
+    @BeforeEach
+    void setUp() {
+        client = new OperatorPasswordSocketClient(PROPS);
+    }
+
+    @Test
+    void buildFrame_estructuraCorrecta() {
+        String frame = client.buildFrame(SUPERVISOR, "191");
+
+        assertThat(frame).startsWith("S'|'26'|'000'|'191'|'0'|'");
+        assertThat(frame).contains("'|'123456789'|'CLAVE1'|'CODE128ABC'|'");
+        assertThat(frame).contains("'|'42");
+    }
+
+    @Test
+    void buildFrame_contieneTimestamp() {
+        String frame = client.buildFrame(SUPERVISOR, "191");
+
+        // Fecha: 20260115103000
+        assertThat(frame).contains("20260115103000");
+    }
+
+    @Test
+    void buildFrame_camposNulos_notienePunteros() {
+        PendingSupervisorUpdate sinFecha = new PendingSupervisorUpdate(
+                2, 999, null, null, null, null, "192.168.1.1", 10
+        );
+
+        String frame = client.buildFrame(sinFecha, "100");
+
+        // No debe lanzar excepciÃ³n; campos nulos deben quedar vacÃ­os
+        assertThat(frame).startsWith("S'|'26'|'000'|'100'|'0'|'");
+        assertThat(frame).doesNotContain("null");
+    }
+
+    @Test
+    void buildFrame_separadorCorrecto() {
+        String frame = client.buildFrame(SUPERVISOR, "191");
+
+        // El separador debe ser '|' (tres caracteres: comilla-pipe-comilla)
+        String[] parts = frame.split("'\\|'", -1);
+        // S | 26 | 000 | 191 | 0 | timestamp | cc | clave | code128 | fechaIni | idreg = 11 partes
+        assertThat(parts).hasSize(11);
+        assertThat(parts[0]).isEqualTo("S");
+        assertThat(parts[1]).isEqualTo("26");
+        assertThat(parts[2]).isEqualTo("000");
+        assertThat(parts[3]).isEqualTo("191");
+        assertThat(parts[4]).isEqualTo("0");
+    }
+
+    @Test
+    void buildFrame_storeCodeDistinto_refleja() {
+        String frame1 = client.buildFrame(SUPERVISOR, "191");
+        String frame2 = client.buildFrame(SUPERVISOR, "205");
+
+        assertThat(frame1).contains("'|'191'|'");
+        assertThat(frame2).contains("'|'205'|'");
+        assertThat(frame1).isNotEqualTo(frame2);
+    }
+}


