--- Diff for /src/main/java/com/elrosado/cersuitecloudlocalcore/service/OperatorPasswordUpdateService.java ---
--- a//src/main/java/com/elrosado/cersuitecloudlocalcore/service/OperatorPasswordUpdateService.java
+++ b//src/main/java/com/elrosado/cersuitecloudlocalcore/service/OperatorPasswordUpdateService.java
@@ -0,0 +1,180 @@
+package com.elrosado.cersuitecloudlocalcore.service;
+
+import com.elrosado.cersuitecloudlocalcore.domain.model.PendingSupervisorUpdate;
+import com.elrosado.cersuitecloudlocalcore.domain.model.SupervisorUpdateResult;
+import com.elrosado.cersuitecloudlocalcore.domain.port.in.OperatorPasswordUpdateUseCase;
+import com.elrosado.cersuitecloudlocalcore.domain.port.out.SupervisorPendingPort;
+import com.elrosado.cersuitecloudlocalcore.domain.port.out.SupervisorStatusPort;
+import com.elrosado.cersuitecloudlocalcore.infrastructure.adapter.out.socket.OperatorPasswordSocketClient;
+import com.elrosado.cersuitecloudlocalcore.infrastructure.config.OperatorPasswordUpdateProperties;
+import com.elrosado.cersuitecloudlocalcore.infrastructure.config.StoreRegistry;
+import org.slf4j.Logger;
+import org.slf4j.LoggerFactory;
+import org.springframework.beans.factory.annotation.Qualifier;
+import org.springframework.core.task.AsyncTaskExecutor;
+import org.springframework.stereotype.Service;
+
+import java.util.List;
+import java.util.Map;
+import java.util.concurrent.CompletableFuture;
+import java.util.concurrent.CopyOnWriteArrayList;
+import java.util.stream.Collectors;
+
+/**
+ * Distribuye actualizaciones de clave de supervisores a los controladores POS de cada tienda.
+ * MULTI_LOCAL: agrupa por codTienda, un virtual thread por tienda, secuencial dentro de cada grupo.
+ */
+@Service
+public class OperatorPasswordUpdateService implements OperatorPasswordUpdateUseCase {
+
+    private static final Logger log = LoggerFactory.getLogger(OperatorPasswordUpdateService.class);
+
+    private final SupervisorPendingPort pendingPort;
+    private final SupervisorStatusPort statusPort;
+    private final StoreRegistry storeRegistry;
+    private final OperatorPasswordSocketClient socketClient;
+    private final OperatorPasswordUpdateProperties properties;
+    private final AsyncTaskExecutor virtualThreadTaskExecutor;
+
+    public OperatorPasswordUpdateService(
+            SupervisorPendingPort pendingPort,
+            SupervisorStatusPort statusPort,
+            StoreRegistry storeRegistry,
+            OperatorPasswordSocketClient socketClient,
+            OperatorPasswordUpdateProperties properties,
+            @Qualifier("virtualThreadTaskExecutor") AsyncTaskExecutor virtualThreadTaskExecutor) {
+        this.pendingPort = pendingPort;
+        this.statusPort = statusPort;
+        this.storeRegistry = storeRegistry;
+        this.socketClient = socketClient;
+        this.properties = properties;
+        this.virtualThreadTaskExecutor = virtualThreadTaskExecutor;
+    }
+
+    @Override
+    public List<SupervisorUpdateResult> processAllPendingUpdates() {
+        if (!properties.enabled()) {
+            log.atDebug().setMessage("OperatorPasswordUpdate deshabilitado").log();
+            return List.of();
+        }
+
+        if (!storeRegistry.isMultiLocalEnabled()) {
+            log.atWarn().setMessage("OperatorPasswordUpdate omitido â no hay tiendas MULTI_LOCAL activas").log();
+            return List.of();
+        }
+
+        List<PendingSupervisorUpdate> pending = pendingPort.findAllPending();
+        if (pending.isEmpty()) {
+            log.atDebug().setMessage("No hay supervisores pendientes de actualizaciÃ³n de clave").log();
+            return List.of();
+        }
+
+        // Filtrar solo supervisores de tiendas MULTI_LOCAL registradas
+        List<PendingSupervisorUpdate> filtered = pending.stream()
+                .filter(s -> s.codTienda() != null && storeRegistry.findByCodTienda(s.codTienda()).isPresent())
+                .toList();
+
+        int skipped = pending.size() - filtered.size();
+        if (skipped > 0) {
+            log.atWarn()
+                    .setMessage("Supervisores ignorados â tienda no en StoreRegistry MULTI_LOCAL")
+                    .addKeyValue("ignorados", skipped)
+                    .log();
+        }
+
+        if (filtered.isEmpty()) return List.of();
+
+        Map<Integer, List<PendingSupervisorUpdate>> byStore = filtered.stream()
+                .collect(Collectors.groupingBy(PendingSupervisorUpdate::codTienda));
+
+        log.atInfo()
+                .setMessage("Iniciando distribuciÃ³n de claves de supervisores")
+                .addKeyValue("totalSupervisores", filtered.size())
+                .addKeyValue("tiendas", byStore.size())
+                .log();
+
+        List<SupervisorUpdateResult> results = new CopyOnWriteArrayList<>();
+
+        List<CompletableFuture<Void>> futures = byStore.entrySet().stream()
+                .map(entry -> CompletableFuture
+                        .runAsync(() -> processStoreGroup(entry.getKey(), entry.getValue(), results),
+                                virtualThreadTaskExecutor)
+                        .exceptionally(ex -> {
+                            log.atError()
+                                    .setMessage("Error no controlado en hilo de tienda para OperatorPasswordUpdate")
+                                    .addKeyValue("codTienda", entry.getKey())
+                                    .setCause(ex)
+                                    .log();
+                            return null;
+                        }))
+                .toList();
+
+        CompletableFuture.allOf(futures.toArray(CompletableFuture[]::new)).join();
+
+        log.atInfo()
+                .setMessage("Ciclo de distribuciÃ³n de claves finalizado")
+                .addKeyValue("procesados", results.size())
+                .addKeyValue("exitosos", results.stream().filter(SupervisorUpdateResult::success).count())
+                .addKeyValue("fallidos", results.stream().filter(r -> !r.success()).count())
+                .log();
+
+        return List.copyOf(results);
+    }
+
+    private void processStoreGroup(int codTienda, List<PendingSupervisorUpdate> supervisors,
+                                   List<SupervisorUpdateResult> results) {
+        var storeOpt = storeRegistry.findByCodTienda(codTienda);
+        if (storeOpt.isEmpty()) return;
+
+        String storeCode = String.valueOf(storeOpt.get().getDesClave());
+
+        log.atInfo()
+                .setMessage("Procesando supervisores de tienda")
+                .addKeyValue("codTienda", codTienda)
+                .addKeyValue("storeCode", storeCode)
+                .addKeyValue("cantidad", supervisors.size())
+                .log();
+
+        supervisors.forEach(supervisor -> results.add(processSupervisor(supervisor, storeCode)));
+    }
+
+    private SupervisorUpdateResult processSupervisor(PendingSupervisorUpdate supervisor, String storeCode) {
+        log.atDebug()
+                .setMessage("STR â enviando clave de supervisor")
+                .addKeyValue("supervisorId", supervisor.supervisorId())
+                .addKeyValue("ipTienda", supervisor.ipTienda())
+                .addKeyValue("storeCode", storeCode)
+                .log();
+
+        try {
+            boolean sent = socketClient.sendSupervisorUpdate(supervisor, storeCode);
+
+            if (sent) {
+                statusPort.markAsActive(supervisor.supervisorId());
+                log.atInfo()
+                        .setMessage("END â clave de supervisor distribuida exitosamente")
+                        .addKeyValue("supervisorId", supervisor.supervisorId())
+                        .addKeyValue("ipTienda", supervisor.ipTienda())
+                        .log();
+                return SupervisorUpdateResult.ok(supervisor.supervisorId());
+            } else {
+                statusPort.markAsFailed(supervisor.supervisorId());
+                log.atWarn()
+                        .setMessage("WAR â controlador POS rechazÃ³ la actualizaciÃ³n de clave")
+                        .addKeyValue("supervisorId", supervisor.supervisorId())
+                        .addKeyValue("ipTienda", supervisor.ipTienda())
+                        .log();
+                return SupervisorUpdateResult.failed(supervisor.supervisorId(), "Controlador POS rechazÃ³ la actualizaciÃ³n");
+            }
+        } catch (Exception e) {
+            statusPort.markAsFailed(supervisor.supervisorId());
+            log.atError()
+                    .setMessage("ERR â error al distribuir clave de supervisor")
+                    .addKeyValue("supervisorId", supervisor.supervisorId())
+                    .addKeyValue("ipTienda", supervisor.ipTienda())
+                    .setCause(e)
+                    .log();
+            return SupervisorUpdateResult.failed(supervisor.supervisorId(), e.getMessage());
+        }
+    }
+}


--- Diff for /src/main/java/com/elrosado/cersuitecloudlocalcore/service/SaveTransactionParser.java ---
--- a//src/main/java/com/elrosado/cersuitecloudlocalcore/service/SaveTransactionParser.java
+++ b//src/main/java/com/elrosado/cersuitecloudlocalcore/service/SaveTransactionParser.java
@@ -0,0 +1,297 @@
+package com.elrosado.cersuitecloudlocalcore.service;
+
+import com.elrosado.cersuitecloudlocalcore.domain.model.SaveTransactionConsumptionRecord;
+import com.elrosado.cersuitecloudlocalcore.domain.model.SaveTransactionDocument;
+import com.elrosado.cersuitecloudlocalcore.domain.model.SaveTransactionHeader;
+import com.elrosado.cersuitecloudlocalcore.domain.model.SaveTransactionItem;
+import com.elrosado.cersuitecloudlocalcore.domain.model.SaveTransactionPointsRecord;
+import com.elrosado.cersuitecloudlocalcore.domain.model.SaveTransactionPromotion;
+import com.elrosado.cersuitecloudlocalcore.domain.model.SaveTransactionTax;
+import com.elrosado.cersuitecloudlocalcore.domain.model.SaveTransactionTender;
+import org.springframework.stereotype.Component;
+
+import java.time.LocalDate;
+import java.time.LocalDateTime;
+import java.time.format.DateTimeFormatter;
+import java.util.ArrayList;
+import java.util.List;
+
+@Component
+public class SaveTransactionParser {
+
+    private static final DateTimeFormatter BUSINESS_DAY_FORMATTER = DateTimeFormatter.ofPattern("yyyyMMdd");
+    private static final DateTimeFormatter DATE_TIME_FORMATTER = DateTimeFormatter.ofPattern("yyyyMMddHHmm");
+    private static final long WHOLESALE_SERVICE_ITEM = 811099999997L;
+
+    public SaveTransactionDocument parseLine(String line, int outputIndex) {
+        String[] segments = line.split(",", -1);
+        if (segments.length == 0 || !segments[0].startsWith("00")) {
+            throw new IllegalArgumentException("SaveTransactions line must start with transaction header 00");
+        }
+
+        Builder builder = new Builder(parseHeader(segments[0]), outputIndex);
+        int promotionSequence = 0;
+
+        for (int i = 1; i < segments.length; i++) {
+            String segment = segments[i];
+            if (segment == null || segment.isBlank()) {
+                continue;
+            }
+            String[] info = segment.split("\\|", -1);
+            String type = value(info, 0);
+            switch (type) {
+                case "01" -> builder.items.add(parseItem(info));
+                case "05" -> builder.tenders.add(new SaveTransactionTender(
+                        value(info, 1), parseLong(info, 2), value(info, 3), false));
+                case "07" -> builder.taxes.add(new SaveTransactionTax(
+                        value(info, 1), value(info, 2), parseLong(info, 3), parseLong(info, 4)));
+                case "09" -> builder.tenders.add(new SaveTransactionTender(
+                        value(info, 1), parseLong(info, 2), "", true));
+                case "10" -> {
+                    builder.invoiceNumber = value(info, 3);
+                    builder.retailTransactionTypeCode = 1;
+                }
+                case "11" -> builder.promotions.add(new SaveTransactionPromotion(
+                        value(info, 1), parseLong(info, 2), parseInt(info, 3), ++promotionSequence));
+                case "12" -> {
+                    builder.customerId = value(info, 1);
+                    builder.customerName = value(info, 2);
+                    builder.customerType = resolveCustomerType(builder.customerId, value(info, 3));
+                }
+                case "13" -> {
+                    builder.webCoupon = value(info, 1);
+                    builder.webCouponQuantity = parseInt(info, 2);
+                }
+                case "14" -> builder.points.add(parsePoints(info, builder.header, builder.items));
+                case "15" -> applyMoto(info, builder.items);
+                case "16" -> {
+                    builder.deducibleFood = parseLong(info, 1);
+                    builder.deducibleClothing = parseLong(info, 2);
+                    builder.deducibleSchool = parseLong(info, 3);
+                }
+                case "17" -> builder.consumptions.add(parseConsumption(info, builder.invoiceNumber));
+                case "18" -> applyWholesale(info, builder);
+                default -> {
+                    // Los segmentos no reconocidos se omiten para conservar tolerancia legacy.
+                }
+            }
+        }
+
+        return builder.build();
+    }
+
+    private SaveTransactionHeader parseHeader(String headerSegment) {
+        String[] trxInfo = headerSegment.split("\\|", -1);
+        return new SaveTransactionHeader(
+                value(trxInfo, 1),
+                parseInt(trxInfo, 2),
+                parseInt(trxInfo, 4),
+                value(trxInfo, 5),
+                parseDateTime(trxInfo, 6),
+                parseDateTime(trxInfo, 7),
+                parseBusinessDay(trxInfo, 3),
+                parseLong(trxInfo, 8),
+                parseLong(trxInfo, 9),
+                0
+        );
+    }
+
+    private SaveTransactionItem parseItem(String[] info) {
+        return new SaveTransactionItem(
+                parseLong(info, 1),
+                parseLong(info, 2),
+                parseLong(info, 3),
+                value(info, 4),
+                parseLong(info, 5),
+                value(info, 6),
+                value(info, 7),
+                parseLong(info, 8),
+                parseInt(info, 9),
+                parseInt(info, 10) == 1,
+                0,
+                "",
+                ""
+        );
+    }
+
+    private SaveTransactionPointsRecord parsePoints(
+            String[] info,
+            SaveTransactionHeader header,
+            List<SaveTransactionItem> items) {
+        int ordinalNumber = parseInt(info, 3);
+        long itemCode = items.stream()
+                .filter(item -> item.ordinalNumber() == ordinalNumber)
+                .findFirst()
+                .map(SaveTransactionItem::itemCode)
+                .orElse(0L);
+
+        return new SaveTransactionPointsRecord(
+                header.storeCode(),
+                "%04d".formatted(parseInt(header.workstationCode())),
+                header.businessDay(),
+                header.sequenceNumber(),
+                itemCode,
+                ordinalNumber,
+                parseInt(info, 2),
+                value(info, 1)
+        );
+    }
+
+    private SaveTransactionConsumptionRecord parseConsumption(String[] info, String invoiceNumber) {
+        return new SaveTransactionConsumptionRecord(
+                invoiceNumber,
+                value(info, 1),
+                value(info, 2),
+                value(info, 3),
+                parseInt(info, 4),
+                parseInt(info, 5),
+                value(info, 6)
+        );
+    }
+
+    private void applyMoto(String[] info, List<SaveTransactionItem> items) {
+        long itemCode = parseLong(info, 1);
+        for (int i = items.size() - 1; i >= 0; i--) {
+            SaveTransactionItem item = items.get(i);
+            if (item.itemCode() == itemCode) {
+                items.set(i, new SaveTransactionItem(
+                        item.itemCode(),
+                        item.regularSalesUnitPrice(),
+                        item.extendedAmount(),
+                        item.entryMethodCode(),
+                        item.quantity(),
+                        item.units(),
+                        item.taxType(),
+                        item.appliedTax(),
+                        item.ordinalNumber(),
+                        item.wholesale(),
+                        item.itemType(),
+                        value(info, 2),
+                        value(info, 3)
+                ));
+                return;
+            }
+        }
+    }
+
+    private void applyWholesale(String[] info, Builder builder) {
+        int sequence = builder.items.stream()
+                .mapToInt(SaveTransactionItem::ordinalNumber)
+                .max()
+                .orElse(0) + 1;
+        long amount = parseLong(info, 1);
+        builder.sequenceNumberMayoreo = sequence;
+        builder.items.add(new SaveTransactionItem(
+                WHOLESALE_SERVICE_ITEM,
+                amount,
+                amount,
+                "SERVICE",
+                1,
+                "",
+                "",
+                0,
+                sequence,
+                true,
+                7,
+                "",
+                ""
+        ));
+    }
+
+    private String resolveCustomerType(String customerId, String flag) {
+        if ("1".equals(flag)) {
+            return "1";
+        }
+        if ("0".equals(flag) && customerId != null && customerId.length() > 10) {
+            return "2";
+        }
+        return "3";
+    }
+
+    private LocalDateTime parseBusinessDay(String[] values, int index) {
+        String raw = value(values, index);
+        return LocalDate.parse(raw, BUSINESS_DAY_FORMATTER).atStartOfDay();
+    }
+
+    private LocalDateTime parseDateTime(String[] values, int index) {
+        return LocalDateTime.parse(value(values, index), DATE_TIME_FORMATTER);
+    }
+
+    private int parseInt(String[] values, int index) {
+        String raw = value(values, index);
+        return parseInt(raw);
+    }
+
+    private int parseInt(String value) {
+        String raw = value == null ? "" : value.trim();
+        return raw.isBlank() ? 0 : Integer.parseInt(raw);
+    }
+
+    private long parseLong(String[] values, int index) {
+        String raw = value(values, index);
+        return raw.isBlank() ? 0L : Long.parseLong(raw.trim());
+    }
+
+    private String value(String[] values, int index) {
+        return index < values.length && values[index] != null ? values[index].trim() : "";
+    }
+
+    private static final class Builder {
+        private final SaveTransactionHeader header;
+        private final int outputIndex;
+        private final List<SaveTransactionItem> items = new ArrayList<>();
+        private final List<SaveTransactionTender> tenders = new ArrayList<>();
+        private final List<SaveTransactionTax> taxes = new ArrayList<>();
+        private final List<SaveTransactionPromotion> promotions = new ArrayList<>();
+        private final List<SaveTransactionConsumptionRecord> consumptions = new ArrayList<>();
+        private final List<SaveTransactionPointsRecord> points = new ArrayList<>();
+        private String invoiceNumber = "";
+        private String customerId = "";
+        private String customerName = "";
+        private String customerType = "";
+        private String webCoupon = "";
+        private int webCouponQuantity;
+        private long sequenceNumberMayoreo;
+        private long deducibleFood;
+        private long deducibleClothing;
+        private long deducibleSchool;
+        private int retailTransactionTypeCode;
+
+        private Builder(SaveTransactionHeader header, int outputIndex) {
+            this.header = header;
+            this.outputIndex = outputIndex;
+        }
+
+        private SaveTransactionDocument build() {
+            SaveTransactionHeader finalHeader = new SaveTransactionHeader(
+                    header.workstationCode(),
+                    header.sequenceNumber(),
+                    header.storeCode(),
+                    header.operatorCode(),
+                    header.beginDateTime(),
+                    header.endDateTime(),
+                    header.businessDay(),
+                    header.grossPositiveAmount(),
+                    header.grossNegativeAmount(),
+                    retailTransactionTypeCode
+            );
+            return new SaveTransactionDocument(
+                    finalHeader,
+                    items,
+                    tenders,
+                    taxes,
+                    promotions,
+                    consumptions,
+                    points,
+                    invoiceNumber,
+                    customerId,
+                    customerName,
+                    customerType,
+                    webCoupon,
+                    webCouponQuantity,
+                    sequenceNumberMayoreo,
+                    outputIndex
+            );
+        }
+    }
+}


