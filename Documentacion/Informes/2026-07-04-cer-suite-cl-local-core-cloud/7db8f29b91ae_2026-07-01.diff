+
+import java.nio.charset.StandardCharsets;
+
+import static org.junit.jupiter.api.Assertions.assertEquals;
+import static org.junit.jupiter.api.Assertions.assertTrue;
+
+class SaveTransactionParserTest {
+
+    private final SaveTransactionParser parser = new SaveTransactionParser();
+    private final SaveTransactionXmlGenerator xmlGenerator = new SaveTransactionXmlGenerator();
+
+    @Test
+    void parseLine_syntheticTrx_mapsLegacySegmentsAndSideTables() {
+        String line = "00|1|123|20260630|101|OP01|202606301000|202606301005|1500|0"
+                + ",01|789|1000|1000|SCAN|1|EA|IVA|120|1|0"
+                + ",05|CASH|1000|"
+                + ",07|ITEM|IVA|120|1000"
+                + ",10|20260630|100500|F001|1000|1120"
+                + ",11|PROMO1|100|1"
+                + ",12|0912345678|CLIENTE UNO|0"
+                + ",13|CUPON1|2"
+                + ",14|PROMOPTS|50|1"
+                + ",15|789|SERIE1|GER1"
+                + ",17|ACC1|SEQ1|AUT1|10|20|00"
+                + ",18|250";
+
+        SaveTransactionDocument document = parser.parseLine(line, 1);
+        String xml = new String(xmlGenerator.generate(document), StandardCharsets.UTF_8);
+
+        assertEquals(101, document.storeCode());
+        assertEquals("101-1-123-20260630000000-1.xml", document.outputFileName());
+        assertEquals(2, document.items().size());
+        assertEquals(1, document.points().size());
+        assertEquals(789L, document.points().getFirst().itemCode());
+        assertEquals(1, document.consumptions().size());
+        assertEquals("F001", document.consumptions().getFirst().invoiceNumber());
+        assertTrue(xml.contains("<RetailStoreCode>101</RetailStoreCode>"));
+        assertTrue(xml.contains("<MotoSerial>SERIE1</MotoSerial>"));
+        assertTrue(xml.contains("<ItemCode>811099999997</ItemCode>"));
+    }
+}


