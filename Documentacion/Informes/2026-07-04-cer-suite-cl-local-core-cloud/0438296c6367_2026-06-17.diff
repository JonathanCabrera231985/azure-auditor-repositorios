+ * Cubre todos los repositorios del proyecto: RetailStore, Invoice, CustomerType,
+ * CustomerExt (tablas en ARTS_EC) y DevTicket (DEVS_EC.dbo.DV_TICKET, accesible
+ * vÃ­a cross-database SQL Server desde la misma instancia, declarado con catalog="DEVS_EC"
+ * en la anotaciÃ³n @Table de la entidad).
+ */
+@Configuration
+@EnableJpaRepositories(
+        basePackages = "com.elrosado.cersuitecloudlocalcore.infrastructure.adapter.out.db.repository",
