+package com.elrosado.cersuitecloudlocalcore.infrastructure.adapter.out.transfer;
+
+import com.elrosado.cersuitecloudlocalcore.domain.port.out.CartaMotoTransferPort;
+import com.elrosado.cersuitecloudlocalcore.infrastructure.config.LegacySendCartaMotoProperties;
+import net.schmizz.sshj.SSHClient;
+import net.schmizz.sshj.sftp.SFTPClient;
+import net.schmizz.sshj.transport.verification.PromiscuousVerifier;
+import net.schmizz.sshj.xfer.InMemorySourceFile;
+import org.slf4j.Logger;
+import org.slf4j.LoggerFactory;
+import org.springframework.stereotype.Component;
+
+import java.io.ByteArrayInputStream;
+import java.io.IOException;
+import java.io.InputStream;
+
+/**
+ * Adaptador SFTP para transferencia de archivos XML de cartas moto.
+ * Reemplaza JSch (legado) con SSHJ para compatibilidad Java 25 y API mÃ¡s limpia.
+ * La verificaciÃ³n de host usa PromiscuousVerifier equivalente al legado StrictHostKeyChecking=no.
+ */
+@Component
+public class SftpCartaMotoTransferAdapter implements CartaMotoTransferPort {
+
+    private static final Logger log = LoggerFactory.getLogger(SftpCartaMotoTransferAdapter.class);
+
+    private final LegacySendCartaMotoProperties legacyProperties;
+
+    public SftpCartaMotoTransferAdapter(LegacySendCartaMotoProperties legacyProperties) {
+        this.legacyProperties = legacyProperties;
+    }
+
+    @Override
+    public void transferFile(String fileName, byte[] content) {
+        String serverIp = legacyProperties.server().serverIp();
+        int port = legacyProperties.server().port();
+        String remoteDir = legacyProperties.server().remoteDir();
+        String username = legacyProperties.username();
+        String password = legacyProperties.password();
+        String remotePath = remoteDir + "/" + fileName;
+
+        log.atDebug()
+                .setMessage("Iniciando transferencia SFTP de carta moto")
+                .addKeyValue("fileName", fileName)
+                .addKeyValue("server", serverIp + ":" + port)
+                .addKeyValue("remotePath", remotePath)
+                .log();
+
+        try (SSHClient ssh = buildSshClient(serverIp, port, username, password);
+             SFTPClient sftp = ssh.newSFTPClient()) {
+
+            sftp.put(new ByteArraySourceFile(fileName, content), remotePath);
+
+            log.atDebug()
+                    .setMessage("Archivo carta moto transferido por SFTP exitosamente")
+                    .addKeyValue("fileName", fileName)
+                    .addKeyValue("remotePath", remotePath)
+                    .log();
+
+        } catch (IOException e) {
+            throw new IllegalStateException(
+                    "Error transfiriendo carta moto por SFTP: " + fileName, e);
+        }
+    }
+
+    private SSHClient buildSshClient(String serverIp, int port, String username, String password)
+            throws IOException {
+        SSHClient ssh = new SSHClient();
+        ssh.addHostKeyVerifier(new PromiscuousVerifier());
+        ssh.connect(serverIp, port);
+        ssh.authPassword(username, password);
+        return ssh;
+    }
+
+    private static final class ByteArraySourceFile extends InMemorySourceFile {
+
+        private final String name;
+        private final byte[] bytes;
+
+        ByteArraySourceFile(String name, byte[] bytes) {
+            this.name = name;
+            this.bytes = bytes;
+        }
+
+        @Override
+        public String getName() {
+            return name;
+        }
+
+        @Override
+        public long getLength() {
+            return bytes.length;
+        }
+
+        @Override
+        public InputStream getInputStream() {
+            return new ByteArrayInputStream(bytes);
+        }
+    }
+}


