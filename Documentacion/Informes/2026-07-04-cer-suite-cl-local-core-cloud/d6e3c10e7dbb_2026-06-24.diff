--- a//src/main/java/com/elrosado/cersuitecloudlocalcore/infrastructure/adapter/out/db/DbUpdateMotoAdapter.java
+++ b//src/main/java/com/elrosado/cersuitecloudlocalcore/infrastructure/adapter/out/db/DbUpdateMotoAdapter.java
@@ -0,0 +1,87 @@
+package com.elrosado.cersuitecloudlocalcore.infrastructure.adapter.out.db;
+
+import com.elrosado.cersuitecloudlocalcore.domain.model.MotoProcessingResult;
+import com.elrosado.cersuitecloudlocalcore.domain.model.MotoRecord;
+import com.elrosado.cersuitecloudlocalcore.domain.port.out.MotoPersistencePort;
+import com.elrosado.cersuitecloudlocalcore.infrastructure.adapter.out.db.entity.ItemEntity;
+import com.elrosado.cersuitecloudlocalcore.infrastructure.adapter.out.db.entity.MotoEntity;
+import com.elrosado.cersuitecloudlocalcore.infrastructure.adapter.out.db.repository.ItemJpaRepository;
+import com.elrosado.cersuitecloudlocalcore.infrastructure.adapter.out.db.repository.MotoJpaRepository;
+import org.slf4j.Logger;
+import org.slf4j.LoggerFactory;
+import org.springframework.stereotype.Component;
+import org.springframework.transaction.annotation.Transactional;
+
+import java.util.List;
+import java.util.Optional;
+
+@Component
+public class DbUpdateMotoAdapter implements MotoPersistencePort {
+
+    private static final Logger log = LoggerFactory.getLogger(DbUpdateMotoAdapter.class);
+
+    private final MotoJpaRepository motoRepository;
+    private final ItemJpaRepository itemRepository;
+
+    public DbUpdateMotoAdapter(
+            MotoJpaRepository motoRepository,
+            ItemJpaRepository itemRepository) {
+        this.motoRepository = motoRepository;
+        this.itemRepository = itemRepository;
+    }
+
+    @Override
+    @Transactional(transactionManager = "artsEcTransactionManager")
+    public MotoProcessingResult processAndSaveBatch(List<MotoRecord> batch) {
+        long inserted = 0;
+        long updated = 0;
+
+        for (MotoRecord record : batch) {
+            String serie = record.serie();
+            Optional<MotoEntity> existing = motoRepository.findBySerie(serie);
+
+            if (existing.isPresent()) {
+                MotoEntity entity = existing.get();
+                entity.updateFrom(record);
+                motoRepository.save(entity);
+                updated++;
+                log.atDebug()
+                        .setMessage("MOTO record updated")
+                        .addKeyValue("serie", serie)
+                        .log();
+            } else {
+                Integer itemId = resolveItemId(record.material());
+                MotoEntity entity = MotoEntity.fromDomain(record, itemId);
+                motoRepository.save(entity);
+                inserted++;
+                if (itemId == null) {
+                    log.atWarn()
+                            .setMessage("MOTO inserted without itemId â SAP code not found in AS_ITM")
+                            .addKeyValue("serie", serie)
+                            .addKeyValue("material", record.material())
+                            .log();
+                } else {
+                    log.atDebug()
+                            .setMessage("MOTO record inserted")
+                            .addKeyValue("serie", serie)
+                            .addKeyValue("itemId", itemId)
+                            .log();
+                }
+            }
+        }
+
+        return new MotoProcessingResult(inserted, updated, 0);
+    }
+
+    private Integer resolveItemId(String material) {
+        if (material == null || material.isBlank()) return null;
+        try {
+            long cdSap = Long.parseLong(material.trim());
+            return itemRepository.findByCdSap(cdSap)
+                    .map(ItemEntity::getIdItm)
+                    .orElse(null);
+        } catch (NumberFormatException e) {
+            return null;
+        }
+    }
+}


