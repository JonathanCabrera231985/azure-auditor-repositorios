+package com.elrosado.cersuitecloudlocalcore.service;
+
+import com.elrosado.cersuitecloudlocalcore.domain.model.MotoRecord;
+import org.springframework.stereotype.Component;
+
+@Component
+public class MotoFileParser {
+
+    private static final int MIN_LINE_LENGTH = 320;
+    private static final String COMBUSTIBLE_ELECTRICO = "ELECTRICO";
+
+    private final TextNormalizer textNormalizer;
+
+    public MotoFileParser(TextNormalizer textNormalizer) {
+        this.textNormalizer = textNormalizer;
+    }
+
+    public MotoRecord parseLine(String line, long lineNumber) {
+        if (line == null || line.length() < MIN_LINE_LENGTH) {
+            int length = line == null ? 0 : line.length();
+            throw new IllegalArgumentException(
+                    "Line " + lineNumber + " too short: expected >= " + MIN_LINE_LENGTH + ", got " + length);
+        }
+
+        String tipoCombustible = textNormalizer.normalize(line.substring(187, 202).trim());
+
+        String ejes = line.length() > 320 ? line.substring(320, 321).trim() : "";
+        if (ejes.isBlank()) ejes = "2";
+
+        String ruedas = line.length() > 321 ? line.substring(321, 322).trim() : "";
+        if (ruedas.isBlank()) ruedas = "2";
+
+        String potencia = "";
+        if (COMBUSTIBLE_ELECTRICO.equals(tipoCombustible) && line.length() > 322) {
+            potencia = line.substring(322, Math.min(342, line.length())).trim();
+        }
+
+        return new MotoRecord(
+                line.substring(0, 3).trim(),
+                line.substring(3, 21).trim(),
+                line.substring(21, 41).trim(),
+                line.substring(41, 61).trim(),
+                line.substring(61, 81).trim(),
+                line.substring(81, 101).trim(),
+                line.substring(101, 105).trim(),
+                line.substring(105, 120).trim(),
+                line.substring(120, 135).trim(),
+                line.substring(135, 145).trim(),
+                line.substring(145, 148).trim(),
+                line.substring(148, 168).trim(),
+                line.substring(168, 169).trim(),
+                line.substring(169, 177).trim(),
+                line.substring(177, 187).trim(),
+                tipoCombustible,
+                line.substring(202, 217).trim(),
+                line.substring(217, 237).trim(),
+                line.substring(237, 257).trim(),
+                line.substring(257, 275).trim(),
+                line.substring(275, 295).trim(),
+                line.substring(295, 315).trim(),
+                line.substring(315, 319).trim(),
+                line.substring(319, 320).trim(),
+                ejes,
+                ruedas,
+                potencia
+        );
+    }
+}


