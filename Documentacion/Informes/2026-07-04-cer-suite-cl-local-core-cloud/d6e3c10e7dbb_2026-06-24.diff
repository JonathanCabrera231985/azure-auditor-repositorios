+package com.elrosado.cersuitecloudlocalcore.service;
+
+import com.elrosado.cersuitecloudlocalcore.domain.exception.SendCartaMotoException;
+import com.elrosado.cersuitecloudlocalcore.domain.model.CartaMoto;
+import com.elrosado.cersuitecloudlocalcore.domain.model.GcsObjectReference;
+import com.elrosado.cersuitecloudlocalcore.domain.model.SendCartaMotoStage;
+import com.elrosado.cersuitecloudlocalcore.domain.port.in.SendCartaMotoUseCase;
+import com.elrosado.cersuitecloudlocalcore.domain.port.out.CartaMotoQueryPort;
+import com.elrosado.cersuitecloudlocalcore.domain.port.out.CartaMotoStoragePort;
+import com.elrosado.cersuitecloudlocalcore.domain.port.out.CartaMotoTransferPort;
+import com.elrosado.cersuitecloudlocalcore.domain.port.out.CartaMotoUpdatePort;
+import com.elrosado.cersuitecloudlocalcore.infrastructure.config.LegacySendCartaMotoProperties;
+import com.elrosado.cersuitecloudlocalcore.infrastructure.config.SendCartaMotoProperties;
+import com.elrosado.cersuitecloudlocalcore.infrastructure.config.StoreRegistry;
+import org.slf4j.Logger;
+import org.slf4j.LoggerFactory;
+import org.springframework.stereotype.Service;
+
+import java.util.List;
+
+@Service
+public class SendCartaMotoService implements SendCartaMotoUseCase {
+
+    private static final Logger log = LoggerFactory.getLogger(SendCartaMotoService.class);
+    private static final int STACKTRACE_MAX_LINES = 8;
+
+    private final CartaMotoQueryPort queryPort;
+    private final CartaMotoUpdatePort updatePort;
+    private final CartaMotoStoragePort storagePort;
+    private final CartaMotoTransferPort transferPort;
+    private final SendCartaMotoProperties properties;
+    private final LegacySendCartaMotoProperties legacyProperties;
+    private final StoreRegistry storeRegistry;
+
+    public SendCartaMotoService(
+            CartaMotoQueryPort queryPort,
+            CartaMotoUpdatePort updatePort,
+            CartaMotoStoragePort storagePort,
+            CartaMotoTransferPort transferPort,
+            SendCartaMotoProperties properties,
+            LegacySendCartaMotoProperties legacyProperties,
+            StoreRegistry storeRegistry) {
+        this.queryPort = queryPort;
+        this.updatePort = updatePort;
+        this.storagePort = storagePort;
+        this.transferPort = transferPort;
+        this.properties = properties;
+        this.legacyProperties = legacyProperties;
+        this.storeRegistry = storeRegistry;
+    }
+
+    @Override
+    public void sendPendingCartas() {
+        if (!properties.enabled()) {
+            log.atDebug().setMessage("SendCartaMoto deshabilitado").log();
+            return;
+        }
+
+        if (!storeRegistry.isMultiLocalEnabled()) {
+            log.atWarn().setMessage("SendCartaMoto omitido â sin tiendas multi-local activas en MN_TIENDA").log();
+            return;
+        }
+
+        List<CartaMoto> pending;
+        try {
+            pending = queryPort.findPendingToSend();
+        } catch (RuntimeException e) {
+            throw new SendCartaMotoException(
+                    SendCartaMotoStage.DATABASE_UPDATE,
+                    "Error consultando cartas moto pendientes en CVMT_EC",
+                    e);
+        }
+
+        if (pending.isEmpty()) {
+            log.atDebug().setMessage("Sin cartas moto pendientes de envÃ­o").log();
+            return;
+        }
+
+        log.atInfo()
+                .setMessage("Cartas moto pendientes de envÃ­o encontradas")
+                .addKeyValue("total", pending.size())
+                .log();
+
+        pending.forEach(this::processWithRetry);
+    }
+
+    private void processWithRetry(CartaMoto carta) {
+        int maxRetries = legacyProperties.retries();
+        String fileName = carta.nombArchXml();
+
+        if (storeRegistry.findByDesClave(carta.desClave()).isEmpty()) {
+            log.atWarn()
+                    .setMessage("Tienda de carta moto no activa en registro multi-local â omitida")
+                    .addKeyValue("idCarta", carta.idCarta())
+                    .addKeyValue("desClave", carta.desClave())
+                    .addKeyValue("fileName", fileName)
+                    .log();
+            return;
+        }
+
+        for (int attempt = 1; attempt <= maxRetries; attempt++) {
+            try {
+                sendCarta(carta);
+                log.atInfo()
+                        .setMessage("Carta moto enviada exitosamente")
+                        .addKeyValue("idCarta", carta.idCarta())
+                        .addKeyValue("fileName", fileName)
+                        .addKeyValue("desClave", carta.desClave())
+                        .log();
+                return;
+
+            } catch (Exception e) {
+                SendCartaMotoStage stage = resolveStage(e);
+                if (attempt < maxRetries) {
+                    log.atWarn()
+                            .setMessage("Error enviando carta moto; reintentando")
+                            .addKeyValue("idCarta", carta.idCarta())
+                            .addKeyValue("fileName", fileName)
+                            .addKeyValue("attempt", attempt)
+                            .addKeyValue("stage", stage)
+                            .setCause(e)
+                            .log();
+                } else {
+                    log.atError()
+                            .setMessage("Carta moto no pudo enviarse tras todos los intentos")
+                            .addKeyValue("idCarta", carta.idCarta())
+                            .addKeyValue("fileName", fileName)
+                            .addKeyValue("stage", stage)
+                            .addKeyValue("maxRetries", maxRetries)
+                            .addKeyValue("stackTrace", summarizeStackTrace(e))
+                            .setCause(e)
+                            .log();
+                }
+            }
+        }
+    }
+
+    private void sendCarta(CartaMoto carta) {
+        String fileName = carta.nombArchXml();
+
+        byte[] content = downloadFromGcs(fileName);
+        transferViaSftp(fileName, content);
+        moveToBackup(fileName);
+        markAsSent(carta.idCarta());
+    }
+
+    private byte[] downloadFromGcs(String fileName) {
+        try {
+            return storagePort.downloadXml(fileName);
+        } catch (RuntimeException e) {
+            throw new SendCartaMotoException(
+                    SendCartaMotoStage.GCS_DOWNLOAD,
+                    "Error descargando XML de carta moto desde GCS: " + fileName,
+                    e);
+        }
+    }
+
+    private void transferViaSftp(String fileName, byte[] content) {
+        try {
+            transferPort.transferFile(fileName, content);
+        } catch (RuntimeException e) {
+            throw new SendCartaMotoException(
+                    SendCartaMotoStage.SFTP_TRANSFER,
+                    "Error transfiriendo carta moto por SFTP: " + fileName,
+                    e);
+        }
+    }
+
+    private void moveToBackup(String fileName) {
+        try {
+            GcsObjectReference backup = storagePort.moveToBackup(fileName);
+            log.atDebug()
+                    .setMessage("Carta moto movida a backup")
+                    .addKeyValue("fileName", fileName)
+                    .addKeyValue("backupUri", backup.toUri())
+                    .log();
+        } catch (RuntimeException e) {
+            throw new SendCartaMotoException(
+                    SendCartaMotoStage.GCS_MOVE_TO_BACKUP,
+                    "Error moviendo carta moto a backup en GCS: " + fileName,
+                    e);
+        }
+    }
+
+    private void markAsSent(int idCarta) {
+        try {
+            updatePort.markAsSent(idCarta);
+        } catch (RuntimeException e) {
+            throw new SendCartaMotoException(
+                    SendCartaMotoStage.DATABASE_UPDATE,
+                    "Error actualizando estado de carta moto en CVMT_EC: " + idCarta,
+                    e);
+        }
+    }
+
+    private SendCartaMotoStage resolveStage(Exception error) {
+        if (error instanceof SendCartaMotoException ex) {
+            return ex.stage();
+        }
+        return SendCartaMotoStage.UNKNOWN;
+    }
+
+    private String summarizeStackTrace(Exception error) {
+        StringBuilder summary = new StringBuilder(error.toString());
+        StackTraceElement[] stackTrace = error.getStackTrace();
+        int max = Math.min(stackTrace.length, STACKTRACE_MAX_LINES);
+        for (int i = 0; i < max; i++) {
+            summary.append(System.lineSeparator()).append("at ").append(stackTrace[i]);
+        }
+        return summary.toString();
+    }
+}


