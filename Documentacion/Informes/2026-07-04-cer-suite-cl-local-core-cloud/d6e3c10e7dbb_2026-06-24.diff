+package com.elrosado.cersuitecloudlocalcore.infrastructure.config;
+
+import com.elrosado.cersuitecloudlocalcore.infrastructure.adapter.out.db.saadmin.entity.StoreEntity;
+import com.elrosado.cersuitecloudlocalcore.infrastructure.adapter.out.db.saadmin.repository.StoreJpaRepository;
+import jakarta.annotation.PostConstruct;
+import org.slf4j.Logger;
+import org.slf4j.LoggerFactory;
+import org.springframework.stereotype.Component;
+
+import java.util.Collections;
+import java.util.List;
+import java.util.Optional;
+
+@Component
+public class StoreRegistry {
+
+    private static final Logger log = LoggerFactory.getLogger(StoreRegistry.class);
+
+    private final StoreJpaRepository storeRepository;
+
+    private volatile List<StoreEntity> activeMultiLocalStores = List.of();
+
+    public StoreRegistry(StoreJpaRepository storeRepository) {
+        this.storeRepository = storeRepository;
+    }
+
+    @PostConstruct
+    public void load() {
+        try {
+            activeMultiLocalStores = storeRepository.findByIndActivoAndMultiLocal(1, 1);
+
+            if (activeMultiLocalStores.isEmpty()) {
+                log.atWarn()
+                        .setMessage("No active multi-local stores found in MN_TIENDA â UpdateMoto scheduler will be skipped")
+                        .log();
+            } else {
+                log.atInfo()
+                        .setMessage("StoreRegistry loaded")
+                        .addKeyValue("stores", activeMultiLocalStores.size())
+                        .addKeyValue("storeCodes", activeMultiLocalStores.stream()
+                                .map(s -> String.valueOf(s.getDesClave()))
+                                .toList())
+                        .log();
+            }
+        } catch (Exception e) {
+            log.atWarn()
+                    .setMessage("Failed to load StoreRegistry from SAADMIN â UpdateMoto scheduler will be skipped")
+                    .setCause(e)
+                    .log();
+        }
+    }
+
+    public List<StoreEntity> getActiveMultiLocalStores() {
+        return Collections.unmodifiableList(activeMultiLocalStores);
+    }
+
+    public List<StoreEntity> getActiveLocalServerStores() {
+        return activeMultiLocalStores.stream()
+                .filter(s -> s.getFlLclSrvr() == 1)
+                .toList();
+    }
+
+    public boolean isMultiLocalEnabled() {
+        return !activeMultiLocalStores.isEmpty();
+    }
+
+    public Optional<StoreEntity> findByDesClave(int desClave) {
+        return activeMultiLocalStores.stream()
+                .filter(s -> s.getDesClave() == desClave)
+                .findFirst();
+    }
+}


