+package com.elrosado.cersuitecloudlocalcore.infrastructure.adapter.out.storage;
+
+import com.elrosado.cersuitecloudlocalcore.domain.model.GcsObjectReference;
+import com.elrosado.cersuitecloudlocalcore.domain.port.out.CartaMotoStoragePort;
+import com.elrosado.cersuitecloudlocalcore.infrastructure.config.LegacySendCartaMotoProperties;
+import com.google.cloud.storage.Blob;
+import com.google.cloud.storage.BlobId;
+import com.google.cloud.storage.BlobInfo;
+import com.google.cloud.storage.Storage;
+import org.slf4j.Logger;
+import org.slf4j.LoggerFactory;
+import org.springframework.stereotype.Component;
+
+@Component
+public class GcsCartaMotoStorageAdapter implements CartaMotoStoragePort {
+
+    private static final Logger log = LoggerFactory.getLogger(GcsCartaMotoStorageAdapter.class);
+
+    private final Storage storage;
+    private final LegacySendCartaMotoProperties legacyProperties;
+
+    public GcsCartaMotoStorageAdapter(Storage storage, LegacySendCartaMotoProperties legacyProperties) {
+        this.storage = storage;
+        this.legacyProperties = legacyProperties;
+    }
+
+    @Override
+    public byte[] downloadXml(String fileName) {
+        GcsObjectReference inputFolder = GcsObjectReference.fromUri(legacyProperties.inputUri());
+        BlobId blobId = BlobId.of(inputFolder.bucket(), inputFolder.objectName() + "/" + fileName);
+
+        Blob blob = storage.get(blobId);
+        if (blob == null) {
+            throw new IllegalArgumentException("Archivo XML no encontrado en GCS: " + blobId);
+        }
+
+        byte[] content = blob.getContent();
+        log.atDebug()
+                .setMessage("Archivo XML descargado de GCS")
+                .addKeyValue("fileName", fileName)
+                .addKeyValue("bytes", content.length)
+                .log();
+        return content;
+    }
+
+    @Override
+    public GcsObjectReference moveToBackup(String fileName) {
+        GcsObjectReference inputFolder = GcsObjectReference.fromUri(legacyProperties.inputUri());
+        GcsObjectReference backupFolder = GcsObjectReference.fromUri(legacyProperties.backupUri());
+        GcsObjectReference target = backupFolder.resolve(fileName);
+
+        BlobId sourceId = BlobId.of(inputFolder.bucket(), inputFolder.objectName() + "/" + fileName);
+        BlobId targetId = BlobId.of(target.bucket(), target.objectName());
+
+        storage.delete(targetId);
+        storage.copy(Storage.CopyRequest.newBuilder()
+                .setSource(sourceId)
+                .setTarget(BlobInfo.newBuilder(targetId).build())
+                .build()).getResult();
+
+        boolean deleted = storage.delete(sourceId);
+        if (!deleted) {
+            log.atWarn()
+                    .setMessage("Objeto fuente no eliminado tras mover a backup en GCS")
+                    .addKeyValue("source", inputFolder.toUri() + "/" + fileName)
+                    .log();
+        }
+
+        log.atDebug()
+                .setMessage("Archivo XML movido a backup en GCS")
+                .addKeyValue("fileName", fileName)
+                .addKeyValue("backupUri", target.toUri())
+                .log();
+        return target;
+    }
+}


--- Diff for /src/main/java/com/elrosado/cersuitecloudlocalcore/infrastructure/adapter/out/storage/GcsUpdateMotoStorageAdapter.java ---
--- a//src/main/java/com/elrosado/cersuitecloudlocalcore/infrastructure/adapter/out/storage/GcsUpdateMotoStorageAdapter.java
+++ b//src/main/java/com/elrosado/cersuitecloudlocalcore/infrastructure/adapter/out/storage/GcsUpdateMotoStorageAdapter.java
@@ -0,0 +1,141 @@
+package com.elrosado.cersuitecloudlocalcore.infrastructure.adapter.out.storage;
+
+import com.elrosado.cersuitecloudlocalcore.domain.model.GcsObjectReference;
+import com.elrosado.cersuitecloudlocalcore.domain.model.MotoFile;
+import com.elrosado.cersuitecloudlocalcore.domain.port.out.MotoStoragePort;
+import com.elrosado.cersuitecloudlocalcore.infrastructure.config.LegacyUpdateMotoProperties;
+import com.elrosado.cersuitecloudlocalcore.infrastructure.config.UpdateMotoProperties;
+import com.google.cloud.storage.Blob;
+import com.google.cloud.storage.BlobId;
+import com.google.cloud.storage.BlobInfo;
+import com.google.cloud.storage.Storage;
+import org.slf4j.Logger;
+import org.slf4j.LoggerFactory;
+import org.springframework.stereotype.Component;
+
+import java.io.BufferedReader;
+import java.io.InputStreamReader;
+import java.nio.channels.Channels;
+import java.nio.charset.StandardCharsets;
+import java.util.Comparator;
+import java.util.List;
+import java.util.Optional;
+import java.util.regex.Matcher;
+import java.util.regex.Pattern;
+import java.util.stream.StreamSupport;
+
+@Component
+public class GcsUpdateMotoStorageAdapter implements MotoStoragePort {
+
+    private static final Logger log = LoggerFactory.getLogger(GcsUpdateMotoStorageAdapter.class);
+
+    // Matches MOLOTE{sequence}.{storeCode} â e.g. MOLOTE517.100, MOLOTE001.001
+    private static final Pattern MOTO_FILE_PATTERN =
+            Pattern.compile("^MOLOTE(\\d+)\\.(\\d+)$", Pattern.CASE_INSENSITIVE);
+
+    private final Storage storage;
+    private final LegacyUpdateMotoProperties legacyProperties;
+    private final UpdateMotoProperties properties;
+
+    public GcsUpdateMotoStorageAdapter(
+            Storage storage,
+            LegacyUpdateMotoProperties legacyProperties,
+            UpdateMotoProperties properties) {
+        this.storage = storage;
+        this.legacyProperties = legacyProperties;
+        this.properties = properties;
+    }
+
+    @Override
+    public List<MotoFile> listPendingFiles() {
+        GcsObjectReference input = GcsObjectReference.fromUri(legacyProperties.inputUri());
+        String prefix = input.prefixWithSlash();
+
+        return StreamSupport.stream(
+                        storage.list(input.bucket(), Storage.BlobListOption.prefix(prefix))
+                                .iterateAll()
+                                .spliterator(), false)
+                .filter(blob -> !blob.isDirectory())
+                .flatMap(blob -> toMotoFile(input, prefix, blob).stream())
+                .sorted(Comparator
+                        .comparingInt(MotoFile::storeCode)
+                        .thenComparingInt(MotoFile::sequenceNumber))
+                .toList();
+    }
+
+    @Override
+    public BufferedReader openReader(MotoFile file) {
+        Blob blob = storage.get(BlobId.of(file.location().bucket(), file.location().objectName()));
+        if (blob == null) {
+            throw new IllegalArgumentException("GCS object not found: " + file.location().toUri());
+        }
+        return new BufferedReader(new InputStreamReader(
+                Channels.newInputStream(blob.reader()),
+                StandardCharsets.UTF_8));
+    }
+
+    @Override
+    public GcsObjectReference moveToBackup(MotoFile file) {
+        String storeCodeStr = String.format("%03d", file.storeCode());
+        GcsObjectReference targetFolder = GcsObjectReference.fromUri(
+                legacyProperties.backupUri() + "/" + storeCodeStr);
+        return move(file, targetFolder);
+    }
+
+    @Override
+    public GcsObjectReference moveToError(MotoFile file) {
+        String storeCodeStr = String.format("%03d", file.storeCode());
+        GcsObjectReference targetFolder = GcsObjectReference.fromUri(
+                properties.gcs().errorUri() + "/" + storeCodeStr);
+        return move(file, targetFolder);
+    }
+
+    private Optional<MotoFile> toMotoFile(GcsObjectReference input, String prefix, Blob blob) {
+        String objectName = blob.getName();
+        if (!objectName.startsWith(prefix)) return Optional.empty();
+
+        String relativeName = objectName.substring(prefix.length());
+        if (relativeName.isBlank() || relativeName.contains("/")) return Optional.empty();
+
+        Matcher matcher = MOTO_FILE_PATTERN.matcher(relativeName);
+        if (!matcher.matches()) return Optional.empty();
+
+        try {
+            int sequence = Integer.parseInt(matcher.group(1));
+            int storeCode = Integer.parseInt(matcher.group(2));
+            return Optional.of(new MotoFile(
+                    new GcsObjectReference(input.bucket(), objectName),
+                    relativeName,
+                    storeCode,
+                    sequence
+            ));
+        } catch (NumberFormatException e) {
+            log.atWarn()
+                    .setMessage("Invalid MOTO filename format; skipped")
+                    .addKeyValue("fileName", relativeName)
+                    .log();
+            return Optional.empty();
+        }
+    }
+
+    private GcsObjectReference move(MotoFile file, GcsObjectReference targetFolder) {
+        GcsObjectReference target = targetFolder.resolve(file.fileName());
+        BlobId sourceId = BlobId.of(file.location().bucket(), file.location().objectName());
+        BlobId targetId = BlobId.of(target.bucket(), target.objectName());
+
+        storage.delete(targetId);
+        storage.copy(Storage.CopyRequest.newBuilder()
+                .setSource(sourceId)
+                .setTarget(BlobInfo.newBuilder(targetId).build())
+                .build()).getResult();
+
+        boolean deleted = storage.delete(sourceId);
+        if (!deleted) {
+            log.atWarn()
+                    .setMessage("Source object not deleted after GCS move")
+                    .addKeyValue("sourceObject", file.location().toUri())
+                    .log();
+        }
+        return target;
+    }
+}


