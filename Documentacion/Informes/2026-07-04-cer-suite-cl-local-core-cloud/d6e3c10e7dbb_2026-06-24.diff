+    private static final int MAX_ATTEMPTS = 3;
+    private static final int STACKTRACE_MAX_LINES = 8;
+    private static final String PROCESS_NAME = "UpdateMotoProcess";
+    private static final String PROCESS_TYPE = "SCHEDULER";
+
+    private final MotoStoragePort storagePort;
+    private final MotoPersistencePort persistencePort;
+    private final MotoErrorTrackerPort errorTrackerPort;
+    private final MotoFileParser parser;
+    private final UpdateMotoProperties properties;
+    private final StoreRegistry storeRegistry;
+    private final AsyncTaskExecutor virtualThreadTaskExecutor;
+
+    public UpdateMotoService(
+            MotoStoragePort storagePort,
+            MotoPersistencePort persistencePort,
+            MotoErrorTrackerPort errorTrackerPort,
+            MotoFileParser parser,
+            UpdateMotoProperties properties,
+            StoreRegistry storeRegistry,
+            @Qualifier("virtualThreadTaskExecutor") AsyncTaskExecutor virtualThreadTaskExecutor) {
+        this.storagePort = storagePort;
+        this.persistencePort = persistencePort;
+        this.errorTrackerPort = errorTrackerPort;
+        this.parser = parser;
+        this.properties = properties;
+        this.storeRegistry = storeRegistry;
+        this.virtualThreadTaskExecutor = virtualThreadTaskExecutor;
+    }
+
+    @Override
+    public void processPendingFiles() {
+        if (!properties.enabled()) {
+            log.atDebug().setMessage("UpdateMoto disabled").log();
+            return;
+        }
+
+        if (!storeRegistry.isMultiLocalEnabled()) {
+            log.atWarn().setMessage("UpdateMoto skipped â no active multi-local stores in MN_TIENDA").log();
+            return;
+        }
+
+        List<MotoFile> pendingFiles;
+        try {
+            pendingFiles = storagePort.listPendingFiles();
+        } catch (RuntimeException e) {
+            throw new MotoProcessingException(
+                    MotoProcessingStage.GCS_LIST,
+                    "Error listing MOTO files in GCS",
+                    e);
+        }
+
+        if (pendingFiles.isEmpty()) {
+            log.atDebug().setMessage("No pending MOTO files").log();
+            return;
+        }
+
+        // Group by storeCode; within each group files are already ordered by sequenceNumber
+        Map<Integer, List<MotoFile>> filesByStore = pendingFiles.stream()
+                .collect(Collectors.groupingBy(MotoFile::storeCode));
+
+        log.atInfo()
+                .setMessage("Pending MOTO files â launching per-store processing")
+                .addKeyValue("totalFiles", pendingFiles.size())
+                .addKeyValue("storeCount", filesByStore.size())
+                .log();
+
+        // One virtual thread per store; files processed sequentially within each store
+        List<CompletableFuture<Void>> futures = filesByStore.entrySet().stream()
+                .map(entry -> CompletableFuture
+                        .runAsync(() -> processStoreFiles(entry.getKey(), entry.getValue()),
+                                virtualThreadTaskExecutor)
+                        .exceptionally(ex -> {
+                            log.atError()
+                                    .setMessage("Unhandled error in MOTO store thread")
+                                    .addKeyValue("storeCode", entry.getKey())
+                                    .setCause(ex)
+                                    .log();
+                            return null;
+                        }))
+                .toList();
+
+        CompletableFuture.allOf(futures.toArray(CompletableFuture[]::new)).join();
+    }
+
+    private void processStoreFiles(int storeCode, List<MotoFile> files) {
+        if (storeRegistry.findByDesClave(storeCode).isEmpty()) {
+            log.atWarn()
+                    .setMessage("MOTO files for store not in registry â moving to error")
+                    .addKeyValue("storeCode", String.format("%03d", storeCode))
+                    .addKeyValue("fileCount", files.size())
+                    .log();
+            files.forEach(file -> moveUnknownStoreToError(file, storeCode));
+            return;
+        }
+
+        log.atInfo()
+                .setMessage("Processing MOTO files for store")
+                .addKeyValue("storeCode", String.format("%03d", storeCode))
+                .addKeyValue("fileCount", files.size())
+                .log();
+
+        files.forEach(this::processWithRetry);
+    }
+
+    private void processWithRetry(MotoFile file) {
+        String processId = UUID.randomUUID().toString();
+        Instant executionDate = Instant.now();
+
+        for (int attempt = 1; attempt <= MAX_ATTEMPTS; attempt++) {
+            try {
+                MotoProcessingResult result = processFile(file);
+                GcsObjectReference backupObject = moveToBackup(file);
+
+                log.atInfo()
+                        .setMessage("MOTO file processed")
+                        .addKeyValue("processId", processId)
+                        .addKeyValue("storeCode", String.format("%03d", file.storeCode()))
+                        .addKeyValue("fileName", file.fileName())
+                        .addKeyValue("linesInserted", result.linesInserted())
+                        .addKeyValue("linesUpdated", result.linesUpdated())
+                        .addKeyValue("backupObject", backupObject.toUri())
+                        .log();
+                return;
+
+            } catch (Exception e) {
+                MotoProcessingStage stage = resolveStage(e);
+                if (attempt < MAX_ATTEMPTS) {
+                    log.atWarn()
+                            .setMessage("Error processing MOTO file; will retry")
+                            .addKeyValue("processId", processId)
+                            .addKeyValue("storeCode", String.format("%03d", file.storeCode()))
+                            .addKeyValue("fileName", file.fileName())
+                            .addKeyValue("attempt", attempt)
+                            .addKeyValue("stage", stage)
+                            .setCause(e)
+                            .log();
+                    continue;
+                }
+
+                handleFinalFailure(file, processId, executionDate, stage, e);
+            }
+        }
+    }
+
+    private void moveUnknownStoreToError(MotoFile file, int storeCode) {
+        String processId = UUID.randomUUID().toString();
+        Instant now = Instant.now();
+        String storeCodeStr = String.format("%03d", storeCode);
+
+        GcsObjectReference errorObject;
+        try {
+            errorObject = storagePort.moveToError(file);
+        } catch (RuntimeException e) {
+            log.atError()
+                    .setMessage("Failed to move unknown-store MOTO file to error bucket")
+                    .addKeyValue("storeCode", storeCodeStr)
+                    .addKeyValue("fileName", file.fileName())
+                    .setCause(e)
+                    .log();
+            return;
+        }
+
+        try {
+            errorTrackerPort.recordError(new MotoErrorRecord(
+                    PROCESS_NAME,
+                    PROCESS_TYPE,
+                    processId,
+                    storeCodeStr,
+                    file.fileName(),
+                    file.location().bucket(),
+                    file.location().toUri(),
+                    MotoProcessingStage.UNKNOWN.name(),
+                    "",
+                    "UnknownStoreCode",
+                    "",
+                    "Store code " + storeCodeStr + " not found in active multi-local registry",
+                    "",
+                    0,
+                    0,
+                    true,
+                    "UNKNOWN_STORE",
+                    now,
+                    now,
+                    System.getenv().getOrDefault("HOSTNAME", ""),
+                    System.getenv().getOrDefault("POD_NAME", ""),
+                    processId
+            ));
+        } catch (RuntimeException e) {
+            log.atError()
+                    .setMessage("Unknown-store MOTO file moved to error without Firestore record")
+                    .addKeyValue("storeCode", storeCodeStr)
+                    .addKeyValue("errorObject", errorObject.toUri())
+                    .setCause(e)
+                    .log();
+        }
+
+        log.atWarn()
+                .setMessage("Unknown-store MOTO file moved to error")
+                .addKeyValue("storeCode", storeCodeStr)
+                .addKeyValue("fileName", file.fileName())
+                .addKeyValue("errorObject", errorObject.toUri())
+                .log();
+    }
+
+    private MotoProcessingResult processFile(MotoFile file) {
+        MotoProcessingResult totalResult = new MotoProcessingResult(0, 0, 0);
+        List<MotoRecord> batch = new ArrayList<>(properties.batchSize());
+        long lineNumber = 0;
+
+        try (BufferedReader reader = openReader(file)) {
+            String line;
+            while ((line = reader.readLine()) != null) {
+                lineNumber++;
+                MotoRecord record = parseLine(line, lineNumber);
+                batch.add(record);
+
+                if (batch.size() >= properties.batchSize()) {
+                    totalResult = totalResult.plus(saveBatch(batch));
+                    batch.clear();
+                }
+            }
+            if (!batch.isEmpty()) {
+                totalResult = totalResult.plus(saveBatch(batch));
+            }
+        } catch (IOException e) {
+            throw new MotoProcessingException(
+                    MotoProcessingStage.GCS_READ,
+                    "Error reading MOTO file from GCS",
+                    e);
+        }
+
+        return totalResult;
+    }
+
+    private BufferedReader openReader(MotoFile file) {
+        try {
+            return storagePort.openReader(file);
+        } catch (RuntimeException e) {
+            throw new MotoProcessingException(
+                    MotoProcessingStage.GCS_READ,
+                    "Error opening MOTO file from GCS",
+                    e);
+        }
+    }
+
+    private MotoRecord parseLine(String line, long lineNumber) {
+        try {
+            return parser.parseLine(line, lineNumber);
+        } catch (RuntimeException e) {
+            throw new MotoProcessingException(
+                    MotoProcessingStage.PARSING,
+                    "Error parsing line " + lineNumber,
+                    e);
+        }
+    }
+
+    private MotoProcessingResult saveBatch(List<MotoRecord> batch) {
+        try {
+            return persistencePort.processAndSaveBatch(List.copyOf(batch));
+        } catch (RuntimeException e) {
+            throw new MotoProcessingException(
+                    MotoProcessingStage.DATABASE_WRITE,
+                    "Error persisting MOTO batch",
+                    e);
+        }
+    }
+
+    private GcsObjectReference moveToBackup(MotoFile file) {
+        try {
+            return storagePort.moveToBackup(file);
+        } catch (RuntimeException e) {
+            throw new MotoProcessingException(
+                    MotoProcessingStage.GCS_MOVE_TO_BACKUP,
+                    "Error moving processed MOTO file to backup GCS",
+                    e);
+        }
+    }
+
+    private void handleFinalFailure(
+            MotoFile file,
+            String processId,
+            Instant executionDate,
+            MotoProcessingStage stage,
+            Exception error) {
+        GcsObjectReference errorObject;
+        try {
+            errorObject = storagePort.moveToError(file);
+        } catch (RuntimeException moveError) {
+            log.atError()
+                    .setMessage("Could not move MOTO file to error bucket")
+                    .addKeyValue("processId", processId)
+                    .addKeyValue("storeCode", String.format("%03d", file.storeCode()))
+                    .addKeyValue("fileName", file.fileName())
+                    .addKeyValue("stage", MotoProcessingStage.GCS_MOVE_TO_ERROR)
+                    .setCause(moveError)
+                    .log();
+            return;
+        }
+
+        Instant now = Instant.now();
+        String storeCodeStr = String.format("%03d", file.storeCode());
+        try {
+            errorTrackerPort.recordError(new MotoErrorRecord(
+                    PROCESS_NAME,
+                    PROCESS_TYPE,
+                    processId,
+                    storeCodeStr,
+                    file.fileName(),
+                    file.location().bucket(),
+                    file.location().toUri(),
+                    stage.name(),
+                    "",
+                    error.getClass().getSimpleName(),
+                    "",
+                    error.getMessage(),
+                    summarizeStackTrace(error),
+                    MAX_ATTEMPTS,
+                    MAX_ATTEMPTS,
+                    true,
+                    "EXHAUSTED",
+                    executionDate,
+                    now,
+                    System.getenv().getOrDefault("HOSTNAME", ""),
+                    System.getenv().getOrDefault("POD_NAME", ""),
+                    processId
+            ));
+        } catch (RuntimeException trackingError) {
+            log.atError()
+                    .setMessage("MOTO file moved to error without Firestore record")
+                    .addKeyValue("processId", processId)
+                    .addKeyValue("storeCode", storeCodeStr)
+                    .addKeyValue("fileName", file.fileName())
+                    .addKeyValue("errorObject", errorObject.toUri())
+                    .setCause(trackingError)
+                    .log();
+        }
+
+        log.atError()
+                .setMessage("MOTO file sent to error bucket")
+                .addKeyValue("processId", processId)
+                .addKeyValue("storeCode", storeCodeStr)
+                .addKeyValue("fileName", file.fileName())
+                .addKeyValue("stage", stage)
+                .addKeyValue("errorObject", errorObject.toUri())
+                .setCause(error)
+                .log();
+    }
+
+    private MotoProcessingStage resolveStage(Exception error) {
+        if (error instanceof MotoProcessingException processingException) {
+            return processingException.stage();
+        }
+        return MotoProcessingStage.UNKNOWN;
+    }
+
+    private String summarizeStackTrace(Exception error) {
+        StringBuilder summary = new StringBuilder(error.toString());
+        StackTraceElement[] stackTrace = error.getStackTrace();
+        int max = Math.min(stackTrace.length, STACKTRACE_MAX_LINES);
+        for (int i = 0; i < max; i++) {
+            summary.append(System.lineSeparator()).append("at ").append(stackTrace[i]);
+        }
+        return summary.toString();
+    }
+}


