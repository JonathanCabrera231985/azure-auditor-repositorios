+package com.elrosado.cersuitecloudlocalcore.infrastructure.adapter.out.zip;
+
+import org.junit.jupiter.api.Test;
+
+import java.io.ByteArrayInputStream;
+import java.io.IOException;
+import java.util.LinkedHashMap;
+import java.util.Map;
+import java.util.zip.ZipEntry;
+import java.util.zip.ZipInputStream;
+
+import static org.assertj.core.api.Assertions.assertThat;
+
+class ZipCompressionAdapterTest {
+
+    private final ZipCompressionAdapter adapter = new ZipCompressionAdapter();
+
+    @Test
+    void compress_singleEntry_returnsValidZip() throws IOException {
+        byte[] content = "file-content".getBytes();
+        Map<String, byte[]> entries = Map.of("report.xml", content);
+
+        byte[] zip = adapter.compress(entries);
+
+        assertThat(zip).isNotEmpty();
+        try (ZipInputStream zis = new ZipInputStream(new ByteArrayInputStream(zip))) {
+            ZipEntry entry = zis.getNextEntry();
+            assertThat(entry).isNotNull();
+            assertThat(entry.getName()).isEqualTo("report.xml");
+            assertThat(zis.readAllBytes()).isEqualTo(content);
+            assertThat(zis.getNextEntry()).isNull();
+        }
+    }
+
+    @Test
+    void compress_multipleEntries_containsAllFiles() throws IOException {
+        byte[] txtContent = "txt-content".getBytes();
+        byte[] pdfContent = "pdf-content".getBytes();
+        Map<String, byte[]> entries = new LinkedHashMap<>();
+        entries.put("summary.txt", txtContent);
+        entries.put("summary.pdf", pdfContent);
+
+        byte[] zip = adapter.compress(entries);
+
+        assertThat(zip).isNotEmpty();
+        int entryCount = 0;
+        try (ZipInputStream zis = new ZipInputStream(new ByteArrayInputStream(zip))) {
+            ZipEntry entry;
+            while ((entry = zis.getNextEntry()) != null) {
+                assertThat(entries).containsKey(entry.getName());
+                entryCount++;
+                zis.closeEntry();
+            }
+        }
+        assertThat(entryCount).isEqualTo(2);
+    }
+}


