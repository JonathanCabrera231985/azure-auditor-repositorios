--- Diff for /src/main/java/com/elrosado/cersuitecloudlocalcore/infrastructure/adapter/out/storage/GcsClosingDayStorageAdapter.java ---
--- a//src/main/java/com/elrosado/cersuitecloudlocalcore/infrastructure/adapter/out/storage/GcsClosingDayStorageAdapter.java
+++ b//src/main/java/com/elrosado/cersuitecloudlocalcore/infrastructure/adapter/out/storage/GcsClosingDayStorageAdapter.java
@@ -0,0 +1,137 @@
+package com.elrosado.cersuitecloudlocalcore.infrastructure.adapter.out.storage;
+
+import com.elrosado.cersuitecloudlocalcore.domain.model.ClosingDayBlob;
+import com.elrosado.cersuitecloudlocalcore.domain.model.GcsObjectReference;
+import com.elrosado.cersuitecloudlocalcore.domain.port.out.ClosingDayStoragePort;
+import com.elrosado.cersuitecloudlocalcore.infrastructure.config.LegacyClosingDayProperties;
+import com.google.cloud.storage.Blob;
+import com.google.cloud.storage.BlobId;
+import com.google.cloud.storage.Storage;
+import org.slf4j.Logger;
+import org.slf4j.LoggerFactory;
+import org.springframework.stereotype.Component;
+
+import java.util.Comparator;
+import java.util.List;
+import java.util.Optional;
+
+@Component
+public class GcsClosingDayStorageAdapter implements ClosingDayStoragePort {
+
+    private static final Logger log = LoggerFactory.getLogger(GcsClosingDayStorageAdapter.class);
+    private static final String ZIP_CONTENT_TYPE = "application/zip";
+
+    private final GcsStorageHelper gcsHelper;
+    private final Storage storage;
+    private final LegacyClosingDayProperties properties;
+
+    public GcsClosingDayStorageAdapter(
+            GcsStorageHelper gcsHelper,
+            Storage storage,
+            LegacyClosingDayProperties properties) {
+        this.gcsHelper = gcsHelper;
+        this.storage = storage;
+        this.properties = properties;
+    }
+
+    @Override
+    public List<ClosingDayBlob> listSourceFiles(String storeCode) {
+        GcsObjectReference storeFolder = buildStoreFolder(storeCode);
+        String prefixWithSlash = storeFolder.prefixWithSlash();
+
+        return gcsHelper.streamBlobs(storeFolder)
+                .flatMap(blob -> toClosingDayBlob(blob, prefixWithSlash).stream())
+                .sorted(Comparator.comparing(ClosingDayBlob::fileName))
+                .toList();
+    }
+
+    @Override
+    public Optional<ClosingDayBlob> findAssociatedPdf(ClosingDayBlob blob) {
+        String objectName = blob.location().objectName();
+        int lastSlash = objectName.lastIndexOf('/');
+        String parentPath = objectName.substring(0, lastSlash);
+        String pdfObjectName = parentPath + "/" + blob.baseName() + ".pdf";
+
+        Blob pdfBlob = storage.get(BlobId.of(blob.location().bucket(), pdfObjectName));
+        if (pdfBlob == null) {
+            return Optional.empty();
+        }
+        return Optional.of(new ClosingDayBlob(
+                new GcsObjectReference(blob.location().bucket(), pdfObjectName),
+                "pdf"
+        ));
+    }
+
+    @Override
+    public byte[] download(ClosingDayBlob blob) {
+        return storage.readAllBytes(blob.location().bucket(), blob.location().objectName());
+    }
+
+    @Override
+    public boolean zipExistsInTransferir(String storeCode, String zipName) {
+        GcsObjectReference zipRef = buildZipRef(storeCode, zipName);
+        Blob blob = storage.get(BlobId.of(zipRef.bucket(), zipRef.objectName()));
+        return blob != null;
+    }
+
+    @Override
+    public GcsObjectReference uploadZip(String storeCode, String zipName, byte[] content) {
+        GcsObjectReference target = buildZipRef(storeCode, zipName);
+        return gcsHelper.upload(target, content, ZIP_CONTENT_TYPE);
+    }
+
+    @Override
+    public void deleteBlob(ClosingDayBlob blob) {
+        boolean deleted = storage.delete(BlobId.of(blob.location().bucket(), blob.location().objectName()));
+        if (!deleted) {
+            log.atWarn()
+                    .setMessage("Blob GCS no eliminado â puede haber sido removido por otro proceso")
+                    .addKeyValue("uri", blob.location().toUri())
+                    .log();
+        }
+    }
+
+    private GcsObjectReference buildStoreFolder(String storeCode) {
+        String objectName = properties.gcs().basePrefix() + "/" + storeCode;
+        return new GcsObjectReference(properties.gcs().bucket(), objectName);
+    }
+
+    private GcsObjectReference buildZipRef(String storeCode, String zipName) {
+        String objectName = properties.gcs().basePrefix()
+                + "/" + storeCode
+                + "/" + properties.gcs().transferirSuffix()
+                + "/" + zipName;
+        return new GcsObjectReference(properties.gcs().bucket(), objectName);
+    }
+
+    private Optional<ClosingDayBlob> toClosingDayBlob(Blob blob, String prefixWithSlash) {
+        String objectName = blob.getName();
+        if (!objectName.startsWith(prefixWithSlash)) {
+            return Optional.empty();
+        }
+
+        String relativeName = objectName.substring(prefixWithSlash.length());
+
+        // Solo blobs directos â sin subfolders como TRANSFERIR/ o PROCESADO/
+        if (relativeName.isBlank() || relativeName.contains("/")) {
+            return Optional.empty();
+        }
+
+        int dotIndex = relativeName.lastIndexOf('.');
+        if (dotIndex <= 0) {
+            return Optional.empty();
+        }
+
+        String extension = relativeName.substring(dotIndex + 1).toLowerCase();
+
+        // Solo .xml y .txt son archivos de entrada vÃ¡lidos
+        if (!extension.equals("xml") && !extension.equals("txt")) {
+            return Optional.empty();
+        }
+
+        return Optional.of(new ClosingDayBlob(
+                new GcsObjectReference(blob.getBucket(), objectName),
+                extension
+        ));
+    }
+}


