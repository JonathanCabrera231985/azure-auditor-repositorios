+import java.util.ArrayList;
+import java.util.LinkedHashMap;
+import java.util.List;
+import java.util.Map;
+
+@Service
+public class SendClosingDayService implements SendClosingDayUseCase {
+
+    private static final Logger log = LoggerFactory.getLogger(SendClosingDayService.class);
+
+    private final ClosingDayStoragePort storagePort;
+    private final ClosingDayZipPort zipPort;
+    private final ClosingDayEventPort eventPort;
+    private final StoreRegistry storeRegistry;
+    private final SendClosingDayProperties properties;
+
+    public SendClosingDayService(
+            ClosingDayStoragePort storagePort,
+            ClosingDayZipPort zipPort,
+            ClosingDayEventPort eventPort,
+            StoreRegistry storeRegistry,
+            SendClosingDayProperties properties) {
+        this.storagePort = storagePort;
+        this.zipPort = zipPort;
+        this.eventPort = eventPort;
+        this.storeRegistry = storeRegistry;
+        this.properties = properties;
+    }
+
+    @Override
+    public void processAllPendingFiles() {
+        if (!properties.enabled()) {
+            log.debug("Proceso SendClosingDay deshabilitado");
+            return;
+        }
+
+        if (!storeRegistry.isMultiLocalEnabled()) {
+            log.debug("No hay tiendas MULTI_LOCAL activas â omitiendo ciclo de cierre de dÃ­a");
+            return;
+        }
+
+        storeRegistry.getActiveMultiLocalStores().forEach(store -> {
+            String storeCode = String.valueOf(store.getDesClave());
+            processStore(storeCode);
+        });
+    }
+
+    private void processStore(String storeCode) {
+        List<ClosingDayBlob> files = storagePort.listSourceFiles(storeCode);
+
+        if (files.isEmpty()) {
+            log.debug("Sin archivos de cierre de dÃ­a pendientes para tienda {}", storeCode);
+            return;
+        }
+
+        log.atInfo()
+                .setMessage("Procesando archivos de cierre de dÃ­a")
+                .addKeyValue("storeCode", storeCode)
+                .addKeyValue("fileCount", files.size())
+                .log();
+
+        files.forEach(blob -> processBlob(storeCode, blob));
+    }
+
+    private void processBlob(String storeCode, ClosingDayBlob blob) {
+        String zipName = blob.baseName() + ".zip";
+
+        if (storagePort.zipExistsInTransferir(storeCode, zipName)) {
+            log.atInfo()
+                    .setMessage("ZIP ya existe en TRANSFERIR, omitiendo")
+                    .addKeyValue("storeCode", storeCode)
+                    .addKeyValue("zipName", zipName)
+                    .log();
+            return;
+        }
+
+        if (!blob.isXml() && !blob.isTxt()) {
+            log.atWarn()
+                    .setMessage("Tipo de archivo no esperado en cierre de dÃ­a, omitiendo")
+                    .addKeyValue("storeCode", storeCode)
+                    .addKeyValue("fileName", blob.fileName())
+                    .addKeyValue("extension", blob.extension())
+                    .log();
+            return;
+        }
+
+        Map<String, byte[]> entries = new LinkedHashMap<>();
+        List<ClosingDayBlob> blobsToDelete = new ArrayList<>();
+
+        entries.put(blob.fileName(), storagePort.download(blob));
+        blobsToDelete.add(blob);
+
+        if (blob.isTxt()) {
+            storagePort.findAssociatedPdf(blob).ifPresent(pdf -> {
+                entries.put(pdf.fileName(), storagePort.download(pdf));
+                blobsToDelete.add(pdf);
+            });
+        }
+
+        byte[] zipContent = zipPort.compress(entries);
+        GcsObjectReference zipRef = storagePort.uploadZip(storeCode, zipName, zipContent);
+
+        eventPort.publishZipReady(storeCode, zipRef.objectName());
+
+        blobsToDelete.forEach(storagePort::deleteBlob);
+
+        log.atInfo()
+                .setMessage("ZIP de cierre de dÃ­a generado y publicado")
+                .addKeyValue("storeCode", storeCode)
+                .addKeyValue("zipName", zipName)
+                .addKeyValue("totalEntries", entries.size())
+                .log();
+    }
+}


