@@ -0,0 +1,39 @@
+package com.elrosado.cersuitecloudlocalcore.domain.model;
+
+import java.util.Objects;
+
+/**
+ * Representa un archivo de cierre de dÃ­a ubicado en GCS antes de ser comprimido.
+ */
+public record ClosingDayBlob(GcsObjectReference location, String extension) {
+
+    public ClosingDayBlob {
+        Objects.requireNonNull(location, "location is required");
+        if (extension == null || extension.isBlank()) {
+            throw new IllegalArgumentException("extension is required");
+        }
+        extension = extension.toLowerCase();
+    }
+
+    public String fileName() {
+        return location.fileName();
+    }
+
+    public String baseName() {
+        String name = fileName();
+        int dot = name.lastIndexOf('.');
+        return dot > 0 ? name.substring(0, dot) : name;
+    }
+
+    public boolean isXml() {
+        return "xml".equals(extension);
+    }
+
+    public boolean isTxt() {
+        return "txt".equals(extension);
+    }
+
+    public boolean isPdf() {
+        return "pdf".equals(extension);
+    }
+}


