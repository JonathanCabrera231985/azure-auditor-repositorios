+package com.elrosado.cersuitecloudlocalcore.infrastructure.adapter.out.firestore;
+
+import com.elrosado.cersuitecloudlocalcore.domain.model.FrameRepro;
+import com.elrosado.cersuitecloudlocalcore.domain.port.out.FrameReproFirestorePort;
+import com.google.cloud.Timestamp;
+import com.google.cloud.firestore.DocumentReference;
+import com.google.cloud.firestore.DocumentSnapshot;
+import com.google.cloud.firestore.FieldValue;
+import com.google.cloud.firestore.Firestore;
+import com.google.cloud.firestore.QuerySnapshot;
+import org.slf4j.Logger;
+import org.slf4j.LoggerFactory;
+import org.springframework.beans.factory.annotation.Value;
+import org.springframework.stereotype.Component;
+
+import java.util.ArrayList;
+import java.util.List;
+import java.util.Map;
+import java.util.concurrent.ExecutionException;
+
+/**
+ * Operaciones Firestore sobre la colecciÃ³n frames-repro.
+ * Usa el bean Firestore directamente (Spring Cloud GCP auto-config) para
+ * queries con filtro null y transacciones atÃ³micas.
+ */
+@Component
+public class FrameReproFirestoreAdapter implements FrameReproFirestorePort {
+
+    private static final Logger log = LoggerFactory.getLogger(FrameReproFirestoreAdapter.class);
+
+    private final Firestore firestore;
+
+    @Value("${app.gcp.firestore.collection-repro:frames-repro}")
+    private String reproCollection;
+
+    public FrameReproFirestoreAdapter(Firestore firestore) {
+        this.firestore = firestore;
+    }
+
+    @Override
+    public List<FrameRepro> queryPending(int maxResults) {
+        try {
+            // whereEqualTo("status", null) captura documentos donde el campo status
+            // estÃ¡ ausente o es explÃ­citamente null â ambos indican inserciÃ³n manual sin procesar.
+            QuerySnapshot snapshot = firestore
+                    .collection(reproCollection)
+                    .whereEqualTo("status", null)
+                    .limit(maxResults)
+                    .get()
+                    .get();
+
+            List<FrameRepro> result = new ArrayList<>();
+            for (DocumentSnapshot doc : snapshot.getDocuments()) {
+                String transactionId = doc.getString("id_repro");
+                if (transactionId != null && !transactionId.isBlank()) {
+                    result.add(new FrameRepro(doc.getId(), transactionId));
+                }
+            }
+            return result;
+
+        } catch (InterruptedException e) {
+            Thread.currentThread().interrupt();
+            throw new IllegalStateException("Consulta frames-repro interrumpida", e);
+        } catch (ExecutionException e) {
+            throw new IllegalStateException("Error consultando frames-repro pendientes", e.getCause());
+        }
+    }
+
+    @Override
+    public boolean claimDocument(String reproId, String instanceId) {
+        DocumentReference ref = firestore.collection(reproCollection).document(reproId);
+
+        try {
+            return firestore.runTransaction(transaction -> {
+                DocumentSnapshot snap = transaction.get(ref).get();
+
+                // CondiciÃ³n de claim: campo status debe estar ausente (null).
+                // Cualquier valor indica que otra rÃ©plica ya lo tomÃ³.
+                if (snap.getString("status") != null) {
+                    return false;
+                }
+
+                transaction.update(ref, Map.of(
+                        "status",     "PROCESSING",
+                        "claimedAt",  Timestamp.now(),
+                        "instanceId", instanceId
+                ));
+                return true;
+
+            }).get();
+
+        } catch (InterruptedException e) {
+            Thread.currentThread().interrupt();
+            throw new IllegalStateException("Claim frames-repro interrumpido: " + reproId, e);
+        } catch (ExecutionException e) {
+            log.atWarn()
+                    .setMessage("Conflicto de claim â otra rÃ©plica ganÃ³")
+                    .addKeyValue("reproId", reproId)
+                    .log();
+            return false;
+        }
+    }
+
+    @Override
+    public void deleteDocument(String reproId) {
+        try {
+            firestore.collection(reproCollection)
+                    .document(reproId)
+                    .delete()
+                    .get();
+
+            log.atInfo()
+                    .setMessage("Documento frames-repro eliminado tras reproceso exitoso")
+                    .addKeyValue("reproId", reproId)
+                    .log();
+
+        } catch (InterruptedException e) {
+            Thread.currentThread().interrupt();
+            throw new IllegalStateException("deleteDocument interrumpido: " + reproId, e);
+        } catch (ExecutionException e) {
+            throw new IllegalStateException("Error eliminando frames-repro: " + reproId, e.getCause());
+        }
+    }
+
+    @Override
+    public void releaseDocument(String reproId) {
+        try {
+            // Eliminar el campo status devuelve el documento al estado inicial
+            // (sin campo status), haciÃ©ndolo tomable en el prÃ³ximo ciclo del scheduler.
+            firestore.collection(reproCollection)
+                    .document(reproId)
+                    .update("status", FieldValue.delete())
+                    .get();
+
+            log.atWarn()
+                    .setMessage("Documento frames-repro liberado para reintento")
+                    .addKeyValue("reproId", reproId)
+                    .log();
+
+        } catch (InterruptedException e) {
+            Thread.currentThread().interrupt();
+            throw new IllegalStateException("releaseDocument interrumpido: " + reproId, e);
+        } catch (ExecutionException e) {
+            throw new IllegalStateException("Error liberando frames-repro: " + reproId, e.getCause());
+        }
+    }
+}


