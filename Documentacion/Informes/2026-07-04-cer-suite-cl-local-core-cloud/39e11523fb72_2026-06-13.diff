+package com.elrosado.cersuitecloudlocalcore.service;
+
+import com.elrosado.cersuitecloudlocalcore.domain.port.in.ReproUseCase;
+import com.elrosado.cersuitecloudlocalcore.domain.port.out.EventPublisherPort;
+import com.elrosado.cersuitecloudlocalcore.domain.port.out.TransactionFirestorePort;
+import org.slf4j.Logger;
+import org.slf4j.LoggerFactory;
+import org.springframework.stereotype.Service;
+
+/**
+ * Orquesta el reproceso de una transacciÃ³n cuyo XML fue corregido manualmente en Firestore.
+ *
+ * Flujo:
+ * 1. Leer storeId del documento frames
+ * 2. Limpiar errorMessageDistributor y marcar XML_GENERATED
+ * 3. Publicar al tÃ³pico de Distributor Cloud
+ */
+@Service
+public class ReproService implements ReproUseCase {
+
+    private static final Logger log = LoggerFactory.getLogger(ReproService.class);
+
+    private final TransactionFirestorePort firestorePort;
+    private final EventPublisherPort distributorPublisher;
+
+    public ReproService(TransactionFirestorePort firestorePort, EventPublisherPort distributorPublisher) {
+        this.firestorePort = firestorePort;
+        this.distributorPublisher = distributorPublisher;
+    }
+
+    @Override
+    public void executeRepro(String reproId, String transactionId) {
+        log.atInfo()
+                .setMessage("Iniciando reproceso de transacciÃ³n")
+                .addKeyValue("reproId", reproId)
+                .addKeyValue("transactionId", transactionId)
+                .log();
+
+        String storeId = firestorePort.readStoreIdForRepro(transactionId);
+
+        firestorePort.clearErrorForRepro(transactionId);
+
+        distributorPublisher.publishXmlGenerated(transactionId, storeId);
+
+        log.atInfo()
+                .setMessage("Reproceso completado â XML_GENERATED publicado al Distributor Cloud")
+                .addKeyValue("reproId", reproId)
+                .addKeyValue("transactionId", transactionId)
+                .addKeyValue("storeId", storeId)
+                .log();
+    }
+}


