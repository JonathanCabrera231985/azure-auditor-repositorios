+package com.elrosado.cersuitecloudlocalcore.infrastructure.adapter.in.scheduler;
+
+import com.elrosado.cersuitecloudlocalcore.domain.model.FrameRepro;
+import com.elrosado.cersuitecloudlocalcore.domain.port.in.ReproUseCase;
+import com.elrosado.cersuitecloudlocalcore.domain.port.out.FrameReproFirestorePort;
+import com.elrosado.cersuitecloudlocalcore.infrastructure.config.ReproProperties;
+import org.slf4j.Logger;
+import org.slf4j.LoggerFactory;
+import org.springframework.scheduling.annotation.Scheduled;
+import org.springframework.stereotype.Component;
+
+import java.net.InetAddress;
+import java.util.List;
+
+/**
+ * Poller periÃ³dico de la colecciÃ³n frames-repro.
+ * Cada rÃ©plica ejecuta este mÃ©todo de forma independiente; el claim atÃ³mico en Firestore
+ * garantiza que cada documento sea procesado por exactamente una rÃ©plica.
+ */
+@Component
+public class FrameReproSchedulerAdapter {
+
+    private static final Logger log = LoggerFactory.getLogger(FrameReproSchedulerAdapter.class);
+    private static final String INSTANCE_ID = resolveInstanceId();
+
+    private final FrameReproFirestorePort reproFirestorePort;
+    private final ReproUseCase reproUseCase;
+    private final ReproProperties reproProperties;
+
+    public FrameReproSchedulerAdapter(
+            FrameReproFirestorePort reproFirestorePort,
+            ReproUseCase reproUseCase,
+            ReproProperties reproProperties) {
+        this.reproFirestorePort = reproFirestorePort;
+        this.reproUseCase = reproUseCase;
+        this.reproProperties = reproProperties;
+    }
+
+    @Scheduled(fixedDelayString = "${app.repro.polling-interval-ms:30000}")
+    public void poll() {
+        if (!reproProperties.enabled()) {
+            return;
+        }
+
+        List<FrameRepro> pending = reproFirestorePort.queryPending(reproProperties.batchSize());
+
+        if (pending.isEmpty()) {
+            log.atDebug().setMessage("Sin documentos frames-repro pendientes").log();
+            return;
+        }
+
+        log.atInfo()
+                .setMessage("Documentos frames-repro detectados")
+                .addKeyValue("count", pending.size())
+                .addKeyValue("instanceId", INSTANCE_ID)
+                .log();
+
+        for (FrameRepro repro : pending) {
+            processOne(repro);
+        }
+    }
+
+    private void processOne(FrameRepro repro) {
+        boolean claimed = reproFirestorePort.claimDocument(repro.reproId(), INSTANCE_ID);
+
+        if (!claimed) {
+            log.atDebug()
+                    .setMessage("frames-repro ya tomado por otra rÃ©plica â skip")
+                    .addKeyValue("reproId", repro.reproId())
+                    .log();
+            return;
+        }
+
+        try {
+            reproUseCase.executeRepro(repro.reproId(), repro.transactionId());
+            reproFirestorePort.deleteDocument(repro.reproId());
+
+        } catch (Exception e) {
+            log.atError()
+                    .setMessage("Error en reproceso â liberando documento para reintento")
+                    .addKeyValue("reproId", repro.reproId())
+                    .addKeyValue("transactionId", repro.transactionId())
+                    .setCause(e)
+                    .log();
+            reproFirestorePort.releaseDocument(repro.reproId());
+        }
+    }
+
+    private static String resolveInstanceId() {
+        try {
+            return InetAddress.getLocalHost().getHostName();
+        } catch (Exception e) {
+            return "unknown-" + ProcessHandle.current().pid();
+        }
+    }
+}


