-    /** Extrae la quantity real de un item desde su registro de extensiÃ³n "02|". */
+    /** Valores derivados del Type02 para Sale/Return. */
+    private record SaleReturnExtensionValues(double quantity, double units, double unitPriceCents) {}
+
+    /** Interpreta Type02 igual que legacy: peso/volumen va a units y conserva Quantity=1. */
+    private SaleReturnExtensionValues resolveSaleReturnExtensionValues(TslLineItem item) {
+        if (item.extensions().isEmpty()) {
+            return new SaleReturnExtensionValues(1.0, 0.0, item.extendedAmountCents());
+        }
+
+        String[] parts = item.extensions().getFirst().split("\\|", -1);
+        double unitPriceCents = parts.length > TYPE02_SALE_PRICE_INDEX
+                && !parts[TYPE02_SALE_PRICE_INDEX].isBlank()
+            ? parseDouble(parts[TYPE02_SALE_PRICE_INDEX])
+            : item.extendedAmountCents();
+        boolean hasQtyOrWeightOrVolume = parts.length > TYPE02_QTY_OR_WEIGHT_OR_VOLUME_INDEX
+                && !parts[TYPE02_QTY_OR_WEIGHT_OR_VOLUME_INDEX].isBlank();
+        if (!hasQtyOrWeightOrVolume) {
+            return new SaleReturnExtensionValues(1.0, 0.0, unitPriceCents);
+        }
+
+        double qtyOrWeightOrVolume = parseDouble(parts[TYPE02_QTY_OR_WEIGHT_OR_VOLUME_INDEX]);
+        long indicat1 = parts.length > TYPE02_INDICAT1_INDEX
+            ? parseLong(parts[TYPE02_INDICAT1_INDEX])
+            : 0L;
+
+        if (isBitOn(indicat1, TYPE02_SCALE_WEIGHT_BIT_POSITION)
+                || isBitOn(indicat1, TYPE02_WEIGHT_OR_VOLUME_KEY_BIT_POSITION)) {
+            return new SaleReturnExtensionValues(1.0, qtyOrWeightOrVolume, unitPriceCents);
+        }
+        return new SaleReturnExtensionValues(qtyOrWeightOrVolume, 0.0, unitPriceCents);
+    }
