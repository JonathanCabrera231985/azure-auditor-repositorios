--- Diff for /src/main/java/com/elrosado/cersuitecloudlocalcore/infrastructure/adapter/out/db/central/DbPiControlAdapter.java ---
--- a//src/main/java/com/elrosado/cersuitecloudlocalcore/infrastructure/adapter/out/db/central/DbPiControlAdapter.java
+++ b//src/main/java/com/elrosado/cersuitecloudlocalcore/infrastructure/adapter/out/db/central/DbPiControlAdapter.java
@@ -0,0 +1,73 @@
+package com.elrosado.cersuitecloudlocalcore.infrastructure.adapter.out.db.central;
+
+import com.elrosado.cersuitecloudlocalcore.domain.port.out.PiControlRepositoryPort;
+import org.slf4j.Logger;
+import org.slf4j.LoggerFactory;
+import org.springframework.beans.factory.annotation.Qualifier;
+import org.springframework.jdbc.core.JdbcTemplate;
+import org.springframework.stereotype.Component;
+
+import javax.sql.DataSource;
+import java.sql.Date;
+import java.time.LocalDate;
+
+/**
+ * Adaptador de salida: consulta [PI_CONTROL] en BD Central (ARTS_EC 10.2.7.21)
+ * mediante JDBC directo (sin JPA) para validar el bloqueo de recepciÃ³n de cajas.
+ * <p>
+ * Migra: validaciÃ³n de cierre contable que en el sistema legado era responsabilidad
+ * del ArmsServer al procesar la trama antes de generar el XML.
+ */
+@Component
+public class DbPiControlAdapter implements PiControlRepositoryPort {
+
+    private static final Logger log = LoggerFactory.getLogger(DbPiControlAdapter.class);
+
+    private static final String SQL_IS_BLOCKED =
+            "SELECT COUNT(1) FROM dbo.PI_CONTROL " +
+            "WHERE COD_TIENDA = ? AND FECHA_CIERRE = ? AND RECEPCION_CAJAS = '1'";
+
+    private final JdbcTemplate centralJdbc;
+
+    public DbPiControlAdapter(@Qualifier("centralDataSource") DataSource centralDataSource) {
+        this.centralJdbc = new JdbcTemplate(centralDataSource);
+    }
+
+    /**
+     * Consulta si la recepciÃ³n de cajas estÃ¡ cerrada para la tienda y fecha contable.
+     * Ante cualquier error de conexiÃ³n se permite el procesamiento (fail-open) y se loguea WARN.
+     */
+    @Override
+    public boolean isReceptionBlocked(String storeCode, LocalDate businessDate) {
+        try {
+            int codTienda = Integer.parseInt(storeCode.trim());
+            Integer count = centralJdbc.queryForObject(
+                    SQL_IS_BLOCKED, Integer.class, codTienda, Date.valueOf(businessDate));
+            boolean blocked = count != null && count > 0;
+
+            log.atDebug()
+                    .setMessage("Consulta PI_CONTROL ejecutada")
+                    .addKeyValue("storeCode", storeCode)
+                    .addKeyValue("businessDate", businessDate)
+                    .addKeyValue("blocked", blocked)
+                    .log();
+
+            return blocked;
+
+        } catch (NumberFormatException e) {
+            log.atWarn()
+                    .setMessage("storeCode no es numÃ©rico â se omite validaciÃ³n PI_CONTROL")
+                    .addKeyValue("storeCode", storeCode)
+                    .log();
+            return false;
+        } catch (Exception e) {
+            log.atWarn()
+                    .setMessage("Error consultando PI_CONTROL en BD Central â se permite el procesamiento")
+                    .addKeyValue("storeCode", storeCode)
+                    .addKeyValue("businessDate", businessDate)
+                    .setCause(e)
+                    .log();
+            return false;
+        }
+    }
+}


