+            props.put("multi-sql.datasources.arts-ec.username", username);
+            props.put("multi-sql.datasources.arts-ec.password", password);
+            props.put("multi-sql.datasources.saadmin.url", saadminUrl);
+            props.put("multi-sql.datasources.saadmin.username", username);
+            props.put("multi-sql.datasources.saadmin.password", password);
