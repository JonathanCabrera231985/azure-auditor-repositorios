+
+    <!-- Reglas de conversiÃ³n (%clr, %wEx, ...) y propiedades base de Spring Boot -->
+    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>
+
+    <!-- PatrÃ³n coloreado para consola. Replica el de application.yaml aÃ±adiendo
+         color; %kvp imprime los pares clave-valor de los logs de negocio. -->
+    <property name="READABLE_LOG_PATTERN"
+              value="%clr(%d{yyyy-MM-dd HH:mm:ss.SSS}){faint} %clr([%thread]){faint} %clr(%-5level) %clr(%logger{36}){cyan} %clr(-){faint} %msg %clr(%kvp){faint}%n"/>
+
+    <!-- PatrÃ³n plano (sin cÃ³digos ANSI de color) para el archivo en disco. -->
+    <property name="FILE_LOG_PATTERN_PLAIN"
+              value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg %kvp%n"/>
