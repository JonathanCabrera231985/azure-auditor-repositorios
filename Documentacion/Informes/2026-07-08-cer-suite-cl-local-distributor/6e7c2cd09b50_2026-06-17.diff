+<?xml version="1.0" encoding="UTF-8"?>
+<!--
+  ConfiguraciÃ³n de logging del servicio TCP cer-suite-local-generador.
+
+  Estrategia por perfil:
+    - local, dev, default (todo lo que NO sea qa/prod): consola legible y coloreada
+      + archivo rotativo en disco (cÃ³modo para desarrollo). Ambos incluyen los
