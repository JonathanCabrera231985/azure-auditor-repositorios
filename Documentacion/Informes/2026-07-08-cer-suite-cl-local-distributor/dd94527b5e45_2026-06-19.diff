+    devs-url-secret: ${SM_DEVS_URL_SECRET:suite-cloud-qa-db-devs-url}
+    db-central-username-secret: ${SM_DB_CENTRAL_USERNAME_SECRET:suite-cloud-qa-db-central-user}
+    db-central-password-secret: ${SM_DB_CENTRAL_PASSWORD_SECRET:suite-cloud-qa-db-central-pass}
+    arts-central-url-secret: ${SM_ARTS_CENTRAL_URL_SECRET:suite-cloud-qa-db-arts-central-url}
+
+# Solo se declara la estructura de cada datasource (entity-packages / primary / batch-size).
+# url, username y password se inyectan desde Secret Manager antes del registro de beans.
+multi-sql:
+  datasources:
+    arts-ec:
+      entity-packages:
+        - com.elrosado.distributor_cloud.infrastructure.adapter.out.db.artsec.entity
+      primary: true
+      batch-size: 300
+    devs-ec:
+      entity-packages:
+        - com.elrosado.distributor_cloud.infrastructure.adapter.out.db.devsec.entity
+    eyes-ec:
+      entity-packages:
+        - com.elrosado.distributor_cloud.infrastructure.adapter.out.db.eyesec.entity
+    saadmin:
+      entity-packages:
+        - com.elrosado.distributor_cloud.infrastructure.adapter.out.db.saadmin.entity
+    arts-ec-central:
+      entity-packages:
+        - com.elrosado.distributor_cloud.infrastructure.adapter.out.db.central.entity
+
+tlog:
+  firestore-collection: ${TLOG_FIRESTORE_COLLECTION:tlog-retail}
+
+pubsub:
+  subscriptions:
+    - topic-id: ${GCP_PUBSUB_TOPIC_DISTRIBUTOR:retail.local.distributor.request.v1}
+      subscription-id: ${GCP_PUBSUB_TOPIC_DISTRIBUTOR_SUB:retail.local.distributor.request.v1-sub}
+    - topic-id: ${GCP_PUBSUB_TOPIC_DISTRIBUTOR_PROCESSED:retail.local.distributor.processed.v1}
+      subscription-id: ${GCP_PUBSUB_TOPIC_DISTRIBUTOR_PROCESSED_SUB:retail.local.distributor.processed.v1-sub}
+
+app:
+  distributor:
+    default-code: ${DISTRIBUTOR_DEFAULT_CODE:1}
+    # mappings se configura via ConfigMap de K8s
+
+logging:
+  level:
+    root: INFO
+    com.elrosado.distributor_cloud: INFO
+  structured:
+    format:
+      console: gcp


