+    eyes-url-secret: ${SM_EYES_URL_SECRET:suite-cloud-dev-db-eyes-url}
+    devs-url-secret: ${SM_DEVS_URL_SECRET:suite-cloud-dev-db-devs-url}
+    db-central-username-secret: ${SM_DB_CENTRAL_USERNAME_SECRET:suite-cloud-dev-db-central-user}
+    db-central-password-secret: ${SM_DB_CENTRAL_PASSWORD_SECRET:suite-cloud-dev-db-central-pass}
+    arts-central-url-secret: ${SM_ARTS_CENTRAL_URL_SECRET:suite-cloud-dev-db-arts-central-url}
