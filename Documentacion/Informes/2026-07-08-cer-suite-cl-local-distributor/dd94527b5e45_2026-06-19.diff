+      project-id: ${GOOGLE_CLOUD_PROJECT}
+      credentials:
+        # Ruta a la llave JSON montada en el pod (ver volumen 'gcp-sa-key' en el Deployment de dev).
+        location: file:${GOOGLE_APPLICATION_CREDENTIALS}
+      firestore:
+        enabled: true
+        database-id: ${FIRESTORE_DATABASE_ID}
+
+distributor:
+  secret-manager:
+    enabled: true
+    db-username-secret: ${SM_DB_USERNAME_SECRET:suite-cloud-dev-db-user}
