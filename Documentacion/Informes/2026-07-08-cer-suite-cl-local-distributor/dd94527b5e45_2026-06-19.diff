--- Diff for /src/main/java/com/elrosado/distributor_cloud/infrastructure/config/datasource/HibernateInsertOrderingPostProcessor.java ---
--- a//src/main/java/com/elrosado/distributor_cloud/infrastructure/config/datasource/HibernateInsertOrderingPostProcessor.java
+++ b//src/main/java/com/elrosado/distributor_cloud/infrastructure/config/datasource/HibernateInsertOrderingPostProcessor.java
@@ -0,0 +1,35 @@
+package com.elrosado.distributor_cloud.infrastructure.config.datasource;
+
+import org.springframework.beans.factory.config.BeanPostProcessor;
+import org.springframework.orm.jpa.LocalContainerEntityManagerFactoryBean;
+import org.springframework.stereotype.Component;
+
+/**
+ * Desactiva {@code hibernate.order_inserts}/{@code order_updates} en los EntityManagerFactory
+ * creados por jlib-multisql.
+ *
+ * <p>jlib-multisql los fuerza a {@code true} para maximizar el batching. Pero este servicio
+ * persiste grafos de transacciÃ³n con dependencias de clave forÃ¡nea (p.ej.
+ * {@code TR_LTM_SLS_RTN â TR_LTM_RTL_TRN}, y en general todo {@code TR_LTM_*}/{@code CO_*} hacia
+ * su cabecera) que <b>no estÃ¡n mapeadas como asociaciones JPA</b> (son entidades independientes
+ * con {@code @EmbeddedId}). Con {@code order_inserts=true}, Hibernate reordena los INSERT
+ * agrupÃ¡ndolos por tabla y, al desconocer la dependencia FK, inserta el hijo antes que el padre,
+ * provocando una violaciÃ³n de FK.
+ *
+ * <p>El cÃ³digo de persistencia ya inserta siempre en orden padreâhijo, por lo que ejecutar los
+ * INSERT en ese mismo orden de persistencia ({@code order_inserts=false}) es correcto. Los grupos
+ * de inserts consecutivos a la misma tabla (totales, StringUsuario, etc.) siguen aprovechando el
+ * batch.
+ */
+@Component
+public class HibernateInsertOrderingPostProcessor implements BeanPostProcessor {
+
+    @Override
+    public Object postProcessBeforeInitialization(Object bean, String beanName) {
+        if (bean instanceof LocalContainerEntityManagerFactoryBean emf) {
+            emf.getJpaPropertyMap().put("hibernate.order_inserts", "false");
+            emf.getJpaPropertyMap().put("hibernate.order_updates", "false");
+        }
+        return bean;
+    }
+}


