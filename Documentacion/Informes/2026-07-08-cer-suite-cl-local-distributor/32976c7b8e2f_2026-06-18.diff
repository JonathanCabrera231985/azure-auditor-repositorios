+package com.elrosado.distributor_cloud.infrastructure.adapter.in.pubsub;
+
+import com.fasterxml.jackson.annotation.JsonIgnoreProperties;
+
+/**
+ * Mensaje JSON que llega por la cola retail.local.distributor.request.v1.
+ * El ID del documento Firestore con el TLOG viaja en {@code transactionId}.
+ *
+ * <p>Ejemplo:
+ * <pre>{@code
+ * {
+ *   "transactionId": "9c949056-d9db-4165-a563-79105b2019f9",
+ *   "status": "XML_GENERATED",
+ *   "publishedAt": "2026-06-17T22:33:06.570808Z",
+ *   "storeId": "100"
+ * }
+ * }</pre>
+ */
+@JsonIgnoreProperties(ignoreUnknown = true)
+public record DistributorRequestMessage(
+        String transactionId,
+        String status,
+        String publishedAt,
+        String storeId
+) {}


