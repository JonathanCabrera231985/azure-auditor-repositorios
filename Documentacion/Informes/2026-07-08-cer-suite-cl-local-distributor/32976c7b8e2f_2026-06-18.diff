+package com.elrosado.distributor_cloud.unit;
+
+import com.elrosado.distributor_cloud.domain.model.xml.InvoiceData;
+import com.elrosado.distributor_cloud.domain.model.xml.Transaction;
+import com.elrosado.distributor_cloud.domain.model.xml.VentaMayoreoItem;
+import com.elrosado.distributor_cloud.infrastructure.adapter.out.tlog.TlogXmlParser;
+import org.junit.jupiter.api.Test;
+
+import java.util.List;
+
+import static org.assertj.core.api.Assertions.assertThat;
+
+/**
+ * Verifica que el binding de InvoiceData y VentaMayoreoItems coincide con los nombres de tag
+ * reales del TLOG (regresiÃ³n de los alias mal mapeados).
+ */
+class TlogXmlParserInvoiceTest {
+
+    private final TlogXmlParser parser = new TlogXmlParser();
+
+    @Test
+    void parseaInvoiceDataConTagsRealesDelTlog() throws Exception {
+        String xml = """
+                <Transaction>
+                  <OperatorID>0123</OperatorID>
+                  <WorkstationID>0001</WorkstationID>
+                  <RetailStoreID>100</RetailStoreID>
+                  <SequenceNumber>615</SequenceNumber>
+                  <RetailTransaction>
+                    <InvoiceData>
+                      <CustomerID>1234567897</CustomerID>
+                      <customerType>3</customerType>
+                      <CustomerName>GRIJALVA GRIJALVA SONIA MARIA</CustomerName>
+                      <Address>Av. Siempre Viva</Address>
+                      <Telephone>0991234567</Telephone>
+                      <flagReg>1</flagReg>
+                    </InvoiceData>
+                  </RetailTransaction>
+                </Transaction>
+                """;
+
+        Transaction trx = parser.parse(xml);
+        InvoiceData inv = trx.getRetailTransaction().getInvoiceData();
+
+        assertThat(inv.getCustomerId()).isEqualTo("1234567897");
+        assertThat(inv.getCustomerType()).isEqualTo("3");
+        assertThat(inv.getNameCustomer()).isEqualTo("GRIJALVA GRIJALVA SONIA MARIA");
+        assertThat(inv.getCustomerDireccion()).isEqualTo("Av. Siempre Viva");
+        assertThat(inv.getCustomerTelefono()).isEqualTo("0991234567");
+        assertThat(inv.getFlagReg()).isEqualTo(1);
+    }
+
+    @Test
+    void parseaVentaMayoreoItems() throws Exception {
+        String xml = """
+                <Transaction>
+                  <RetailStoreID>100</RetailStoreID>
+                  <SequenceNumber>6745</SequenceNumber>
+                  <RetailTransaction>
+                    <VentaMayoreoItems>
+                      <VentaMayoreoItem><SequenceNumber>27</SequenceNumber><sequenceNumberMay>28</sequenceNumberMay></VentaMayoreoItem>
+                      <VentaMayoreoItem><SequenceNumber>27</SequenceNumber><sequenceNumberMay>29</sequenceNumberMay></VentaMayoreoItem>
+                      <VentaMayoreoItem><SequenceNumber>27</SequenceNumber><sequenceNumberMay>30</sequenceNumberMay></VentaMayoreoItem>
+                    </VentaMayoreoItems>
+                  </RetailTransaction>
+                </Transaction>
+                """;
+
+        Transaction trx = parser.parse(xml);
+        List<VentaMayoreoItem> items = trx.getRetailTransaction().getItemsVentaMayoreo();
+
+        assertThat(items).hasSize(3);
+        assertThat(items).allMatch(i -> i.getSequenceNumber() == 27);
+        assertThat(items).extracting(VentaMayoreoItem::getSequenceNumberMay)
+                .containsExactlyInAnyOrder(28, 29, 30);
+    }
+}


