+        // obteniendo getSaleLI()/getReturnLI() como side-effect en todos los visitados.
+        // En la K-Ã©sima llamada (0-indexed) se saltan (K) promo items previos.
+        int skipCount = b.promotionDiscounts.size() - 1;
+        int foundCount = 0;
+        for (int idx = 0; idx < b.lineItems.size(); idx++) {
+            TslLineItem li = b.lineItems.get(idx);
+            if (PROMOTION_ITEM_CODE.equals(li.itemCode())
