+    /** 99|06|16: venta al por mayor â registra ordinal del Ãºltimo Ã­tem vÃ¡lido y cantidad.
+     *  El sequenceNumber se resuelve en build() usando ordinalToSeqNum. */
+    private void processVentaMayoreo(TransactionBuilder b, String[] f) {
+        int lastIdx = findLastLegacySaleReturnCandidateIndex(b.lineItems);
+        if (lastIdx >= 0) {
+            markReverseSearchVisitedLineItems(b, lastIdx);
+            TslLineItem lastItem = b.lineItems.get(lastIdx);
+            int lastOrdinal = lastItem.ordinalNumber();
+            int quantity    = parseInt(safeGet(f, 5));
+            b.ventaMayoreoRaw.add(new int[]{lastOrdinal, quantity});
+            b.lineItems.set(lastIdx, lastItem.withIsPorMayor(true));
+        }
+    }
