+
+    private static String fourDigitAsciiLen(String asciiValue) {
+        String lenPrefix = "%04d".formatted(asciiValue.length());
+        return lenPrefix + asciiToHex(asciiValue);
+    }
+
+    private static String asciiToHex(String value) {
+        StringBuilder hex = new StringBuilder();
+        for (char c : value.toCharArray()) {
+            hex.append("%02X".formatted((int) c));
+        }
+        return hex.toString();
