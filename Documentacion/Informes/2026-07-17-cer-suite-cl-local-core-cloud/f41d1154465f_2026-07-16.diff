+
+    private static String bitmapHex(int totalBits, int[] activeFields) {
+        boolean[] bits = new boolean[totalBits];
+        for (int f : activeFields) {
+            bits[f - 1] = true;
+        }
+        StringBuilder hex = new StringBuilder();
+        for (int nibbleStart = 0; nibbleStart < totalBits; nibbleStart += 4) {
+            int val = 0;
+            for (int j = 0; j < 4; j++) {
+                val = (val << 1) | (bits[nibbleStart + j] ? 1 : 0);
+            }
+            hex.append(Integer.toHexString(val).toUpperCase());
+        }
+        return hex.toString();
+    }
+
+    private static int[] shiftedBy64(int[] fieldNumbers) {
+        int[] shifted = new int[fieldNumbers.length];
+        for (int i = 0; i < fieldNumbers.length; i++) {
+            shifted[i] = fieldNumbers[i] - 64;
+        }
+        return shifted;
+    }
