+        } else if (line.startsWith(PREFIX_ARC_ITE)) {
+            if (state.currentFleje != null) {
+                state.currentFleje.addArchivo(parseArchivoImp(line));
+            }
+
+        } else if (line.startsWith(PREFIX_LOTE_MAYOREO)) {
+            state.closeCurrentFleje();
+            state.closeCurrentLote();
+            state.currentLote = parseLoteMayoreo(line);
+
+        } else if (line.startsWith(PREFIX_ARCHIVO_IMP_MAYOREO)) {
+            if (state.currentLote != null) {
+                state.currentLote.addArchivo(parseArchivoImpMayoreo(line));
+            }
+
+        } else {
+            log.debug("LÃ­nea desconocida ignorada en REG_ITEM: {}",
+                    line.substring(0, Math.min(10, line.length())));
+        }
+    }
