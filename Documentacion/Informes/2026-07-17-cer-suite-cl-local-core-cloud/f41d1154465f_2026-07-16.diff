+    /** 99|06|41: impuesto aplicado por Ã­tem (ISSUE-08 / ISSUE-V3-06).
+     *  f[3]=itemCode, f[4]=taxCents, f[5]=INDITAX (sobreescribe taxType â VERIF-03). */
+    private void processTaxData(TransactionBuilder b, String[] f) {
+        String itemCode = stripLeadingZero(safeGet(f, 3));
+        long taxCents   = parseLong(safeGet(f, 4));
+        b.appliedTaxByItemCode.merge(itemCode, taxCents, Long::sum);
+        // Paridad legacy: getLineItemToSetTax() busca el primer item con este cÃ³digo
+        // sin tax aplicado, iterando lineItems desde el inicio (FIFO). Todos los items
+        // visitados antes del match obtienen getSaleLI() como side-effect â emiten <sequenceNumber>.
+        int nthTaxForCode = b.appliedTaxQueues.containsKey(itemCode)
+            ? b.appliedTaxQueues.get(itemCode).size() : 0;
+        int matchCount = 0;
+        for (int idx = 0; idx < b.lineItems.size(); idx++) {
+            if (b.lineItems.get(idx).itemCode().equals(itemCode)) {
+                if (matchCount == nthTaxForCode) {
+                    b.innerSeqHighWaterMarkIndex = Math.max(b.innerSeqHighWaterMarkIndex, idx);
+                    break;
+                }
+                matchCount++;
+            }
+        }
+        b.appliedTaxQueues.computeIfAbsent(itemCode, k -> new ArrayDeque<>()).add(taxCents);
+        b.indiTaxQueues.computeIfAbsent(itemCode, k -> new ArrayDeque<>()).add(safeGet(f, 5));
+    }
