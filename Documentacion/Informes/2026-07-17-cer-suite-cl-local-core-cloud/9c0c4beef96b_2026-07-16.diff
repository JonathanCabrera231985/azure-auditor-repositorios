+    }
+
+    @Override
+    public String buildResponse(String rawPayload) {
+        String[] parts = FrameProtocol.split(rawPayload);
+        if (parts.length <= KEY_INDEX) {
+            throw new IllegalArgumentException(
+                    "Trama op. 13 sin tipo/clave (body[0]/body[1]): " + parts.length + " segmentos");
+        }
+
+        String type = parts[TYPE_INDEX].trim();
+        String key = parts[KEY_INDEX].trim();
+
+        String message = resolveMessage(type, key).orElse(NOT_FOUND);
+        String suffix = FrameProtocol.SEPARATOR + message;
+        return FrameProtocol.buildFramedResponse(parts, suffix, properties.lengthPrefixDigits());
+    }
+
+    /** Despacha por tipo y arma el {@code message} de Ã©xito; vacÃ­o si no hay coincidencia. */
+    private Optional<String> resolveMessage(String type, String key) {
+        return switch (type) {
+            case TYPE_ID_CARD, TYPE_RUC -> queryUseCase.findCedRuc(key).map(this::formatCedRuc);
+            case TYPE_FOREIGNER -> queryUseCase.findForeigner(key).map(this::formatForeigner);
+            default -> {
