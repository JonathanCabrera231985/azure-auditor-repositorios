+package com.elrosado.cersuitecloudlocalcore.service;
+
+import com.elrosado.cersuitecloudlocalcore.domain.exception.OperatorUpdateException;
+import com.elrosado.cersuitecloudlocalcore.domain.port.out.DistributedLockPort;
+import org.junit.jupiter.api.Test;
+import org.junit.jupiter.api.extension.ExtendWith;
+import org.mockito.Mock;
+import org.mockito.junit.jupiter.MockitoExtension;
+
+import java.time.Duration;
+import java.util.concurrent.atomic.AtomicInteger;
+
+import static org.assertj.core.api.Assertions.assertThat;
+import static org.assertj.core.api.Assertions.assertThatThrownBy;
+import static org.mockito.ArgumentMatchers.any;
+import static org.mockito.ArgumentMatchers.eq;
+import static org.mockito.Mockito.never;
+import static org.mockito.Mockito.times;
+import static org.mockito.Mockito.verify;
+import static org.mockito.Mockito.when;
+
+/**
+ * Verifica que {@link OperatorUpdateLock} serializa por {@code CC_OPERADOR}: ejecuta la acciÃ³n cuando
+ * adquiere el lock, siempre libera, y ante contenciÃ³n sostenida hace timeout con excepciÃ³n (â NACK).
+ */
+@ExtendWith(MockitoExtension.class)
+class OperatorUpdateLockTest {
+
+    private static final int CC_OPERADOR = 77712451;
+    private static final String LOCK_KEY = "operator:update:lock:" + CC_OPERADOR;
+
+    @Mock
+    DistributedLockPort lockPort;
+
+    /** Lock con tiempos pequeÃ±os para que el camino de timeout no ralentice la prueba. */
+    private OperatorUpdateLock newLock() {
+        return new OperatorUpdateLock(
+                lockPort, Duration.ofMillis(200), Duration.ofMillis(120), Duration.ofMillis(20));
+    }
+
+    @Test
+    void runExclusive_lockConcedido_ejecutaAccionYLibera() {
+        when(lockPort.tryAcquire(eq(LOCK_KEY), any(Duration.class))).thenReturn(true);
+        OperatorUpdateLock lock = newLock();
+
+        AtomicInteger calls = new AtomicInteger();
+        int result = lock.runExclusive(CC_OPERADOR, () -> {
+            calls.incrementAndGet();
+            return 5031;
+        });
+
+        assertThat(result).isEqualTo(5031);
+        assertThat(calls.get()).isEqualTo(1);
+        verify(lockPort).release(LOCK_KEY);
+    }
+
+    @Test
+    void runExclusive_liberaAunSiLaAccionFalla() {
+        when(lockPort.tryAcquire(eq(LOCK_KEY), any(Duration.class))).thenReturn(true);
+        OperatorUpdateLock lock = newLock();
+
+        assertThatThrownBy(() -> lock.runExclusive(CC_OPERADOR, () -> {
+            throw new IllegalStateException("boom");
+        })).isInstanceOf(IllegalStateException.class);
+
+        verify(lockPort).release(LOCK_KEY);
+    }
+
+    @Test
+    void runExclusive_contencionSostenida_timeoutLanzaExcepcion() {
+        // El lock nunca se concede â tras agotar la espera se lanza OperatorUpdateException y no se ejecuta.
+        when(lockPort.tryAcquire(eq(LOCK_KEY), any(Duration.class))).thenReturn(false);
+        OperatorUpdateLock lock = newLock();
+
+        AtomicInteger calls = new AtomicInteger();
+        assertThatThrownBy(() -> lock.runExclusive(CC_OPERADOR, () -> {
+            calls.incrementAndGet();
+            return 1;
+        })).isInstanceOf(OperatorUpdateException.class);
+
+        assertThat(calls.get()).isZero();
+        verify(lockPort, never()).release(LOCK_KEY);
+    }
+
+    @Test
+    void runExclusive_segundoIntentoTrasEspera_adquiereYEjecuta() {
+        // Primer intento ocupado, segundo libre: reproduce la trama duplicada que espera y luego procede.
+        when(lockPort.tryAcquire(eq(LOCK_KEY), any(Duration.class))).thenReturn(false, true);
+        OperatorUpdateLock lock = newLock();
+
+        int result = lock.runExclusive(CC_OPERADOR, () -> 5031);
+
+        assertThat(result).isEqualTo(5031);
+        verify(lockPort, times(2)).tryAcquire(eq(LOCK_KEY), any(Duration.class));
+        verify(lockPort).release(LOCK_KEY);
+    }
+}


