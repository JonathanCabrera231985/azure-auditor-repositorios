+ * <p>
+ * <b>Por quÃ© existe:</b> el legacy {@code OperatorUpdateOperation} procesaba las tramas de forma
+ * secuencial sobre la misma conexiÃ³n TCP, por lo que una trama duplicada del mismo operador (Central
+ * reenvÃ­a, o Pub/Sub reentrega at-least-once) veÃ­a la fila creada por la anterior y la <em>actualizaba</em>.
+ * En cloud, el carril ventas despacha cada trama en un virtual thread independiente, de modo que dos
+ * tramas del mismo operador corren el {@code findFirstByCcOperador â insert} en paralelo, ambas no
+ * encuentran fila y ambas insertan â dos filas con el mismo {@code CC_OPERADOR} (la tabla no tiene Ã­ndice
+ * Ãºnico sobre esa columna). Este lock reproduce la serializaciÃ³n del legacy: la segunda trama espera,
+ * luego encuentra la fila de la primera y la actualiza.
+ * <p>
+ * Solo envuelve la secciÃ³n crÃ­tica de persistencia (el upsert), no el push por socket al agente, para
+ * mantener el lock corto y no sostenerlo durante I/O de red â el doble push que pudiera ocurrir ante un
+ * duplicado es inocuo (idempotente en el agente) y tambiÃ©n sucedÃ­a en el legacy (una trama = un push).
+ */
+@Component
+public class OperatorUpdateLock {
+
+    private static final Logger log = LoggerFactory.getLogger(OperatorUpdateLock.class);
+
+    private static final String KEY_PREFIX = "operator:update:lock:";
+
+    /** Vida del lock; supera con holgura el upsert (round-trips a OPERAC_EC). Si el hilo muere, expira. */
+    private static final Duration LOCK_TTL = Duration.ofSeconds(20);
+    /** Espera mÃ¡xima de un hilo por el lock; mayor que el TTL para poder tomarlo si el dueÃ±o muriÃ³. */
+    private static final Duration MAX_WAIT = Duration.ofSeconds(25);
+    /** Pausa entre reintentos de adquisiciÃ³n. */
+    private static final Duration RETRY_BACKOFF = Duration.ofMillis(100);
+
+    private final DistributedLockPort lockPort;
+    private final Duration lockTtl;
+    private final Duration maxWait;
+    private final Duration retryBackoff;
+
+    @Autowired
+    public OperatorUpdateLock(DistributedLockPort lockPort) {
+        this(lockPort, LOCK_TTL, MAX_WAIT, RETRY_BACKOFF);
+    }
+
+    /** Constructor con tiempos parametrizables (para pruebas). */
+    OperatorUpdateLock(DistributedLockPort lockPort, Duration lockTtl, Duration maxWait, Duration retryBackoff) {
+        this.lockPort = lockPort;
+        this.lockTtl = lockTtl;
+        this.maxWait = maxWait;
+        this.retryBackoff = retryBackoff;
+    }
+
+    /**
+     * Ejecuta {@code action} con exclusiÃ³n mutua para el operador dado. Si no logra adquirir el lock
+     * dentro de {@link #MAX_WAIT}, lanza {@link OperatorUpdateException} â el carril ventas hace NACK y
+     * Pub/Sub reentrega la trama mÃ¡s tarde, cuando el dueÃ±o ya liberÃ³.
+     *
+     * @param identityDocument cÃ©dula del operador ({@code CC_OPERADOR}), clave de serializaciÃ³n
+     * @param action           secciÃ³n crÃ­tica (el upsert); devuelve el id local del operador
+     */
+    public <T> T runExclusive(int identityDocument, Supplier<T> action) {
+        String lockKey = KEY_PREFIX + identityDocument;
+        if (!acquireWithWait(lockKey, identityDocument)) {
+            throw new OperatorUpdateException(
+                    "No se pudo adquirir el lock del operador " + identityDocument + " tras " + maxWait);
+        }
+        try {
+            return action.get();
+        } finally {
+            lockPort.release(lockKey);
+        }
+    }
+
+    /** Spin-acquire con backoff hasta {@link #MAX_WAIT}; los virtual threads hacen barata la espera. */
+    private boolean acquireWithWait(String lockKey, int identityDocument) {
+        long deadline = System.nanoTime() + maxWait.toNanos();
+        boolean waited = false;
+        while (true) {
+            if (lockPort.tryAcquire(lockKey, lockTtl)) {
+                return true;
+            }
+            if (System.nanoTime() >= deadline) {
+                return false;
+            }
+            if (!waited) {
+                waited = true;
+                log.atInfo()
+                        .setMessage("Trama de operador concurrente â esperando el lock para serializar el upsert")
+                        .addKeyValue("identityDocument", identityDocument)
+                        .log();
+            }
+            try {
+                Thread.sleep(RETRY_BACKOFF.toMillis());
+            } catch (InterruptedException e) {
+                Thread.currentThread().interrupt();
+                return false;
+            }
+        }
+    }
+}


