+public class CedPadRucQueryFrameOperation implements RequestReplyOperation {
+
+    private static final Logger log = LoggerFactory.getLogger(CedPadRucQueryFrameOperation.class);
+
+    /** Op. TCP 13 (ConsultaCedPadRucOperation legacy). */
+    private static final String FRAME_TYPE = "13";
+
+    /** Ãndice del tipo de consulta (body[0]). */
+    private static final int TYPE_INDEX = FrameProtocol.BODY_START_INDEX;
+    /** Ãndice de la clave a consultar (body[1]). */
+    private static final int KEY_INDEX = FrameProtocol.BODY_START_INDEX + 1;
+
+    private static final String FOUND = "0";
+    private static final String NOT_FOUND = "1";
+
+    private static final String TYPE_ID_CARD = "1";
+    private static final String TYPE_RUC = "2";
+    private static final String TYPE_FOREIGNER = "4";
+
+    private final CedPadRucQueryUseCase queryUseCase;
+    private final RequestReplyProperties properties;
+
+    public CedPadRucQueryFrameOperation(CedPadRucQueryUseCase queryUseCase, RequestReplyProperties properties) {
+        this.queryUseCase = queryUseCase;
+        this.properties = properties;
+    }
+
+    @Override
+    public String frameType() {
