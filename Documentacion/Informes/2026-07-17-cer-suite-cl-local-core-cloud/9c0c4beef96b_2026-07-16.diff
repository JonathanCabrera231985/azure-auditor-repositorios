+    private String formatCedRuc(CedRucIdentity identity) {
+        return FOUND
+                + FrameProtocol.SEPARATOR + nullToEmpty(identity.code())
+                + FrameProtocol.SEPARATOR + nullToEmpty(identity.name())
+                + FrameProtocol.SEPARATOR + nullToEmpty(identity.address())
+                + FrameProtocol.SEPARATOR + nullToEmpty(identity.phone())
+                + FrameProtocol.SEPARATOR + nullToEmpty(identity.gender());
+    }
+
+    private String formatForeigner(ForeignerIdentity identity) {
