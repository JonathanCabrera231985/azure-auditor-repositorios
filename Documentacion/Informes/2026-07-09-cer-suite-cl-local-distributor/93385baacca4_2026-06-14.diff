--- a//src/main/java/com/elrosado/distributor_cloud/infrastructure/adapter/out/tlog/DistributorFirestoreAdapter.java
+++ b//src/main/java/com/elrosado/distributor_cloud/infrastructure/adapter/out/tlog/DistributorFirestoreAdapter.java
@@ -0,0 +1,106 @@
+package com.elrosado.distributor_cloud.infrastructure.adapter.out.tlog;
+
+import com.elrosado.distributor_cloud.domain.model.CentralReplicationPayload;
+import com.elrosado.distributor_cloud.domain.port.out.DistributorFirestorePort;
+import com.elrosado.distributor_cloud.infrastructure.config.properties.TlogProperties;
+import com.elrosado.jlib_firestore.interfaces.IFirestoreService;
+import lombok.RequiredArgsConstructor;
+import lombok.extern.slf4j.Slf4j;
+import org.springframework.stereotype.Component;
+
+import java.time.LocalDateTime;
+import java.time.ZoneId;
+import java.util.Map;
+
+/**
+ * Adaptador Firestore para el flujo de replicaciÃ³n central.
+ * Lee campos propios del ciclo de replicaciÃ³n y escribe PROCESSED_CENTRAL / errorMessageDistributor
+ * sin interferir con los campos que gestiona TlogFirestoreAdapter.
+ */
+@Component
+@RequiredArgsConstructor
+@Slf4j
+public class DistributorFirestoreAdapter implements DistributorFirestorePort {
+
+    private static final String FIELD_XML        = "xmlGenerated";
+    private static final String FIELD_STORE_ID   = "storeId";
+    private static final String FIELD_TYPE_TRAMA = "typeTrama";
+    private static final String FIELD_CREATED_AT = "created_at";
+    private static final String FIELD_STATUS     = "status";
+    private static final String FIELD_ERROR      = "errorMessageDistributor";
+
+    private static final String STATUS_PROCESSED_CENTRAL = "PROCESSED_CENTRAL";
+    private static final String ZONE_ECUADOR             = "America/Guayaquil";
+
+    private final IFirestoreService firestoreService;
+    private final TlogProperties    tlogProperties;
+
+    @Override
+    public CentralReplicationPayload readReplicationPayload(String transactionId) {
+        Map<String, Object> doc = firestoreService.getDocument(
+                tlogProperties.firestoreCollection(), transactionId);
+
+        String xmlGenerated = extractRequired(doc, FIELD_XML, transactionId);
+        String storeId      = extractString(doc, FIELD_STORE_ID);
+        String typeTrama    = extractString(doc, FIELD_TYPE_TRAMA);
+        LocalDateTime createdAt = extractCreatedAt(doc);
+
+        return new CentralReplicationPayload(transactionId, xmlGenerated, storeId, typeTrama, createdAt);
+    }
+
+    @Override
+    public void updateStatusProcessedCentral(String transactionId) {
+        firestoreService.mergeDocument(
+                tlogProperties.firestoreCollection(),
+                transactionId,
+                Map.of(FIELD_STATUS, STATUS_PROCESSED_CENTRAL));
+
+        log.atInfo()
+           .setMessage("Estado Firestore actualizado a PROCESSED_CENTRAL")
+           .addKeyValue("transactionId", transactionId)
+           .log();
+    }
+
+    @Override
+    public void updateReplicationError(String transactionId, String errorMessage) {
+        String msg = errorMessage != null ? errorMessage : "Error desconocido en replicaciÃ³n central";
+        firestoreService.mergeDocument(
+                tlogProperties.firestoreCollection(),
+                transactionId,
+                Map.of(FIELD_ERROR, msg));
+
+        log.atWarn()
+           .setMessage("Error de replicaciÃ³n registrado en Firestore")
+           .addKeyValue("transactionId", transactionId)
+           .addKeyValue("error", msg)
+           .log();
+    }
+
+    private String extractRequired(Map<String, Object> doc, String field, String docId) {
+        Object value = doc.get(field);
+        if (value == null || value.toString().isBlank()) {
+            throw new IllegalStateException(
+                    "Campo '%s' ausente o vacÃ­o en documento Firestore: %s".formatted(field, docId));
+        }
+        return value.toString();
+    }
+
+    private String extractString(Map<String, Object> doc, String field) {
+        Object value = doc.get(field);
+        return value != null ? value.toString() : null;
+    }
+
+    private LocalDateTime extractCreatedAt(Map<String, Object> doc) {
+        Object raw = doc.get(FIELD_CREATED_AT);
+        ZoneId zone = ZoneId.of(ZONE_ECUADOR);
+
+        if (raw instanceof com.google.cloud.Timestamp ts) {
+            return ts.toDate().toInstant().atZone(zone).toLocalDateTime();
+        }
+        if (raw instanceof java.util.Date date) {
+            return date.toInstant().atZone(zone).toLocalDateTime();
+        }
+        log.warn("Campo '{}' no encontrado o tipo inesperado â se usa LocalDateTime.now() como fallback", FIELD_CREATED_AT);
+        return LocalDateTime.now();
+    }
+}


