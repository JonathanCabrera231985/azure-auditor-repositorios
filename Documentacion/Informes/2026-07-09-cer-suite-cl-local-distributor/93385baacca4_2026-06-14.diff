+package com.elrosado.distributor_cloud.application.service;
+
+import com.elrosado.distributor_cloud.domain.model.CentralReplicationPayload;
+import com.elrosado.distributor_cloud.domain.model.CentralXmlRecord;
+import com.elrosado.distributor_cloud.domain.model.TmTransactionData;
+import com.elrosado.distributor_cloud.domain.port.in.ReplicateToCentralUseCase;
+import com.elrosado.distributor_cloud.domain.port.out.DistributorFirestorePort;
+import com.elrosado.distributor_cloud.domain.port.out.SaleXmlGeneratorPort;
+import com.elrosado.distributor_cloud.domain.port.out.TmTransactionPort;
+import com.elrosado.distributor_cloud.infrastructure.config.properties.DistributorProperties;
+import lombok.RequiredArgsConstructor;
+import lombok.extern.slf4j.Slf4j;
+import org.springframework.stereotype.Service;
+import org.w3c.dom.Document;
+import org.w3c.dom.NodeList;
+import org.xml.sax.InputSource;
+
+import javax.xml.parsers.DocumentBuilderFactory;
+import java.io.StringReader;
+import java.time.LocalDate;
+import java.time.LocalDateTime;
+import java.time.LocalTime;
+import java.time.format.DateTimeFormatter;
+
+/**
+ * Caso de uso: replicaciÃ³n de transacciones hacia BD Central (ARTS_EC).
+ * Bifurca entre TBL_XML_GENERATOR (SALE tipo 10) y TR_TM_TRN (TM tipo 67).
+ * Reemplaza completamente la lÃ³gica de SP_TRANSACCIONES_PROCESSED y el endpoint
+ * POST /transactions/compress del servicio legacy cer-suite-central-serv-suite-service.
+ */
+@Service
+@RequiredArgsConstructor
+@Slf4j
+public class CentralReplicationService implements ReplicateToCentralUseCase {
+
+    private static final String TYPE_SALE = "10";
+    private static final String TYPE_TM   = "67";
+
+    private final DistributorFirestorePort firestorePort;
+    private final SaleXmlGeneratorPort     salePort;
+    private final TmTransactionPort        tmPort;
+    private final DistributorProperties    distributorProps;
+
+    @Override
+    public void replicate(String transactionId) {
+        CentralReplicationPayload payload = firestorePort.readReplicationPayload(transactionId);
+
+        switch (payload.typeTrama()) {
+            case TYPE_SALE -> replicateSale(transactionId, payload);
+            case TYPE_TM   -> replicateTm(transactionId, payload);
+            default -> {
+                log.atWarn()
+                   .setMessage("typeTrama no soportado para replicaciÃ³n central â se omite sin error")
+                   .addKeyValue("transactionId", transactionId)
+                   .addKeyValue("typeTrama", payload.typeTrama())
+                   .log();
+                firestorePort.updateReplicationError(transactionId,
+                        "typeTrama no soportado para replicaciÃ³n central: " + payload.typeTrama());
+                return;
+            }
+        }
+
+        firestorePort.updateStatusProcessedCentral(transactionId);
+    }
+
+    // --- SALE (tipo 10) â TBL_XML_GENERATOR ---
+
+    private void replicateSale(String transactionId, CentralReplicationPayload payload) {
+        String codDistributor = distributorProps.resolveCode(payload.storeId());
+        LocalDateTime fechaTrans = payload.createdAt();
+        String fileName = buildSaleFileName(transactionId, payload.storeId(), fechaTrans);
+
+        salePort.insert(new CentralXmlRecord(
+                payload.storeId(),
+                fechaTrans,
+                codDistributor,
+                payload.xmlGenerated(),
+                fileName));
+
+        log.atInfo()
+           .setMessage("XML SALE replicado en TBL_XML_GENERATOR")
+           .addKeyValue("transactionId", transactionId)
+           .addKeyValue("storeId", payload.storeId())
+           .addKeyValue("codDistributor", codDistributor)
+           .addKeyValue("fileName", fileName)
+           .log();
+    }
+
+    // --- TM (tipo 67) â TR_TM_TRN (lÃ³gica migrada de SP_TRANSACCIONES_PROCESSED) ---
+
+    private void replicateTm(String transactionId, CentralReplicationPayload payload) {
+        TmTransactionData data = parseTmXml(payload.xmlGenerated());
+
+        // Dedup idempotente â equivale al LEFT JOIN â¦ WHERE t.NUMERO_FACTURA IS NULL del SP
+        if (tmPort.existsByInvoiceNumber(data.invoiceNumber())) {
+            log.atWarn()
+               .setMessage("TM duplicado â ya existe en TR_TM_TRN, se omite inserciÃ³n")
+               .addKeyValue("transactionId", transactionId)
+               .addKeyValue("invoiceNumber", data.invoiceNumber())
+               .log();
+            return;
+        }
+
+        tmPort.insert(data);
+
+        log.atInfo()
+           .setMessage("XML TM replicado en TR_TM_TRN")
+           .addKeyValue("transactionId", transactionId)
+           .addKeyValue("invoiceNumber", data.invoiceNumber())
+           .addKeyValue("storeCode", data.storeCode())
+           .log();
+    }
+
+    // --- Parsing DOM del XML TM (reemplaza XQuery de SP_TRANSACCIONES_PROCESSED) ---
+
+    private TmTransactionData parseTmXml(String xmlContent) {
+        try {
+            DocumentBuilderFactory factory = DocumentBuilderFactory.newInstance();
+            // PrevenciÃ³n de XXE â SonarQube S2755
+            factory.setFeature("http://apache.org/xml/features/disallow-doctype-decl", true);
+            factory.setFeature("http://xml.org/sax/features/external-general-entities", false);
+            factory.setFeature("http://xml.org/sax/features/external-parameter-entities", false);
+            factory.setExpandEntityReferences(false);
+
+            Document doc = factory.newDocumentBuilder()
+                    .parse(new InputSource(new StringReader(xmlContent)));
+            doc.getDocumentElement().normalize();
+
+            return new TmTransactionData(
+                    Integer.parseInt(getText(doc, "StoreCode")),
+                    getText(doc, "InvoiceNumber"),
+                    LocalDate.parse(getText(doc, "TransactionDate")),
+                    LocalTime.parse(getText(doc, "BeginTime")),
+                    LocalTime.parse(getText(doc, "PayTime")),
+                    LocalTime.parse(getText(doc, "EndTime")),
+                    Integer.parseInt(getText(doc, "AssuredTime")),
+                    Integer.parseInt(getText(doc, "IdleTime")));
+        } catch (Exception ex) {
+            throw new IllegalArgumentException(
+                    "XML TM malformado â no se puede parsear para TR_TM_TRN", ex);
+        }
+    }
+
+    private String getText(Document doc, String tag) {
+        NodeList nodes = doc.getElementsByTagName(tag);
+        if (nodes.getLength() == 0 || nodes.item(0) == null) {
+            throw new IllegalArgumentException("Elemento XML no encontrado: " + tag);
+        }
+        return nodes.item(0).getTextContent().strip();
+    }
+
+    private String buildSaleFileName(String transactionId, String storeId, LocalDateTime fechaTrans) {
+        String fecha = fechaTrans.format(DateTimeFormatter.ofPattern("yyyyMMdd"));
+        return "%s_%s_SALE_%s.xml".formatted(storeId, fecha, transactionId);
+    }
+}


