+package com.elrosado.distributor_cloud.unit;
+
+import com.elrosado.distributor_cloud.infrastructure.adapter.in.pubsub.CentralReplicationMessageHandler;
+import com.elrosado.distributor_cloud.infrastructure.adapter.in.pubsub.TlogMessageHandler;
+import com.elrosado.distributor_cloud.infrastructure.adapter.in.pubsub.TlogPubSubSubscriber;
+import com.elrosado.jlib_pubsub.interfaces.IMessageSubscriber;
+import org.junit.jupiter.api.Test;
+import org.junit.jupiter.api.extension.ExtendWith;
+import org.mockito.ArgumentCaptor;
+import org.mockito.InjectMocks;
+import org.mockito.Mock;
+import org.mockito.junit.jupiter.MockitoExtension;
+
+import java.util.concurrent.CompletableFuture;
+import java.util.function.BiFunction;
+
+import static org.assertj.core.api.Assertions.assertThat;
+import static org.mockito.Mockito.*;
+
+@ExtendWith(MockitoExtension.class)
+class TlogPubSubSubscriberTest {
+
+    @Mock IMessageSubscriber               messageSubscriber;
+    @Mock TlogMessageHandler               tlogHandler;
+    @Mock CentralReplicationMessageHandler centralHandler;
+
+    @InjectMocks TlogPubSubSubscriber subscriber;
+
+    private static final String TLOG_SUB    = "retail.local.distributor.request.v1-sub";
+    private static final String CENTRAL_SUB = "retail.local.distributor.processed.v1-sub";
+    private static final String DOC_ID      = "doc-123";
+
+    @SuppressWarnings("unchecked")
+    private BiFunction<String, String, CompletableFuture<Boolean>> captureRouter() {
+        subscriber.iniciar();
+        ArgumentCaptor<BiFunction<String, String, CompletableFuture<Boolean>>> captor =
+                ArgumentCaptor.forClass(BiFunction.class);
+        verify(messageSubscriber).startListening(captor.capture());
+        return captor.getValue();
+    }
+
+    @Test
+    void iniciar_registraListenerEnMessageSubscriber() {
+        subscriber.iniciar();
+        verify(messageSubscriber).startListening(any());
+    }
+
+    @Test
+    void routeMessage_subscripcionTlog_delegaATlogHandler() {
+        when(tlogHandler.handle(TLOG_SUB, DOC_ID))
+                .thenReturn(CompletableFuture.completedFuture(true));
+
+        BiFunction<String, String, CompletableFuture<Boolean>> router = captureRouter();
+        router.apply(TLOG_SUB, DOC_ID);
+
+        verify(tlogHandler).handle(TLOG_SUB, DOC_ID);
+        verifyNoInteractions(centralHandler);
+    }
+
+    @Test
+    void routeMessage_subscripcionCentral_delegaACentralHandler() {
+        when(centralHandler.handle(CENTRAL_SUB, DOC_ID))
+                .thenReturn(CompletableFuture.completedFuture(true));
+
+        BiFunction<String, String, CompletableFuture<Boolean>> router = captureRouter();
+        router.apply(CENTRAL_SUB, DOC_ID);
+
+        verify(centralHandler).handle(CENTRAL_SUB, DOC_ID);
+        verifyNoInteractions(tlogHandler);
+    }
+
+    @Test
+    void routeMessage_subscripcionDesconocida_retornaAckSinDelegarANingunHandler() throws Exception {
+        BiFunction<String, String, CompletableFuture<Boolean>> router = captureRouter();
+        CompletableFuture<Boolean> result = router.apply("subscription-desconocida", DOC_ID);
+
+        assertThat(result.get()).isTrue();
+        verifyNoInteractions(tlogHandler, centralHandler);
+    }
+
+    @Test
+    void routeMessage_tlogHandler_propagaResultadoDelHandler() throws Exception {
+        when(tlogHandler.handle(TLOG_SUB, DOC_ID))
+                .thenReturn(CompletableFuture.completedFuture(false));
+
+        BiFunction<String, String, CompletableFuture<Boolean>> router = captureRouter();
+        Boolean result = router.apply(TLOG_SUB, DOC_ID).get();
+
+        assertThat(result).isFalse();
+    }
+}


