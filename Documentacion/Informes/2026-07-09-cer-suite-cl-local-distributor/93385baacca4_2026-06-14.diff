+    @Mock TransactionProcessingService transactionProcessingService;
+    @Mock IMessagePublisher            messagePublisher;
+
+    @InjectMocks TlogMessageHandler handler;
+
+    private static final String SUBSCRIPTION = "retail.local.distributor.request.v1-sub";
+    private static final String DOC_ID       = "doc-12345";
+    private static final String XML_CONTENT  = "<Transaction/>";
+
+    @BeforeEach
+    void setUp() {
+        lenient().when(messagePublisher.publishAsync(any(), any()))
+                .thenReturn(CompletableFuture.completedFuture("msg-id-1"));
+    }
+
+    @Test
+    void handle_tlogNuevoExitoso_procesaPublicaYRetornaAck() throws Exception {
+        Transaction tx = mock(Transaction.class);
+        when(tx.getRetailStoreCode()).thenReturn("0005");
+        when(tx.getSequenceNumber()).thenReturn("12345");
+        when(tlogDocumentPort.isDuplicated(DOC_ID)).thenReturn(false);
+        when(tlogDocumentPort.readXml(DOC_ID)).thenReturn(XML_CONTENT);
+        when(tlogXmlParser.parse(XML_CONTENT)).thenReturn(tx);
+
+        Boolean result = handler.handle(SUBSCRIPTION, DOC_ID).get();
+
+        assertThat(result).isTrue();
+        verify(transactionProcessingService).process(tx);
+        verify(tlogDocumentPort).markSaved(DOC_ID, "0005");
+        verify(messagePublisher).publishAsync(eq("retail.local.distributor.processed.v1"), eq(DOC_ID));
+    }
+
+    @Test
+    void handle_tlogDuplicado_marcaDuplicadoYRetornaAckSinProcesar() throws Exception {
+        when(tlogDocumentPort.isDuplicated(DOC_ID)).thenReturn(true);
+
+        Boolean result = handler.handle(SUBSCRIPTION, DOC_ID).get();
+
+        assertThat(result).isTrue();
+        verify(tlogDocumentPort).markDuplicated(DOC_ID);
+        verifyNoInteractions(tlogXmlParser, transactionProcessingService, messagePublisher);
+    }
+
+    @Test
+    void handle_xmlVacioEnFirestore_marcaErrorYRetornaAck() throws Exception {
+        when(tlogDocumentPort.isDuplicated(DOC_ID)).thenReturn(false);
+        when(tlogDocumentPort.readXml(DOC_ID)).thenReturn("  ");
+
+        Boolean result = handler.handle(SUBSCRIPTION, DOC_ID).get();
+
+        assertThat(result).isTrue();
+        verify(tlogDocumentPort).markError(eq(DOC_ID), any());
+        verifyNoInteractions(tlogXmlParser, transactionProcessingService, messagePublisher);
+    }
+
+    @Test
+    void handle_xmlNuloEnFirestore_marcaErrorYRetornaAck() throws Exception {
+        when(tlogDocumentPort.isDuplicated(DOC_ID)).thenReturn(false);
+        when(tlogDocumentPort.readXml(DOC_ID)).thenReturn(null);
+
+        Boolean result = handler.handle(SUBSCRIPTION, DOC_ID).get();
+
+        assertThat(result).isTrue();
+        verify(tlogDocumentPort).markError(eq(DOC_ID), any());
+    }
+
+    @Test
+    void handle_firestoreException_retornaNackParaReintento() throws Exception {
+        when(tlogDocumentPort.isDuplicated(DOC_ID))
+                .thenThrow(new FirestoreException("Firestore no disponible"));
+
+        Boolean result = handler.handle(SUBSCRIPTION, DOC_ID).get();
+
+        assertThat(result).isFalse();
+        verify(tlogDocumentPort, never()).markSaved(any(), any());
+    }
+
+    @Test
+    void handle_excepcionGeneral_intentaMarcarErrorYRetornaAck() throws Exception {
+        when(tlogDocumentPort.isDuplicated(DOC_ID)).thenReturn(false);
+        when(tlogDocumentPort.readXml(DOC_ID)).thenReturn(XML_CONTENT);
+        when(tlogXmlParser.parse(any())).thenThrow(new RuntimeException("Error de parseo"));
+
+        Boolean result = handler.handle(SUBSCRIPTION, DOC_ID).get();
+
+        assertThat(result).isTrue();
+        verify(tlogDocumentPort).markError(eq(DOC_ID), any());
+        verify(messagePublisher, never()).publishAsync(any(), any());
+    }
+
+    @Test
+    void handle_publishAsyncFalla_retornaAckIgualmente() throws Exception {
+        Transaction tx = mock(Transaction.class);
+        when(tx.getRetailStoreCode()).thenReturn("0005");
+        when(tx.getSequenceNumber()).thenReturn("12345");
+        when(tlogDocumentPort.isDuplicated(DOC_ID)).thenReturn(false);
+        when(tlogDocumentPort.readXml(DOC_ID)).thenReturn(XML_CONTENT);
+        when(tlogXmlParser.parse(XML_CONTENT)).thenReturn(tx);
+        when(messagePublisher.publishAsync(any(), any()))
+                .thenReturn(CompletableFuture.failedFuture(new RuntimeException("Pub/Sub error")));
+
+        Boolean result = handler.handle(SUBSCRIPTION, DOC_ID).get();
+
+        // El TLOG ya fue guardado â se ACK aunque el publish falle
+        assertThat(result).isTrue();
+        verify(tlogDocumentPort).markSaved(DOC_ID, "0005");
+    }
+}


