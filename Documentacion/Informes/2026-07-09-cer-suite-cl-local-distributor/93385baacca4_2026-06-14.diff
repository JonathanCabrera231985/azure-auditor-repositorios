+package com.elrosado.distributor_cloud.infrastructure.adapter.in.pubsub;
+
+import com.elrosado.distributor_cloud.domain.port.in.ReplicateToCentralUseCase;
+import com.elrosado.distributor_cloud.domain.port.out.DistributorFirestorePort;
+import lombok.RequiredArgsConstructor;
+import lombok.extern.slf4j.Slf4j;
+import org.springframework.stereotype.Component;
+
+import java.util.concurrent.CompletableFuture;
+
+/**
+ * Handler del flujo BD Multi-Local â BD Central.
+ * Procesa mensajes de retail.local.distributor.processed.v1-sub y replica el XML
+ * en TBL_XML_GENERATOR (SALE) o TR_TM_TRN (TM) segÃºn el typeTrama del documento Firestore.
+ *
+ * <p>ACK/NACK:
+ * <ul>
+ *   <li>ACK â procesado OK, duplicado TM (idempotente), typeTrama no soportado (no reintentable)</li>
+ *   <li>NACK â cualquier excepciÃ³n de infraestructura (BD Central / Firestore): Pub/Sub reintenta con backoff</li>
+ * </ul>
+ */
+@Component
+@RequiredArgsConstructor
+@Slf4j
+public class CentralReplicationMessageHandler {
+
+    private final ReplicateToCentralUseCase replicateUseCase;
+    private final DistributorFirestorePort  firestorePort;
+
+    public CompletableFuture<Boolean> handle(String subscriptionId, String transactionId) {
+        log.atInfo()
+           .setMessage("Mensaje de replicaciÃ³n central recibido")
+           .addKeyValue("subscriptionId", subscriptionId)
+           .addKeyValue("transactionId", transactionId)
+           .log();
+
+        try {
+            replicateUseCase.replicate(transactionId);
+            return CompletableFuture.completedFuture(true);
+
+        } catch (com.elrosado.jlib_firestore.exceptions.FirestoreException e) {
+            log.atError()
+               .setMessage("Error de Firestore en replicaciÃ³n central â NACK para reintento")
+               .addKeyValue("transactionId", transactionId)
+               .setCause(e)
+               .log();
+            return CompletableFuture.completedFuture(false);
+
+        } catch (Exception e) {
+            log.atError()
+               .setMessage("Error en replicaciÃ³n a BD Central â NACK para reintento")
+               .addKeyValue("transactionId", transactionId)
+               .setCause(e)
+               .log();
+            intentarRegistrarError(transactionId, e.getMessage());
+            return CompletableFuture.completedFuture(false);
+        }
+    }
+
+    private void intentarRegistrarError(String transactionId, String mensaje) {
+        try {
+            firestorePort.updateReplicationError(transactionId, mensaje);
+        } catch (Exception ex) {
+            log.atError()
+               .setMessage("No se pudo registrar error de replicaciÃ³n en Firestore")
+               .addKeyValue("transactionId", transactionId)
+               .setCause(ex)
+               .log();
+        }
+    }
+}


