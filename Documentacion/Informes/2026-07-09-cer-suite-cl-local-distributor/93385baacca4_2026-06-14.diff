+package com.elrosado.distributor_cloud.infrastructure.config.properties;
+
+import jakarta.validation.constraints.NotBlank;
+import org.springframework.boot.context.properties.ConfigurationProperties;
+import org.springframework.validation.annotation.Validated;
+
+import java.util.List;
+
+/**
+ * ConfiguraciÃ³n del mapeo tienda â cÃ³digo de distribuidor.
+ * Reemplaza la lectura de distributionStores.json del sistema legacy.
+ */
+@ConfigurationProperties(prefix = "app.distributor")
+@Validated
+public record DistributorProperties(
+        @NotBlank String defaultCode,
+        List<StoreMappingEntry> mappings
+) {
+    public record StoreMappingEntry(List<String> stores, String code) {}
+
+    /**
+     * Resuelve el cÃ³digo de distribuidor para la tienda dada.
+     * Si la tienda no estÃ¡ en ningÃºn grupo de mappings, devuelve defaultCode.
+     */
+    public String resolveCode(String storeId) {
+        if (storeId == null || mappings == null || mappings.isEmpty()) {
+            return defaultCode;
+        }
+        return mappings.stream()
+                .filter(m -> m.stores() != null && m.stores().contains(storeId))
+                .map(StoreMappingEntry::code)
+                .findFirst()
+                .orElse(defaultCode);
+    }
+}


