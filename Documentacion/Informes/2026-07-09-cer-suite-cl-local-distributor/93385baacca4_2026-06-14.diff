+
+        assertThat(adapter.existsByInvoiceNumber("00050000012345")).isTrue();
+    }
+
+    @Test
+    void existsByInvoiceNumber_cuandoNoExiste_retornaFalse() {
+        when(repository.existsByNumeroFactura("99990000000000")).thenReturn(false);
+
+        assertThat(adapter.existsByInvoiceNumber("99990000000000")).isFalse();
+    }
+
+    @Test
+    void insert_guardaEntidadConCamposCorrectos() {
