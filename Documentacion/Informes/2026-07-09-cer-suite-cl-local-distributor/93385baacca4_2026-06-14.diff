+package com.elrosado.distributor_cloud.infrastructure.adapter.in.pubsub;
+
+import com.elrosado.distributor_cloud.application.service.TransactionProcessingService;
+import com.elrosado.distributor_cloud.domain.model.xml.Transaction;
+import com.elrosado.distributor_cloud.domain.port.out.TlogDocumentPort;
+import com.elrosado.distributor_cloud.infrastructure.adapter.out.tlog.TlogXmlParser;
+import com.elrosado.jlib_pubsub.interfaces.IMessagePublisher;
+import lombok.RequiredArgsConstructor;
+import lombok.extern.slf4j.Slf4j;
+import org.springframework.stereotype.Component;
+
+import java.util.concurrent.CompletableFuture;
+
+/**
+ * Handler del flujo TLOG â BD Multi-Local.
+ * Procesa mensajes de retail.local.distributor.request.v1-sub y, tras guardar correctamente,
+ * publica el transactionId en retail.local.distributor.processed.v1 para disparar la
+ * replicaciÃ³n central.
+ */
+@Component
+@RequiredArgsConstructor
+@Slf4j
+public class TlogMessageHandler {
+
+    private static final String TOPIC_PROCESSED = "retail.local.distributor.processed.v1";
+
+    private final TlogDocumentPort           tlogDocumentPort;
+    private final TlogXmlParser              tlogXmlParser;
+    private final TransactionProcessingService transactionProcessingService;
+    private final IMessagePublisher          messagePublisher;
+
+    public CompletableFuture<Boolean> handle(String subscriptionId, String documentId) {
+        log.atInfo()
+           .setMessage("Mensaje TLOG recibido")
+           .addKeyValue("subscriptionId", subscriptionId)
+           .addKeyValue("documentId", documentId)
+           .log();
+
+        try {
+            if (tlogDocumentPort.isDuplicated(documentId)) {
+                tlogDocumentPort.markDuplicated(documentId);
+                return CompletableFuture.completedFuture(true);
+            }
+
+            String xml = tlogDocumentPort.readXml(documentId);
+            if (xml == null || xml.isBlank()) {
+                tlogDocumentPort.markError(documentId, "Campo xmlGenerated ausente o vacÃ­o en el documento");
+                return CompletableFuture.completedFuture(true);
+            }
+
+            Transaction transaction = tlogXmlParser.parse(xml);
+            transactionProcessingService.process(transaction);
+            tlogDocumentPort.markSaved(documentId, transaction.getRetailStoreCode());
+
+            log.atInfo()
+               .setMessage("TLOG procesado correctamente")
+               .addKeyValue("documentId", documentId)
+               .addKeyValue("tienda", transaction.getRetailStoreCode())
+               .addKeyValue("secuencia", transaction.getSequenceNumber())
+               .log();
+
+            // Dispara la replicaciÃ³n central de forma asÃ­ncrona; si falla se registra en log
+            // pero se ACK de todas formas ya que el TLOG ya fue guardado en Multi-Local
+            return messagePublisher.publishAsync(TOPIC_PROCESSED, documentId)
+                    .thenApply(msgId -> true)
+                    .exceptionally(ex -> {
+                        log.atWarn()
+                           .setMessage("No se pudo publicar en topic processed â replicaciÃ³n central podrÃ­a no ejecutarse")
+                           .addKeyValue("documentId", documentId)
+                           .setCause(ex)
+                           .log();
+                        return true;
+                    });
+
+        } catch (com.elrosado.jlib_firestore.exceptions.FirestoreException e) {
+            log.atError()
+               .setMessage("Error de Firestore â NACK para reintento")
+               .addKeyValue("documentId", documentId)
+               .setCause(e)
+               .log();
+            return CompletableFuture.completedFuture(false);
+
+        } catch (Exception e) {
+            log.atError()
+               .setMessage("Error procesando TLOG")
+               .addKeyValue("documentId", documentId)
+               .setCause(e)
+               .log();
+            intentarMarcarError(documentId, e.getMessage());
+            return CompletableFuture.completedFuture(true);
+        }
+    }
+
+    private void intentarMarcarError(String documentId, String mensaje) {
+        try {
+            tlogDocumentPort.markError(documentId, mensaje);
+        } catch (Exception ex) {
+            log.atError()
+               .setMessage("No se pudo actualizar estado error en Firestore")
+               .addKeyValue("documentId", documentId)
+               .setCause(ex)
+               .log();
+        }
+    }
+}


