@@ -0,0 +1,33 @@
+package com.elrosado.synchrosrv.infrastructure.exception;
+
+import org.junit.jupiter.api.Test;
+import org.springframework.http.HttpStatus;
+import org.springframework.http.ProblemDetail;
+
+import static org.assertj.core.api.Assertions.assertThat;
+
+class GlobalExceptionHandlerTest {
+
+    private final GlobalExceptionHandler handler = new GlobalExceptionHandler();
+
+    @Test
+    void handleIllegalArgument_returnsBadRequest() {
+        IllegalArgumentException ex = new IllegalArgumentException("campo requerido faltante");
+
+        ProblemDetail result = handler.handleIllegalArgument(ex);
+
+        assertThat(result.getStatus()).isEqualTo(HttpStatus.BAD_REQUEST.value());
+        assertThat(result.getDetail()).contains("campo requerido faltante");
+        assertThat(result.getType()).hasToString("/errors/invalid-argument");
+    }
+
+    @Test
+    void handleGeneral_returnsInternalServerError() {
+        Exception ex = new RuntimeException("error interno de prueba");
+
+        ProblemDetail result = handler.handleGeneral(ex);
+
+        assertThat(result.getStatus()).isEqualTo(HttpStatus.INTERNAL_SERVER_ERROR.value());
+        assertThat(result.getDetail()).contains("Error interno");
+    }
+}


