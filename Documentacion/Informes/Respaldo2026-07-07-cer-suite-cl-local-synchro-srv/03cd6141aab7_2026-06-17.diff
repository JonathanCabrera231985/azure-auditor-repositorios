--- Diff for /build.sh ---
--- a//build.sh
+++ b//build.sh
@@ -0,0 +1,28 @@
+#!/bin/bash
+set -e
+
+ARTIFACT_ID=$(mvn help:evaluate -Dexpression=project.artifactId -q -DforceStdout | tr -d '\r\n[:space:]')
+VERSION=$(mvn help:evaluate -Dexpression=project.version -q -DforceStdout | tr -d '\r\n[:space:]')
+
+if [ -z "$ARTIFACT_ID" ] || [ -z "$VERSION" ]; then
+    echo "Error: Failed to extract artifactId or version from pom.xml"
+    exit 1
+fi
+
+IMAGE_TAG_VERSION="localhost:30500/${ARTIFACT_ID}:${VERSION}"
+IMAGE_TAG_LATEST="localhost:30500/${ARTIFACT_ID}:latest"
+
+echo "Building image: ${IMAGE_TAG_VERSION} and ${IMAGE_TAG_LATEST} using Podman..."
+podman build -f docker/dev/Dockerfile -t "${IMAGE_TAG_VERSION}" -t "${IMAGE_TAG_LATEST}" .
+
+echo "Pushing images to local registry..."
+podman push --tls-verify=false "${IMAGE_TAG_VERSION}"
+podman push --tls-verify=false "${IMAGE_TAG_LATEST}"
+
+if [ -n "$IMAGE" ]; then
+    echo "Skaffold dynamic tagging: tagging as $IMAGE"
+    podman tag "${IMAGE_TAG_VERSION}" "$IMAGE"
+    podman push --tls-verify=false "$IMAGE"
+fi
+
+echo "Build and push completed successfully."


