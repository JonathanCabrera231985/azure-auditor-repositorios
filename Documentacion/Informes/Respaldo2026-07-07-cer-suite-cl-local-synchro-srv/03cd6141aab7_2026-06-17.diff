+package com.elrosado.synchrosrv.application.service;
+
+import com.elrosado.synchrosrv.domain.model.StoreTransferConfig;
+import com.elrosado.synchrosrv.domain.model.TransferCommand;
+import com.elrosado.synchrosrv.domain.model.TransferResult;
+import com.elrosado.synchrosrv.domain.port.in.TransferDevolutionFileUseCase;
+import com.elrosado.synchrosrv.domain.port.out.FileTransferPort;
+import com.elrosado.synchrosrv.domain.port.out.GcsFileDownloadPort;
+import com.elrosado.synchrosrv.domain.port.out.StoreQueryPort;
+import lombok.RequiredArgsConstructor;
+import lombok.extern.slf4j.Slf4j;
+import org.springframework.stereotype.Service;
+
+@Service
+@RequiredArgsConstructor
+@Slf4j
+public class TransferDevolutionFileService implements TransferDevolutionFileUseCase {
+
+    private final StoreQueryPort storeQueryPort;
+    private final GcsFileDownloadPort gcsFileDownloadPort;
+    private final FileTransferPort fileTransferPort;
+
+    @Override
+    public TransferResult transfer(TransferCommand command) {
+        log.atDebug()
+                .setMessage("Iniciando transferencia de archivo DV al controlador POS")
+                .addKeyValue("devolutionId", command.devolutionId())
+                .addKeyValue("codStore", command.codStore())
+                .addKeyValue("fileName", command.fileName())
+                .log();
+
+        StoreTransferConfig storeConfig = storeQueryPort.findByCode(command.codStore());
+
+        log.atDebug()
+                .setMessage("ConfiguraciÃ³n de tienda obtenida para transferencia")
+                .addKeyValue("devolutionId", command.devolutionId())
+                .addKeyValue("codStore", command.codStore())
+                .addKeyValue("controllerIp", storeConfig.controllerIp())
+                .log();
+
+        byte[] fileContent = gcsFileDownloadPort.download(command.gcsBucket(), command.gcsPath());
+
+        log.atDebug()
+                .setMessage("Archivo DV descargado desde GCS")
+                .addKeyValue("devolutionId", command.devolutionId())
+                .addKeyValue("gcsBucket", command.gcsBucket())
+                .addKeyValue("gcsPath", command.gcsPath())
+                .addKeyValue("sizeBytes", fileContent.length)
+                .log();
+
+        TransferResult result = fileTransferPort.transfer(
+                storeConfig,
+                command.targetDir(),
+                command.fileName(),
+                fileContent
+        );
+
+        log.atInfo()
+                .setMessage("Archivo DV transferido exitosamente al controlador POS")
+                .addKeyValue("devolutionId", command.devolutionId())
+                .addKeyValue("codStore", command.codStore())
+                .addKeyValue("fileName", result.fileName())
+                .addKeyValue("endpoint", result.endpoint())
+                .addKeyValue("statusCode", result.statusCode())
+                .addKeyValue("transferredAt", result.transferredAt())
+                .log();
+
+        return result;
+    }
+}


