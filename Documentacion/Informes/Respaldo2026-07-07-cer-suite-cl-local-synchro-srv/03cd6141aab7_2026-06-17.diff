--- Diff for /src/main/java/com/elrosado/synchrosrv/infrastructure/adapter/out/security/SecretManagerBearerTokenProvider.java ---
--- a//src/main/java/com/elrosado/synchrosrv/infrastructure/adapter/out/security/SecretManagerBearerTokenProvider.java
+++ b//src/main/java/com/elrosado/synchrosrv/infrastructure/adapter/out/security/SecretManagerBearerTokenProvider.java
@@ -0,0 +1,121 @@
+package com.elrosado.synchrosrv.infrastructure.adapter.out.security;
+
+import com.elrosado.synchrosrv.domain.exception.FileTransferPermanentException;
+import com.elrosado.synchrosrv.domain.exception.FileTransferTransientException;
+import com.elrosado.synchrosrv.domain.port.out.BearerTokenPort;
+import com.elrosado.synchrosrv.infrastructure.config.TransferProperties;
+import com.google.api.gax.rpc.ApiException;
+import com.google.api.gax.rpc.StatusCode;
+import com.google.cloud.secretmanager.v1.AccessSecretVersionResponse;
+import com.google.cloud.secretmanager.v1.SecretManagerServiceClient;
+import com.google.cloud.secretmanager.v1.SecretVersionName;
+import lombok.extern.slf4j.Slf4j;
+import org.springframework.beans.factory.annotation.Value;
+import org.springframework.stereotype.Component;
+
+import java.time.Duration;
+
+@Component
+@Slf4j
+public class SecretManagerBearerTokenProvider implements BearerTokenPort {
+
+    private final SecretManagerServiceClient secretManagerServiceClient;
+    private final TransferProperties properties;
+    private final String projectId;
+
+    private volatile CachedAuthorizationHeader cachedHeader;
+
+    public SecretManagerBearerTokenProvider(
+            SecretManagerServiceClient secretManagerServiceClient,
+            TransferProperties properties,
+            @Value("${spring.cloud.gcp.project-id:}") String projectId
+    ) {
+        this.secretManagerServiceClient = secretManagerServiceClient;
+        this.properties = properties;
+        this.projectId = projectId;
+    }
+
+    @Override
+    public String authorizationHeader() {
+        long nowNanos = System.nanoTime();
+        CachedAuthorizationHeader header = cachedHeader;
+        if (isCacheValid(header, nowNanos)) {
+            return header.value();
+        }
+
+        synchronized (this) {
+            header = cachedHeader;
+            if (!isCacheValid(header, nowNanos)) {
+                header = new CachedAuthorizationHeader(loadFromSecretManager(), System.nanoTime());
+                cachedHeader = header;
+            }
+            return header.value();
+        }
+    }
+
+    private String loadFromSecretManager() {
+        String secretId = requireNonBlank(properties.getBearerTokenSecretId(), "app.transfer.bearer-token-secret-id");
+        String version  = blankDefault(properties.getBearerTokenSecretVersion(), "latest");
+        String project  = requireNonBlank(projectId, "spring.cloud.gcp.project-id");
+
+        try {
+            SecretVersionName versionName = SecretVersionName.of(project, secretId, version);
+            AccessSecretVersionResponse response = secretManagerServiceClient.accessSecretVersion(versionName);
+            String token = response.getPayload().getData().toStringUtf8();
+
+            if (token == null || token.isBlank()) {
+                throw new FileTransferPermanentException("Bearer token vacÃ­o en Secret Manager: secretId=" + secretId);
+            }
+
+            log.atDebug()
+                    .setMessage("Bearer token cargado desde Secret Manager")
+                    .addKeyValue("secretId", secretId)
+                    .addKeyValue("version", version)
+                    .log();
+
+            return token.regionMatches(true, 0, "Bearer ", 0, "Bearer ".length())
+                    ? token.strip()
+                    : "Bearer " + token.strip();
+
+        } catch (FileTransferPermanentException ex) {
+            throw ex;
+        } catch (ApiException ex) {
+            if (isPermanentError(ex)) {
+                throw new FileTransferPermanentException(
+                        "Error permanente obteniendo bearer token. statusCode=" + ex.getStatusCode().getCode(), ex);
+            }
+            throw new FileTransferTransientException("Error transitorio obteniendo bearer token", ex);
+        } catch (Exception ex) {
+            throw new FileTransferTransientException("Error inesperado obteniendo bearer token", ex);
+        }
+    }
+
+    private boolean isCacheValid(CachedAuthorizationHeader header, long nowNanos) {
+        if (header == null) return false;
+        long ttlSeconds = properties.getBearerTokenCacheTtlSeconds();
+        if (ttlSeconds <= 0) return false;
+        return nowNanos - header.loadedAtNanos() < Duration.ofSeconds(ttlSeconds).toNanos();
+    }
+
+    private boolean isPermanentError(ApiException ex) {
+        StatusCode.Code code = ex.getStatusCode().getCode();
+        return code == StatusCode.Code.NOT_FOUND
+                || code == StatusCode.Code.PERMISSION_DENIED
+                || code == StatusCode.Code.UNAUTHENTICATED
+                || code == StatusCode.Code.INVALID_ARGUMENT
+                || code == StatusCode.Code.FAILED_PRECONDITION;
+    }
+
+    private String requireNonBlank(String value, String propertyName) {
+        if (value == null || value.isBlank()) {
+            throw new FileTransferPermanentException(propertyName + " no estÃ¡ configurado");
+        }
+        return value.strip();
+    }
+
+    private String blankDefault(String value, String defaultValue) {
+        return (value == null || value.isBlank()) ? defaultValue : value.strip();
+    }
+
+    private record CachedAuthorizationHeader(String value, long loadedAtNanos) {}
+}


