--- Diff for /src/main/java/com/elrosado/synchrosrv/infrastructure/adapter/in/event/DevolutionTransferMessageHandler.java ---
--- a//src/main/java/com/elrosado/synchrosrv/infrastructure/adapter/in/event/DevolutionTransferMessageHandler.java
+++ b//src/main/java/com/elrosado/synchrosrv/infrastructure/adapter/in/event/DevolutionTransferMessageHandler.java
@@ -0,0 +1,167 @@
+package com.elrosado.synchrosrv.infrastructure.adapter.in.event;
+
+import com.elrosado.synchrosrv.domain.exception.FileTransferPermanentException;
+import com.elrosado.synchrosrv.domain.exception.FileTransferTransientException;
+import com.elrosado.synchrosrv.domain.exception.StoreNotFoundException;
+import com.elrosado.synchrosrv.domain.model.TransferCommand;
+import com.elrosado.synchrosrv.domain.port.in.TransferDevolutionFileUseCase;
+import com.elrosado.synchrosrv.infrastructure.config.TransferProperties;
+import lombok.RequiredArgsConstructor;
+import lombok.extern.slf4j.Slf4j;
+import org.slf4j.MDC;
+import org.springframework.stereotype.Component;
+import tools.jackson.databind.ObjectMapper;
+
+import java.util.UUID;
+
+@Component
+@RequiredArgsConstructor
+@Slf4j
+public class DevolutionTransferMessageHandler {
+
+    private final TransferDevolutionFileUseCase transferDevolutionFileUseCase;
+    private final TransferProperties transferProperties;
+    private final ObjectMapper objectMapper;
+
+    public boolean handle(String subscriptionId, String body) {
+        DevolutionTransferEvent event;
+        try {
+            event = objectMapper.readValue(body, DevolutionTransferEvent.class);
+        } catch (Exception ex) {
+            log.atWarn()
+                    .setMessage("Evento de transferencia descartado: JSON invÃ¡lido")
+                    .addKeyValue("subscriptionId", subscriptionId)
+                    .setCause(ex)
+                    .log();
+            return true;
+        }
+
+        if (event == null) {
+            log.atWarn()
+                    .setMessage("Evento de transferencia descartado: payload nulo")
+                    .addKeyValue("subscriptionId", subscriptionId)
+                    .log();
+            return true;
+        }
+
+        if (!isEventValid(event, subscriptionId)) {
+            return true;
+        }
+
+        MDC.put("devolutionId", String.valueOf(event.devolutionId()));
+        MDC.put("codStore",     String.valueOf(event.codStore()));
+        MDC.put("correlationId", UUID.randomUUID().toString());
+
+        try {
+            if (!transferProperties.isEnabled()) {
+                log.atWarn()
+                        .setMessage("Transferencia deshabilitada por configuraciÃ³n â evento descartado")
+                        .addKeyValue("subscriptionId", subscriptionId)
+                        .addKeyValue("devolutionId", event.devolutionId())
+                        .log();
+                return true;
+            }
+
+            log.atDebug()
+                    .setMessage("Evento de transferencia recibido en synchro-srv")
+                    .addKeyValue("subscriptionId", subscriptionId)
+                    .addKeyValue("devolutionId", event.devolutionId())
+                    .addKeyValue("codStore", event.codStore())
+                    .addKeyValue("fileName", event.fileName())
+                    .log();
+
+            transferDevolutionFileUseCase.transfer(new TransferCommand(
+                    event.devolutionId(),
+                    event.codStore(),
+                    event.numNc(),
+                    event.creditNoteNumber(),
+                    event.gcsBucket(),
+                    event.gcsPath(),
+                    transferProperties.getPosTargetDir(),
+                    event.fileName(),
+                    event.processedAt()
+            ));
+
+            return true;
+
+        } catch (StoreNotFoundException ex) {
+            log.atError()
+                    .setMessage("Tienda no encontrada en MN_TIENDA â transferencia permanentemente rechazada")
+                    .addKeyValue("subscriptionId", subscriptionId)
+                    .addKeyValue("devolutionId", event.devolutionId())
+                    .addKeyValue("codStore", event.codStore())
+                    .setCause(ex)
+                    .log();
+            return true;
+
+        } catch (FileTransferPermanentException | IllegalArgumentException ex) {
+            log.atError()
+                    .setMessage("Error permanente en transferencia al controlador POS â descartando mensaje")
+                    .addKeyValue("subscriptionId", subscriptionId)
+                    .addKeyValue("devolutionId", event.devolutionId())
+                    .addKeyValue("codStore", event.codStore())
+                    .setCause(ex)
+                    .log();
+            return true;
+
+        } catch (FileTransferTransientException ex) {
+            log.atWarn()
+                    .setMessage("Error transitorio en transferencia al controlador POS â reintentando via Nack")
+                    .addKeyValue("subscriptionId", subscriptionId)
+                    .addKeyValue("devolutionId", event.devolutionId())
+                    .addKeyValue("codStore", event.codStore())
+                    .setCause(ex)
+                    .log();
+            return false;
+
+        } catch (Exception ex) {
+            log.atError()
+                    .setMessage("Error inesperado procesando evento de transferencia â reintentando via Nack")
+                    .addKeyValue("subscriptionId", subscriptionId)
+                    .addKeyValue("devolutionId", event.devolutionId())
+                    .setCause(ex)
+                    .log();
+            return false;
+
+        } finally {
+            MDC.remove("devolutionId");
+            MDC.remove("codStore");
+            MDC.remove("correlationId");
+        }
+    }
+
+    private boolean isEventValid(DevolutionTransferEvent event, String subscriptionId) {
+        if (event.devolutionId() == null) {
+            log.atWarn()
+                    .setMessage("Evento descartado: devolutionId ausente")
+                    .addKeyValue("subscriptionId", subscriptionId)
+                    .log();
+            return false;
+        }
+        if (event.codStore() == null) {
+            log.atWarn()
+                    .setMessage("Evento descartado: codStore ausente")
+                    .addKeyValue("subscriptionId", subscriptionId)
+                    .addKeyValue("devolutionId", event.devolutionId())
+                    .log();
+            return false;
+        }
+        if (event.gcsPath() == null || event.gcsPath().isBlank()) {
+            log.atWarn()
+                    .setMessage("Evento descartado: gcsPath ausente")
+                    .addKeyValue("subscriptionId", subscriptionId)
+                    .addKeyValue("devolutionId", event.devolutionId())
+                    .log();
+            return false;
+        }
+        if (event.fileName() == null || event.fileName().isBlank()) {
+            log.atWarn()
+                    .setMessage("Evento descartado: fileName ausente")
+                    .addKeyValue("subscriptionId", subscriptionId)
+                    .addKeyValue("devolutionId", event.devolutionId())
+                    .log();
+            return false;
+        }
+        return true;
+    }
+}


