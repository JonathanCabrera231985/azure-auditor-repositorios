+    public StoreTransferConfig findByCode(Integer codStore) {
+        MnTiendaEntity store = mnTiendaRepository
+                .findByDesClaveAndIndActivo(codStore, ACTIVE)
+                .orElseThrow(() -> new StoreNotFoundException(String.valueOf(codStore)));
+
+        String controllerIp = store.getIp();
+        if (controllerIp == null || controllerIp.isBlank()) {
+            throw new FileTransferPermanentException(
+                    "MN_TIENDA.IP not configured for store=" + codStore
+            );
+        }
+
+        log.atDebug()
+                .setMessage("IP del controlador TCx Sky obtenida desde MN_TIENDA")
+                .addKeyValue("codStore", codStore)
+                .addKeyValue("controllerIp", controllerIp)
+                .log();
+
+        return new StoreTransferConfig(codStore, controllerIp.strip());
+    }
+}


