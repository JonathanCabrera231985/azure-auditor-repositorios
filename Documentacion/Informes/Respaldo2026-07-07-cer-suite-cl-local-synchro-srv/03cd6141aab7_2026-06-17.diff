+package com.elrosado.synchrosrv.infrastructure.adapter.out.transfer;
+
+import com.elrosado.synchrosrv.domain.exception.FileTransferPermanentException;
+import com.elrosado.synchrosrv.domain.exception.FileTransferTransientException;
+import com.elrosado.synchrosrv.domain.model.StoreTransferConfig;
+import com.elrosado.synchrosrv.domain.model.TransferResult;
+import com.elrosado.synchrosrv.domain.port.out.BearerTokenPort;
+import com.elrosado.synchrosrv.domain.port.out.FileTransferPort;
+import com.elrosado.synchrosrv.infrastructure.config.TransferProperties;
+import lombok.extern.slf4j.Slf4j;
+import org.springframework.beans.factory.annotation.Qualifier;
+import org.springframework.http.HttpHeaders;
+import org.springframework.http.MediaType;
+import org.springframework.http.ResponseEntity;
+import org.springframework.stereotype.Component;
+import org.springframework.web.client.HttpClientErrorException;
+import org.springframework.web.client.HttpServerErrorException;
+import org.springframework.web.client.ResourceAccessException;
+import org.springframework.web.client.RestClient;
+import org.springframework.web.client.RestClientException;
+
+import java.time.Instant;
+import java.util.Base64;
+
+@Component
+@Slf4j
+public class TcxSkyFileTransferAdapter implements FileTransferPort {
+
+    private final RestClient restClient;
+    private final TransferProperties properties;
+    private final BearerTokenPort bearerTokenPort;
+
+    public TcxSkyFileTransferAdapter(
+            @Qualifier("tcxSkyRestClient") RestClient restClient,
+            TransferProperties properties,
+            BearerTokenPort bearerTokenPort
+    ) {
+        this.restClient = restClient;
+        this.properties = properties;
+        this.bearerTokenPort = bearerTokenPort;
+    }
+
+    @Override
+    public TransferResult transfer(StoreTransferConfig storeConfig, String targetDir, String fileName, byte[] content) {
+        validateRequest(storeConfig, fileName, content);
+
+        String endpoint = properties.buildTransferUrl(storeConfig.controllerIp());
+        String normalizedDir = normalizeTargetDir(targetDir);
+        String base64Content = Base64.getEncoder().encodeToString(content);
+        String authorizationHeader = bearerTokenPort.authorizationHeader();
+
+        FileTransferRequestBody body = new FileTransferRequestBody(fileName, normalizedDir, base64Content);
+
+        log.atDebug()
+                .setMessage("Enviando archivo DV al controlador TCx Sky")
+                .addKeyValue("codStore", storeConfig.codStore())
+                .addKeyValue("endpoint", endpoint)
+                .addKeyValue("fileName", fileName)
+                .addKeyValue("targetDir", normalizedDir)
+                .log();
+
+        try {
+            ResponseEntity<Void> response = restClient.post()
+                    .uri(endpoint)
+                    .header(HttpHeaders.AUTHORIZATION, authorizationHeader)
+                    .contentType(MediaType.APPLICATION_JSON)
+                    .body(body)
+                    .retrieve()
+                    .toBodilessEntity();
+
+            int statusCode = response.getStatusCode().value();
+
+            if (statusCode != 201) {
+                log.atWarn()
+                        .setMessage("API TCx Sky respondiÃ³ con cÃ³digo 2xx distinto de 201")
+                        .addKeyValue("codStore", storeConfig.codStore())
+                        .addKeyValue("endpoint", endpoint)
+                        .addKeyValue("statusCode", statusCode)
+                        .log();
+            }
+
+            return new TransferResult(fileName, endpoint, statusCode, Instant.now());
+
+        } catch (HttpClientErrorException ex) {
+            throw new FileTransferPermanentException(
+                    "Error permanente en API TCx Sky. endpoint=" + endpoint
+                            + " statusCode=" + ex.getStatusCode().value(), ex);
+        } catch (HttpServerErrorException | ResourceAccessException ex) {
+            throw new FileTransferTransientException(
+                    "Error transitorio en API TCx Sky. endpoint=" + endpoint, ex);
+        } catch (RestClientException ex) {
+            throw new FileTransferTransientException(
+                    "Error HTTP inesperado en API TCx Sky. endpoint=" + endpoint, ex);
+        }
+    }
+
+    private void validateRequest(StoreTransferConfig storeConfig, String fileName, byte[] content) {
+        if (storeConfig == null || storeConfig.controllerIp() == null || storeConfig.controllerIp().isBlank()) {
+            throw new FileTransferPermanentException("controllerIp no puede ser nulo o vacÃ­o");
+        }
+        if (fileName == null || fileName.isBlank()) {
+            throw new FileTransferPermanentException("fileName es requerido para transferir al controlador TCx Sky");
+        }
+        if (content == null || content.length == 0) {
+            throw new FileTransferPermanentException("content es requerido para transferir al controlador TCx Sky");
+        }
+    }
+
+    private String normalizeTargetDir(String targetDir) {
+        if (targetDir == null || targetDir.isBlank()) {
+            throw new FileTransferPermanentException("targetDir no estÃ¡ configurado para la transferencia");
+        }
+        String normalized = targetDir.strip();
+        while (normalized.endsWith("/") || normalized.endsWith("\\")) {
+            normalized = normalized.substring(0, normalized.length() - 1);
+        }
+        if (normalized.isBlank()) {
+            throw new FileTransferPermanentException("targetDir no puede quedar vacÃ­o tras normalizar");
+        }
+        return normalized;
+    }
+
+    private record FileTransferRequestBody(String file, String dir, String content) {}
+}


