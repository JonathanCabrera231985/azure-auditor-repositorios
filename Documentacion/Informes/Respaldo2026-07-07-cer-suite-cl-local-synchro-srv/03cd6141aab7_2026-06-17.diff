--- a//src/main/java/com/elrosado/synchrosrv/infrastructure/adapter/in/event/DevolutionSyncSubscriber.java
+++ b//src/main/java/com/elrosado/synchrosrv/infrastructure/adapter/in/event/DevolutionSyncSubscriber.java
@@ -0,0 +1,53 @@
+package com.elrosado.synchrosrv.infrastructure.adapter.in.event;
+
+import com.elrosado.jlib_pubsub.interfaces.IMessageSubscriber;
+import com.elrosado.synchrosrv.infrastructure.config.PubSubRoutingProperties;
+import jakarta.annotation.PostConstruct;
+import lombok.RequiredArgsConstructor;
+import lombok.extern.slf4j.Slf4j;
+import org.springframework.stereotype.Component;
+
+import java.util.concurrent.CompletableFuture;
+import java.util.concurrent.ExecutorService;
+import java.util.concurrent.Executors;
+
+@Component
+@RequiredArgsConstructor
+@Slf4j
+public class DevolutionSyncSubscriber {
+
+    private static final ExecutorService VIRTUAL_EXECUTOR =
+            Executors.newVirtualThreadPerTaskExecutor();
+
+    private final IMessageSubscriber messageSubscriber;
+    private final DevolutionTransferMessageHandler transferMessageHandler;
+    private final PubSubRoutingProperties routingProperties;
+
+    @PostConstruct
+    public void startSubscription() {
+        messageSubscriber.startListening(this::handleMessage);
+        log.atInfo()
+                .setMessage("Suscriptor Pub/Sub de sincronizaciÃ³n iniciado")
+                .addKeyValue("subscriptionDevolutionProcessed", routingProperties.getSubscriptionDevolutionProcessed())
+                .log();
+    }
+
+    private CompletableFuture<Boolean> handleMessage(String subscriptionId, String body) {
+        return CompletableFuture.supplyAsync(
+                () -> routeMessage(subscriptionId, body),
+                VIRTUAL_EXECUTOR
+        );
+    }
+
+    private boolean routeMessage(String subscriptionId, String body) {
+        if (routingProperties.isDevolutionProcessedSubscription(subscriptionId)) {
+            return transferMessageHandler.handle(subscriptionId, body);
+        }
+
+        log.atWarn()
+                .setMessage("Mensaje Pub/Sub descartado: subscriptionId no configurado para este servicio")
+                .addKeyValue("subscriptionId", subscriptionId)
+                .log();
+        return true;
+    }
+}


