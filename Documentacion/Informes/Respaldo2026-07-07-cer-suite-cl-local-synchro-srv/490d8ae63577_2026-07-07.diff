--- Diff for /src/main/java/com/elrosado/synchrosrv/infrastructure/config/SaadminSecretManagerEnvironmentPostProcessor.java ---
--- a//src/main/java/com/elrosado/synchrosrv/infrastructure/config/SaadminSecretManagerEnvironmentPostProcessor.java
+++ b//src/main/java/com/elrosado/synchrosrv/infrastructure/config/SaadminSecretManagerEnvironmentPostProcessor.java
@@ -0,0 +1,83 @@
+package com.elrosado.synchrosrv.infrastructure.config;
+
+import com.google.cloud.secretmanager.v1.AccessSecretVersionResponse;
+import com.google.cloud.secretmanager.v1.SecretManagerServiceClient;
+import com.google.cloud.secretmanager.v1.SecretVersionName;
+import org.springframework.boot.SpringApplication;
+import org.springframework.boot.env.EnvironmentPostProcessor;
+import org.springframework.core.Ordered;
+import org.springframework.core.env.ConfigurableEnvironment;
+import org.springframework.core.env.MapPropertySource;
+
+import java.io.IOException;
+import java.util.LinkedHashMap;
+import java.util.Map;
+
+/**
+ * Resuelve las credenciales de SAADMIN (URL, usuario, password) desde GCP Secret Manager antes de
+ * que se cree el ApplicationContext, para que {@code jlib-multisql} las reciba ya resueltas al leer
+ * {@code multi-sql.datasources.saadmin.*} durante el registro de beans del DataSource.
+ * <p>
+ * Se activa solo si {@code app.saadmin-db.*-secret-id} esta configurado (perfil {@code prod}); en
+ * perfiles sin esos IDs (local/dev) no hace nada y se mantienen las credenciales literales existentes.
+ */
+public class SaadminSecretManagerEnvironmentPostProcessor implements EnvironmentPostProcessor, Ordered {
+
+    private static final String URL_SECRET_ID_PROP = "app.saadmin-db.url-secret-id";
+    private static final String USER_SECRET_ID_PROP = "app.saadmin-db.user-secret-id";
+    private static final String PASSWORD_SECRET_ID_PROP = "app.saadmin-db.password-secret-id";
+    private static final String SECRET_VERSION_PROP = "app.saadmin-db.secret-version";
+    private static final String PROJECT_ID_PROP = "spring.cloud.gcp.project-id";
+
+    @Override
+    public int getOrder() {
+        // Debe ejecutarse despues de ConfigDataEnvironmentPostProcessor (que carga application*.yaml)
+        return Ordered.LOWEST_PRECEDENCE;
+    }
+
+    @Override
+    public void postProcessEnvironment(ConfigurableEnvironment environment, SpringApplication application) {
+        String urlSecretId = environment.getProperty(URL_SECRET_ID_PROP);
+        String userSecretId = environment.getProperty(USER_SECRET_ID_PROP);
+        String passwordSecretId = environment.getProperty(PASSWORD_SECRET_ID_PROP);
+
+        if (isBlank(urlSecretId) && isBlank(userSecretId) && isBlank(passwordSecretId)) {
+            return;
+        }
+
+        String projectId = environment.getProperty(PROJECT_ID_PROP);
+        if (isBlank(projectId)) {
+            throw new IllegalStateException(PROJECT_ID_PROP + " es requerido para resolver credenciales SAADMIN desde Secret Manager");
+        }
+        String version = environment.getProperty(SECRET_VERSION_PROP, "latest");
+
+        try (SecretManagerServiceClient client = SecretManagerServiceClient.create()) {
+            Map<String, Object> resolved = new LinkedHashMap<>();
+            resolved.put("DB_SAADMIN_URL", requireSecret(client, projectId, urlSecretId, version, URL_SECRET_ID_PROP));
+            resolved.put("DB_SAADMIN_USER", requireSecret(client, projectId, userSecretId, version, USER_SECRET_ID_PROP));
+            resolved.put("DB_SAADMIN_PASSWORD", requireSecret(client, projectId, passwordSecretId, version, PASSWORD_SECRET_ID_PROP));
+
+            environment.getPropertySources().addFirst(new MapPropertySource("saadminSecretManagerCredentials", resolved));
+        } catch (IOException ex) {
+            throw new IllegalStateException("No se pudo inicializar el cliente de Secret Manager para credenciales SAADMIN", ex);
+        }
+    }
+
+    private String requireSecret(SecretManagerServiceClient client, String projectId, String secretId,
+                                  String version, String propertyName) {
+        if (isBlank(secretId)) {
+            throw new IllegalStateException(propertyName + " no esta configurado");
+        }
+        SecretVersionName secretVersionName = SecretVersionName.of(projectId, secretId, version);
+        AccessSecretVersionResponse response = client.accessSecretVersion(secretVersionName);
+        String value = response.getPayload().getData().toStringUtf8();
+        if (isBlank(value)) {
+            throw new IllegalStateException("El secreto '" + secretId + "' esta vacio en Secret Manager");
+        }
+        return value.strip();
+    }
+
+    private boolean isBlank(String value) {
+        return value == null || value.isBlank();
+    }
+}


